---
import CookieBanner from './CookieBanner.astro';
import { supabase } from '../lib/supabase.js';

const currentPath = Astro.url.pathname;

const [{ data: players }, { data: teams }, { data: nations }] = await Promise.all([
  supabase.from('players').select('name, slug, role, nation').not('slug','is',null),
  supabase.from('teams').select('name, slug').not('slug','is',null),
  supabase.from('nations').select('name').not('name','is',null),
]);

const searchIndex = [
  ...(players ?? []).map(p => ({
    type: 'player',
    label: p.name ?? '',
    sub: (p.role ?? '') + ' · ' + (p.nation ?? ''),
    url: '/player/' + p.slug,
  })),
  ...(teams ?? []).map(t => ({
    type: 'team',
    label: t.name ?? '',
    sub: 'All-Time Team',
    url: '/team/' + t.slug,
  })),
  ...(nations ?? []).map(n => ({
    type: 'nation',
    label: n.name ?? '',
    sub: 'Nation',
    url: '/nation/' + n.name.toLowerCase().replace(/\s+/g, '-'),
  })),
];
---

<!-- SEARCH OVERLAY -->
<div id="searchOverlay" aria-hidden="true" role="dialog" aria-label="Search">
  <div id="searchBackdrop"></div>
  <div id="searchModal">
    <div id="searchInputWrap">
      <svg id="searchInputIcon" width="16" height="16" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <circle cx="9" cy="9" r="6.5" stroke="#aeaeb2" stroke-width="1.6"/>
        <line x1="14" y1="14" x2="18" y2="18" stroke="#aeaeb2" stroke-width="1.6" stroke-linecap="round"/>
      </svg>
      <input
        type="text"
        id="searchInput"
        placeholder="Search players, teams, nations..."
        autocomplete="off"
        spellcheck="false"
      />
      <button id="searchClose" type="button" aria-label="Close search">
        <span>esc</span>
      </button>
    </div>
    <div id="searchResults"></div>
    <div id="searchEmpty">Start typing to search across 1000+ legends, teams and nations.</div>
  </div>
</div>

<nav class="nav" id="siteNav">
  <div class="nav-inner">
    <a href="/" class="nav-logo">
      <img src="/logo.svg" alt="Legends Database" height="22" style="mix-blend-mode: multiply;" />
    </a>

    <div class="nav-links">
      <a href="/" class={currentPath === '/' ? 'active' : ''}>Database</a>
      <a href="/nations" class={currentPath === '/nations' || currentPath.startsWith('/nation/') ? 'active' : ''}>Nations</a>
      <a href="/teams" class={currentPath === '/teams' || currentPath.startsWith('/team/') ? 'active' : ''}>All-Time Teams</a>
      <a href="/best" class={currentPath.startsWith('/best') ? 'active' : ''}>The Best</a>
      <a href="/timeline" class={currentPath === '/timeline' ? 'active' : ''}>Timeline</a>
      <a href="/articles" class={currentPath === '/articles' || currentPath.startsWith('/articles/') ? 'active' : ''}>Articles</a>
      <a href="/about" class={currentPath === '/about' ? 'active' : ''}>About</a>
      <a href="/legenda" class={currentPath === '/legenda' ? 'active' : ''}>Legend</a>
    </div>

    <div class="nav-right">
      <button class="nav-search-btn" id="navSearchBtn" type="button" aria-label="Search">
        <svg width="16" height="16" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <circle cx="9" cy="9" r="6.5" stroke="currentColor" stroke-width="1.6"/>
          <line x1="14" y1="14" x2="18" y2="18" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
        </svg>
      </button>
      <button class="nav-toggle" id="navToggle" aria-label="Open menu" aria-expanded="false" aria-controls="mobileMenu" type="button">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </div>
</nav>

<div class="mobile-menu" id="mobileMenu" aria-hidden="true">
  <div class="mobile-menu-head">
    <div class="mobile-menu-brand">
      <img src="/logo.svg" alt="Legends Database" height="22" style="mix-blend-mode: multiply;" />
    </div>
    <div class="mobile-menu-head-right">
      <button class="mobile-search-btn" id="mobileSearchBtn" type="button" aria-label="Search">
        <svg width="18" height="18" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <circle cx="9" cy="9" r="6.5" stroke="currentColor" stroke-width="1.6"/>
          <line x1="14" y1="14" x2="18" y2="18" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
        </svg>
      </button>
      <button class="mobile-close" id="mobileClose" aria-label="Close menu" type="button">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M1 1L17 17M17 1L1 17" stroke="#1d1d1f" stroke-width="1.8" stroke-linecap="round"/>
        </svg>
      </button>
    </div>
  </div>

  <div class="mobile-menu-links">
    <a href="/" class={currentPath === '/' ? 'active' : ''}>Database</a>
    <a href="/nations" class={currentPath === '/nations' || currentPath.startsWith('/nation/') ? 'active' : ''}>Nations</a>
    <a href="/teams" class={currentPath === '/teams' || currentPath.startsWith('/team/') ? 'active' : ''}>All-Time Teams</a>
    <a href="/best" class={currentPath.startsWith('/best') ? 'active' : ''}>The Best</a>
    <a href="/timeline" class={currentPath === '/timeline' ? 'active' : ''}>Timeline</a>
    <a href="/articles" class={currentPath === '/articles' || currentPath.startsWith('/articles/') ? 'active' : ''}>Articles</a>
    <a href="/about" class={currentPath === '/about' ? 'active' : ''}>About</a>
    <a href="/legenda" class={currentPath === '/legenda' ? 'active' : ''}>Legend</a>
  </div>
</div>

<CookieBanner />

<script define:vars={{ searchIndex }}>
  // ── NAVBAR MENU ──────────────────────────────────────────────────────────
  const navToggle   = document.getElementById('navToggle');
  const mobileMenu  = document.getElementById('mobileMenu');
  const mobileClose = document.getElementById('mobileClose');

  function openMenu() {
    if (!mobileMenu || !navToggle) return;
    mobileMenu.classList.add('open');
    navToggle.setAttribute('aria-expanded', 'true');
    mobileMenu.setAttribute('aria-hidden', 'false');
    document.body.classList.add('menu-open');
  }
  function closeMenu() {
    if (!mobileMenu || !navToggle) return;
    mobileMenu.classList.remove('open');
    navToggle.setAttribute('aria-expanded', 'false');
    mobileMenu.setAttribute('aria-hidden', 'true');
    document.body.classList.remove('menu-open');
  }

  navToggle?.addEventListener('click', () => {
    mobileMenu?.classList.contains('open') ? closeMenu() : openMenu();
  });
  mobileClose?.addEventListener('click', closeMenu);
  mobileMenu?.querySelectorAll('a').forEach(link => link.addEventListener('click', closeMenu));
  window.addEventListener('keydown', e => { if (e.key === 'Escape') closeMenu(); });
  window.addEventListener('resize', () => { if (window.innerWidth > 768) closeMenu(); });

  // ── SEARCH ───────────────────────────────────────────────────────────────
  const overlay     = document.getElementById('searchOverlay');
  const backdrop    = document.getElementById('searchBackdrop');
  const searchInput = document.getElementById('searchInput');
  const resultsEl   = document.getElementById('searchResults');
  const emptyEl     = document.getElementById('searchEmpty');

  function openSearch() {
    if (!overlay) return;
    overlay.classList.add('open');
    overlay.setAttribute('aria-hidden', 'false');
    document.body.classList.add('search-open');
    setTimeout(() => searchInput?.focus(), 80);
    closeMenu();
  }
  function closeSearch() {
    if (!overlay) return;
    overlay.classList.remove('open');
    overlay.setAttribute('aria-hidden', 'true');
    document.body.classList.remove('search-open');
    if (searchInput) searchInput.value = '';
    if (resultsEl)  resultsEl.innerHTML = '';
    if (emptyEl)    emptyEl.style.display = 'block';
  }

  document.getElementById('navSearchBtn')?.addEventListener('click', openSearch);
  document.getElementById('mobileSearchBtn')?.addEventListener('click', openSearch);
  document.getElementById('searchClose')?.addEventListener('click', closeSearch);
  backdrop?.addEventListener('click', closeSearch);
  window.addEventListener('keydown', e => { if (e.key === 'Escape') closeSearch(); });

  const TYPE_ICON  = { player: '🧑', team: '🏆', nation: '🌍' };
  const TYPE_LABEL = { player: 'Players', team: 'Teams', nation: 'Nations' };
  const TYPE_COLOR = { player: '#0071e3', team: '#1a7a1a', nation: '#c8a800' };

  function normalize(s) {
    return s.toLowerCase()
      .normalize('NFD').replace(/[\u0300-\u036f]/g, '')
      .replace(/[^a-z0-9\s]/g, '');
  }

  let selectedIdx = -1;

  function renderResults(query) {
    if (!resultsEl || !emptyEl) return;
    const q = normalize(query.trim());
    if (!q || q.length < 2) {
      resultsEl.innerHTML = '';
      emptyEl.style.display = 'block';
      selectedIdx = -1;
      return;
    }

    const matched = searchIndex
      .filter(item => normalize(item.label).includes(q))
      .sort((a, b) => {
        const aStarts = normalize(a.label).startsWith(q) ? 0 : 1;
        const bStarts = normalize(b.label).startsWith(q) ? 0 : 1;
        return aStarts - bStarts || a.label.localeCompare(b.label);
      })
      .slice(0, 24);

    if (!matched.length) {
      resultsEl.innerHTML = '<div class="search-no-results">No results for "' + query.trim() + '"</div>';
      emptyEl.style.display = 'none';
      selectedIdx = -1;
      return;
    }

    emptyEl.style.display = 'none';
    const groups = {};
    matched.forEach(item => {
      if (!groups[item.type]) groups[item.type] = [];
      groups[item.type].push(item);
    });

    let html = '';
    for (const type of ['player', 'team', 'nation']) {
      if (!groups[type]) continue;
      html += '<div class="search-group">';
      html += '<div class="search-group-label">' + TYPE_ICON[type] + ' ' + TYPE_LABEL[type] + '</div>';
      groups[type].forEach(item => {
        const hi = item.label.replace(new RegExp('(' + query.trim().replace(/[.*+?^${}()|[\]\\]/g,'\\$&') + ')', 'gi'), '<mark>$1</mark>');
        html += '<a href="' + item.url + '" class="search-result-item" data-type="' + type + '">';
        html += '<span class="sri-label">' + hi + '</span>';
        html += '<span class="sri-sub">' + item.sub + '</span>';
        html += '</a>';
      });
      html += '</div>';
    }
    resultsEl.innerHTML = html;
    selectedIdx = -1;
  }

  searchInput?.addEventListener('input', e => renderResults(e.target.value));

  // Keyboard navigation
  searchInput?.addEventListener('keydown', e => {
    const items = resultsEl?.querySelectorAll('.search-result-item') ?? [];
    if (e.key === 'ArrowDown') {
      e.preventDefault();
      selectedIdx = Math.min(selectedIdx + 1, items.length - 1);
    } else if (e.key === 'ArrowUp') {
      e.preventDefault();
      selectedIdx = Math.max(selectedIdx - 1, -1);
    } else if (e.key === 'Enter' && selectedIdx >= 0) {
      e.preventDefault();
      items[selectedIdx]?.click();
      return;
    } else if (e.key === 'Enter' && items.length > 0) {
      e.preventDefault();
      items[0]?.click();
      return;
    }
    items.forEach((el, i) => el.classList.toggle('selected', i === selectedIdx));
    if (selectedIdx >= 0) items[selectedIdx]?.scrollIntoView({ block: 'nearest' });
  });
</script>

<script async src="/_vercel/insights/script.js"></script>

<style is:global>
  body.menu-open   { overflow: hidden; }
  body.search-open { overflow: hidden; }

  /* ── NAV ── */
  .nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 120;
    background: rgba(242, 242, 247, 0.82);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(0,0,0,0.08);
    height: 44px;
  }
  .nav-inner {
    max-width: 1800px;
    margin: 0 auto;
    padding: 0 40px;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    position: relative;
  }
  .nav-logo img { display: block; }
  .nav-links {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    align-items: center;
    gap: 32px;
  }
  .nav-links a {
    font-family: -apple-system, 'SF Pro Text', 'Inter', sans-serif;
    font-size: 13px;
    font-weight: 400;
    color: #6e6e73;
    text-decoration: none;
    transition: color 0.15s;
    -webkit-font-smoothing: antialiased;
  }
  .nav-links a:hover  { color: #1d1d1f; }
  .nav-links a.active { color: #1d1d1f; font-weight: 500; }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 4px;
  }
  .nav-search-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border: none;
    background: transparent;
    cursor: pointer;
    color: #6e6e73;
    border-radius: 8px;
    transition: color 0.15s, background 0.15s;
    padding: 0;
  }
  .nav-search-btn:hover { color: #1d1d1f; background: rgba(0,0,0,0.05); }

  .nav-toggle {
    display: none;
    width: 36px; height: 36px;
    border: none; background: transparent; padding: 0;
    cursor: pointer;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 4px;
  }
  .nav-toggle span {
    display: block;
    width: 18px; height: 1.5px;
    border-radius: 999px;
    background: #1d1d1f;
  }

  /* ── MOBILE MENU ── */
  .mobile-menu {
    position: fixed;
    inset: 0;
    z-index: 999;
    background: rgba(255, 255, 255, 0.98);
    backdrop-filter: blur(28px);
    -webkit-backdrop-filter: blur(28px);
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 0.22s ease, visibility 0.22s ease;
    overflow-y: auto;
  }
  .mobile-menu.open { opacity: 1; visibility: visible; pointer-events: auto; }
  .mobile-menu-head {
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 18px;
  }
  .mobile-menu-brand { display: flex; align-items: center; }
  .mobile-menu-brand img { display: block; }
  .mobile-menu-head-right { display: flex; align-items: center; gap: 4px; }

  .mobile-search-btn {
    width: 36px; height: 36px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: none;
    background: transparent;
    cursor: pointer;
    color: #6e6e73;
    padding: 0;
    border-radius: 999px;
    transition: background 0.15s;
  }
  .mobile-search-btn:hover { background: rgba(0,0,0,0.05); }

  .mobile-close {
    width: 36px; height: 36px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: none;
    background: transparent;
    cursor: pointer;
    padding: 0;
    border-radius: 999px;
    transition: background 0.15s ease;
  }
  .mobile-close:hover { background: rgba(0,0,0,0.05); }

  .mobile-menu-links {
    display: flex;
    flex-direction: column;
    padding: 12px 32px 40px;
  }
  .mobile-menu-links a {
    font-family: -apple-system, 'SF Pro Display', 'Inter', sans-serif;
    -webkit-font-smoothing: antialiased;
    font-size: 31px;
    font-weight: 600;
    letter-spacing: -0.05em;
    color: #1d1d1f;
    text-decoration: none;
    line-height: 1.08;
    padding: 10px 0;
    transition: color 0.12s ease;
  }
  .mobile-menu-links a.active { color: #6e6e73; }
  .mobile-menu-links a:hover:not(.active) { color: #0071e3; }

  /* ── SEARCH OVERLAY ── */
  #searchOverlay {
    position: fixed;
    inset: 0;
    z-index: 9000;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding-top: 80px;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 0.18s ease, visibility 0.18s ease;
  }
  #searchOverlay.open {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }
  #searchBackdrop {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.35);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }
  #searchModal {
    position: relative;
    width: 100%;
    max-width: 580px;
    margin: 0 20px;
    background: #ffffff;
    border-radius: 18px;
    box-shadow: 0 24px 80px rgba(0,0,0,0.22);
    overflow: hidden;
    transform: translateY(-8px) scale(0.98);
    transition: transform 0.18s ease;
  }
  #searchOverlay.open #searchModal {
    transform: translateY(0) scale(1);
  }

  #searchInputWrap {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 16px 18px;
    border-bottom: 1px solid #f0f0f5;
  }
  #searchInputIcon { flex-shrink: 0; }
  #searchInput {
    flex: 1;
    font-family: -apple-system, 'SF Pro Text', 'Inter', sans-serif;
    font-size: 16px;
    font-weight: 400;
    color: #1d1d1f;
    border: none;
    outline: none;
    background: transparent;
    -webkit-font-smoothing: antialiased;
  }
  #searchInput::placeholder { color: #aeaeb2; }
  #searchClose {
    font-family: inherit;
    font-size: 11px;
    font-weight: 600;
    color: #aeaeb2;
    background: #f5f5f7;
    border: none;
    padding: 4px 8px;
    border-radius: 6px;
    cursor: pointer;
    flex-shrink: 0;
    transition: color 0.12s;
  }
  #searchClose:hover { color: #1d1d1f; }
  #searchClose span { letter-spacing: 0.02em; }

  #searchResults {
    max-height: 420px;
    overflow-y: auto;
    overscroll-behavior: contain;
  }
  #searchEmpty {
    padding: 24px 20px;
    font-size: 13.5px;
    color: #aeaeb2;
    text-align: center;
    line-height: 1.6;
  }
  .search-no-results {
    padding: 24px 20px;
    font-size: 13.5px;
    color: #aeaeb2;
    text-align: center;
  }
  .search-group { padding: 8px 0; }
  .search-group + .search-group { border-top: 1px solid #f5f5f7; }
  .search-group-label {
    font-size: 10.5px;
    font-weight: 700;
    color: #aeaeb2;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    padding: 8px 18px 4px;
  }
  .search-result-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 18px;
    text-decoration: none;
    cursor: pointer;
    transition: background 0.1s;
    gap: 12px;
  }
  .search-result-item:hover,
  .search-result-item.selected {
    background: #f5f5f7;
  }
  .sri-label {
    font-size: 13.5px;
    font-weight: 500;
    color: #1d1d1f;
    flex: 1;
    min-width: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .sri-label mark {
    background: transparent;
    color: #0071e3;
    font-weight: 700;
  }
  .sri-sub {
    font-size: 11.5px;
    color: #aeaeb2;
    flex-shrink: 0;
    white-space: nowrap;
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 768px) {
    .nav-inner  { padding: 0 18px; }
    .nav-links  { display: none; }
    .nav-toggle { display: inline-flex; }
    #searchOverlay { padding-top: 60px; }
    #searchModal { margin: 0 12px; border-radius: 14px; }
    #searchInput { font-size: 15px; }
    #searchResults { max-height: 55vh; }
  }

  @media (min-width: 769px) {
    .mobile-menu { display: none; }
  }
</style>