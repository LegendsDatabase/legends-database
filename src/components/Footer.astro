---
const year = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="footer-inner">
    <span class="footer-brand">Legends Database</span>
    <span class="footer-sep">·</span>
    <span class="footer-copy">© {year}</span>
    <nav class="footer-nav">
      <a href="/contact">Contact</a>
      <a href="/source">Sources</a>
      <a href="/privacy">Privacy</a>
      <a href="/sitemap.xml">Sitemap</a>
    </nav>
  </div>
</footer>
<style>
  .site-footer {
    border-top: 1px solid #e5e5ea;
    background: #f9f9fb;
    padding: 20px 40px;
    width: 100%;
    margin-top: auto;
  }
  .footer-inner {
    max-width: 900px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .footer-brand {
    font-size: 12.5px; font-weight: 600; color: #1d1d1f; letter-spacing: -0.1px;
  }
  .footer-sep { color: #d1d1d6; font-size: 12px; }
  .footer-copy { font-size: 12px; color: #aeaeb2; }
  .footer-nav { display: flex; align-items: center; gap: 20px; margin-left: auto; }
  .footer-nav a {
    font-size: 12px; font-weight: 500; color: #6e6e73;
    text-decoration: none; transition: color 0.14s;
  }
  .footer-nav a:hover { color: #0071e3; }
  @media (max-width: 600px) {
    .site-footer { padding: 18px 20px; }
    .footer-nav { margin-left: 0; gap: 14px; flex-wrap: wrap; }
  }
</style>