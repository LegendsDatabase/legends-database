---
import Navbar from '../components/Navbar.astro';
---

<html>
<head>
  <meta charset="UTF-8" />
  <title>Legend – Legends Database</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: -apple-system, 'SF Pro Text', 'Inter', sans-serif;
      background: #f2f2f7;
      color: #1d1d1f;
      font-size: 14px;
      line-height: 1.7;
      -webkit-font-smoothing: antialiased;
      padding-top: 44px; /* spazio per la navbar fixed */
    }

    .page {
      max-width: 860px;
      margin: 0 auto;
      padding: 48px 40px 80px;
      display: grid;
      grid-template-columns: 200px 1fr;
      gap: 48px;
      align-items: start;
    }

    .sidebar {
      position: sticky;
      top: 68px; /* 44px navbar + 24px margine */
    }

    .sidebar p {
      font-size: 11px;
      font-weight: 600;
      color: #aeaeb2;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      margin-bottom: 12px;
    }

    .sidebar ul {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 4px;
    }

    .sidebar ul li a {
      font-size: 13px;
      color: #6e6e73;
      text-decoration: none;
      padding: 4px 0;
      display: block;
      transition: color 0.15s;
    }

    .sidebar ul li a:hover { color: #0071e3; }

    .content h1 {
      font-size: 28px;
      font-weight: 600;
      letter-spacing: -0.5px;
      color: #1d1d1f;
      margin-bottom: 8px;
    }

    .content .subtitle {
      font-size: 14px;
      color: #6e6e73;
      margin-bottom: 48px;
    }

    .section {
      margin-bottom: 48px;
    }

    .section h2 {
      font-size: 18px;
      font-weight: 600;
      color: #1d1d1f;
      letter-spacing: -0.3px;
      margin-bottom: 16px;
      padding-bottom: 10px;
      border-bottom: 1px solid #e5e5ea;
    }

    .note {
      background: #ffffff;
      border: 1px solid #e5e5ea;
      border-radius: 10px;
      padding: 14px 16px;
      font-size: 13px;
      color: #6e6e73;
      margin-top: 12px;
    }

    .note strong { color: #1d1d1f; }

    .skill-list {
      display: flex;
      flex-direction: column;
      gap: 2px;
    }

    .skill-row {
      display: grid;
      grid-template-columns: 90px 1fr;
      gap: 16px;
      padding: 9px 12px;
      border-radius: 8px;
      transition: background 0.1s;
    }

    .skill-row:hover { background: #ffffff; }

    .skill-key {
      font-size: 11px;
      font-weight: 600;
      color: #1d1d1f;
      letter-spacing: 0.02em;
      text-transform: uppercase;
      padding-top: 1px;
    }

    .skill-val {
      font-size: 13px;
      color: #3a3a3c;
    }

    .role-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 2px;
    }

    .role-row {
      display: flex;
      align-items: baseline;
      gap: 10px;
      padding: 8px 12px;
      border-radius: 8px;
      transition: background 0.1s;
    }

    .role-row:hover { background: #ffffff; }

    .role-code {
      font-size: 11px;
      font-weight: 600;
      color: #1d1d1f;
      letter-spacing: 0.04em;
      min-width: 36px;
    }

    .role-name {
      font-size: 13px;
      color: #3a3a3c;
    }

    .ovr-badge {
      display: inline-block;
      font-size: 13px;
      font-weight: 600;
      color: #c0392b;
      margin-right: 6px;
    }

    @media (max-width: 640px) {
      .page { grid-template-columns: 1fr; padding: 24px 20px 60px; }
      .sidebar { display: none; }
      .role-grid { grid-template-columns: 1fr; }
    }
  </style>
</head>

<body>
  <Navbar />

  <div class="page">

    <aside class="sidebar">
      <p>On this page</p>
      <ul>
        <li><a href="#roles">Roles</a></li>
        <li><a href="#ovr">Overall Rating</a></li>
        <li><a href="#athletic">Athletic Skills</a></li>
        <li><a href="#technical">Technical Skills</a></li>
        <li><a href="#mental">Mental Skills</a></li>
        <li><a href="#tactical">Tactical Skills</a></li>
        <li><a href="#gk">Goalkeeping Skills</a></li>
      </ul>
    </aside>

    <main class="content">

      <h1>Legend</h1>
      <p class="subtitle">A clear and precise explanation of every attribute and skill used in this database.</p>

      <section class="section" id="roles">
        <h2>Roles</h2>
        <div class="role-grid">
          <div class="role-row"><span class="role-code">GK</span><span class="role-name">Goalkeeper</span></div>
          <div class="role-row"><span class="role-code">CB</span><span class="role-name">Centre-back</span></div>
          <div class="role-row"><span class="role-code">SW</span><span class="role-name">Sweeper</span></div>
          <div class="role-row"><span class="role-code">RB</span><span class="role-name">Right Back</span></div>
          <div class="role-row"><span class="role-code">LB</span><span class="role-name">Left Back</span></div>
          <div class="role-row"><span class="role-code">DM</span><span class="role-name">Defensive Midfielder</span></div>
          <div class="role-row"><span class="role-code">CM</span><span class="role-name">Central Midfielder</span></div>
          <div class="role-row"><span class="role-code">RM</span><span class="role-name">Right Midfielder</span></div>
          <div class="role-row"><span class="role-code">LM</span><span class="role-name">Left Midfielder</span></div>
          <div class="role-row"><span class="role-code">AM</span><span class="role-name">Attacking Midfielder</span></div>
          <div class="role-row"><span class="role-code">FW</span><span class="role-name">Forward / Second Striker</span></div>
          <div class="role-row"><span class="role-code">RW</span><span class="role-name">Right Winger</span></div>
          <div class="role-row"><span class="role-code">LW</span><span class="role-name">Left Winger</span></div>
          <div class="role-row"><span class="role-code">ST</span><span class="role-name">Striker</span></div>
        </div>
        <div class="note">
          <strong>Note —</strong> Only a player's primary role is taken into account: the position where they played most frequently and performed at their highest level during their prime years.
        </div>
      </section>

      <section class="section" id="ovr">
        <h2>Overall Rating</h2>
        <p style="font-size:13px; color:#3a3a3c;">
          <span class="ovr-badge">OVR</span> is a global score from <strong>1 to 100</strong> representing a player's overall quality. It is <em>not</em> a statistical average — it factors in historical context, career achievements, consistency, impact on their era, and peak performance. It is, by nature, subjective and representative.
        </p>
      </section>

      <section class="section" id="athletic">
        <h2>Athletic Skills</h2>
        <div class="skill-list">
          <div class="skill-row"><span class="skill-key">ACC</span><span class="skill-val">Acceleration — A player's burst of speed over short distances.</span></div>
          <div class="skill-row"><span class="skill-key">PAC</span><span class="skill-val">Pace — Top speed over medium and long distances.</span></div>
          <div class="skill-row"><span class="skill-key">AGI</span><span class="skill-val">Agility — How quickly a player can change direction in tight spaces.</span></div>
          <div class="skill-row"><span class="skill-key">STR</span><span class="skill-val">Strength — Raw physical power; the ability to hold off or displace opponents.</span></div>
          <div class="skill-row"><span class="skill-key">BAL</span><span class="skill-val">Balance — The ability to stay on one's feet and resist challenges without going to ground.</span></div>
          <div class="skill-row"><span class="skill-key">JMP</span><span class="skill-val">Jumping — Aerial reach, both from a standing position and in motion.</span></div>
          <div class="skill-row"><span class="skill-key">STA</span><span class="skill-val">Stamina — Lung capacity; how far and how long a player can run before tiring.</span></div>
          <div class="skill-row"><span class="skill-key">FIT</span><span class="skill-val">Fitness — Physical resilience and injury resistance over the course of a season.</span></div>
        </div>
      </section>

      <section class="section" id="technical">
        <h2>Technical Skills</h2>
        <div class="skill-list">
          <div class="skill-row"><span class="skill-key">DRI</span><span class="skill-val">Dribbling — Speed, effectiveness, and variety in taking on opponents with the ball.</span></div>
          <div class="skill-row"><span class="skill-key">S-PAS</span><span class="skill-val">Short Passing — Accuracy and weight of passes over short distances.</span></div>
          <div class="skill-row"><span class="skill-key">L-PAS</span><span class="skill-val">Long Passing — Accuracy and range when playing the ball over long distances.</span></div>
          <div class="skill-row"><span class="skill-key">FIN</span><span class="skill-val">Finishing — Clinical ability in front of goal; how lethal a player is when shooting.</span></div>
          <div class="skill-row"><span class="skill-key">SHO-A</span><span class="skill-val">Shot Accuracy — Precision in hitting the target when shooting at goal.</span></div>
          <div class="skill-row"><span class="skill-key">SHO-P</span><span class="skill-val">Shot Power — Force and velocity generated when striking the ball.</span></div>
          <div class="skill-row"><span class="skill-key">HEA</span><span class="skill-val">Heading — Power and precision in aerial duels; often, but not always, related to jumping ability.</span></div>
          <div class="skill-row"><span class="skill-key">TAC</span><span class="skill-val">Tackling — Ability to win the ball cleanly from an opponent without fouling.</span></div>
          <div class="skill-row"><span class="skill-key">FRK</span><span class="skill-val">Free Kick — Accuracy and effectiveness from dead-ball situations, both near and far from goal.</span></div>
          <div class="skill-row"><span class="skill-key">PEN</span><span class="skill-val">Penalties — Composure, technique, and conversion rate from the penalty spot.</span></div>
          <div class="skill-row"><span class="skill-key">1-TCH</span><span class="skill-val">First Touch — Quality of first control; a high rating means the player can cushion even the most difficult balls cleanly.</span></div>
        </div>
      </section>

      <section class="section" id="mental">
        <h2>Mental Skills</h2>
        <div class="skill-list">
          <div class="skill-row"><span class="skill-key">COM</span><span class="skill-val">Composure — Ability to stay calm and focused under pressure, without panicking in decisive moments.</span></div>
          <div class="skill-row"><span class="skill-key">AGG</span><span class="skill-val">Aggression — A higher value indicates a playing style built on intensity, tenacity, and fighting spirit.</span></div>
          <div class="skill-row"><span class="skill-key">CON</span><span class="skill-val">Consistency — Arguably the most important mental attribute. How reliably a player performs at their best — a low score means erratic, unpredictable performances.</span></div>
          <div class="skill-row"><span class="skill-key">CREA</span><span class="skill-val">Creativity — The capacity to produce unexpected, improvised moments of brilliance that catch opponents off guard.</span></div>
          <div class="skill-row"><span class="skill-key">WRT</span><span class="skill-val">Work Rate — Commitment and sacrifice for the team; how much a player gives off the ball.</span></div>
        </div>
      </section>

      <section class="section" id="tactical">
        <h2>Tactical Skills</h2>
        <div class="skill-list">
          <div class="skill-row"><span class="skill-key">VIS</span><span class="skill-val">Vision — Spatial awareness; a player's ability to read the position of teammates and opponents at all times. Also a mental skill.</span></div>
          <div class="skill-row"><span class="skill-key">OFB</span><span class="skill-val">Off the Ball — The ability to find space and make runs that unsettle the opposition. A primarily offensive attribute.</span></div>
          <div class="skill-row"><span class="skill-key">DEF</span><span class="skill-val">Def. Positioning — Defensive awareness; knowing where to stand to cut out danger without being caught out of position.</span></div>
          <div class="skill-row"><span class="skill-key">TMW</span><span class="skill-val">Teamwork — A high score means a player is selfless and plays for the collective; a low score points to individualism and a tendency to hold the ball.</span></div>
          <div class="skill-row"><span class="skill-key">ANT</span><span class="skill-val">Anticipation — An innate ability — both offensive and defensive — to read the game and get a step ahead of the opponent.</span></div>
          <div class="skill-row"><span class="skill-key">MAR</span><span class="skill-val">Marking — Ability to track and shadow an opponent, staying tight without committing fouls.</span></div>
        </div>
      </section>

      <section class="section" id="gk">
        <h2>Goalkeeping Skills</h2>
        <div class="skill-list">
          <div class="skill-row"><span class="skill-key">REF</span><span class="skill-val">Reflexes — Pure, instinctive reaction speed; the ability to respond to shots with no time to think.</span></div>
          <div class="skill-row"><span class="skill-key">POS</span><span class="skill-val">Positioning — Reading the game to be in the right place on the goal line before the shot is even taken.</span></div>
          <div class="skill-row"><span class="skill-key">HAN</span><span class="skill-val">Handling — The ability to hold and secure the ball cleanly rather than parrying it back into danger.</span></div>
          <div class="skill-row"><span class="skill-key">KIC</span><span class="skill-val">Kicking — Quality of distribution; launching powerful and accurate restarts to quickly transition into attack.</span></div>
        </div>
      </section>

    </main>
  </div>
---
import Footer from '../components/Footer.astro';
---
<!-- in fondo all'HTML, prima di </body> -->
<Footer/>

</body>
</html>