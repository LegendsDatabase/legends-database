import { supabase } from '../../lib/supabase.js';
import Navbar from '../../components/Navbar.astro';
import Footer from '../components/Footer.astro';

export async function getStaticPaths() {
  const { data: teams } = await supabase.from('teams').select('*');
  const { data: players } = await supabase.from('players').select('*');
  return (teams ?? []).map(t => ({
    params: { slug: t.slug },
    props: { team: t, allPlayers: players ?? [], allTeams: teams ?? [] }
  }));
}

const { team: t, allPlayers, allTeams } = Astro.props;

const displayName = (t.slug ?? '')
  .split('-')
  .map(w => w.charAt(0).toUpperCase() + w.slice(1))
  .join(' ');

function ovrColor(v) {
  if(v>=95)return'#0071e3';if(v>=90)return'#1a5e1a';if(v>=80)return'#2e8b2e';
  if(v>=70)return'#6aaa2a';if(v>=60)return'#c8a800';if(v>=50)return'#e07800';
  if(v>=40)return'#cc4400';return'#c0392b';
}
function skillColor(v) {
  if(v>=95)return'#5aabff';if(v>=90)return'#1a5e1a';if(v>=80)return'#2e8b2e';
  if(v>=70)return'#6aaa2a';if(v>=60)return'#c8a800';if(v>=40)return'#e07800';
  return'#c0392b';
}
function avg(vals) {
  const v=vals.filter(x=>x!=null&&!isNaN(Number(x)));
  return v.length?Math.round(v.reduce((a,b)=>a+Number(b),0)/v.length):0;
}
function sortByOvr(arr) {
  return [...arr].sort((a,b)=>(b.overall_rating??0)-(a.overall_rating??0)||(a.name??'').localeCompare(b.name??''));
}
function pick(pool,n,usedIds) {
  return sortByOvr(pool.filter(p=>!usedIds.has(p.id))).slice(0,n);
}
function pAtt(p)  { return avg([p.finishing,p.off_the_ball,p.composure,p.anticipation,p.shot_accuracy]); }
function pPlay(p) { return avg([p.short_passing,p.long_passing,p.vision,p.composure]); }
function pDef(p)  { return avg([p.marking,p.tackling,p.def_positioning,p.anticipation,p.heading,p.composure]); }
function pSpd(p)  { return avg([p.pace,p.acceleration]); }

const isNational = t.type==='national team'||t.type==='national';

const teamPlayers = allPlayers.filter(p =>
  isNational
    ? (p.nation??'').toLowerCase()===(t.name??'').toLowerCase()
    : (p.iconic_club??'').toLowerCase()===(t.name??'').toLowerCase()
);

const used = new Set();

const gkR = pick(teamPlayers.filter(p=>p.role==='GK'),3,used);
gkR.forEach(p=>used.add(p.id));
const rbR = pick(teamPlayers.filter(p=>p.role==='RB'),2,used);
rbR.forEach(p=>used.add(p.id));
const lbR = pick(teamPlayers.filter(p=>p.role==='LB'),2,used);
lbR.forEach(p=>used.add(p.id));
const swAvail = sortByOvr(teamPlayers.filter(p=>p.role==='SW'&&!used.has(p.id)));
const cbAvail = sortByOvr(teamPlayers.filter(p=>p.role==='CB'&&!used.has(p.id)));
const swSlot  = swAvail.length?[swAvail[0]]:[];
swSlot.forEach(p=>used.add(p.id));
const centerPool = sortByOvr([...cbAvail.filter(p=>!used.has(p.id)),...swAvail.filter(p=>!used.has(p.id))]);
const centerR = [...swSlot,...pick(centerPool,4-swSlot.length,used)];
centerR.forEach(p=>used.add(p.id));
const defR = [...rbR,...lbR,...centerR];
const dmR = pick(teamPlayers.filter(p=>p.role==='DM'),2,used);
dmR.forEach(p=>used.add(p.id));
const cmamR = pick(teamPlayers.filter(p=>['CM','AM'].includes(p.role)),4,used);
cmamR.forEach(p=>used.add(p.id));
const rmlmR = pick(teamPlayers.filter(p=>['RM','LM','CM','AM','DM'].includes(p.role)),2,used);
rmlmR.forEach(p=>used.add(p.id));
const midR = [...dmR,...cmamR,...rmlmR];
const stR = pick(teamPlayers.filter(p=>p.role==='ST'),4,used);
stR.forEach(p=>used.add(p.id));
const wingS = pick(teamPlayers.filter(p=>['RW','LW'].includes(p.role)&&!used.has(p.id)),1,used);
wingS.forEach(p=>used.add(p.id));
const attFill = pick(teamPlayers.filter(p=>['ST','FW','RW','LW'].includes(p.role)&&!used.has(p.id)),6-wingS.length,used);
attFill.forEach(p=>used.add(p.id));
const attR = [...stR,...wingS,...attFill];
const roster = [...gkR,...defR,...midR,...attR];

const teamOvr = avg(roster.map(p=>p.overall_rating));
const gkOvr   = avg(gkR.map(p=>p.overall_rating));
const defOvr  = avg(defR.map(p=>p.overall_rating));
const midOvr  = avg(midR.map(p=>p.overall_rating));
const attOvr  = avg(attR.map(p=>p.overall_rating));

function sortBy(arr,fn) {
  return [...arr].sort((a,b)=>fn(b)-fn(a)||(a.name??'').localeCompare(b.name??''));
}
const appsKey  = isNational?'nat_apps':'club_apps';
const goalsKey = isNational?'nat_goals':'club_goals';
const ratioKey = isNational?'nat_goal_ratio':'club_goal_ratio';
const bestPlayer = sortBy(roster,p=>p.overall_rating??0)[0];
const bestTech   = sortBy(roster,p=>p['first-touch']??0)[0];
const fastestP   = sortBy(roster,p=>pSpd(p))[0];
const strongestP = sortBy(roster,p=>p.strength??0)[0];
const mostAppsP  = sortBy(roster,p=>p[appsKey]??0)[0];
const mostGoalsP = sortBy(roster,p=>p[goalsKey]??0)[0];
const bestRatioP = sortBy(roster.filter(p=>(p[appsKey]??0)>=5),p=>parseFloat(p[ratioKey]??0))[0];

function hAvg(arr) {
  const v=arr.map(p=>p.height).filter(Boolean);
  return v.length?Math.round(v.reduce((a,b)=>a+b,0)/v.length):null;
}
const hGK=hAvg(gkR),hDEF=hAvg(defR),hMID=hAvg(midR),hATT=hAvg(attR),hTOT=hAvg(roster);
const logoSrc = `/teams/${t.slug}.svg`;

const rosterData = roster.map(p => ({
  name:     p.name??'',
  slug:     p.slug??'',
  role:     p.role??'',
  alt_roles:p.alt_roles??'',
  section:  gkR.some(g=>g.id===p.id)?'GK':defR.some(d=>d.id===p.id)?'DEF':midR.some(m=>m.id===p.id)?'MID':'ATT',
  ovr:      p.overall_rating??0,
  def:      pDef(p),
  play:     pPlay(p),
  att:      pAtt(p),
}));
const sameType = allTeams
  .filter(x => x.type === t.type)
  .sort((a, b) => (a.name ?? '').localeCompare(b.name ?? ''));
const currentIdx = sameType.findIndex(x => x.slug === t.slug);
const prevTeam = currentIdx > 0 ? sameType[currentIdx - 1] : sameType[sameType.length - 1];
const nextTeam = currentIdx < sameType.length - 1 ? sameType[currentIdx + 1] : sameType[0];
function teamDisplayName(slug) {
  return (slug ?? '').split('-').map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(' ');
}
