// ─── ROSTER TABLE ──────────────────────────────────────────────────────────

function ovrColor(v){if(v>=95)return'#0071e3';if(v>=90)return'#1a5e1a';if(v>=80)return'#2e8b2e';if(v>=70)return'#6aaa2a';if(v>=60)return'#c8a800';if(v>=50)return'#e07800';if(v>=40)return'#cc4400';return'#c0392b';}
function skillColor(v){if(v>=95)return'#5aabff';if(v>=90)return'#1a5e1a';if(v>=80)return'#2e8b2e';if(v>=70)return'#6aaa2a';if(v>=60)return'#c8a800';if(v>=40)return'#e07800';return'#c0392b';}
function roleCls(r){if(r==='GK')return'role-gk';if(['CB','SW','RB','LB'].includes(r))return'role-def';if(['DM','CM','AM','RM','LM'].includes(r))return'role-mid';return'role-att';}

let currentSort={col:null,dir:1};

function renderRoster(data){
  const tbody=document.getElementById('rosterBody');
  if(!tbody)return;
  tbody.innerHTML='';
  const isSorted=currentSort.col!==null;
  if(isSorted){
    [...data].sort((a,b)=>{let va=a[currentSort.col],vb=b[currentSort.col];if(typeof va==='string')return va.localeCompare(vb)*currentSort.dir;return(vb-va)*currentSort.dir;}).forEach(p=>tbody.appendChild(makeRosterRow(p)));
  } else {
    ['GK','DEF','MID','ATT'].forEach(sec=>{
      const group=data.filter(p=>p.section===sec);if(!group.length)return;
      const labels={GK:'Goalkeepers',DEF:'Defenders',MID:'Midfielders',ATT:'Attackers'};
      const hr=document.createElement('tr');hr.className='section-row';
      hr.innerHTML=`<td colspan="6">${labels[sec]}</td>`;tbody.appendChild(hr);
      group.forEach(p=>tbody.appendChild(makeRosterRow(p)));
    });
  }
}

function makeRosterRow(p){
  const tr=document.createElement('tr');tr.className='player-row';
  const isGK=p.role==='GK';
  tr.innerHTML=`<td><a href="/player/${p.slug}" class="player-link">${p.name}</a></td><td><span class="role-badge ${roleCls(p.role)}">${p.role}</span></td><td class="col-ovr" style="color:${ovrColor(p.ovr)}">${p.ovr}</td><td class="col-stat${isGK?' muted':''}" style="${isGK?'':` color:${skillColor(p.def)}`}">${isGK?'—':p.def}</td><td class="col-stat${isGK?' muted':''}" style="${isGK?'':` color:${skillColor(p.play)}`}">${isGK?'—':p.play}</td><td class="col-stat${isGK?' muted':''}" style="${isGK?'':` color:${skillColor(p.att)}`}">${isGK?'—':p.att}</td>`;
  return tr;
}

function updateRosterHeaders(){
  document.querySelectorAll('#rosterTable thead th').forEach(th=>{
    const col=th.getAttribute('data-col');const span=th.querySelector('span');
    th.classList.remove('sorted');if(span)span.textContent='';
    if(col===currentSort.col){th.classList.add('sorted');if(span)span.textContent=currentSort.dir===1?' ↑':' ↓';}
  });
}

document.querySelectorAll('#rosterTable thead th').forEach(th=>{
  th.addEventListener('click',()=>{
    const col=th.getAttribute('data-col');if(!col)return;
    if(currentSort.col===col){currentSort.dir===1?currentSort.dir=-1:(currentSort={col:null,dir:1});}
    else{currentSort={col,dir:1};}
    updateRosterHeaders();renderRoster(rosterData);
  });
});

renderRoster(rosterData);

// ─── TACTICAL LINEUP ───────────────────────────────────────────────────────

// Role colors for pitch tokens
const ROLE_BG = {
