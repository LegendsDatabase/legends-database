---
import { supabase } from '../lib/supabase.js';

const { data: players, error } = await supabase
  .from('players')
  .select('*')
  .order('name', { ascending: true });
---

<html>
<head>
  <meta charset="UTF-8" />
  <title>Legends Database</title>
</head>

<body style="font-family: Arial; padding:20px;">
  <h1>Legends Database</h1>

  {error && <p>Errore</p>}

  {!error && (
    <div style="overflow-x:auto;">
      <table border="1" cellpadding="6" cellspacing="0">
        <thead>
          <tr>
            <!-- BASE -->
            <th>Name</th>
            <th>Birth Year</th>
            <th>Nation</th>
            <th>Role</th>
            <th>Height</th>
            <th>Weight</th>
            <th>Foot</th>
            <th>Decade</th>
            <th>Club</th>
            <th>Overall</th>

            <!-- STATS -->
            <th onclick="toggle('stats-col', this)">Stats ▾</th>
            <th class="stats-col" style="display:none;">Club Apps</th>
            <th class="stats-col" style="display:none;">Club Goals</th>
            <th class="stats-col" style="display:none;">Club Ratio</th>
            <th class="stats-col" style="display:none;">Nat Apps</th>
            <th class="stats-col" style="display:none;">Nat Goals</th>
            <th class="stats-col" style="display:none;">Nat Ratio</th>

            <!-- ATHLETIC -->
            <th onclick="toggle('ath-col', this)">Athletic Skills ▾</th>
            <th class="ath-col" style="display:none;">Acceleration</th>
            <th class="ath-col" style="display:none;">Pace</th>
            <th class="ath-col" style="display:none;">Agility</th>
            <th class="ath-col" style="display:none;">Strength</th>
            <th class="ath-col" style="display:none;">Balance</th>
            <th class="ath-col" style="display:none;">Jumping</th>
            <th class="ath-col" style="display:none;">Stamina</th>
            <th class="ath-col" style="display:none;">Fitness</th>

            <!-- TECHNICAL -->
            <th onclick="toggle('tech-col', this)">Technical Skills ▾</th>
            <th class="tech-col" style="display:none;">Dribbling</th>
            <th class="tech-col" style="display:none;">Short Passing</th>
            <th class="tech-col" style="display:none;">Long Passing</th>
            <th class="tech-col" style="display:none;">Finishing</th>
            <th class="tech-col" style="display:none;">Shot Accuracy</th>
            <th class="tech-col" style="display:none;">Shot Power</th>
            <th class="tech-col" style="display:none;">Heading</th>
            <th class="tech-col" style="display:none;">Tackling</th>
            <th class="tech-col" style="display:none;">Free Kick</th>
            <th class="tech-col" style="display:none;">Penalties</th>
            <th class="tech-col" style="display:none;">First Touch</th>

            <!-- MENTAL -->
            <th onclick="toggle('ment-col', this)">Mental Skills ▾</th>
            <th class="ment-col" style="display:none;">Composure</th>
            <th class="ment-col" style="display:none;">Aggression</th>
            <th class="ment-col" style="display:none;">Consistency</th>
            <th class="ment-col" style="display:none;">Creativity</th>
            <th class="ment-col" style="display:none;">Work Rate</th>

            <!-- TACTICAL -->
            <th onclick="toggle('tact-col', this)">Tactical Skills ▾</th>
            <th class="tact-col" style="display:none;">Vision</th>
            <th class="tact-col" style="display:none;">Off Ball</th>
            <th class="tact-col" style="display:none;">Def Positioning</th>
            <th class="tact-col" style="display:none;">Teamwork</th>
            <th class="tact-col" style="display:none;">Anticipation</th>
            <th class="tact-col" style="display:none;">Marking</th>

            <!-- GK -->
            <th onclick="toggle('gk-col', this)">GK Skills ▾</th>
            <th class="gk-col" style="display:none;">Reflexes</th>
            <th class="gk-col" style="display:none;">Positioning</th>
            <th class="gk-col" style="display:none;">Handling</th>
            <th class="gk-col" style="display:none;">Kicking</th>
          </tr>
        </thead>

        <tbody>
          {players.map((p) => (
            <tr>
              <!-- BASE -->
              <td>{p.name}</td>
              <td>{p.birth_year}</td>
              <td>{p.nation}</td>
              <td>{p.role}</td>
              <td>{p.height}</td>
              <td>{p.weight}</td>
              <td>{p.preferred_foot}</td>
              <td>{p.decade}</td>
              <td>{p.iconic_club}</td>
              <td>{p.overall_rating}</td>

              <!-- STATS -->
              <td></td>
              <td class="stats-col" style="display:none;">{p.club_apps}</td>
              <td class="stats-col" style="display:none;">{p.club_goals}</td>
              <td class="stats-col" style="display:none;">{p.club_goal_ratio}</td>
              <td class="stats-col" style="display:none;">{p.nat_apps}</td>
              <td class="stats-col" style="display:none;">{p.nat_goals}</td>
              <td class="stats-col" style="display:none;">{p.nat_goal_ratio}</td>

              <!-- ATH -->
              <td></td>
              <td class="ath-col" style="display:none;">{p.acceleration}</td>
              <td class="ath-col" style="display:none;">{p.pace}</td>
              <td class="ath-col" style="display:none;">{p.agility}</td>
              <td class="ath-col" style="display:none;">{p.strength}</td>
              <td class="ath-col" style="display:none;">{p.balance}</td>
              <td class="ath-col" style="display:none;">{p.jumping}</td>
              <td class="ath-col" style="display:none;">{p.stamina}</td>
              <td class="ath-col" style="display:none;">{p.fitness}</td>

              <!-- TECH -->
              <td></td>
              <td class="tech-col" style="display:none;">{p.dribbling}</td>
              <td class="tech-col" style="display:none;">{p.short_passing}</td>
              <td class="tech-col" style="display:none;">{p.long_passing}</td>
              <td class="tech-col" style="display:none;">{p.finishing}</td>
              <td class="tech-col" style="display:none;">{p.shot_accuracy}</td>
              <td class="tech-col" style="display:none;">{p.shot_power}</td>
              <td class="tech-col" style="display:none;">{p.heading}</td>
              <td class="tech-col" style="display:none;">{p.tackling}</td>
              <td class="tech-col" style="display:none;">{p.free_kick}</td>
              <td class="tech-col" style="display:none;">{p.penalties}</td>
              <td class="tech-col" style="display:none;">{p['first-touch']}</td>

              <!-- MENTAL -->
              <td></td>
              <td class="ment-col" style="display:none;">{p.composure}</td>
              <td class="ment-col" style="display:none;">{p.aggression}</td>
              <td class="ment-col" style="display:none;">{p.consistency}</td>
              <td class="ment-col" style="display:none;">{p.creativity}</td>
              <td class="ment-col" style="display:none;">{p.work_rate}</td>

              <!-- TACTICAL -->
              <td></td>
              <td class="tact-col" style="display:none;">{p.vision}</td>
              <td class="tact-col" style="display:none;">{p.off_the_ball}</td>
              <td class="tact-col" style="display:none;">{p.def_positioning}</td>
              <td class="tact-col" style="display:none;">{p.teamwork}</td>
              <td class="tact-col" style="display:none;">{p.anticipation}</td>
              <td class="tact-col" style="display:none;">{p.marking}</td>

              <!-- GK -->
              <td></td>
              <td class="gk-col" style="display:none;">{p.reflexes}</td>
              <td class="gk-col" style="display:none;">{p.positioning}</td>
              <td class="gk-col" style="display:none;">{p.handling}</td>
              <td class="gk-col" style="display:none;">{p.kicking}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  )}

  <script is:inline>
    function toggle(className, el) {
      const cols = document.querySelectorAll('.' + className);
      let open = false;

      cols.forEach(c => {
        if (c.style.display === 'table-cell') open = true;
      });

      cols.forEach(c => {
        c.style.display = open ? 'none' : 'table-cell';
      });

      el.innerText = open
        ? el.innerText.replace('▴','▾')
        : el.innerText.replace('▾','▴');
    }
  </script>

</body>
</html>