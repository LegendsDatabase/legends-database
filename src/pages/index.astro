---
import { supabase } from '../lib/supabase.js';

const { data: players, error } = await supabase
  .from('players')
  .select('*')
  .order('name', { ascending: true });
---

<html>
  <head>
    <meta charset="UTF-8" />
    <title>Legends Database</title>
  </head>

  <body style="font-family: Arial; padding:20px;">
    <h1>Legends Database</h1>

    {error && <p>Errore nel caricamento</p>}

    {!error && (
      <table border="1" cellpadding="6" cellspacing="0">
        <thead>
          <tr>
            <th>Name</th>
            <th>Birth Year</th>
            <th>Nation</th>
            <th>Role</th>
            <th>Height</th>
            <th>Weight</th>
            <th>Foot</th>
            <th>Decade</th>
            <th>Club</th>
            <th>Overall</th>
            <th>Stats</th>
          </tr>
        </thead>

        <tbody>
          {players.map((p) => (
            <tr>
              <td>{p.name}</td>
              <td>{p.birth_year}</td>
              <td>{p.nation}</td>
              <td>{p.role}</td>
              <td>{p.height}</td>
              <td>{p.weight}</td>
              <td>{p.preferred_foot}</td>
              <td>{p.decade}</td>
              <td>{p.iconic_club}</td>
              <td>{p.overall_rating}</td>

              <td>
                <div onclick={`toggleStats('${p.name}')`} style="cursor:pointer;">
                  📊 Stats
                </div>

                <div id={`stats-${p.name}`} style="display:none; font-size:12px; margin-top:5px;">
                  Apps: {p.club_apps}<br/>
                  Goals: {p.club_goals}<br/>
                  Ratio: {p.club_goal_ratio}<br/>
                  Nat Apps: {p.nat_apps}<br/>
                  Nat Goals: {p.nat_goals}<br/>
                </div>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    )}

    <script>
      function toggleStats(name) {
        const el = document.getElementById("stats-" + name);
        el.style.display = el.style.display === "none" ? "block" : "none";
      }
    </script>
  </body>
</html>