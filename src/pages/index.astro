---
import { supabase } from '../lib/supabase.js';

const { data: players, error } = await supabase
  .from('players')
  .select('*')
  .order('name', { ascending: true });
---

<html>
<head>
  <meta charset="UTF-8" />
  <title>Legends Database</title>
</head>

<body style="font-family: Arial; padding:20px;">
  <h1>Legends Database</h1>

  <input type="text" id="searchInput" placeholder="Search player..." style="padding:8px; margin-bottom:15px; width:250px;" />

  <select id="filterRole" style="padding:8px; margin-left:8px;">
    <option value="">All Roles</option>
    <option value="GK">GK</option>
    <option value="CB">CB</option>
    <option value="RB">RB</option>
    <option value="LB">LB</option>
    <option value="SW">SW</option>
    <option value="DM">DM</option>
    <option value="CM">CM</option>
    <option value="AM">AM</option>
    <option value="RW">RW</option>
    <option value="LW">LW</option>
    <option value="FW">FW</option>
  </select>

  <select id="filterNation" style="padding:8px; margin-left:8px;">
    <option value="">All Nations</option>
  </select>

  <select id="filterClub" style="padding:8px; margin-left:8px;">
    <option value="">All Clubs</option>
  </select>

  <select id="filterDecade" style="padding:8px; margin-left:8px;">
    <option value="">All Decades</option>
    <option value="1950">1950</option>
    <option value="1960">1960</option>
    <option value="1970">1970</option>
    <option value="1980">1980</option>
    <option value="1990">1990</option>
    <option value="2000">2000</option>
    <option value="2010">2010</option>
    <option value="2020">2020</option>
  </select>

  {!error && (
    <div style="overflow-x:auto; margin-top:15px;">
      <table border="1" cellpadding="6" cellspacing="0">
        <thead>
  <tr>
    <th data-key="name" onclick="handleSort('name')" style="cursor:pointer;">Name</th>
    <th data-key="birth_year" onclick="handleSort('birth_year')" style="cursor:pointer;">Birth Year</th>
    <th data-key="nation" onclick="handleSort('nation')" style="cursor:pointer;">Nation</th>
    <th data-key="role" onclick="handleSort('role')" style="cursor:pointer;">Role</th>
    <th data-key="height" onclick="handleSort('height')" style="cursor:pointer;">Height</th>
    <th data-key="weight" onclick="handleSort('weight')" style="cursor:pointer;">Weight</th>
    <th data-key="preferred_foot" onclick="handleSort('preferred_foot')" style="cursor:pointer;">Foot</th>
    <th data-key="decade" onclick="handleSort('decade')" style="cursor:pointer;">Decade</th>
    <th data-key="iconic_club" onclick="handleSort('iconic_club')" style="cursor:pointer;">Club</th>
    <th data-key="overall_rating" onclick="handleSort('overall_rating')" style="cursor:pointer;">Overall</th>

    <th onclick="toggle('stats-col', this)" style="cursor:pointer;">Stats ▾</th>
    <th class="stats-col" data-key="club_apps" onclick="handleSort('club_apps')" style="display:none; cursor:pointer;">Club Apps</th>
    <th class="stats-col" data-key="club_goals" onclick="handleSort('club_goals')" style="display:none; cursor:pointer;">Club Goals</th>
    <th class="stats-col" data-key="club_goal_ratio" onclick="handleSort('club_goal_ratio')" style="display:none; cursor:pointer;">Club Ratio</th>
    <th class="stats-col" data-key="nat_apps" onclick="handleSort('nat_apps')" style="display:none; cursor:pointer;">Nat Apps</th>
    <th class="stats-col" data-key="nat_goals" onclick="handleSort('nat_goals')" style="display:none; cursor:pointer;">Nat Goals</th>
    <th class="stats-col" data-key="nat_goal_ratio" onclick="handleSort('nat_goal_ratio')" style="display:none; cursor:pointer;">Nat Ratio</th>

    <th onclick="toggle('ath-col', this)" style="cursor:pointer;">Athletic ▾</th>
    <th class="ath-col" data-key="acceleration" onclick="handleSort('acceleration')" style="display:none; cursor:pointer;">Acceleration</th>
    <th class="ath-col" data-key="pace" onclick="handleSort('pace')" style="display:none; cursor:pointer;">Pace</th>
    <th class="ath-col" data-key="agility" onclick="handleSort('agility')" style="display:none; cursor:pointer;">Agility</th>
    <th class="ath-col" data-key="strength" onclick="handleSort('strength')" style="display:none; cursor:pointer;">Strength</th>
    <th class="ath-col" data-key="balance" onclick="handleSort('balance')" style="display:none; cursor:pointer;">Balance</th>
    <th class="ath-col" data-key="jumping" onclick="handleSort('jumping')" style="display:none; cursor:pointer;">Jumping</th>
    <th class="ath-col" data-key="stamina" onclick="handleSort('stamina')" style="display:none; cursor:pointer;">Stamina</th>
    <th class="ath-col" data-key="fitness" onclick="handleSort('fitness')" style="display:none; cursor:pointer;">Fitness</th>

    <th onclick="toggle('tech-col', this)" style="cursor:pointer;">Technical ▾</th>
    <th class="tech-col" data-key="dribbling" onclick="handleSort('dribbling')" style="display:none; cursor:pointer;">Dribbling</th>
    <th class="tech-col" data-key="short_passing" onclick="handleSort('short_passing')" style="display:none; cursor:pointer;">Short Passing</th>
    <th class="tech-col" data-key="long_passing" onclick="handleSort('long_passing')" style="display:none; cursor:pointer;">Long Passing</th>
    <th class="tech-col" data-key="finishing" onclick="handleSort('finishing')" style="display:none; cursor:pointer;">Finishing</th>
    <th class="tech-col" data-key="shot_accuracy" onclick="handleSort('shot_accuracy')" style="display:none; cursor:pointer;">Shot Accuracy</th>
    <th class="tech-col" data-key="shot_power" onclick="handleSort('shot_power')" style="display:none; cursor:pointer;">Shot Power</th>
    <th class="tech-col" data-key="heading" onclick="handleSort('heading')" style="display:none; cursor:pointer;">Heading</th>
    <th class="tech-col" data-key="tackling" onclick="handleSort('tackling')" style="display:none; cursor:pointer;">Tackling</th>
    <th class="tech-col" data-key="free_kick" onclick="handleSort('free_kick')" style="display:none; cursor:pointer;">Free Kick</th>
    <th class="tech-col" data-key="penalties" onclick="handleSort('penalties')" style="display:none; cursor:pointer;">Penalties</th>
    <th class="tech-col" data-key="first-touch" onclick="handleSort('first-touch')" style="display:none; cursor:pointer;">First Touch</th>

    <th onclick="toggle('ment-col', this)" style="cursor:pointer;">Mental ▾</th>
    <th class="ment-col" data-key="composure" onclick="handleSort('composure')" style="display:none; cursor:pointer;">Composure</th>
    <th class="ment-col" data-key="aggression" onclick="handleSort('aggression')" style="display:none; cursor:pointer;">Aggression</th>
    <th class="ment-col" data-key="consistency" onclick="handleSort('consistency')" style="display:none; cursor:pointer;">Consistency</th>
    <th class="ment-col" data-key="creativity" onclick="handleSort('creativity')" style="display:none; cursor:pointer;">Creativity</th>
    <th class="ment-col" data-key="work_rate" onclick="handleSort('work_rate')" style="display:none; cursor:pointer;">Work Rate</th>

    <th onclick="toggle('tact-col', this)" style="cursor:pointer;">Tactical ▾</th>
    <th class="tact-col" data-key="vision" onclick="handleSort('vision')" style="display:none; cursor:pointer;">Vision</th>
    <th class="tact-col" data-key="off_the_ball" onclick="handleSort('off_the_ball')" style="display:none; cursor:pointer;">Off Ball</th>
    <th class="tact-col" data-key="def_positioning" onclick="handleSort('def_positioning')" style="display:none; cursor:pointer;">Def Positioning</th>
    <th class="tact-col" data-key="teamwork" onclick="handleSort('teamwork')" style="display:none; cursor:pointer;">Teamwork</th>
    <th class="tact-col" data-key="anticipation" onclick="handleSort('anticipation')" style="display:none; cursor:pointer;">Anticipation</th>
    <th class="tact-col" data-key="marking" onclick="handleSort('marking')" style="display:none; cursor:pointer;">Marking</th>

    <th onclick="toggle('gk-col', this)" style="cursor:pointer;">GK ▾</th>
    <th class="gk-col" data-key="reflexes" onclick="handleSort('reflexes')" style="display:none; cursor:pointer;">Reflexes</th>
    <th class="gk-col" data-key="positioning" onclick="handleSort('positioning')" style="display:none; cursor:pointer;">Positioning</th>
    <th class="gk-col" data-key="handling" onclick="handleSort('handling')" style="display:none; cursor:pointer;">Handling</th>
    <th class="gk-col" data-key="kicking" onclick="handleSort('kicking')" style="display:none; cursor:pointer;">Kicking</th>
  </tr>
</thead>
        <tbody id="table-body"></tbody>
      </table>
    </div>
  )}

<script define:vars={{ players }}>
  const allPlayers = players;
  const tbody = document.getElementById('table-body');
  const input = document.getElementById('searchInput');
  const roleFilter = document.getElementById('filterRole');
  const nationFilter = document.getElementById('filterNation');
  const clubFilter = document.getElementById('filterClub'); // FIX
  const decadeFilter = document.getElementById('filterDecade');

  let currentSort = null;
  let sortDirection = 'asc';

  // Popola nazioni
  const nations = [...new Set(allPlayers.map(p => p.nation).filter(Boolean))].sort();
  nations.forEach(n => {
    const opt = document.createElement('option');
    opt.value = n;
    opt.textContent = n;
    nationFilter.appendChild(opt);
  });

  // Popola clubs
  const clubs = [...new Set(allPlayers.map(p => p.iconic_club).filter(Boolean))].sort();
  clubs.forEach(c => {
    const opt = document.createElement('option');
    opt.value = c;
    opt.textContent = c;
    clubFilter.appendChild(opt);
  });

  function renderRows(data) {
    tbody.innerHTML = '';
    data.forEach(p => {
      const row = document.createElement('tr');
      row.innerHTML = `
        <td>${p.name ?? ''}</td>
        <td>${p.birth_year ?? ''}</td>
        <td>${p.nation ?? ''}</td>
        <td>${p.role ?? ''}</td>
        <td>${p.height ?? ''}</td>
        <td>${p.weight ?? ''}</td>
        <td>${p.preferred_foot ?? ''}</td>
        <td>${p.decade ?? ''}</td>
        <td>${p.iconic_club ?? ''}</td>
        <td>${p.overall_rating ?? ''}</td>

        <td></td>
        <td class="stats-col" style="display:none;">${p.club_apps ?? ''}</td>
        <td class="stats-col" style="display:none;">${p.club_goals ?? ''}</td>
        <td class="stats-col" style="display:none;">${p.club_goal_ratio ?? ''}</td>
        <td class="stats-col" style="display:none;">${p.nat_apps ?? ''}</td>
        <td class="stats-col" style="display:none;">${p.nat_goals ?? ''}</td>
        <td class="stats-col" style="display:none;">${p.nat_goal_ratio ?? ''}</td>

        <td></td>
        <td class="ath-col" style="display:none;">${p.acceleration ?? ''}</td>
        <td class="ath-col" style="display:none;">${p.pace ?? ''}</td>
        <td class="ath-col" style="display:none;">${p.agility ?? ''}</td>
        <td class="ath-col" style="display:none;">${p.strength ?? ''}</td>
        <td class="ath-col" style="display:none;">${p.balance ?? ''}</td>
        <td class="ath-col" style="display:none;">${p.jumping ?? ''}</td>
        <td class="ath-col" style="display:none;">${p.stamina ?? ''}</td>
        <td class="ath-col" style="display:none;">${p.fitness ?? ''}</td>

        <td></td>
        <td class="tech-col" style="display:none;">${p.dribbling ?? ''}</td>
        <td class="tech-col" style="display:none;">${p.short_passing ?? ''}</td>
        <td class="tech-col" style="display:none;">${p.long_passing ?? ''}</td>
        <td class="tech-col" style="display:none;">${p.finishing ?? ''}</td>
        <td class="tech-col" style="display:none;">${p.shot_accuracy ?? ''}</td>
        <td class="tech-col" style="display:none;">${p.shot_power ?? ''}</td>
        <td class="tech-col" style="display:none;">${p.heading ?? ''}</td>
        <td class="tech-col" style="display:none;">${p.tackling ?? ''}</td>
        <td class="tech-col" style="display:none;">${p.free_kick ?? ''}</td>
        <td class="tech-col" style="display:none;">${p.penalties ?? ''}</td>
        <td class="tech-col" style="display:none;">${p['first-touch'] ?? ''}</td>

        <td></td>
        <td class="ment-col" style="display:none;">${p.composure ?? ''}</td>
        <td class="ment-col" style="display:none;">${p.aggression ?? ''}</td>
        <td class="ment-col" style="display:none;">${p.consistency ?? ''}</td>
        <td class="ment-col" style="display:none;">${p.creativity ?? ''}</td>
        <td class="ment-col" style="display:none;">${p.work_rate ?? ''}</td>

        <td></td>
        <td class="tact-col" style="display:none;">${p.vision ?? ''}</td>
        <td class="tact-col" style="display:none;">${p.off_the_ball ?? ''}</td>
        <td class="tact-col" style="display:none;">${p.def_positioning ?? ''}</td>
        <td class="tact-col" style="display:none;">${p.teamwork ?? ''}</td>
        <td class="tact-col" style="display:none;">${p.anticipation ?? ''}</td>
        <td class="tact-col" style="display:none;">${p.marking ?? ''}</td>

        <td></td>
        <td class="gk-col" style="display:none;">${p.reflexes ?? ''}</td>
        <td class="gk-col" style="display:none;">${p.positioning ?? ''}</td>
        <td class="gk-col" style="display:none;">${p.handling ?? ''}</td>
        <td class="gk-col" style="display:none;">${p.kicking ?? ''}</td>
      `;
      tbody.appendChild(row);
    });
  }

  function applyFilters() {
    const q = input.value.toLowerCase().trim();
    const role = roleFilter.value;
    const nation = nationFilter.value;
    const club = clubFilter.value; // FIX
    const decade = decadeFilter.value;

    let filtered = allPlayers.filter(p =>
      (!q || p.name?.toLowerCase().includes(q)) &&
      (!role || p.role === role) &&
      (!nation || p.nation === nation) &&
      (!club || p.iconic_club === club) && // FIX
      (!decade || String(p.decade) === decade)
    );

    if (currentSort) {
      filtered = [...filtered].sort((a, b) => {
        let valA = a[currentSort];
        let valB = b[currentSort];
        if (!isNaN(valA) && !isNaN(valB)) {
          valA = Number(valA);
          valB = Number(valB);
        } else {
          valA = String(valA ?? '').toLowerCase();
          valB = String(valB ?? '').toLowerCase();
        }
        if (valA < valB) return sortDirection === 'asc' ? -1 : 1;
        if (valA > valB) return sortDirection === 'asc' ? 1 : -1;
        return 0;
      });
    }

    renderRows(filtered);
  }

  function handleSort(key) {
    if (currentSort === key) {
      sortDirection = sortDirection === 'asc' ? 'desc' : 'asc';
    } else {
      currentSort = key;
      sortDirection = 'asc';
    }

    document.querySelectorAll('th[data-key]').forEach(th => {
      const k = th.getAttribute('data-key');
      const label = th.textContent.replace(' ↑', '').replace(' ↓', '');
      th.textContent = k === currentSort
        ? label + (sortDirection === 'asc' ? ' ↑' : ' ↓')
        : label;
    });

    applyFilters();
  }

  function toggle(className, el) {
    const cols = document.querySelectorAll('.' + className);
    let open = false;
    cols.forEach(c => { if (c.style.display === 'table-cell') open = true; });
    cols.forEach(c => { c.style.display = open ? 'none' : 'table-cell'; });
    el.textContent = open
      ? el.textContent.replace('▴', '▾')
      : el.textContent.replace('▾', '▴');
  }

  input.addEventListener('input', applyFilters);
  roleFilter.addEventListener('change', applyFilters);
  nationFilter.addEventListener('change', applyFilters);
  clubFilter.addEventListener('change', applyFilters); // FIX
  decadeFilter.addEventListener('change', applyFilters);

  window.toggle = toggle;
  window.handleSort = handleSort;

  renderRows(allPlayers);
</script>
</body>
</html>