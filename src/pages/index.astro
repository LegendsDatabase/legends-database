---
import { supabase } from '../lib/supabase.js';

const { data: players, error } = await supabase
  .from('players')
  .select('*')
  .order('name', { ascending: true });
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Legends Database</title>
  </head>

  <body style="font-family: Arial, sans-serif; padding: 20px;">
    <h1>Legends Database</h1>

    {error && <p>Errore nel caricamento dati.</p>}

    {!error && (
      <>
        <table border="1" cellpadding="8" cellspacing="0">
          <thead>
            <tr>
              <th>Name</th>
              <th>Nation</th>
              <th>Role</th>
              <th>Birth Year</th>
            </tr>
          </thead>

          <tbody>
            {players?.map((player) => (
              <>
                <tr style="cursor:pointer;" onclick={`togglePlayer('${player.name}')`}>
                  <td>{player.name}</td>
                  <td>{player.nation}</td>
                  <td>{player.role}</td>
                  <td>{player.birth_year}</td>
                </tr>

                <tr id={`detail-${player.name}`} style="display:none; background:#f5f5f5;">
                  <td colspan="4">
                    <strong>{player.name}</strong><br/>
                    Height: {player.height} cm<br/>
                    Weight: {player.weight} kg<br/>
                    Preferred Foot: {player.preferred_foot}<br/>
                    Iconic Club: {player.iconic_club}
                  </td>
                </tr>
              </>
            ))}
          </tbody>
        </table>
      </>
    )}

    <script>
      function togglePlayer(name) {
        const row = document.getElementById("detail-" + name);
        if (row.style.display === "none") {
          row.style.display = "table-row";
        } else {
          row.style.display = "none";
        }
      }
    </script>
  </body>
</html>