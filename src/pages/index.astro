---
import { supabase } from '../lib/supabase.js';

const { data: players, error } = await supabase
  .from('players')
  .select('*')
  .order('name', { ascending: true });
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Legends Database</title>
  </head>

  <body style="font-family: Arial, sans-serif; padding: 20px;">
    <h1>Legends Database</h1>

    {error && <p>Errore nel caricamento dati.</p>}

    {!error && (
      <table border="1" cellpadding="6" cellspacing="0">
        <thead>
          <tr>
            <th>Name</th>
            <th>Birth Year</th>
            <th>Nation</th>
            <th>Role</th>
            <th>Height</th>
            <th>Weight</th>
            <th>Foot</th>
            <th>Decade</th>
            <th>Club</th>
            <th>Overall</th>
            <th>Stats</th>
          </tr>
        </thead>

        <tbody>
          {players?.map((p, index) => (
            <tr>
              <td>{p.name}</td>
              <td>{p.birth_year}</td>
              <td>{p.nation}</td>
              <td>{p.role}</td>
              <td>{p.height}</td>
              <td>{p.weight}</td>
              <td>{p.preferred_foot}</td>
              <td>{p.decade}</td>
              <td>{p.iconic_club}</td>
              <td>{p.overall_rating}</td>

              <td>
                <div
                  class="toggle-stats"
                  data-target={`stats-${index}`}
                  style="cursor:pointer; user-select:none;"
                >
                  📊 Stats
                </div>

                <div
                  id={`stats-${index}`}
                  style="display:none; font-size:12px; margin-top:5px; line-height:1.4;"
                >
                  Club Apps: {p.club_apps}<br />
                  Club Goals: {p.club_goals}<br />
                  Club Ratio: {p.club_goal_ratio}<br />
                  Nat Apps: {p.nat_apps}<br />
                  Nat Goals: {p.nat_goals}<br />
                  Nat Ratio: {p.nat_goal_ratio}
                </div>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    )}

    <script is:inline>
      document.addEventListener('DOMContentLoaded', () => {
        const toggles = document.querySelectorAll('.toggle-stats');

        toggles.forEach((toggle) => {
          toggle.addEventListener('click', () => {
            const targetId = toggle.getAttribute('data-target');
            const content = document.getElementById(targetId);

            if (!content) return;

            if (content.style.display === 'none' || content.style.display === '') {
              content.style.display = 'block';
            } else {
              content.style.display = 'none';
            }
          });
        });
      });
    </script>
  </body>
</html>