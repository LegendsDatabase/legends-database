---
import { supabase } from '../lib/supabase.js';

const { data: players, error } = await supabase
  .from('players')
  .select('*')
  .order('name', { ascending: true });
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Legends Database</title>
  </head>

  <body style="font-family: Arial, sans-serif; padding: 20px;">
    <h1>Legends Database</h1>

    {error && <p>Errore nel caricamento dati.</p>}

    {!error && (
      <>
        <table border="1" cellpadding="8" cellspacing="0">
          <thead>
            <tr>
              <th>Name</th>
              <th>Nation</th>
              <th>Role</th>
              <th>Birth Year</th>
            </tr>
          </thead>

          <tbody>
            {players?.map((player) => (
              <tr style="cursor:pointer;" onclick={`selectPlayer('${player.name}')`}>
                <td>{player.name}</td>
                <td>{player.nation}</td>
                <td>{player.role}</td>
                <td>{player.birth_year}</td>
              </tr>
            ))}
          </tbody>
        </table>

        <div id="selectedPlayer" style="margin-top:20px; font-size:18px;"></div>
      </>
    )}

    <script>
      function selectPlayer(name) {
        document.getElementById("selectedPlayer").innerText =
          "Hai selezionato: " + name;
      }
    </script>
  </body>
</html>