initCoachSelect('setCoachA');initCoachSelect('setCoachB');initRefereeSelect();
['A','B'].forEach(side=>{initFormationBtns(side);initRandomBtns(side);buildSlots(side,false);buildSlots(side,true);drawPitch('pitch'+side,side);});
updateValidation();
</script>
