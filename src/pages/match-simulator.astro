<circle cx="${W/2}" cy="${H/2}" r="30" fill="none" stroke="rgba(255,255,255,0.16)" stroke-width="0.8"/>
<circle cx="${W/2}" cy="${H/2}" r="2" fill="rgba(255,255,255,0.4)"/>
<rect x="44" y="8" width="${W-88}" height="55" fill="none" stroke="rgba(255,255,255,0.16)" stroke-width="0.8"/>
<rect x="74" y="8" width="${W-148}" height="24" fill="none" stroke="rgba(255,255,255,0.11)" stroke-width="0.7"/>
<rect x="44" y="${H-63}" width="${W-88}" height="55" fill="none" stroke="rgba(255,255,255,0.16)" stroke-width="0.8"/>
<rect x="74" y="${H-32}" width="${W-148}" height="24" fill="none" stroke="rgba(255,255,255,0.11)" stroke-width="0.7"/>`;
  formation.coords.forEach((coord,i)=>{
    const x=(coord[0]/100)*W,y=(coord[1]/100)*H;
