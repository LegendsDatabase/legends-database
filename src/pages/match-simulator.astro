    .preview-v{font-size:10.5px;font-weight:700;color:#1d1d1f;line-height:1.35;}
    .role-fit-tag{font-size:7.5px;font-weight:800;letter-spacing:0.04em;text-transform:uppercase;border-radius:999px;padding:2px 5px;min-width:34px;text-align:center;white-space:nowrap;}
