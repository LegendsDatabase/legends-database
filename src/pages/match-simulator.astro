          <option value="5">5 Subs</option>
        </select>
      </div>
      <div class="mset-group"><label class="mset-label">Coach A</label>
        <select class="mset-select" id="setCoachA"></select>
      </div>
      <div class="mset-group"><label class="mset-label">Coach B</label>
        <select class="mset-select" id="setCoachB"></select>
      </div>
    </div>
    <!-- SETTINGS ROW 2 -->
    <div class="match-settings-bar row2">
      <div class="mset-group"><label class="mset-label">Referee</label>
        <select class="mset-select" id="setReferee"></select>
      </div>
      <div></div>
      <div style="display:flex;align-items:flex-end;">
        <div class="validation-row" id="validationRow">
          <div class="val-dot" id="valGkA"></div><span class="val-label" id="valGkALbl">Team A: needs GK</span>
          <div class="val-dot" style="margin-left:9px;" id="valGkB"></div><span class="val-label" id="valGkBLbl">Team B: needs GK</span>
