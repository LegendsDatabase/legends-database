              <div class="stat-bar-wrap"><div class="stat-bar-a" id="stOnTargetBarA"></div><div class="stat-bar-b" id="stOnTargetBarB"></div></div>
            </div>
            <div class="stat-val right" id="stOnTargetB">0</div>
          </div>
          <div class="stat-row">
            <div class="stat-val" id="stCornersA">0</div>
            <div>
              <div style="font-size:9.5px;font-weight:600;color:#aeaeb2;text-align:center;letter-spacing:0.04em;text-transform:uppercase;margin-bottom:4px;">Corners</div>
              <div class="stat-bar-wrap"><div class="stat-bar-a" id="stCornersBarA"></div><div class="stat-bar-b" id="stCornersBarB"></div></div>
            </div>
            <div class="stat-val right" id="stCornersB">0</div>
          </div>
        </div>
        <div class="stat-row-group">
          <div class="stat-group-title">Possession & Discipline</div>
          <div class="stat-row">
            <div class="stat-val" id="stPossA">0%</div>
            <div>
              <div style="font-size:9.5px;font-weight:600;color:#aeaeb2;text-align:center;letter-spacing:0.04em;text-transform:uppercase;margin-bottom:4px;">Possession</div>
              <div class="stat-bar-wrap"><div class="stat-bar-a" id="stPossBarA"></div><div class="stat-bar-b" id="stPossBarB"></div></div>
            </div>
            <div class="stat-val right" id="stPossB">0%</div>
          </div>
          <div class="stat-row">
            <div class="stat-val" id="stFoulsA">0</div>
            <div>
              <div style="font-size:9.5px;font-weight:600;color:#aeaeb2;text-align:center;letter-spacing:0.04em;text-transform:uppercase;margin-bottom:4px;">Fouls</div>
              <div class="stat-bar-wrap"><div class="stat-bar-a" id="stFoulsBarA"></div><div class="stat-bar-b" id="stFoulsBarB"></div></div>
            </div>
            <div class="stat-val right" id="stFoulsB">0</div>
          </div>
          <div class="stat-row-full" style="margin-top:10px;">
            <span class="stat-row-full-label">Yellow Cards</span>
            <div class="stat-row-full-vals">
              <span class="stat-chip a" id="stYellowA">0</span>
              <span style="font-size:10px;color:#aeaeb2;">vs</span>
              <span class="stat-chip b" id="stYellowB">0</span>
            </div>
          </div>
          <div class="stat-row-full">
            <span class="stat-row-full-label">Red Cards</span>
            <div class="stat-row-full-vals">
              <span class="stat-chip a" id="stRedA">0</span>
              <span style="font-size:10px;color:#aeaeb2;">vs</span>
              <span class="stat-chip b" id="stRedB">0</span>
            </div>
          </div>
          <div class="stat-row-full">
            <span class="stat-row-full-label">Offsides</span>
            <div class="stat-row-full-vals">
              <span class="stat-chip a" id="stOffA">0</span>
              <span style="font-size:10px;color:#aeaeb2;">vs</span>
              <span class="stat-chip b" id="stOffB">0</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<Footer/>

