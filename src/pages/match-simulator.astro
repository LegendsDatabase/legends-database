    .penalty-kick { width: 26px; height: 26px; border-radius: 50%; font-size: 13px; display: flex; align-items: center; justify-content: center; font-weight: 700; border: 2px solid transparent; }
    .pk-scored-a { background: rgba(77,255,136,0.15); border-color: #4dff88; color: #4dff88; }
