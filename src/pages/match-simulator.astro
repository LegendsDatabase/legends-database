          <div class="tsb-item"><div class="tsb-val" id="defB">—</div><div class="tsb-lbl">Defense</div></div>
          <div class="tsb-item">
            <div class="gelling-badge" id="gelB">✦ 0<span class="gelling-tooltip" id="gelTipB">No players yet.</span></div>
            <div class="tsb-lbl" style="margin-top:3px;">Gelling</div>
          </div>
        </div>
