---
import { supabase } from '../lib/supabase.js';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const { data: raw } = await supabase
  .from('players')
  .select(`id,slug,name,role,nation,iconic_club,overall_rating,decade,
           acceleration,pace,agility,strength,balance,jumping,stamina,fitness,
           dribbling,short_passing,long_passing,finishing,shot_accuracy,shot_power,
           heading,tackling,free_kick,penalties,composure,aggression,consistency,
           creativity,work_rate,vision,off_the_ball,def_positioning,teamwork,
           anticipation,marking,reflexes,positioning,handling,kicking,alt_roles`)
  .not('slug','is',null)
  .order('overall_rating',{ascending:false});

const players = (raw ?? []).map(p => ({
  id:p.id, slug:p.slug||'', n:p.name??'', r:(p.role??'CM').toUpperCase(),
  nat:p.nation??'', club:p.iconic_club??'', ovr:p.overall_rating??70,
  dec:p.decade??0, alt:p.alt_roles??'',
  acc:p.acceleration??70, pac:p.pace??70, agi:p.agility??70, str:p.strength??70,
  bal:p.balance??70, jmp:p.jumping??70, sta:p.stamina??70, fit:p.fitness??70,
  dri:p.dribbling??70, sps:p.short_passing??70, lps:p.long_passing??70,
  fin:p.finishing??70, sha:p.shot_accuracy??70, shp:p.shot_power??70,
  hea:p.heading??70, tac:p.tackling??70, frk:p.free_kick??70, pen:p.penalties??70,
  com:p.composure??70, agg:p.aggression??70, con:p.consistency??70,
  cre:p.creativity??70, wrt:p.work_rate??70, vis:p.vision??70,
  otb:p.off_the_ball??70, dep:p.def_positioning??70, tmw:p.teamwork??70,
  ant:p.anticipation??70, mar:p.marking??70, ref:p.reflexes??70,
  pos:p.positioning??70, han:p.handling??70, kic:p.kicking??70,
}));

const allNations = [...new Set(players.map(p=>p.nat).filter(Boolean))].sort();
const allDecades = [1950,1960,1970,1980,1990,2000,2010];
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1"/>
  <title>Legendary Match Simulator – Legends Database</title>
  <meta name="description" content="Simulate a legendary football match between historical all-time squads."/>
  <meta name="robots" content="index, follow"/>
  <link rel="canonical" href="https://legendsdatabase.com/match-simulator"/>
  <link rel="icon" type="image/png" href="/favicon.png"/>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet"/>
  <style is:global>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
    body{font-family:-apple-system,'SF Pro Text','Inter',sans-serif;background:#f2f2f7;color:#1d1d1f;padding-top:44px;-webkit-font-smoothing:antialiased;min-height:100vh;display:flex;flex-direction:column;}
    #mobileWall{display:none;flex-direction:column;align-items:center;justify-content:center;min-height:60vh;padding:40px 24px;text-align:center;}
    #mobileWall h2{font-size:22px;font-weight:700;margin-bottom:10px;}
    #mobileWall p{font-size:15px;color:#6e6e73;line-height:1.6;}
    @media(max-width:1023px){#mobileWall{display:flex;}#simulator{display:none!important;}}
    #simulator{flex:1;display:flex;flex-direction:column;}
    .beta-banner{background:linear-gradient(135deg,#0a0a1a,#1a1a2e);padding:10px 40px;display:flex;align-items:center;gap:14px;}
    .beta-pill{font-size:9px;font-weight:800;letter-spacing:0.14em;text-transform:uppercase;background:#0071e3;color:#fff;padding:3px 8px;border-radius:5px;flex-shrink:0;}
    .beta-text{font-size:11px;color:rgba(255,255,255,0.48);}
    .beta-text strong{color:rgba(255,255,255,0.80);font-weight:600;}
    .sim-header{background:linear-gradient(135deg,#0a0a1a 0%,#1a1a2e 50%,#0f3460 100%);padding:20px 40px 16px;position:relative;overflow:hidden;}
    .sim-header::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 60% 0%,rgba(0,113,227,0.12),transparent 70%);}
    .sim-header-inner{position:relative;}
    .sim-eyebrow{font-size:9.5px;font-weight:800;color:#0071e3;letter-spacing:0.14em;text-transform:uppercase;margin-bottom:4px;}
    .sim-title{font-size:24px;font-weight:800;letter-spacing:-0.5px;color:#fff;line-height:1.1;margin-bottom:2px;}
    .sim-sub{font-size:11px;color:rgba(255,255,255,0.36);}
    .match-settings-bar{background:#fff;border-bottom:1px solid #e5e5ea;padding:12px 40px;display:grid;grid-template-columns:repeat(7,1fr);gap:9px;align-items:end;}
    .match-settings-bar.row2{border-top:none;padding-top:5px;padding-bottom:10px;grid-template-columns:1fr 1fr 1fr 4fr;}
    .mset-group{display:flex;flex-direction:column;gap:3px;}
    .mset-label{font-size:8.5px;font-weight:700;color:#aeaeb2;letter-spacing:0.08em;text-transform:uppercase;}
    .mset-select{font-family:inherit;font-size:10.5px;font-weight:500;color:#1d1d1f;background:#f9f9fb;border:1.5px solid #e5e5ea;border-radius:7px;padding:5px 6px;outline:none;cursor:pointer;transition:border-color 0.14s;}
    .mset-select:focus{border-color:#0071e3;}
    .mset-select.coach-req{border-color:#ffb800!important;}
    .mset-select.coach-ok{border-color:#2e8b2e!important;}
    .match-identity-bar{background:linear-gradient(180deg,#f0f0f8,#f2f2f7);border-bottom:1px solid #e5e5ea;padding:11px 40px;display:flex;align-items:center;justify-content:space-between;gap:16px;}
    .mib-name{font-size:14px;font-weight:800;letter-spacing:-0.3px;flex:1;}
    .mib-name.mib-a{color:#1a7a1a;}
    .mib-name.mib-b{color:#c0392b;text-align:right;}
    .mib-center{flex:0;display:flex;flex-direction:column;align-items:center;gap:7px;min-width:200px;}
    .mib-vs{font-size:10.5px;font-weight:800;color:#aeaeb2;letter-spacing:0.1em;}
    .mib-clash-row{display:flex;gap:5px;flex-wrap:wrap;justify-content:center;}
    .clash-badge{font-size:9px;font-weight:700;padding:2px 8px;border-radius:10px;letter-spacing:0.02em;white-space:nowrap;}
    .clash-a{background:#efffee;color:#1a7a1a;border:1px solid #c6ead4;}
    .clash-b{background:#fff0ee;color:#c0392b;border:1px solid #f5c6bc;}
    .clash-eq{background:#f5f5f7;color:#6e6e73;border:1px solid #e5e5ea;}
    #phase-setup{flex:1;}
    .setup-body{display:grid;grid-template-columns:1fr 34px 1fr;gap:0;align-items:start;}
    .team-builder{background:#fff;padding:16px 20px 20px;min-height:560px;}
    .tb-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:9px;gap:8px;}
    .tb-header-left{display:flex;align-items:center;gap:7px;flex:1;}
    .tb-name-input{font-family:inherit;font-size:14px;font-weight:700;color:#1d1d1f;background:transparent;border:none;outline:none;letter-spacing:-0.2px;width:160px;}
    .tb-name-input:focus{border-bottom:2px solid #0071e3;}
    .btn-reset-squad{font-family:inherit;font-size:10px;font-weight:600;padding:3px 9px;border-radius:6px;border:1.5px solid #e5e5ea;background:#f9f9fb;color:#aeaeb2;cursor:pointer;transition:all 0.13s;white-space:nowrap;}
    .btn-reset-squad:hover{border-color:#c0392b;color:#c0392b;background:#fff5f5;}
    .tb-formation-row{display:flex;align-items:center;gap:5px;margin-bottom:8px;flex-wrap:wrap;}
    .tb-label{font-size:9px;font-weight:700;color:#aeaeb2;letter-spacing:0.08em;text-transform:uppercase;flex-shrink:0;}
    .formation-btn{font-family:inherit;font-size:9.5px;font-weight:600;padding:3px 7px;border-radius:5px;border:1.5px solid #e5e5ea;background:#f9f9fb;color:#6e6e73;cursor:pointer;transition:all 0.13s;}
    .formation-btn.active{background:#0071e3;color:#fff;border-color:#0071e3;}
    .formation-btn.active-b{background:#c0392b;color:#fff;border-color:#c0392b;}
    .formation-btn:hover:not(.active):not(.active-b){border-color:#aeaeb2;color:#1d1d1f;}
    .tb-tactics-row{display:flex;align-items:center;gap:7px;margin-bottom:8px;}
    .tactics-select{font-family:inherit;font-size:10.5px;font-weight:600;color:#1d1d1f;background:#f5f5f7;border:1.5px solid #e5e5ea;border-radius:7px;padding:4px 7px;outline:none;cursor:pointer;flex:1;transition:border-color 0.14s;}
    .tactics-select:focus{border-color:#0071e3;}
    .coach-fit-badge{font-size:8.5px;font-weight:700;padding:2px 6px;border-radius:5px;flex-shrink:0;white-space:nowrap;}
    .cfit-ok{background:#efffee;color:#1a7a1a;}
    .cfit-bad{background:#fff0ee;color:#c0392b;}
    .cfit-med{background:#fef9e7;color:#b7950b;}
    .pitch-wrap{position:relative;width:100%;max-width:300px;margin:0 auto 10px;}
    .pitch-svg{width:100%;height:auto;display:block;border-radius:10px;}
    .slot-filters{display:flex;gap:5px;margin-bottom:7px;align-items:center;}
    .slot-filter-lbl{font-size:9px;font-weight:700;color:#aeaeb2;letter-spacing:0.06em;text-transform:uppercase;white-space:nowrap;}
    .slot-filter-select{font-family:inherit;font-size:9.5px;font-weight:600;color:#6e6e73;background:#f9f9fb;border:1.5px solid #e5e5ea;border-radius:5px;padding:2px 5px;outline:none;cursor:pointer;flex:1;max-width:110px;}
    .slots-area{display:flex;flex-direction:column;gap:4px;max-height:230px;overflow-y:auto;scrollbar-width:thin;padding-right:3px;}
    .slots-area::-webkit-scrollbar{width:3px;}
    .slots-area::-webkit-scrollbar-thumb{background:#d1d1d6;border-radius:2px;}
    .slot-row{display:flex;align-items:center;gap:5px;}
    .slot-pos{font-size:8px;font-weight:800;padding:2px 4px;border-radius:4px;min-width:26px;text-align:center;letter-spacing:0.04em;flex-shrink:0;}
    .slot-pos.gk{background:#fef9e7;color:#b7950b;}
    .slot-pos.def{background:#efffee;color:#1a7a1a;}
    .slot-pos.mid{background:#eef4ff;color:#0071e3;}
    .slot-pos.att{background:#fff0ee;color:#c0392b;}
    .slot-input-wrap{flex:1;position:relative;}
    .slot-input{width:100%;font-family:inherit;font-size:10.5px;font-weight:500;color:#1d1d1f;background:#f9f9fb;border:1.5px solid #e5e5ea;border-radius:5px;padding:5px 6px;outline:none;transition:border-color 0.14s;cursor:pointer;}
    .slot-input:focus{border-color:#0071e3;background:#fff;}
    .slot-input.filled{background:#f0f9f0;border-color:#2e8b2e;}
    .slot-input.filled-b{background:#fff0f0;border-color:#c0392b;}
    .slot-input.out-of-pos{border-style:dashed;}
    .slot-input.duplicate{border-color:#e07800!important;background:#fffbf0!important;}
    .slot-ovr{font-size:10px;font-weight:700;min-width:20px;text-align:right;font-variant-numeric:tabular-nums;}
    .slot-dropdown{position:absolute;top:calc(100% + 2px);left:0;right:0;background:#fff;border:1.5px solid #e5e5ea;border-radius:9px;box-shadow:0 8px 32px rgba(0,0,0,0.14);z-index:100;max-height:180px;overflow-y:auto;display:none;}
    .slot-dropdown.open{display:block;}
    .dd-item{display:flex;align-items:center;gap:6px;padding:6px 8px;cursor:pointer;transition:background 0.1s;border-bottom:1px solid #f5f5f7;}
    .dd-item:last-child{border-bottom:none;}
    .dd-item:hover{background:#f5f5f7;}
    .dd-item-name{font-size:11px;font-weight:500;color:#1d1d1f;flex:1;}
    .dd-item-role{font-size:8.5px;font-weight:700;padding:1px 4px;border-radius:3px;}
    .dd-item-ovr{font-size:10px;font-weight:700;min-width:20px;text-align:right;}
    .dd-item-nat{font-size:9px;color:#aeaeb2;}
    .dd-item-dup{font-size:9px;color:#e07800;flex-shrink:0;}
    .slot-clear{width:15px;height:15px;border:none;background:transparent;color:#aeaeb2;cursor:pointer;font-size:11px;display:flex;align-items:center;justify-content:center;border-radius:50%;transition:all 0.1s;flex-shrink:0;visibility:hidden;}
    .slot-clear.visible{visibility:visible;}
    .slot-clear:hover{background:#fee;color:#c0392b;}
    .bench-toggle{font-family:inherit;font-size:10px;font-weight:600;color:#0071e3;background:transparent;border:none;cursor:pointer;padding:4px 0;display:flex;align-items:center;gap:4px;margin-bottom:4px;}
    .bench-section{display:none;}
    .bench-section.open{display:block;}
    .random-row{display:flex;gap:4px;flex-wrap:wrap;margin-bottom:8px;}
    .random-btn{font-family:inherit;font-size:9.5px;font-weight:600;padding:3px 8px;border-radius:6px;border:1.5px solid #e5e5ea;background:#f9f9fb;color:#6e6e73;cursor:pointer;transition:all 0.13s;}
    .random-btn:hover{border-color:#0071e3;color:#0071e3;background:#f0f6ff;}
    .team-stats-bar{display:grid;grid-template-columns:repeat(4,1fr);gap:5px;margin-top:9px;padding-top:9px;border-top:1px solid #f0f0f5;}
    .tsb-item{text-align:center;}
    .tsb-val{font-size:15px;font-weight:700;letter-spacing:-0.2px;color:#1d1d1f;line-height:1;}
    .tsb-lbl{font-size:8.5px;font-weight:700;color:#aeaeb2;letter-spacing:0.06em;text-transform:uppercase;margin-top:2px;}
    .gelling-badge{display:inline-flex;align-items:center;gap:3px;font-size:10.5px;font-weight:600;padding:3px 7px;border-radius:7px;background:#f5f5f7;color:#6e6e73;cursor:help;position:relative;}
    .gelling-badge.high{background:#efffee;color:#1a7a1a;}
    .gelling-badge.med{background:#eef4ff;color:#0071e3;}
    .gelling-badge.low{background:#fff0ee;color:#c0392b;}
    .gelling-tooltip{position:absolute;bottom:calc(100% + 6px);left:50%;transform:translateX(-50%);background:#1d1d1f;color:#fff;font-size:10px;padding:7px 11px;border-radius:7px;white-space:nowrap;pointer-events:none;opacity:0;transition:opacity 0.15s;z-index:50;line-height:1.6;text-align:left;}
    .gelling-badge:hover .gelling-tooltip{opacity:1;}
    .attitude-badge{display:inline-flex;align-items:center;gap:3px;font-size:9px;font-weight:700;padding:2px 6px;border-radius:5px;letter-spacing:0.04em;text-transform:uppercase;}
    .att-off{background:#fff0ee;color:#c0392b;}
    .att-bal{background:#eef4ff;color:#0071e3;}
    .att-def{background:#efffee;color:#1a7a1a;}
    .vs-divider{background:#f2f2f7;display:flex;align-items:center;justify-content:center;writing-mode:vertical-rl;}
    .vs-text{font-size:9px;font-weight:800;color:#aeaeb2;letter-spacing:0.1em;}
    .win-prob-wrap{display:none;flex-direction:column;gap:5px;flex:1;margin-right:18px;}
    .win-prob-wrap.visible{display:flex;}
    .win-prob-row{display:flex;justify-content:space-between;align-items:center;}
    .win-prob-team{font-size:11px;font-weight:700;color:#1d1d1f;}
    .win-prob-pct{font-size:13px;font-weight:800;font-variant-numeric:tabular-nums;}
    .win-prob-pct.a{color:#1a7a1a;}
    .win-prob-pct.b{color:#c0392b;}
    .win-prob-track{height:7px;border-radius:4px;background:#e5e5ea;overflow:hidden;display:flex;}
    .win-prob-bar-a{height:100%;background:linear-gradient(to right,#1a7a1a,#2e8b2e);border-radius:4px 0 0 4px;transition:width 0.4s ease;}
    .win-prob-bar-b{height:100%;background:linear-gradient(to left,#c0392b,#e74c3c);border-radius:0 4px 4px 0;transition:width 0.4s ease;}
    .win-prob-edge{font-size:10px;font-weight:600;color:#6e6e73;text-align:center;font-style:italic;}
    .win-prob-reasons{font-size:9.5px;color:#aeaeb2;text-align:center;}
    .simulate-bar{background:#fff;border-top:1px solid #e5e5ea;padding:12px 40px;display:flex;align-items:center;gap:14px;}
    .sim-bar-left{flex:1;display:flex;flex-direction:column;gap:5px;}
    .validate-msg{font-size:11.5px;color:#c0392b;font-weight:500;}
    .simulate-btn{font-family:inherit;font-size:13px;font-weight:700;padding:11px 36px;background:linear-gradient(135deg,#0071e3,#0077ed);color:#fff;border:none;border-radius:10px;cursor:pointer;transition:transform 0.14s,box-shadow 0.14s,opacity 0.14s;box-shadow:0 4px 20px rgba(0,113,227,0.3);flex-shrink:0;}
    .simulate-btn:hover:not(:disabled){transform:translateY(-2px);box-shadow:0 8px 28px rgba(0,113,227,0.4);}
    .simulate-btn:disabled{opacity:0.45;cursor:not-allowed;}
    .validation-row{display:flex;align-items:center;gap:6px;flex-wrap:wrap;}
    .val-dot{width:6px;height:6px;border-radius:50%;background:#e5e5ea;}
    .val-dot.ok{background:#2e8b2e;}
    .val-dot.warn{background:#c8a800;}
    .val-dot.err{background:#c0392b;}
    .val-label{font-size:9.5px;color:#6e6e73;}
    .loading-overlay{position:fixed;inset:0;background:rgba(10,10,26,0.90);backdrop-filter:blur(12px);z-index:300;display:none;flex-direction:column;align-items:center;justify-content:center;gap:18px;}
    .loading-overlay.active{display:flex;}
    .loading-spinner{width:44px;height:44px;border:3px solid rgba(255,255,255,0.10);border-top-color:#0071e3;border-radius:50%;animation:spin 0.8s linear infinite;}
    @keyframes spin{to{transform:rotate(360deg);}}
    .loading-text{font-size:13px;font-weight:600;color:rgba(255,255,255,0.70);}
    .loading-sub{font-size:10.5px;color:rgba(255,255,255,0.32);}
    #phase-match{flex:1;display:flex;flex-direction:column;background:#0a0a1a;}
    #phase-match.hidden{display:none;}
    .match-header-bar{padding:12px 40px;background:linear-gradient(180deg,#0f0f1e,#0a0a1a);border-bottom:1px solid rgba(255,255,255,0.06);display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:8px;}
    .mhb-competition{font-size:10px;font-weight:700;color:rgba(255,255,255,0.38);letter-spacing:0.1em;text-transform:uppercase;}
    .mhb-meta{display:flex;gap:10px;flex-wrap:wrap;align-items:center;}
    .mhb-item{font-size:10px;color:rgba(255,255,255,0.28);}
    .mhb-personality{font-size:9.5px;font-weight:700;padding:2px 8px;border-radius:5px;letter-spacing:0.04em;}
    .mp-tactical{background:rgba(0,113,227,0.18);color:#6ab0ff;}
    .mp-physical{background:rgba(255,100,100,0.18);color:#ff9090;}
    .mp-technical{background:rgba(77,255,136,0.18);color:#4dff88;}
    .mp-open{background:rgba(255,200,0,0.18);color:#ffd700;}
    .mp-chaotic{background:rgba(255,140,0,0.18);color:#ffaa40;}
    .mhb-ref{font-size:9.5px;color:rgba(255,255,255,0.35);}
    .scoreboard{padding:20px 40px 16px;display:grid;grid-template-columns:1fr auto 1fr;align-items:center;gap:20px;background:#0a0a1a;}
    .sb-team{display:flex;flex-direction:column;align-items:center;gap:4px;}
    .sb-team-name{font-size:12px;font-weight:700;color:rgba(255,255,255,0.65);text-align:center;}
    .sb-team-meta{font-size:8.5px;color:rgba(255,255,255,0.25);text-align:center;line-height:1.4;}
    .sb-score-wrap{display:flex;flex-direction:column;align-items:center;gap:3px;}
    .sb-score{display:flex;align-items:center;gap:6px;font-size:60px;font-weight:900;letter-spacing:-3px;font-variant-numeric:tabular-nums;line-height:1;}
    .sb-score-a{color:#4dff88;}
    .sb-score-b{color:#ff6b5b;}
    .sb-score-sep{color:rgba(255,255,255,0.16);font-size:32px;letter-spacing:0;}
    .sb-time{font-size:10px;font-weight:600;color:rgba(255,255,255,0.26);letter-spacing:0.06em;}
    .sb-status{font-size:9px;font-weight:700;padding:2px 8px;border-radius:5px;letter-spacing:0.08em;text-transform:uppercase;}
    .sb-status.live{background:rgba(255,100,100,0.18);color:#ff6b6b;animation:pulse-live 1.5s infinite;}
    .sb-status.ft{background:rgba(77,255,136,0.14);color:#4dff88;}
    @keyframes pulse-live{0%,100%{opacity:1;}50%{opacity:0.4;}}
    @keyframes goal-flash{0%{transform:scale(1);}20%{transform:scale(1.38);color:#ffd700;}65%{transform:scale(1.12);}100%{transform:scale(1);}}
    .goal-flash{animation:goal-flash 0.65s ease-out;}
    .commentary-wrap{flex:1;max-width:820px;width:100%;margin:0 auto;padding:0 40px 14px;}
    .commentary-feed{display:flex;flex-direction:column;gap:0;max-height:360px;overflow-y:auto;scrollbar-width:thin;scrollbar-color:rgba(255,255,255,0.07) transparent;padding-right:3px;}
    .commentary-feed::-webkit-scrollbar{width:3px;}
    .commentary-feed::-webkit-scrollbar-thumb{background:rgba(255,255,255,0.07);border-radius:2px;}
    .cmt-item{display:grid;grid-template-columns:38px 1fr;gap:9px;padding:7px 0;border-bottom:1px solid rgba(255,255,255,0.04);opacity:0;transform:translateY(5px);transition:opacity 0.28s ease,transform 0.28s ease;}
    .cmt-item.visible{opacity:1;transform:translateY(0);}
    .cmt-item.ht-item{border-top:1px solid rgba(255,255,255,0.07);}
    .cmt-min{font-size:10px;font-weight:800;color:rgba(255,255,255,0.20);font-variant-numeric:tabular-nums;padding-top:2px;text-align:right;}
    .cmt-text{font-size:12px;color:rgba(255,255,255,0.66);line-height:1.6;}
