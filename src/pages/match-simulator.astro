    .ratings-team-header.b { background: #c0392b; }
    .ratings-team-header span { font-size: 10.5px; opacity: 0.75; }
    .rating-row { display: flex; align-items: center; padding: 8px 16px; border-bottom: 1px solid #f5f5f7; }
    .rating-row:last-child { border-bottom: none; }
    .rating-pos { font-size: 9.5px; font-weight: 700; padding: 1px 5px; border-radius: 4px; min-width: 26px; text-align: center; margin-right: 9px; }
    .rating-name { font-size: 12.5px; font-weight: 500; color: #1d1d1f; flex: 1; }
    .rating-events { font-size: 10.5px; color: #6e6e73; margin-right: 9px; }
    .rating-score { font-size: 15px; font-weight: 800; min-width: 28px; text-align: right; font-variant-numeric: tabular-nums; }
    .rs-great { color: #1a7a1a; }
    .rs-good  { color: #2e8b2e; }
    .rs-avg   { color: #c8a800; }
    .rs-poor  { color: #c0392b; }

    /* ── MATCH ACTIONS ── */
    .match-actions {
      background: #0a0a1a; padding: 14px 40px;
      display: flex; align-items: center; justify-content: center; gap: 12px;
      border-top: 1px solid rgba(255,255,255,0.06);
    }
    .action-btn { font-family: inherit; font-size: 13px; font-weight: 600; padding: 10px 26px; border-radius: 11px; border: none; cursor: pointer; transition: all 0.14s; }
    .action-btn.primary   { background: #0071e3; color: #fff; }
    .action-btn.primary:hover { background: #0077ed; }
    .action-btn.secondary { background: rgba(255,255,255,0.08); color: rgba(255,255,255,0.75); }
    .action-btn.secondary:hover { background: rgba(255,255,255,0.13); }

    /* ── PENALTIES ── */
    .penalty-section { padding: 14px 40px; text-align: center; background: #0a0a1a; }
    .penalty-title { font-size: 13px; font-weight: 700; color: rgba(255,255,255,0.7); margin-bottom: 10px; }
