    .broadcast-card{position:relative;overflow:hidden;border:1px solid rgba(255,255,255,0.085);border-radius:18px;background:linear-gradient(135deg,rgba(var(--team-a-rgb),0.16),rgba(255,255,255,0.045) 42%,rgba(var(--team-b-rgb),0.16));box-shadow:0 20px 60px rgba(0,0,0,0.24);padding:18px 20px;}
