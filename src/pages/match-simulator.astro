    .result-meta-pill.win-b{background:var(--team-b-soft);color:var(--team-b);border-color:var(--team-b-border);}
    .result-comment{font-size:13px;color:#3a3a3c;line-height:1.75;text-align:center;max-width:560px;margin:10px auto 14px;}
    .result-share-row{display:flex;align-items:center;justify-content:center;gap:9px;margin:12px 0 4px;}
    .share-result-btn{font-family:inherit;font-size:10.5px;font-weight:800;letter-spacing:0.04em;text-transform:uppercase;color:#0071e3;background:#eef6ff;border:1.5px solid #cfe4ff;border-radius:999px;padding:7px 12px;cursor:pointer;transition:all 0.14s;}
    .share-result-btn:hover{background:#dfefff;border-color:#0071e3;}
    .copy-status{font-size:10.5px;font-weight:600;color:#1a7a1a;min-width:56px;}
    .tv-facts-section{max-width:820px;margin:0 auto 20px;display:grid;grid-template-columns:repeat(5,1fr);gap:9px;}
    .tv-fact{background:#fff;border-radius:13px;padding:13px 14px;box-shadow:0 1px 4px rgba(0,0,0,0.06);border:1px solid rgba(0,0,0,0.035);min-height:92px;position:relative;overflow:hidden;}
    .tv-fact::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:linear-gradient(to right,var(--team-a-live),var(--team-b-live));opacity:0.85;}
    .tv-fact-k{font-size:8px;font-weight:900;color:#aeaeb2;letter-spacing:0.1em;text-transform:uppercase;margin-bottom:7px;}
    .tv-fact-v{font-size:11px;font-weight:700;color:#1d1d1f;line-height:1.45;}
    .pundit-focus{max-width:820px;margin:0 auto 20px;background:linear-gradient(135deg,#ffffff,#f6f7fb);border:1px solid #e8e8ef;border-radius:18px;padding:18px 20px;box-shadow:0 8px 26px rgba(0,0,0,.07);display:grid;grid-template-columns:auto 1fr;gap:15px;align-items:center;}
    .pundit-avatar{width:72px;height:72px;border-radius:50%;object-fit:cover;border:3px solid #fff;box-shadow:0 8px 22px rgba(0,0,0,.16);}
    .pundit-kicker{font-size:8.5px;font-weight:900;color:#aeaeb2;letter-spacing:.12em;text-transform:uppercase;margin-bottom:3px;}
    .pundit-name{font-size:16px;font-weight:900;color:#1d1d1f;letter-spacing:-.25px;}
    .pundit-role{font-size:10px;font-weight:700;color:#8e8e93;margin:2px 0 8px;}
    .pundit-quote{font-size:12.5px;line-height:1.75;color:#303034;font-weight:500;}
    .event-map-section{max-width:820px;margin:0 auto 20px;background:#fff;border-radius:15px;padding:17px 20px;box-shadow:0 1px 4px rgba(0,0,0,0.06);}
    .event-map-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;}
    .event-map-title{font-size:9.5px;font-weight:900;color:#aeaeb2;letter-spacing:0.1em;text-transform:uppercase;}
    .event-map-note{font-size:9.5px;font-weight:600;color:#8e8e93;}
    .event-pitch{position:relative;height:170px;border-radius:14px;overflow:hidden;background:linear-gradient(90deg,#1f5c2a,#256b31 50%,#1f5c2a);border:1px solid rgba(0,0,0,0.08);}
    .event-pitch::before{content:'';position:absolute;inset:10px;border:1px solid rgba(255,255,255,0.24);border-radius:8px;}
    .event-pitch::after{content:'';position:absolute;left:50%;top:10px;bottom:10px;border-left:1px solid rgba(255,255,255,0.20);}
    .event-map-dot{position:absolute;width:20px;height:20px;border-radius:50%;transform:translate(-50%,-50%);display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:900;color:#081108;border:2px solid rgba(255,255,255,0.75);box-shadow:0 6px 18px rgba(0,0,0,0.22);z-index:2;}
    .event-map-dot.goal-a{background:var(--team-a-live);}
    .event-map-dot.goal-b{background:var(--team-b-live);}
    .event-map-dot.save{background:#80d0ff;}
    .event-map-dot.red{background:#ff5555;color:#fff;}
    .event-map-dot.wood{background:#ffd166;}
    .event-map-dot.injury{background:#c0a0ff;}
    .scorers-strip{display:flex;align-items:flex-start;gap:10px;padding-top:12px;border-top:1px solid #f0f0f5;}
    .scorers-col{flex:1;display:flex;flex-direction:column;gap:3px;}
    .scorers-col.right{align-items:flex-end;}
    .scorer-item{font-size:11px;color:#3a3a3c;font-weight:500;display:flex;align-items:center;gap:5px;}
    .scorer-min{font-size:9px;color:#aeaeb2;font-weight:600;font-variant-numeric:tabular-nums;}
    .scorers-sep{font-size:9px;font-weight:700;color:#aeaeb2;align-self:center;padding:0 4px;}
    .empty-state{font-size:11px;font-weight:500;color:#8e8e93;line-height:1.55;padding:8px 0;}
    .build-toast{position:fixed;left:50%;bottom:22px;transform:translate(-50%,12px);background:#1d1d1f;color:#fff;font-size:12px;font-weight:700;padding:9px 14px;border-radius:999px;box-shadow:0 10px 30px rgba(0,0,0,0.22);opacity:0;pointer-events:none;transition:opacity 0.2s,transform 0.2s;z-index:500;}
    .build-toast.visible{opacity:1;transform:translate(-50%,0);}
    .cinematic-section{max-width:820px;margin:0 auto 20px;display:grid;grid-template-columns:repeat(3,1fr);gap:12px;}
    .cpill{background:#fff;border-radius:14px;padding:16px 18px;box-shadow:0 1px 4px rgba(0,0,0,0.07);display:flex;flex-direction:column;gap:6px;position:relative;overflow:hidden;}
    .cpill::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;}
    .cpill-tp::before{background:linear-gradient(to right,#0071e3,#34aadc);}
    .cpill-kd::before{background:linear-gradient(to right,#c0392b,#e74c3c);}
    .cpill-ts::before{background:linear-gradient(to right,#1a7a1a,#2e8b2e);}
    .cpill-icon{font-size:18px;line-height:1;}
    .cpill-label{font-size:9px;font-weight:800;color:#aeaeb2;letter-spacing:0.1em;text-transform:uppercase;}
    .cpill-text{font-size:11.5px;color:#1d1d1f;line-height:1.55;font-weight:500;}
    .post-notes-section{max-width:820px;margin:0 auto 20px;display:grid;grid-template-columns:repeat(3,1fr);gap:12px;}
    .post-note{background:#fff;border-radius:14px;padding:15px 17px;box-shadow:0 1px 4px rgba(0,0,0,0.07);border:1px solid rgba(0,0,0,0.035);}
    .post-note-label{font-size:8.5px;font-weight:800;color:#aeaeb2;letter-spacing:0.1em;text-transform:uppercase;margin-bottom:6px;}
    .post-note-text{font-size:11.5px;color:#1d1d1f;line-height:1.55;font-weight:500;}
    .key-duels-section{max-width:820px;margin:0 auto 20px;background:#fff;border-radius:14px;padding:18px 22px;box-shadow:0 1px 4px rgba(0,0,0,0.06);}
    .kd-title{font-size:9.5px;font-weight:700;color:#aeaeb2;letter-spacing:0.1em;text-transform:uppercase;margin-bottom:14px;}
    .collapse-toggle{width:100%;font-family:inherit;font-size:9.5px;font-weight:800;color:#aeaeb2;letter-spacing:0.1em;text-transform:uppercase;background:transparent;border:none;padding:0;margin:0 0 14px;display:flex;align-items:center;justify-content:space-between;cursor:pointer;}
    .collapse-toggle span{font-size:9px;font-weight:700;letter-spacing:0.04em;text-transform:none;color:#0071e3;background:#eef6ff;border-radius:999px;padding:3px 8px;}
    .collapse-body.collapsed{display:none!important;}
    .section-toggle-wrap{max-width:820px;margin:0 auto 8px;background:#fff;border-radius:12px;padding:10px 14px;box-shadow:0 1px 4px rgba(0,0,0,0.05);}
    .kd-row{display:grid;grid-template-columns:130px 1fr auto 1fr;align-items:center;gap:8px;margin-bottom:9px;padding-bottom:9px;border-bottom:1px solid #f5f5f7;}
    .kd-row:last-child{margin-bottom:0;padding-bottom:0;border-bottom:none;}
    .kd-type{font-size:9px;font-weight:700;color:#aeaeb2;letter-spacing:0.04em;}
    .kd-player-a{font-size:11.5px;font-weight:600;color:var(--team-a);text-align:right;}
    .kd-player-b{font-size:11.5px;font-weight:600;color:var(--team-b);}
    .kd-score{font-size:11px;font-weight:800;font-variant-numeric:tabular-nums;white-space:nowrap;text-align:center;}
    .kd-score.a-won{color:var(--team-a);}
    .kd-score.b-won{color:var(--team-b);}
    .kd-score.draw{color:#aeaeb2;}
    .motm-section{max-width:820px;margin:0 auto 18px;}
    .motm-card{background:linear-gradient(135deg,#1a1a2e,#0f3460);border-radius:14px;padding:18px 22px;display:flex;align-items:center;gap:16px;position:relative;overflow:hidden;}
    .motm-card::after{content:'⭐';position:absolute;right:18px;top:12px;font-size:26px;opacity:0.14;}
    .motm-badge{font-size:9px;font-weight:800;color:#ffd700;letter-spacing:0.1em;text-transform:uppercase;margin-bottom:4px;}
    .motm-name{font-size:18px;font-weight:800;color:#fff;letter-spacing:-0.2px;margin-bottom:2px;}
    .motm-meta{font-size:11px;color:rgba(255,255,255,0.40);}
    .motm-rating{margin-left:auto;font-size:40px;font-weight:900;color:#ffd700;letter-spacing:-2px;line-height:1;}
    .results-grid{max-width:820px;margin:0 auto 18px;display:grid;grid-template-columns:1fr 1fr;gap:11px;}
    .ratings-team{background:#fff;border-radius:13px;overflow:hidden;box-shadow:0 1px 4px rgba(0,0,0,0.06);}
    .ratings-team-header{padding:9px 14px;font-size:11px;font-weight:700;color:#fff;display:flex;align-items:center;justify-content:space-between;}
    .ratings-team-header.a{background:var(--team-a);}
    .ratings-team-header.b{background:var(--team-b);}
    .ratings-team-header span{font-size:9.5px;opacity:0.70;}
    .rating-row{display:flex;align-items:center;padding:6px 13px;border-bottom:1px solid #f5f5f7;}
    .rating-row:last-child{border-bottom:none;}
    .rating-row.sub-row{background:linear-gradient(90deg,#fbfcff,#fff);}
    .rating-row.off-row{background:#fcfcfd;}
    .rating-pos{font-size:8.5px;font-weight:700;padding:1px 4px;border-radius:3px;min-width:22px;text-align:center;margin-right:7px;}
    .rating-player{flex:1;min-width:0;display:flex;flex-direction:column;gap:1px;}
    .rating-name{font-size:11.5px;font-weight:500;color:#1d1d1f;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
    .off-row .rating-name{color:#8e8e93;}
    .rating-subdetail{font-size:8.5px;font-weight:700;color:#8e8e93;letter-spacing:0.02em;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
    .sub-row .rating-subdetail{color:#4b6f9f;}
    .rating-events{font-size:9.5px;color:#6e6e73;margin-right:7px;}
    .rating-score{font-size:13px;font-weight:800;min-width:24px;text-align:right;font-variant-numeric:tabular-nums;}
    .rs-elite{color:#0071e3;}.rs-great{color:#1a7a1a;}.rs-good{color:#2e8b2e;}.rs-avg{color:#c8a800;}.rs-poor{color:#e07800;}.rs-bad{color:#c0392b;}
    .match-stats-section{max-width:820px;margin:0 auto 18px;background:#fff;border-radius:13px;padding:18px 22px;box-shadow:0 1px 4px rgba(0,0,0,0.06);}
    .stats-section-title{font-size:9.5px;font-weight:700;color:#aeaeb2;letter-spacing:0.1em;text-transform:uppercase;margin-bottom:16px;}
    .stat-row{display:grid;grid-template-columns:44px 1fr 44px;align-items:center;gap:8px;margin-bottom:10px;}
    .stat-row:last-child{margin-bottom:0;}
    .stat-val{font-size:12.5px;font-weight:700;color:#1d1d1f;font-variant-numeric:tabular-nums;}
    .stat-val.right{text-align:right;}
    .stat-bar-wrap{height:5px;border-radius:3px;background:#f0f0f5;overflow:hidden;display:flex;}
    .stat-bar-a{height:100%;background:var(--team-a);border-radius:3px 0 0 3px;transition:width 0.6s ease;}
    .stat-bar-b{height:100%;background:var(--team-b);border-radius:0 3px 3px 0;transition:width 0.6s ease;}
    .stat-row-full{display:flex;align-items:center;justify-content:space-between;margin-bottom:9px;}
    .stat-row-full:last-child{margin-bottom:0;}
    .stat-row-full-label{font-size:9px;font-weight:600;color:#aeaeb2;letter-spacing:0.04em;text-transform:uppercase;}
    .stat-row-full-vals{display:flex;gap:7px;align-items:center;}
    .stat-chip{font-size:11px;font-weight:700;padding:2px 8px;border-radius:5px;}
    .stat-chip.a{background:var(--team-a-soft);color:var(--team-a);}
    .stat-chip.b{background:var(--team-b-soft);color:var(--team-b);}
    .stat-row-group{margin-bottom:14px;}
    .stat-row-group:last-child{margin-bottom:0;}
    .stat-group-title{font-size:8.5px;font-weight:700;color:#c7c7cc;letter-spacing:0.08em;text-transform:uppercase;margin-bottom:8px;}
  </style>
</head>
<body>
<Navbar/>
<div class="loading-overlay" id="loadingOverlay">
  <div class="loading-spinner"></div>
  <div class="loading-text">Simulating the match…</div>
  <div class="loading-sub">Processing gelling, momentum, key duels &amp; chaos</div>
</div>
<div class="final-reveal" id="finalReveal">
  <div class="final-reveal-card">
    <div class="final-reveal-cup" id="finalRevealCup">Full Time</div>
    <div class="final-reveal-teams" id="finalRevealTeams">Legends XI vs Rival XI</div>
    <div class="final-reveal-score" id="finalRevealScore">0 - 0</div>
    <div class="final-reveal-winner" id="finalRevealWinner">Winner</div>
  </div>
</div>
<div id="mobileWall">
  <h2>⚽ Desktop Only Feature</h2>
  <p>The Legendary Match Simulator requires a larger screen.</p>
</div>
<div id="simulator">
  <div class="beta-banner">
    <span class="beta-pill">Beta</span>
    <span class="beta-text"><strong>Legendary Match Simulator</strong> — Beta phase. Premium feature coming soon.</span>
  </div>
  <div class="sim-header">
    <div class="sim-header-inner">
      <div class="sim-eyebrow">Legends Database</div>
      <div class="sim-title">Create Your Legendary Game</div>
      <div class="sim-sub">Build two all-time squads and simulate the match of the century</div>
    </div>
  </div>
  <div id="phase-setup">
    <div class="setup-cta-row">
      <div>
        <div class="setup-cta-title">Fast start</div>
        <div class="setup-cta-sub">Generate a balanced match or inspect the simulator logic before kick-off.</div>
      </div>
      <div class="sim-header-actions">
        <button class="header-cta surprise" id="btnSurpriseMe" type="button">Surprise Me</button>
        <button class="header-cta primary" id="calcToggle" type="button">How is the result calculated?</button>
      </div>
    </div>
    <div class="calc-info" id="calcInfo">
      <div class="calc-card">
        <div class="calc-title">The simulator is not pure random: it layers football logic with controlled chaos.</div>
        <div class="calc-grid">
          <div class="calc-item"><strong>Squad strength</strong>Overall rating, role fit, attack/defence departments, goalkeeper value and chemistry shape the baseline.</div>
          <div class="calc-item"><strong>Coach and tactics</strong>Coach bonuses improve specific attributes; a coach aligned with the formation gives an extra tactical bump.</div>
          <div class="calc-item"><strong>Context</strong>Weather changes technique/physicality, stadium gives a small home-nation edge, referee affects cards and chaos.</div>
          <div class="calc-item"><strong>Match flow</strong>Momentum, fatigue, substitutions, red cards, woodwork and randomness decide the final story.</div>
        </div>
      </div>
    </div>
    <div class="match-settings-shell">
      <div class="settings-card">
        <div class="settings-card-head">
          <span class="settings-card-title">Match Context</span>
          <span class="settings-card-sub">venue, weather, format</span>
        </div>
        <div class="settings-card-grid">
      <div class="mset-group"><label class="mset-label">Competition</label>
        <select class="mset-select" id="setCompetition">
          <option value="friendly">⚽ Friendly</option>
          <option value="worldcup">🌍 WC Final</option>
          <option value="champions">⭐ UCL Final</option>
          <option value="libertadores">🏆 Libertadores Final</option>
        </select></div>
      <div class="mset-group"><label class="mset-label">Stadium</label>
        <select class="mset-select" id="setStadium">
          <option value="maracana">🇧🇷 Maracanã</option>
          <option value="wembley">🏴󠁧󠁢󠁥󠁮󠁧󠁿 Wembley</option>
          <option value="bernabeu">🇪🇸 Bernabéu</option>
          <option value="sansiro">🇮🇹 San Siro</option>
          <option value="campnou">🇪🇸 Camp Nou</option>
          <option value="azteca">🇲🇽 Azteca</option>
          <option value="anfield">🏴󠁧󠁢󠁥󠁮󠁧󠁿 Anfield</option>
          <option value="bombonera">🇦🇷 La Bombonera</option>
          <option value="iduna">🇩🇪 Iduna Park</option>
          <option value="centenario">🇺🇾 Centenario</option>
          <option value="oldtrafford">🏴󠁧󠁢󠁥󠁮󠁧󠁿 Old Trafford</option>
          <option value="allianz">🇩🇪 Allianz Arena</option>
          <option value="psg">🇫🇷 Parc des Princes</option>
        </select></div>
      <div class="mset-group"><label class="mset-label">Weather</label>
        <select class="mset-select" id="setWeather">
          <option value="sun">☀️ Perfect</option>
          <option value="light_rain">🌧️ Light Rain</option>
          <option value="heavy_rain">⛈️ Heavy Rain</option>
          <option value="storm">🌪️ Storm &amp; Wind</option>
          <option value="snow">🌨️ Snow</option>
          <option value="random">🎲 Random</option>
        </select></div>
      <div class="mset-group"><label class="mset-label">Match Type</label>
        <select class="mset-select" id="setMatchType">
          <option value="90">90 Minutes</option>
          <option value="et">Extra Time + Pens</option>
          <option value="golden">Golden Goal</option>
        </select></div>
        </div>
      </div>
      <div class="settings-card control">
        <div class="settings-card-head">
          <span class="settings-card-title">Match Control</span>
          <span class="settings-card-sub">referee, subs, readiness</span>
        </div>
        <div class="settings-card-grid">
          <div class="mset-group"><label class="mset-label">Referee</label>
            <select class="mset-select" id="setReferee"></select>
            <div class="referee-insight" id="refereeInsight">Referee personality will shape cards, rhythm and controversy.</div>
          </div>
          <div class="mset-group"><label class="mset-label">Substitutions</label>
            <select class="mset-select" id="setSubs">
              <option value="3">3 Subs</option>
              <option value="5">5 Subs</option>
            </select></div>
          <div class="mset-group">
            <label class="mset-label">Readiness</label>
            <div class="validation-row">
              <div class="val-dot" id="valGkA"></div><span class="val-label" id="valGkALbl">A:GK</span>
              <div class="val-dot" id="valGkB"></div><span class="val-label" id="valGkBLbl">B:GK</span>
              <div class="val-dot" id="valFullA"></div><span class="val-label" id="valFullALbl">A:11</span>
              <div class="val-dot" id="valFullB"></div><span class="val-label" id="valFullBLbl">B:11</span>
              <div class="val-dot" id="valCoach"></div><span class="val-label" id="valCoachLbl">Coaches</span>
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="match-identity-bar">
      <span class="mib-name mib-a" id="mibNameA">Legends XI</span>
      <div class="mib-center">
        <div class="mib-vs">VS</div>
        <div class="mib-clash-row" id="mibClashRow"><span class="clash-badge clash-eq">Build your squads</span></div>
      </div>
      <span class="mib-name mib-b" id="mibNameB">Rival XI</span>
