        <div class="team-stats-bar">
          <div class="tsb-item"><div class="tsb-val" id="ovrA">—</div><div class="tsb-lbl">OVR</div></div>
          <div class="tsb-item"><div class="tsb-val" id="attA">—</div><div class="tsb-lbl">Attack</div></div>
          <div class="tsb-item"><div class="tsb-val" id="defA">—</div><div class="tsb-lbl">Defense</div></div>
          <div class="tsb-item">
            <div class="gelling-badge" id="gelA">✦ 0<span class="gelling-tooltip" id="gelTipA">No players yet.</span></div>
            <div class="tsb-lbl" style="margin-top:3px;">Gelling</div>
          </div>
        </div>
      </div>

      <div class="vs-divider"><span class="vs-text">VS</span></div>

      <!-- TEAM B -->
      <div class="team-builder" id="builderB">
        <div class="tb-header">
          <div class="tb-header-left">
            <input type="text" class="tb-name-input" id="nameB" value="Rival XI" maxlength="24"/>
            <span id="attitudeB" class="attitude-badge att-bal">⚖️ Balanced</span>
          </div>
