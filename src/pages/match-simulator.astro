    .val-dot.ok{background:#2e8b2e;}
    .val-dot.warn{background:#c8a800;}
    .val-dot.err{background:#c0392b;}
    .val-label{font-size:9.5px;color:#6e6e73;}
    .referee-insight{margin-top:5px;font-size:9.5px;font-weight:650;color:#8e8e93;line-height:1.45;}
    .loading-overlay{position:fixed;inset:0;background:rgba(10,10,26,0.90);backdrop-filter:blur(12px);z-index:300;display:none;flex-direction:column;align-items:center;justify-content:center;gap:18px;}
    .loading-overlay.active{display:flex;}
    .loading-spinner{width:44px;height:44px;border:3px solid rgba(255,255,255,0.10);border-top-color:#0071e3;border-radius:50%;animation:spin 0.8s linear infinite;}
