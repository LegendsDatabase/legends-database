  </div>

  <!-- MATCH PHASE -->
  <div id="phase-match" class="hidden">
    <div class="match-header-bar">
      <span class="mhb-competition" id="mhCompetition">Friendly</span>
      <div class="mhb-meta">
        <span id="mhStadium">🏟 Wembley</span>
        <span id="mhWeather">☀️ Perfect</span>
        <span id="mhReferee">⚖️ Collina</span>
      </div>
    </div>
    <div class="scoreboard">
      <div class="sb-team">
        <div class="sb-team-name" id="sbNameA">Legends XI</div>
        <div class="sb-team-formation" id="sbFormationA">4-3-3</div>
      </div>
      <div class="sb-score-wrap">
        <div class="sb-score">
          <span class="sb-score-a" id="sbScoreA">0</span>
          <span class="sb-score-sep">–</span>
          <span class="sb-score-b" id="sbScoreB">0</span>
        </div>
        <div class="sb-time" id="sbTime">0'</div>
        <span class="sb-status live" id="sbStatus">LIVE</span>
      </div>
      <div class="sb-team">
