<rect width="${W}" height="${H}" fill="url(#pg${side})" rx="8"/>
<rect x="0" y="0" width="${W}" height="44" fill="rgba(255,255,255,0.03)"/>
<rect x="0" y="88" width="${W}" height="44" fill="rgba(255,255,255,0.03)"/>
<rect x="0" y="175" width="${W}" height="44" fill="rgba(255,255,255,0.03)"/>
<rect x="0" y="263" width="${W}" height="44" fill="rgba(255,255,255,0.03)"/>
