---
import { supabase } from '../lib/supabase.js';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const { data: raw } = await supabase
  .from('players')
  .select(`id,name,role,nation,iconic_club,overall_rating,acceleration,pace,agility,strength,balance,jumping,stamina,fitness,dribbling,short_passing,long_passing,finishing,shot_accuracy,shot_power,heading,tackling,free_kick,penalties,composure,aggression,consistency,creativity,work_rate,vision,off_the_ball,def_positioning,teamwork,anticipation,marking,reflexes,positioning,handling,kicking,alt_roles`)
  .not('slug','is',null)
  .order('overall_rating',{ascending:false});

const players = (raw ?? []).map(p => ({
  id:   p.id,
  n:    p.name ?? '',
  r:    (p.role ?? 'CM').toUpperCase(),
  nat:  p.nation ?? '',
  club: p.iconic_club ?? '',
  ovr:  p.overall_rating ?? 70,
  acc:  p.acceleration ?? 70,   pac: p.pace ?? 70,
  agi:  p.agility ?? 70,        str: p.strength ?? 70,
  bal:  p.balance ?? 70,        jmp: p.jumping ?? 70,
  sta:  p.stamina ?? 70,        fit: p.fitness ?? 70,
  dri:  p.dribbling ?? 70,      sps: p.short_passing ?? 70,
  lps:  p.long_passing ?? 70,   fin: p.finishing ?? 70,
  sha:  p.shot_accuracy ?? 70,  shp: p.shot_power ?? 70,
  hea:  p.heading ?? 70,        tac: p.tackling ?? 70,
  frk:  p.free_kick ?? 70,      pen: p.penalties ?? 70,
  com:  p.composure ?? 70,      agg: p.aggression ?? 70,
  con:  p.consistency ?? 70,    cre: p.creativity ?? 70,
  wrt:  p.work_rate ?? 70,      vis: p.vision ?? 70,
  otb:  p.off_the_ball ?? 70,   dep: p.def_positioning ?? 70,
  tmw:  p.teamwork ?? 70,       ant: p.anticipation ?? 70,
  mar:  p.marking ?? 70,        ref: p.reflexes ?? 70,
  pos:  p.positioning ?? 70,    han: p.handling ?? 70,
  kic:  p.kicking ?? 70,        alt: p.alt_roles ?? '',
}));
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1"/>
  <title>Legendary Match Simulator – Legends Database</title>
  <meta name="description" content="Simulate a legendary football match between historical all-time squads. Pick your formation, players and conditions."/>
  <meta name="robots" content="index, follow"/>
  <link rel="canonical" href="https://legendsdatabase.com/match-simulator"/>
  <link rel="icon" type="image/png" href="/favicon.png"/>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet"/>
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: -apple-system, 'SF Pro Text', 'Inter', sans-serif;
      background: #f2f2f7;
      color: #1d1d1f;
      padding-top: 44px;
      -webkit-font-smoothing: antialiased;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    /* ── MOBILE WALL ── */
    #mobileWall {
      display: none;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      min-height: 60vh;
      padding: 40px 24px;
      text-align: center;
    }
    #mobileWall h2 { font-size: 22px; font-weight: 700; color: #1d1d1f; margin-bottom: 10px; }
    #mobileWall p  { font-size: 15px; color: #6e6e73; line-height: 1.6; }
    @media (max-width: 1023px) {
      #mobileWall { display: flex; }
      #simulator  { display: none !important; }
    }

    /* ── SIMULATOR SHELL ── */
    #simulator { flex: 1; display: flex; flex-direction: column; }

    /* ── BETA BANNER ── */
    .beta-banner {
      background: linear-gradient(135deg, #0a0a1a, #1a1a2e);
      padding: 14px 40px;
      display: flex;
      align-items: center;
      gap: 16px;
    }
    .beta-pill {
      font-size: 9.5px;
      font-weight: 800;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      background: #0071e3;
      color: #fff;
      padding: 3px 9px;
      border-radius: 6px;
      flex-shrink: 0;
    }
    .beta-text { font-size: 12px; color: rgba(255,255,255,0.55); line-height: 1.5; }
    .beta-text strong { color: rgba(255,255,255,0.85); font-weight: 600; }

    /* ── PAGE HEADER ── */
    .sim-header {
      background: linear-gradient(135deg, #0a0a1a 0%, #1a1a2e 50%, #0f3460 100%);
      padding: 28px 40px 24px;
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      position: relative;
      overflow: hidden;
    }
    .sim-header::before {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse at 60% 0%, rgba(0,113,227,0.12) 0%, transparent 70%);
    }
    .sim-header-left { position: relative; }
    .sim-eyebrow { font-size: 10px; font-weight: 800; color: #0071e3; letter-spacing: 0.14em; text-transform: uppercase; margin-bottom: 6px; }
    .sim-title { font-size: 28px; font-weight: 800; letter-spacing: -0.8px; color: #ffffff; line-height: 1.1; margin-bottom: 4px; }
    .sim-sub { font-size: 12px; color: rgba(255,255,255,0.40); }

    /* ── MATCH SETTINGS BAR (now on top) ── */
    .match-settings-bar {
      background: #ffffff;
      border-bottom: 1px solid #e5e5ea;
      padding: 16px 40px;
      display: grid;
      grid-template-columns: repeat(7, 1fr);
      gap: 12px;
      align-items: end;
    }
    .mset-group { display: flex; flex-direction: column; gap: 5px; }
    .mset-label { font-size: 9.5px; font-weight: 700; color: #aeaeb2; letter-spacing: 0.08em; text-transform: uppercase; }
    .mset-select {
      font-family: inherit;
      font-size: 11.5px;
      font-weight: 500;
      color: #1d1d1f;
      background: #f9f9fb;
      border: 1.5px solid #e5e5ea;
      border-radius: 8px;
      padding: 6px 8px;
      outline: none;
      cursor: pointer;
      transition: border-color 0.14s;
    }
    .mset-select:focus { border-color: #0071e3; }
    .mset-select:hover { border-color: #aeaeb2; }

    /* ── SETUP LAYOUT ── */
    #phase-setup { flex: 1; }
    .setup-body {
      display: grid;
      grid-template-columns: 1fr 40px 1fr;
      gap: 0;
      align-items: start;
    }

    /* ── TEAM BUILDER ── */
    .team-builder {
      background: #ffffff;
      padding: 20px 24px 24px;
      min-height: 640px;
    }

    .tb-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 12px;
      gap: 8px;
    }
    .tb-header-left { display: flex; align-items: center; gap: 8px; flex: 1; }
    .tb-name-input {
      font-family: inherit;
      font-size: 16px;
      font-weight: 700;
      color: #1d1d1f;
      background: transparent;
      border: none;
      outline: none;
      letter-spacing: -0.3px;
      width: 180px;
      cursor: text;
    }
    .tb-name-input:focus { border-bottom: 2px solid #0071e3; }

    /* ── RESET BUTTON ── */
    .btn-reset-squad {
      font-family: inherit;
      font-size: 11px;
      font-weight: 600;
      padding: 5px 12px;
      border-radius: 8px;
      border: 1.5px solid #e5e5ea;
      background: #f9f9fb;
      color: #aeaeb2;
      cursor: pointer;
      transition: all 0.13s;
      white-space: nowrap;
      display: flex;
      align-items: center;
      gap: 4px;
    }
    .btn-reset-squad:hover { border-color: #c0392b; color: #c0392b; background: #fff5f5; }

    .tb-formation-row {
      display: flex;
      align-items: center;
      gap: 6px;
      margin-bottom: 12px;
      flex-wrap: wrap;
    }
    .tb-label { font-size: 10px; font-weight: 700; color: #aeaeb2; letter-spacing: 0.08em; text-transform: uppercase; flex-shrink: 0; }
    .formation-btn {
      font-family: inherit;
      font-size: 11px;
      font-weight: 600;
      padding: 4px 10px;
      border-radius: 7px;
      border: 1.5px solid #e5e5ea;
      background: #f9f9fb;
      color: #6e6e73;
      cursor: pointer;
      transition: all 0.13s;
      letter-spacing: 0.02em;
    }
    .formation-btn.active   { background: #0071e3; color: #fff; border-color: #0071e3; }
    .formation-btn.active-b { background: #c0392b; color: #fff; border-color: #c0392b; }
    .formation-btn:hover:not(.active):not(.active-b) { border-color: #aeaeb2; color: #1d1d1f; background: #f0f0f5; }

    /* ── PITCH ── */
    .pitch-wrap {
      position: relative;
      width: 100%;
      margin-bottom: 14px;
    }
    .pitch-svg { width: 100%; height: auto; display: block; border-radius: 10px; }

    /* ── PLAYER SLOTS ── */
    .slots-area {
      display: flex;
      flex-direction: column;
      gap: 5px;
      max-height: 260px;
      overflow-y: auto;
      scrollbar-width: thin;
      padding-right: 4px;
    }
    .slots-area::-webkit-scrollbar { width: 4px; }
    .slots-area::-webkit-scrollbar-track { background: #f5f5f7; border-radius: 2px; }
    .slots-area::-webkit-scrollbar-thumb { background: #d1d1d6; border-radius: 2px; }

    .slot-row { display: flex; align-items: center; gap: 7px; }
    .slot-pos {
      font-size: 9px; font-weight: 800; padding: 2px 5px;
      border-radius: 5px; min-width: 30px; text-align: center;
      letter-spacing: 0.04em; flex-shrink: 0;
    }
    .slot-pos.gk  { background: #fef9e7; color: #b7950b; }
    .slot-pos.def { background: #efffee; color: #1a7a1a; }
    .slot-pos.mid { background: #eef4ff; color: #0071e3; }
    .slot-pos.att { background: #fff0ee; color: #c0392b; }

    .slot-input-wrap { flex: 1; position: relative; }
    .slot-input {
      width: 100%;
      font-family: inherit;
      font-size: 11.5px;
      font-weight: 500;
      color: #1d1d1f;
      background: #f9f9fb;
      border: 1.5px solid #e5e5ea;
      border-radius: 7px;
      padding: 6px 8px;
      outline: none;
      transition: border-color 0.14s;
      cursor: pointer;
    }
    .slot-input:focus { border-color: #0071e3; background: #fff; }
    .slot-input.filled   { background: #f0f9f0; border-color: #2e8b2e; }
    .slot-input.filled-b { background: #fff0f0; border-color: #c0392b; }
    .slot-input.out-of-pos { border-style: dashed; }

    .slot-ovr { font-size: 11px; font-weight: 700; min-width: 22px; text-align: right; font-variant-numeric: tabular-nums; }

    .slot-dropdown {
      position: absolute;
      top: calc(100% + 2px);
      left: 0; right: 0;
      background: #fff;
      border: 1.5px solid #e5e5ea;
      border-radius: 10px;
      box-shadow: 0 8px 32px rgba(0,0,0,0.14);
      z-index: 100;
      max-height: 200px;
      overflow-y: auto;
      display: none;
    }
    .slot-dropdown.open { display: block; }
    .dd-item {
      display: flex; align-items: center; gap: 8px;
      padding: 7px 10px; cursor: pointer;
      transition: background 0.1s;
      border-bottom: 1px solid #f5f5f7;
    }
    .dd-item:last-child { border-bottom: none; }
    .dd-item:hover { background: #f5f5f7; }
    .dd-item-name { font-size: 12px; font-weight: 500; color: #1d1d1f; flex: 1; }
    .dd-item-role { font-size: 9.5px; font-weight: 700; padding: 1px 5px; border-radius: 4px; }
    .dd-item-ovr  { font-size: 11px; font-weight: 700; color: #0071e3; min-width: 22px; text-align: right; }
    .dd-item-nat  { font-size: 10px; color: #aeaeb2; }

    .slot-clear {
      width: 18px; height: 18px; border: none; background: transparent;
      color: #aeaeb2; cursor: pointer; font-size: 13px;
      display: flex; align-items: center; justify-content: center;
      border-radius: 50%; transition: background 0.1s, color 0.1s;
      flex-shrink: 0; visibility: hidden;
    }
    .slot-clear.visible { visibility: visible; }
    .slot-clear:hover { background: #fee; color: #c0392b; }

    /* ── BENCH ── */
    .bench-toggle {
      font-family: inherit; font-size: 11px; font-weight: 600;
      color: #0071e3; background: transparent; border: none;
      cursor: pointer; padding: 5px 0;
      display: flex; align-items: center; gap: 5px;
      margin-bottom: 6px;
    }
    .bench-section { display: none; }
    .bench-section.open { display: block; }

    /* ── TEAM STATS BAR ── */
    .team-stats-bar {
      display: grid; grid-template-columns: repeat(4, 1fr);
      gap: 8px; margin-top: 12px; padding-top: 12px;
      border-top: 1px solid #f0f0f5;
    }
    .tsb-item { text-align: center; }
    .tsb-val { font-size: 17px; font-weight: 700; letter-spacing: -0.3px; color: #1d1d1f; line-height: 1; }
    .tsb-lbl { font-size: 9px; font-weight: 700; color: #aeaeb2; letter-spacing: 0.06em; text-transform: uppercase; margin-top: 3px; }

    /* ── GELLING BADGE ── */
    .gelling-badge {
      display: inline-flex; align-items: center; gap: 4px;
      font-size: 11.5px; font-weight: 600; padding: 4px 9px;
      border-radius: 9px; background: #f5f5f7; color: #6e6e73;
      cursor: help; position: relative;
    }
    .gelling-badge.high { background: #efffee; color: #1a7a1a; }
    .gelling-badge.med  { background: #eef4ff; color: #0071e3; }
    .gelling-badge.low  { background: #fff0ee; color: #c0392b; }
    .gelling-tooltip {
      position: absolute; bottom: calc(100% + 6px); left: 50%;
      transform: translateX(-50%); background: #1d1d1f; color: #fff;
      font-size: 11px; font-weight: 500; padding: 8px 12px;
      border-radius: 8px; white-space: nowrap; pointer-events: none;
      opacity: 0; transition: opacity 0.15s; z-index: 50;
      line-height: 1.6; text-align: left;
    }
    .gelling-badge:hover .gelling-tooltip { opacity: 1; }

    /* ── RANDOM BUTTONS ── */
    .random-row { display: flex; gap: 5px; flex-wrap: wrap; margin-bottom: 10px; }
    .random-btn {
      font-family: inherit; font-size: 10.5px; font-weight: 600;
      padding: 4px 10px; border-radius: 7px;
      border: 1.5px solid #e5e5ea; background: #f9f9fb; color: #6e6e73;
      cursor: pointer; transition: all 0.13s;
      display: flex; align-items: center; gap: 3px;
    }
    .random-btn:hover { border-color: #0071e3; color: #0071e3; background: #f0f6ff; }

    /* ── VS DIVIDER ── */
    .vs-divider { background: #f2f2f7; display: flex; align-items: center; justify-content: center; writing-mode: vertical-rl; }
    .vs-text { font-size: 11px; font-weight: 800; color: #aeaeb2; letter-spacing: 0.1em; }

    /* ── VALIDATE + SIMULATE ── */
    .simulate-bar {
      background: #ffffff; border-top: 1px solid #e5e5ea;
      padding: 16px 40px; display: flex; align-items: center; justify-content: space-between;
    }
    .validate-msg { font-size: 12.5px; color: #c0392b; font-weight: 500; }
    .simulate-btn {
      font-family: inherit; font-size: 14px; font-weight: 700;
      padding: 13px 44px; background: linear-gradient(135deg, #0071e3, #0077ed);
      color: #fff; border: none; border-radius: 12px; cursor: pointer;
      letter-spacing: -0.1px; transition: transform 0.14s, box-shadow 0.14s, opacity 0.14s;
      box-shadow: 0 4px 20px rgba(0,113,227,0.3);
    }
    .simulate-btn:hover:not(:disabled) { transform: translateY(-2px); box-shadow: 0 8px 28px rgba(0,113,227,0.4); }
    .simulate-btn:disabled { opacity: 0.45; cursor: not-allowed; }

    .validation-row { display: flex; align-items: center; gap: 8px; }
    .val-dot { width: 8px; height: 8px; border-radius: 50%; background: #e5e5ea; }
    .val-dot.ok   { background: #2e8b2e; }
    .val-dot.warn { background: #c8a800; }
    .val-dot.err  { background: #c0392b; }
    .val-label { font-size: 10.5px; color: #6e6e73; }

    /* ── ATTITUDE BADGE ── */
    .attitude-badge { display: inline-flex; align-items: center; gap: 4px; font-size: 10px; font-weight: 700; padding: 3px 7px; border-radius: 6px; letter-spacing: 0.04em; text-transform: uppercase; }
    .att-off { background: #fff0ee; color: #c0392b; }
    .att-bal { background: #eef4ff; color: #0071e3; }
    .att-def { background: #efffee; color: #1a7a1a; }

    /* ── MATCH PHASE ── */
    #phase-match { flex: 1; display: flex; flex-direction: column; background: #0a0a1a; }
    #phase-match.hidden { display: none; }

    .match-header-bar {
      padding: 16px 40px; background: linear-gradient(180deg, #0f0f1e 0%, #0a0a1a 100%);
      border-bottom: 1px solid rgba(255,255,255,0.06);
      display: flex; align-items: center; justify-content: space-between;
    }
    .mhb-competition { font-size: 11px; font-weight: 700; color: rgba(255,255,255,0.40); letter-spacing: 0.1em; text-transform: uppercase; }
    .mhb-meta { font-size: 11px; color: rgba(255,255,255,0.30); display: flex; gap: 16px; }

    /* ── SCOREBOARD ── */
    .scoreboard {
      padding: 24px 40px 20px;
      display: grid; grid-template-columns: 1fr auto 1fr;
      align-items: center; gap: 24px; background: #0a0a1a;
    }
    .sb-team { display: flex; flex-direction: column; align-items: center; gap: 5px; }
    .sb-team-name { font-size: 13px; font-weight: 700; color: rgba(255,255,255,0.65); text-align: center; }
    .sb-score-wrap { display: flex; flex-direction: column; align-items: center; gap: 4px; }
    .sb-score {
      display: flex; align-items: center; gap: 8px;
      font-size: 68px; font-weight: 900; letter-spacing: -4px;
      font-variant-numeric: tabular-nums; line-height: 1;
    }
    .sb-score-a { color: #4dff88; }
    .sb-score-b { color: #ff6b5b; }
    .sb-score-sep { color: rgba(255,255,255,0.20); font-size: 36px; letter-spacing: 0; }
    .sb-time { font-size: 11px; font-weight: 600; color: rgba(255,255,255,0.30); letter-spacing: 0.06em; }
    .sb-status { font-size: 10px; font-weight: 700; padding: 3px 10px; border-radius: 6px; letter-spacing: 0.08em; text-transform: uppercase; }
    .sb-status.live { background: rgba(255,100,100,0.2); color: #ff6b6b; animation: pulse-live 1.5s infinite; }
    .sb-status.ft   { background: rgba(77,255,136,0.15); color: #4dff88; }
    @keyframes pulse-live { 0%,100% { opacity: 1; } 50% { opacity: 0.5; } }

    /* ── COMMENTARY ── */
    .commentary-wrap {
      flex: 1; max-width: 860px; width: 100%;
      margin: 0 auto; padding: 0 40px 20px;
    }
    .commentary-feed {
      display: flex; flex-direction: column; gap: 0;
      max-height: 420px; overflow-y: auto;
      scrollbar-width: thin; scrollbar-color: rgba(255,255,255,0.1) transparent;
      padding-right: 4px;
    }
    .commentary-feed::-webkit-scrollbar { width: 3px; }
    .commentary-feed::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); border-radius: 2px; }

    .cmt-item {
      display: grid; grid-template-columns: 42px 1fr; gap: 12px;
      padding: 10px 0; border-bottom: 1px solid rgba(255,255,255,0.04);
      opacity: 0; transform: translateY(8px);
      transition: opacity 0.35s ease, transform 0.35s ease;
    }
    .cmt-item.visible { opacity: 1; transform: translateY(0); }
    .cmt-item.ht-item { border-top: 1px solid rgba(255,255,255,0.08); }

    .cmt-min { font-size: 11px; font-weight: 800; color: rgba(255,255,255,0.25); font-variant-numeric: tabular-nums; padding-top: 2px; text-align: right; }
    .cmt-text { font-size: 13px; color: rgba(255,255,255,0.70); line-height: 1.6; }
    .cmt-text.goal-event    { color: #4dff88; font-weight: 600; }
    .cmt-text.save-event    { color: #f0c040; }
    .cmt-text.danger-event  { color: #ff9944; }
    .cmt-text.red-event     { color: #ff5555; font-weight: 600; }
    .cmt-text.ht-event      { color: rgba(255,255,255,0.40); font-style: italic; }
    .cmt-text.sub-event     { color: #a0c8ff; }

    /* ── MATCH RESULTS ── */
    #match-results { background: #f2f2f7; padding: 40px 40px 60px; display: none; }
    #match-results.visible { display: block; }
    .results-header { max-width: 860px; margin: 0 auto 28px; text-align: center; }
    .results-final-score { font-size: 48px; font-weight: 900; letter-spacing: -2px; color: #1d1d1f; margin-bottom: 6px; }
    .results-competition { font-size: 12px; font-weight: 600; color: #aeaeb2; letter-spacing: 0.08em; text-transform: uppercase; }
    .results-comment { font-size: 15px; color: #6e6e73; line-height: 1.7; max-width: 600px; margin: 14px auto 0; font-style: italic; }

    /* ── MOTM ── */
    .motm-section { max-width: 860px; margin: 0 auto 24px; }
    .motm-card {
      background: linear-gradient(135deg, #1a1a2e, #0f3460);
      border-radius: 18px; padding: 22px 26px;
      display: flex; align-items: center; gap: 20px;
      position: relative; overflow: hidden;
    }
    .motm-card::after { content: '⭐'; position: absolute; right: 22px; top: 14px; font-size: 30px; opacity: 0.2; }
    .motm-badge { font-size: 10px; font-weight: 800; color: #ffd700; letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 5px; }
