        <div class="tb-header">
          <div class="tb-header-left">
            <input type="text" class="tb-name-input" id="nameA" value="Legends XI" maxlength="24"/>
            <span id="attitudeA" class="attitude-badge att-bal">⚖️ Balanced</span>
            <button class="save-roster-btn" id="saveRosterA" type="button" title="Save or load this roster">💾</button>
          </div>
          <button class="btn-reset-squad" id="resetSquadA" type="button">↺ Clear</button>
        </div>
        <div class="roster-save-panel" id="savePanelA"></div>
        <div class="random-row" id="randomRowA"></div>
        <div class="tb-formation-row">
          <span class="tb-label">Formation</span>
          <div id="formationBtnsA" class="tb-formation-row" style="flex-wrap:wrap;gap:4px;margin:0;"></div>
        </div>
        <div class="tb-coach-row">
          <span class="tb-label">Coach</span>
          <select class="mset-select coach-req" id="setCoachA"><option value="">— Select —</option></select>
        </div>
        <div class="team-color-row">
          <span class="tb-label">Kit</span>
          <span class="team-color-swatch" id="colorSwatchA"></span>
          <select class="team-color-select" id="teamColorA"></select>
        </div>
        <div class="tb-tactics-row">
          <span class="tb-label">Tactics</span>
