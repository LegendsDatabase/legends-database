---
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';

const title = "Figueroa vs Passarella — The Soul of South American Defending";
const description = "Two of the greatest defenders South America has ever produced. One ruled with serenity and positional genius. The other with fire, aggression and a cannon of a left foot. A duel between ice and flame.";
const date = "May 2025";
const readTime = "16 min read";
const author = "Francesco B.";

const F = {
  name: "Figueroa", nation: "Chile", slug: "figueroa-elas",
  ovr: 91, acceleration: 82, pace: 80, agility: 78, strength: 87,
  balance: 85, jumping: 92, stamina: 84, dribbling: 80,
  short_passing: 84, long_passing: 77, finishing: 67,
  shot_accuracy: 65, shot_power: 84, heading: 88,
  tackling: 94, composure: 93, aggression: 83,
  consistency: 86, creativity: 68, vision: 80,
  off_the_ball: 65, anticipation: 91, first_touch: 82,
  nat_apps: 47, nat_goals: 3, club_apps: 791, club_goals: 40,
  height: 184, color: '#d52b1e', flag: '🇨🇱',
};
const P = {
  name: "Passarella", nation: "Argentina", slug: "passarella-daniel",
  ovr: 90, acceleration: 77, pace: 75, agility: 77, strength: 82,
  balance: 86, jumping: 95, stamina: 86, dribbling: 78,
  short_passing: 82, long_passing: 86, finishing: 77,
  shot_accuracy: 77, shot_power: 90, heading: 90,
  tackling: 87, composure: 84, aggression: 91,
  consistency: 87, creativity: 75, vision: 85,
  off_the_ball: 75, anticipation: 85, first_touch: 82,
  nat_apps: 70, nat_goals: 22, club_apps: 579, club_goals: 162,
  height: 177, color: '#74acdf', flag: '🇦🇷',
};
---

<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1"/>
  <title>{title} – Legends Database</title>
  <meta name="description" content={description}/>
  <meta name="robots" content="index, follow"/>
  <link rel="canonical" href="https://legendsdatabase.com/articles/duel-figueroa-passarella"/>
  <meta property="og:type"         content="article"/>
  <meta property="og:url"          content="https://legendsdatabase.com/articles/duel-figueroa-passarella"/>
  <meta property="og:title"        content={title}/>
  <meta property="og:description"  content={description}/>
  <meta property="og:image"        content="https://legendsdatabase.com/articles/duel-vanbasten-ronaldo.jpg"/>
  <meta property="og:image:width"  content="1200"/>
  <meta property="og:image:height" content="630"/>
  <meta name="twitter:card"        content="summary_large_image"/>
  <meta name="twitter:title"       content={title}/>
  <meta name="twitter:description" content={description}/>
  <meta name="twitter:image"       content="https://legendsdatabase.com/articles/duel-vanbasten-ronaldo.jpg"/>
  <link rel="icon" type="image/png" href="/favicon.png"/>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Playfair+Display:ital,wght@0,700;1,700&display=swap" rel="stylesheet"/>
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: -apple-system, 'SF Pro Text', 'Inter', sans-serif;
      background: #f2f2f7;
      color: #1d1d1f;
      padding-top: 44px;
      -webkit-font-smoothing: antialiased;
      display: flex;
      flex-direction: column;
      min-height: 100vh;
    }

    /* ── HERO ── */
    .hero-image-wrap {
      width: 100%;
      height: clamp(380px, 60vw, 640px);
      overflow: hidden;
      position: relative;
    }
    .hero-image {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center 30%;
      display: block;
      filter: brightness(0.52);
      transition: transform 10s ease;
    }
    .hero-image-wrap:hover .hero-image { transform: scale(1.04); }
    .hero-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(160deg, rgba(213,43,30,0.15) 0%, rgba(0,0,0,0.70) 100%);
    }
    .hero-caption {
      position: absolute;
      bottom: 32px;
      left: 40px;
      right: 40px;
    }
    .hero-series {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      font-size: 10.5px;
      font-weight: 800;
      color: rgba(255,255,255,0.55);
      letter-spacing: 0.15em;
      text-transform: uppercase;
      margin-bottom: 14px;
      padding: 4px 12px;
      background: rgba(255,255,255,0.08);
      border-radius: 20px;
      border: 1px solid rgba(255,255,255,0.12);
      backdrop-filter: blur(4px);
      width: fit-content;
    }
    .hero-series-dot { width: 5px; height: 5px; border-radius: 50%; background: #fff; opacity: 0.6; }
    .hero-vs-row {
      display: flex;
      align-items: center;
      gap: 16px;
      margin-bottom: 16px;
      flex-wrap: wrap;
    }
    .hero-player-name {
      font-family: 'Playfair Display', Georgia, serif;
      font-size: clamp(26px, 5vw, 52px);
      font-weight: 700;
      line-height: 1.0;
      letter-spacing: -1px;
    }
    .hero-player-name.red { color: #ff6b5b; }
    .hero-player-name.blue { color: #a8d4ff; }
    .hero-vs {
      font-size: clamp(14px, 2.5vw, 22px);
      font-weight: 900;
      color: rgba(255,255,255,0.28);
      letter-spacing: 0.1em;
      flex-shrink: 0;
    }
    .hero-subtitle {
      font-size: 15px;
      color: rgba(255,255,255,0.45);
      font-style: italic;
      margin-bottom: 14px;
      font-family: 'Playfair Display', Georgia, serif;
    }
    .hero-meta {
      display: flex;
      align-items: center;
      gap: 12px;
      font-size: 12px;
      color: rgba(255,255,255,0.38);
      font-weight: 500;
    }
    .hero-meta-sep { opacity: 0.4; }
    .hero-author { color: rgba(255,255,255,0.62); font-weight: 500; }

    /* ── LAYOUT ── */
    .article-wrap {
      flex: 1;
      max-width: 760px;
      width: 100%;
      margin: 0 auto;
      padding: 48px 40px 80px;
    }
    .back-link {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-size: 13px;
      font-weight: 500;
      color: #6e6e73;
      text-decoration: none;
      margin-bottom: 36px;
      transition: color 0.15s;
    }
    .back-link:hover { color: #0071e3; }

    /* ── PLAYER STRIP ── */
    .players-strip {
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      gap: 12px;
      align-items: center;
      margin-bottom: 40px;
    }
    .player-strip-card {
      background: #fff;
      border-radius: 16px;
      padding: 20px 18px;
      box-shadow: 0 1px 4px rgba(0,0,0,0.06);
      text-decoration: none;
      display: flex;
      flex-direction: column;
      gap: 6px;
      border-top: 4px solid transparent;
      transition: transform 0.14s;
    }
    .player-strip-card:hover { transform: translateY(-2px); }
    .player-strip-card.red  { border-top-color: #d52b1e; }
    .player-strip-card.blue { border-top-color: #74acdf; }
    .player-strip-card.right { align-items: flex-end; }
    .psc-flag { font-size: 22px; }
    .psc-name { font-size: 15px; font-weight: 700; color: #1d1d1f; letter-spacing: -0.2px; }
    .psc-role { font-size: 10px; font-weight: 700; padding: 2px 7px; border-radius: 4px; display: inline-block; letter-spacing: 0.04em; background: #eeffee; color: #1a7a1a; }
    .psc-meta { font-size: 11.5px; color: #aeaeb2; }
    .psc-ovr { font-size: 28px; font-weight: 800; letter-spacing: -1px; margin-top: 4px; }
    .psc-ovr.red  { color: #d52b1e; }
    .psc-ovr.blue { color: #74acdf; }
    .strip-vs {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 6px;
    }
    .strip-vs-text { font-size: 18px; font-weight: 900; color: #aeaeb2; }
    .strip-vs-line { width: 1px; height: 24px; background: #e5e5ea; }

    /* ── INDEX ── */
    .article-index {
      background: #ffffff;
      border-radius: 18px;
      padding: 24px 28px;
      margin-bottom: 48px;
      box-shadow: 0 1px 4px rgba(0,0,0,0.06);
      border-left: 4px solid #1d1d1f;
    }
    .index-title {
      font-size: 10.5px;
      font-weight: 800;
      color: #aeaeb2;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      margin-bottom: 14px;
    }
    .index-list { list-style: none; display: flex; flex-direction: column; gap: 2px; }
    .index-list li a {
      display: flex;
      align-items: center;
      gap: 10px;
      font-size: 13.5px;
      font-weight: 500;
      color: #3a3a3c;
      text-decoration: none;
      padding: 6px 8px;
      border-radius: 8px;
      transition: background 0.12s, color 0.12s;
    }
    .index-list li a:hover { background: #f5f5f7; color: #0071e3; }
    .index-num { font-size: 11px; font-weight: 700; color: #aeaeb2; min-width: 20px; }

    /* ── PROSE ── */
    .prose p {
      font-size: 16px;
      line-height: 1.82;
      color: #3a3a3c;
      margin-bottom: 24px;
    }
    .prose p:last-child { margin-bottom: 0; }
    .prose strong { color: #1d1d1f; font-weight: 600; }
    .prose em { font-style: italic; }
    .prose a { color: #0071e3; text-decoration: none; border-bottom: 1px solid rgba(0,113,227,0.3); }
    .prose a:hover { border-color: #0071e3; }

    /* ── SECTION ── */
    .section-anchor { display: block; height: 80px; margin-top: -80px; visibility: hidden; }
    .section-heading { margin: 56px 0 20px; }
    .section-heading-top { display: flex; align-items: center; gap: 10px; margin-bottom: 10px; }
    .section-num { font-size: 10px; font-weight: 800; color: #aeaeb2; letter-spacing: 0.1em; }
    .section-accent {
      display: inline-block;
      height: 3px;
      flex: 1;
      max-width: 28px;
      background: linear-gradient(90deg, #d52b1e, #74acdf);
      border-radius: 2px;
    }
    .section-heading h2 {
      font-family: 'Playfair Display', Georgia, serif;
      font-size: 28px;
      font-weight: 700;
      letter-spacing: -0.5px;
      color: #1d1d1f;
      line-height: 1.2;
    }

    /* ── DUEL BARS ── */
    .duel-bars {
      background: #ffffff;
      border-radius: 20px;
      padding: 28px 24px;
      margin: 32px 0;
      box-shadow: 0 2px 12px rgba(0,0,0,0.06);
    }
    .duel-bars-title {
      font-size: 11px;
      font-weight: 700;
      color: #aeaeb2;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      margin-bottom: 22px;
      text-align: center;
    }
    .duel-legend {
      display: flex;
      justify-content: center;
      gap: 24px;
      margin-bottom: 20px;
    }
    .duel-legend-item {
      display: flex;
      align-items: center;
      gap: 6px;
      font-size: 12px;
      font-weight: 600;
      color: #6e6e73;
    }
    .duel-legend-dot { width: 10px; height: 10px; border-radius: 50%; }
    .duel-bar-row {
      display: grid;
      grid-template-columns: 1fr 60px 1fr;
      align-items: center;
      gap: 10px;
      margin-bottom: 12px;
    }
    .duel-bar-row:last-child { margin-bottom: 0; }
    .duel-bar-left  { display: flex; align-items: center; justify-content: flex-end; gap: 8px; }
    .duel-bar-right { display: flex; align-items: center; justify-content: flex-start; gap: 8px; }
    .duel-bar-lbl { font-size: 9.5px; font-weight: 700; color: #6e6e73; text-transform: uppercase; letter-spacing: 0.05em; text-align: center; }
    .duel-track { flex: 1; height: 8px; background: #f0f0f5; border-radius: 4px; overflow: hidden; }
    .duel-fill-left  { height: 100%; border-radius: 4px; float: right; background: #d52b1e; transition: width 0.9s cubic-bezier(0.34,1.2,0.64,1); }
    .duel-fill-right { height: 100%; border-radius: 4px; background: #74acdf; transition: width 0.9s cubic-bezier(0.34,1.2,0.64,1); }
    .duel-val { font-size: 13px; font-weight: 700; font-variant-numeric: tabular-nums; min-width: 26px; }
    .duel-val.left  { text-align: right; }
    .duel-val.right { text-align: left; }
    .duel-val.win-red  { color: #d52b1e; font-size: 14px; }
    .duel-val.win-blue { color: #74acdf; font-size: 14px; }

    /* ── SECTION WINNER ── */
    .section-winner {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      margin: 24px 0;
      padding: 14px 20px;
      border-radius: 14px;
      font-size: 13px;
      font-weight: 700;
    }
    .section-winner.red  { background: rgba(213,43,30,0.07); color: #d52b1e; border: 1.5px solid rgba(213,43,30,0.18); }
    .section-winner.blue { background: rgba(116,172,223,0.10); color: #4a8dbf; border: 1.5px solid rgba(116,172,223,0.25); }
    .section-winner.draw { background: #f5f5f7; color: #6e6e73; border: 1.5px solid #e5e5ea; }
    .sw-icon { font-size: 16px; }

    /* ── PULL QUOTE ── */
    .pull-quote {
      margin: 40px 0;
      padding: 26px 32px;
      background: #ffffff;
      border-radius: 18px;
      border-left: 4px solid #1d1d1f;
      box-shadow: 0 2px 12px rgba(0,0,0,0.06);
      position: relative;
      overflow: hidden;
    }
    .pull-quote::before {
      content: '"';
      position: absolute;
      top: 8px; right: 20px;
      font-family: Georgia, serif;
      font-size: 80px;
      color: #1d1d1f;
      opacity: 0.05;
      line-height: 1;
    }
    .pull-quote.red { border-left-color: #d52b1e; }
    .pull-quote.blue { border-left-color: #74acdf; }
    .pull-quote-text {
      font-family: 'Playfair Display', Georgia, serif;
      font-size: 18px;
      font-style: italic;
      font-weight: 700;
      line-height: 1.55;
      color: #1d1d1f;
      margin-bottom: 8px;
    }
    .pull-quote-attr {
      font-size: 11.5px;
      font-weight: 700;
      color: #aeaeb2;
      letter-spacing: 0.05em;
      text-transform: uppercase;
    }

    /* ── PHILOSOPHY BOX ── */
    .philosophy-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 10px;
      margin: 32px 0;
    }
    .philosophy-card {
      border-radius: 18px;
      padding: 24px 22px;
      position: relative;
      overflow: hidden;
    }
    .philosophy-card.red  { background: linear-gradient(135deg, #1a0503, #2d0a07); }
    .philosophy-card.blue { background: linear-gradient(135deg, #020d1a, #051a2d); }
    .philosophy-card::after {
      content: '';
      position: absolute;
      right: -20px; top: -20px;
      width: 100px; height: 100px;
      border-radius: 50%;
      background: rgba(255,255,255,0.04);
    }
    .pc-label {
      font-size: 10px;
      font-weight: 800;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      margin-bottom: 10px;
    }
    .pc-label.red  { color: #ff6b5b; }
    .pc-label.blue { color: #a8d4ff; }
    .pc-title {
      font-family: 'Playfair Display', Georgia, serif;
      font-size: 18px;
      font-weight: 700;
      color: #ffffff;
      line-height: 1.3;
      margin-bottom: 10px;
    }
    .pc-body { font-size: 12.5px; color: rgba(255,255,255,0.50); line-height: 1.65; }

    /* ── CAREER STATS ── */
    .career-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
      margin: 32px 0;
    }
    .career-card {
      background: #ffffff;
      border-radius: 16px;
      padding: 22px 20px;
      box-shadow: 0 1px 4px rgba(0,0,0,0.06);
      border-top: 4px solid transparent;
    }
    .career-card.red  { border-top-color: #d52b1e; }
    .career-card.blue { border-top-color: #74acdf; }
    .career-card-name {
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: 13px;
      font-weight: 700;
      color: #1d1d1f;
      margin-bottom: 16px;
    }
    .career-stat-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 8px 0;
      border-bottom: 1px solid #f5f5f7;
    }
    .career-stat-row:last-child { border-bottom: none; }
    .cs-label { font-size: 11.5px; color: #6e6e73; font-weight: 500; }
    .cs-val { font-size: 15px; font-weight: 700; color: #1d1d1f; }
    .cs-val.red  { color: #d52b1e; }
    .cs-val.blue { color: #74acdf; }

    /* ── DARK QUOTE ── */
    .dark-quote {
      background: linear-gradient(135deg, #0a0a12, #1a1a2e);
      border-radius: 18px;
      padding: 28px 32px;
      margin: 40px 0;
      position: relative;
      overflow: hidden;
    }
    .dark-quote::after {
      content: '';
      position: absolute;
      right: -30px; bottom: -30px;
      width: 140px; height: 140px;
      border-radius: 50%;
      background: rgba(255,255,255,0.03);
    }
    .dark-quote-label {
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      margin-bottom: 12px;
      color: rgba(255,255,255,0.35);
    }
    .dark-quote-text {
      font-family: 'Playfair Display', Georgia, serif;
      font-size: 17px;
      font-style: italic;
      font-weight: 700;
      color: #ffffff;
      line-height: 1.6;
      margin-bottom: 10px;
    }
    .dark-quote-attr { font-size: 12px; color: rgba(255,255,255,0.30); font-weight: 500; }

    /* ── ACHIEVEMENT STRIP ── */
    .achievement-strip {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 10px;
      margin: 28px 0;
    }
    .ach-card {
      background: #ffffff;
      border-radius: 14px;
      padding: 16px 14px;
      text-align: center;
      box-shadow: 0 1px 4px rgba(0,0,0,0.06);
    }
    .ach-icon { font-size: 22px; margin-bottom: 6px; }
    .ach-val { font-size: 18px; font-weight: 800; color: #1d1d1f; letter-spacing: -0.3px; margin-bottom: 3px; }
    .ach-val.red  { color: #d52b1e; }
    .ach-val.blue { color: #74acdf; }
    .ach-label { font-size: 10px; font-weight: 700; color: #aeaeb2; letter-spacing: 0.05em; text-transform: uppercase; line-height: 1.3; }

    /* ── CONTRAST TABLE ── */
    .contrast-table {
      background: #ffffff;
      border-radius: 18px;
      overflow: hidden;
      margin: 32px 0;
      box-shadow: 0 2px 12px rgba(0,0,0,0.06);
    }
    .ct-header {
      display: grid;
      grid-template-columns: 1fr 120px 1fr;
      background: #f9f9fb;
      padding: 12px 20px;
      border-bottom: 1px solid #f0f0f5;
    }
    .ct-header-name {
      font-size: 11px;
      font-weight: 800;
      letter-spacing: 0.06em;
      text-transform: uppercase;
    }
    .ct-header-name.red  { color: #d52b1e; }
    .ct-header-name.blue { color: #74acdf; text-align: right; }
    .ct-header-mid { font-size: 10px; font-weight: 700; color: #aeaeb2; text-align: center; letter-spacing: 0.06em; text-transform: uppercase; }
    .ct-row {
      display: grid;
      grid-template-columns: 1fr 120px 1fr;
      padding: 13px 20px;
      border-bottom: 1px solid #f5f5f7;
    }
    .ct-row:last-child { border-bottom: none; }
    .ct-left  { font-size: 13px; font-weight: 500; color: #1d1d1f; }
    .ct-mid   { font-size: 10.5px; font-weight: 700; color: #aeaeb2; text-align: center; letter-spacing: 0.04em; text-transform: uppercase; }
    .ct-right { font-size: 13px; font-weight: 500; color: #1d1d1f; text-align: right; }
    .ct-left.win  { color: #d52b1e; font-weight: 700; }
    .ct-right.win { color: #74acdf; font-weight: 700; }

    /* ── SCOREBOARD ── */
    .scoreboard {
      background: linear-gradient(135deg, #0a0a12, #1a1a2e);
      border-radius: 20px;
      padding: 32px 28px;
      margin: 48px 0;
      position: relative;
      overflow: hidden;
    }
    .scoreboard::before {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse at 50% 0%, rgba(255,255,255,0.03) 0%, transparent 70%);
    }
    .sb-title {
      font-size: 10.5px;
      font-weight: 800;
      color: rgba(255,255,255,0.28);
      letter-spacing: 0.14em;
      text-transform: uppercase;
      text-align: center;
      margin-bottom: 24px;
    }
    .sb-main {
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      align-items: center;
      gap: 20px;
      margin-bottom: 28px;
    }
    .sb-side { display: flex; flex-direction: column; align-items: center; gap: 8px; }
    .sb-flag { font-size: 36px; }
    .sb-name { font-size: 18px; font-weight: 800; letter-spacing: -0.3px; text-align: center; }
    .sb-name.red  { color: #ff6b5b; }
    .sb-name.blue { color: #a8d4ff; }
    .sb-sub { font-size: 11px; color: rgba(255,255,255,0.28); text-align: center; }
    .sb-score-wrap { display: flex; flex-direction: column; align-items: center; gap: 6px; }
    .sb-score { display: flex; align-items: center; gap: 12px; }
