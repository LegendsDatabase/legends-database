---
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';

const title = "Van Basten vs Ronaldo — The Eternal Duel";
const description = "Two of the greatest centre-forwards in football history, dissected across every dimension: physical, technical, tactical, mental, club and international. A duel for the ages.";
const date = "May 2025";
const readTime = "18 min read";
const author = "Francesco B.";

const R = {
  name: "Ronaldo", nation: "Brazil", slug: "ronaldo-lus-nazrio",
  ovr: 95, acceleration: 97, pace: 94, agility: 92, strength: 83,
  balance: 89, jumping: 78, stamina: 83, dribbling: 97,
  short_passing: 82, finishing: 92, shot_accuracy: 91, shot_power: 86,
  heading: 77, composure: 85, creativity: 94, vision: 82,
  off_the_ball: 90, anticipation: 90, first_touch: 96,
  nat_apps: 98, nat_goals: 62, club_apps: 518, club_goals: 352,
  height: 183, color: '#009c3b', flag: '🇧🇷',
};
const V = {
  name: "Van Basten", nation: "Netherlands", slug: "van-basten-marco",
  ovr: 93, acceleration: 83, pace: 86, agility: 84, strength: 85,
  balance: 78, jumping: 85, stamina: 81, dribbling: 92,
  short_passing: 85, finishing: 97, shot_accuracy: 97, shot_power: 85,
  heading: 95, composure: 92, creativity: 88, vision: 86,
  off_the_ball: 93, anticipation: 94, first_touch: 92,
  nat_apps: 58, nat_goals: 24, club_apps: 373, club_goals: 277,
  height: 188, color: '#FF6600', flag: '🇳🇱',
};
---

<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1"/>
  <title>{title} – Legends Database</title>
  <meta name="description" content={description}/>
  <meta name="robots" content="index, follow"/>
  <link rel="canonical" href="https://legendsdatabase.com/articles/duel-van-basten-ronaldo"/>
  <meta property="og:type"         content="article"/>
  <meta property="og:url"          content="https://legendsdatabase.com/articles/duel-van-basten-ronaldo"/>
  <meta property="og:title"        content={title}/>
  <meta property="og:description"  content={description}/>
  <meta property="og:image"        content="https://legendsdatabase.com/articles/duel-vanbasten-ronaldo.jpg"/>
  <meta property="og:image:width"  content="1200"/>
  <meta property="og:image:height" content="630"/>
  <meta name="twitter:card"        content="summary_large_image"/>
  <meta name="twitter:title"       content={title}/>
  <meta name="twitter:description" content={description}/>
  <meta name="twitter:image"       content="https://legendsdatabase.com/articles/duel-vanbasten-ronaldo.jpg"/>
  <link rel="icon" type="image/png" href="/favicon.png"/>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Playfair+Display:ital,wght@0,700;1,700&display=swap" rel="stylesheet"/>
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: -apple-system, 'SF Pro Text', 'Inter', sans-serif;
      background: #f2f2f7;
      color: #1d1d1f;
      padding-top: 44px;
      -webkit-font-smoothing: antialiased;
      display: flex;
      flex-direction: column;
      min-height: 100vh;
    }

    /* ── HERO ── */
    .hero-image-wrap {
      width: 100%;
      height: clamp(380px, 60vw, 640px);
      overflow: hidden;
      position: relative;
    }
    .hero-image {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center 30%;
      display: block;
      filter: brightness(0.55);
      transition: transform 10s ease;
    }
    .hero-image-wrap:hover .hero-image { transform: scale(1.04); }
    .hero-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(to bottom, rgba(0,0,0,0.1) 0%, rgba(0,0,0,0.70) 100%);
    }
    .hero-caption {
      position: absolute;
      bottom: 32px;
      left: 40px;
      right: 40px;
    }
    .hero-series {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      font-size: 10.5px;
      font-weight: 800;
      color: rgba(255,255,255,0.60);
      letter-spacing: 0.15em;
      text-transform: uppercase;
      margin-bottom: 14px;
      padding: 4px 12px;
      background: rgba(255,255,255,0.10);
      border-radius: 20px;
      border: 1px solid rgba(255,255,255,0.15);
      backdrop-filter: blur(4px);
      width: fit-content;
    }
    .hero-series-dot { width: 5px; height: 5px; border-radius: 50%; background: #fff; opacity: 0.7; }
    .hero-vs-row {
      display: flex;
      align-items: center;
      gap: 16px;
      margin-bottom: 16px;
    }
    .hero-player-name {
      font-family: 'Playfair Display', Georgia, serif;
      font-size: clamp(26px, 5vw, 52px);
      font-weight: 700;
      line-height: 1.0;
      letter-spacing: -1px;
    }
    .hero-player-name.green { color: #4dff88; }
    .hero-player-name.orange { color: #ff9944; }
    .hero-vs {
      font-size: clamp(14px, 2.5vw, 22px);
      font-weight: 900;
      color: rgba(255,255,255,0.35);
      letter-spacing: 0.1em;
      flex-shrink: 0;
    }
    .hero-meta {
      display: flex;
      align-items: center;
      gap: 12px;
      font-size: 12px;
      color: rgba(255,255,255,0.40);
      font-weight: 500;
    }
    .hero-meta-sep { opacity: 0.4; }
    .hero-author { color: rgba(255,255,255,0.65); font-weight: 500; }

    /* ── LAYOUT ── */
    .article-wrap {
      flex: 1;
      max-width: 760px;
      width: 100%;
      margin: 0 auto;
      padding: 48px 40px 80px;
    }
    .back-link {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-size: 13px;
      font-weight: 500;
      color: #6e6e73;
      text-decoration: none;
      margin-bottom: 36px;
      transition: color 0.15s;
    }
    .back-link:hover { color: #0071e3; }

    /* ── INDEX ── */
    .article-index {
      background: #ffffff;
      border-radius: 18px;
      padding: 24px 28px;
      margin-bottom: 48px;
      box-shadow: 0 1px 4px rgba(0,0,0,0.06);
      border-left: 4px solid #1d1d1f;
    }
    .index-title {
      font-size: 10.5px;
      font-weight: 800;
      color: #aeaeb2;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      margin-bottom: 14px;
    }
    .index-list {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 2px;
    }
    .index-list li a {
      display: flex;
      align-items: center;
      gap: 10px;
      font-size: 13.5px;
      font-weight: 500;
      color: #3a3a3c;
      text-decoration: none;
      padding: 6px 8px;
      border-radius: 8px;
      transition: background 0.12s, color 0.12s;
    }
    .index-list li a:hover { background: #f5f5f7; color: #0071e3; }
    .index-num {
      font-size: 11px;
      font-weight: 700;
      color: #aeaeb2;
      min-width: 20px;
    }

    /* ── PLAYER HEADER STRIP ── */
    .players-strip {
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      gap: 12px;
      align-items: center;
      margin-bottom: 40px;
    }
    .player-strip-card {
      background: #fff;
      border-radius: 16px;
      padding: 18px 20px;
      box-shadow: 0 1px 4px rgba(0,0,0,0.06);
      text-decoration: none;
      display: flex;
      flex-direction: column;
      gap: 6px;
      border-top: 4px solid transparent;
      transition: transform 0.14s;
    }
    .player-strip-card:hover { transform: translateY(-2px); }
    .player-strip-card.green { border-top-color: #009c3b; }
    .player-strip-card.orange { border-top-color: #FF6600; }
    .player-strip-card.right { align-items: flex-end; }
    .psc-flag { font-size: 22px; }
    .psc-name { font-size: 15px; font-weight: 700; color: #1d1d1f; letter-spacing: -0.2px; }
    .psc-meta { font-size: 11.5px; color: #aeaeb2; }
    .psc-ovr { font-size: 28px; font-weight: 800; letter-spacing: -1px; }
    .psc-ovr.green { color: #009c3b; }
    .psc-ovr.orange { color: #FF6600; }
    .strip-vs {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 4px;
    }
    .strip-vs-text { font-size: 18px; font-weight: 900; color: #aeaeb2; letter-spacing: 0.05em; }
    .strip-vs-line { width: 1px; height: 28px; background: #e5e5ea; }

    /* ── PROSE ── */
    .prose p {
      font-size: 16px;
      line-height: 1.82;
      color: #3a3a3c;
      margin-bottom: 24px;
    }
    .prose p:last-child { margin-bottom: 0; }
    .prose strong { color: #1d1d1f; font-weight: 600; }
    .prose em { font-style: italic; }
    .prose a { color: #0071e3; text-decoration: none; border-bottom: 1px solid rgba(0,113,227,0.3); transition: border-color 0.15s; }
    .prose a:hover { border-color: #0071e3; }

    /* ── SECTION ANCHOR ── */
    .section-anchor { display: block; height: 80px; margin-top: -80px; visibility: hidden; }
    .section-heading { margin: 56px 0 20px; }
    .section-heading-top {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 10px;
    }
    .section-num {
      font-size: 10px;
      font-weight: 800;
      color: #aeaeb2;
      letter-spacing: 0.1em;
    }
    .section-accent {
      display: inline-block;
      height: 3px;
      flex: 1;
      max-width: 28px;
      background: linear-gradient(90deg, #009c3b, #FF6600);
      border-radius: 2px;
    }
    .section-heading h2 {
      font-family: 'Playfair Display', Georgia, serif;
      font-size: 28px;
      font-weight: 700;
      letter-spacing: -0.5px;
      color: #1d1d1f;
      line-height: 1.2;
    }

    /* ── DUEL BAR ── */
    .duel-bars {
      background: #ffffff;
      border-radius: 20px;
      padding: 28px 24px;
      margin: 32px 0;
      box-shadow: 0 2px 12px rgba(0,0,0,0.06);
    }
    .duel-bars-title {
      font-size: 11px;
      font-weight: 700;
      color: #aeaeb2;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      margin-bottom: 22px;
      text-align: center;
    }
    .duel-bar-row {
      display: grid;
      grid-template-columns: 1fr 54px 1fr;
      align-items: center;
      gap: 10px;
      margin-bottom: 12px;
    }
    .duel-bar-row:last-child { margin-bottom: 0; }
    .duel-bar-left { display: flex; align-items: center; justify-content: flex-end; gap: 8px; }
    .duel-bar-right { display: flex; align-items: center; justify-content: flex-start; gap: 8px; }
    .duel-bar-lbl {
      font-size: 10px;
      font-weight: 700;
      color: #6e6e73;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      text-align: center;
    }
    .duel-track { flex: 1; height: 8px; background: #f0f0f5; border-radius: 4px; overflow: hidden; }
    .duel-fill-left  { height: 100%; border-radius: 4px; float: right; background: #009c3b; transition: width 0.9s cubic-bezier(0.34,1.2,0.64,1); }
    .duel-fill-right { height: 100%; border-radius: 4px; background: #FF6600; transition: width 0.9s cubic-bezier(0.34,1.2,0.64,1); }
    .duel-val {
      font-size: 13px;
      font-weight: 700;
      font-variant-numeric: tabular-nums;
      min-width: 28px;
    }
    .duel-val.left  { text-align: right; }
    .duel-val.right { text-align: left; }
    .duel-val.win-green { color: #009c3b; font-size: 14px; }
    .duel-val.win-orange { color: #FF6600; font-size: 14px; }

    /* ── SECTION WINNER ── */
    .section-winner {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      margin: 24px 0;
      padding: 14px 20px;
      border-radius: 14px;
      font-size: 13px;
      font-weight: 700;
    }
    .section-winner.green { background: rgba(0,156,59,0.08); color: #009c3b; border: 1.5px solid rgba(0,156,59,0.2); }
    .section-winner.orange { background: rgba(255,102,0,0.08); color: #FF6600; border: 1.5px solid rgba(255,102,0,0.2); }
    .section-winner.draw { background: #f5f5f7; color: #6e6e73; border: 1.5px solid #e5e5ea; }
    .sw-icon { font-size: 16px; }

    /* ── PULL QUOTE ── */
    .pull-quote {
      margin: 40px 0;
      padding: 26px 32px;
      background: #ffffff;
      border-radius: 18px;
      border-left: 4px solid #1d1d1f;
      box-shadow: 0 2px 12px rgba(0,0,0,0.06);
      position: relative;
      overflow: hidden;
    }
    .pull-quote::before {
      content: '"';
      position: absolute;
      top: 8px; right: 20px;
      font-family: Georgia, serif;
      font-size: 80px;
      color: #1d1d1f;
      opacity: 0.05;
      line-height: 1;
    }
    .pull-quote-text {
      font-family: 'Playfair Display', Georgia, serif;
      font-size: 18px;
      font-style: italic;
      font-weight: 700;
      line-height: 1.55;
      color: #1d1d1f;
      margin-bottom: 8px;
    }
    .pull-quote-attr {
      font-size: 11.5px;
      font-weight: 700;
      color: #aeaeb2;
      letter-spacing: 0.05em;
      text-transform: uppercase;
    }

    /* ── RADAR CHART ── */
    .radar-wrap {
      background: #ffffff;
      border-radius: 20px;
      padding: 28px 24px;
      margin: 32px 0;
      box-shadow: 0 2px 12px rgba(0,0,0,0.06);
    }
    .radar-title {
      font-size: 11px;
      font-weight: 700;
      color: #aeaeb2;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      text-align: center;
      margin-bottom: 20px;
    }
    .radar-legend {
      display: flex;
      justify-content: center;
      gap: 24px;
      margin-top: 16px;
    }
    .radar-legend-item {
      display: flex;
      align-items: center;
      gap: 6px;
      font-size: 12px;
      font-weight: 600;
      color: #6e6e73;
    }
    .radar-legend-dot {
      width: 10px;
      height: 10px;
      border-radius: 50%;
    }

    /* ── CAREER STATS ── */
    .career-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
      margin: 32px 0;
    }
    .career-card {
      background: #ffffff;
      border-radius: 16px;
      padding: 22px 20px;
      box-shadow: 0 1px 4px rgba(0,0,0,0.06);
      border-top: 4px solid transparent;
    }
    .career-card.green { border-top-color: #009c3b; }
    .career-card.orange { border-top-color: #FF6600; }
    .career-card-name {
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: 13px;
      font-weight: 700;
      color: #1d1d1f;
      margin-bottom: 16px;
    }
    .career-stat-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 8px 0;
      border-bottom: 1px solid #f5f5f7;
    }
    .career-stat-row:last-child { border-bottom: none; }
    .cs-label { font-size: 11.5px; color: #6e6e73; font-weight: 500; }
    .cs-val { font-size: 15px; font-weight: 700; color: #1d1d1f; }
    .cs-val.green { color: #009c3b; }
    .cs-val.orange { color: #FF6600; }

    /* ── VERDICT BOX ── */
    .verdict-box {
      border-radius: 20px;
      padding: 32px 28px;
      margin: 40px 0;
      position: relative;
      overflow: hidden;
    }
    .verdict-box.dark {
      background: linear-gradient(135deg, #0a0a12, #1a1a2e);
    }
    .verdict-box.draw-bg {
      background: linear-gradient(135deg, #0f1f0f, #1f1a0a);
    }
    .verdict-box::after {
      content: '';
      position: absolute;
      right: -30px; top: -30px;
      width: 160px; height: 160px;
      border-radius: 50%;
      background: rgba(255,255,255,0.04);
    }
    .verdict-label {
      font-size: 10px;
      font-weight: 800;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      margin-bottom: 14px;
    }
    .verdict-label.green { color: #4dff88; }
    .verdict-label.orange { color: #ff9944; }
    .verdict-label.gold { color: #ffd700; }
    .verdict-title {
      font-family: 'Playfair Display', Georgia, serif;
      font-size: clamp(20px, 3vw, 28px);
      font-weight: 700;
      color: #ffffff;
      line-height: 1.3;
      margin-bottom: 14px;
    }
    .verdict-body {
      font-size: 14.5px;
      color: rgba(255,255,255,0.65);
      line-height: 1.75;
    }
    .verdict-body strong { color: rgba(255,255,255,0.90); font-weight: 600; }

    /* ── SCORE BOARD ── */
    .scoreboard {
      background: linear-gradient(135deg, #0a0a12, #1a1a2e);
      border-radius: 20px;
      padding: 32px 28px;
      margin: 48px 0;
      position: relative;
      overflow: hidden;
    }
    .scoreboard::before {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse at 50% 0%, rgba(255,255,255,0.04) 0%, transparent 70%);
    }
    .sb-title {
      font-size: 10.5px;
      font-weight: 800;
      color: rgba(255,255,255,0.35);
      letter-spacing: 0.14em;
      text-transform: uppercase;
      text-align: center;
      margin-bottom: 24px;
    }
    .sb-main {
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      align-items: center;
      gap: 20px;
      margin-bottom: 28px;
    }
    .sb-side { display: flex; flex-direction: column; align-items: center; gap: 8px; }
    .sb-flag { font-size: 36px; }
    .sb-name { font-size: 18px; font-weight: 800; letter-spacing: -0.3px; text-align: center; }
    .sb-name.green { color: #4dff88; }
    .sb-name.orange { color: #ff9944; }
    .sb-sub { font-size: 11px; color: rgba(255,255,255,0.35); text-align: center; }
    .sb-score-wrap { display: flex; flex-direction: column; align-items: center; gap: 6px; }
    .sb-score { display: flex; align-items: center; gap: 12px; }
    .sb-score-num {
      font-size: 48px;
      font-weight: 900;
      letter-spacing: -2px;
      font-variant-numeric: tabular-nums;
      line-height: 1;
    }
    .sb-score-num.green { color: #4dff88; }
    .sb-score-num.orange { color: #ff9944; }
    .sb-score-num.dim { color: rgba(255,255,255,0.20); }
    .sb-score-sep { font-size: 24px; color: rgba(255,255,255,0.25); font-weight: 300; }
    .sb-sub-score { font-size: 11px; color: rgba(255,255,255,0.30); text-align: center; letter-spacing: 0.04em; }
    .sb-categories {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 8px;
    }
    .sb-cat {
      background: rgba(255,255,255,0.05);
      border-radius: 10px;
      padding: 12px 10px;
      text-align: center;
    }
    .sb-cat-label { font-size: 9.5px; font-weight: 700; color: rgba(255,255,255,0.30); letter-spacing: 0.06em; text-transform: uppercase; margin-bottom: 6px; }
    .sb-cat-winner { font-size: 12px; font-weight: 700; }
    .sb-cat-winner.green { color: #4dff88; }
    .sb-cat-winner.orange { color: #ff9944; }
    .sb-cat-winner.draw { color: rgba(255,255,255,0.45); }

    /* ── DIVIDER ── */
    .prose-divider {
      height: 1px;
      background: linear-gradient(90deg, transparent, #e5e5ea, transparent);
      margin: 52px 0;
    }

    /* ── FADE IN ── */
    .fade-in {
      opacity: 0;
      transform: translateY(14px);
      transition: opacity 0.5s ease, transform 0.5s ease;
    }
    .fade-in.visible { opacity: 1; transform: translateY(0); }

    /* ── MOBILE ── */
    @media (max-width: 640px) {
      .hero-caption { left: 20px; right: 20px; bottom: 20px; }
      .hero-player-name { font-size: clamp(20px, 7vw, 36px); }
      .article-wrap { padding: 32px 20px 64px; }
      .prose p { font-size: 15px; }
      .players-strip { gap: 8px; }
      .psc-name { font-size: 13px; }
      .psc-ovr { font-size: 22px; }
      .duel-bar-row { grid-template-columns: 1fr 44px 1fr; gap: 6px; }
      .duel-val { font-size: 12px; min-width: 22px; }
      .duel-bar-lbl { font-size: 9px; }
      .career-grid { grid-template-columns: 1fr; }
      .sb-main { gap: 10px; }
      .sb-flag { font-size: 28px; }
      .sb-name { font-size: 15px; }
      .sb-score-num { font-size: 36px; }
      .sb-categories { grid-template-columns: repeat(3,1fr); }
      .sb-cat { padding: 10px 6px; }
      .sb-cat-label { font-size: 8.5px; }
      .verdict-box { padding: 24px 20px; }
      .scoreboard { padding: 24px 20px; }
      .section-heading h2 { font-size: 24px; }
    }
  </style>
</head>
<body>
  <Navbar/>

  <!-- HERO -->
  <div class="hero-image-wrap">
    <img
      src="/articles/duel-vanbasten-ronaldo.jpg"
      alt="Van Basten vs Ronaldo"
      class="hero-image"
    />
    <div class="hero-overlay"></div>
    <div class="hero-caption">
      <div class="hero-series">
        <span class="hero-series-dot"></span>
