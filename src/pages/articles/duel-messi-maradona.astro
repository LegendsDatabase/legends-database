---
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';

const title = "Messi vs Maradona — The Question That Has No Answer";
const description = "Two Argentines, one left foot seemingly touched by God, one impossible comparison that divided Italy and united the world. The deepest duel in football history, dissected across every dimension.";
const slug = "duel-messi-maradona";
const canonicalUrl = "https://legendsdatabase.com/articles/" + slug;
const heroImage = "/articles/duel-vanbasten-ronaldo.jpg";
const ogImage = "https://legendsdatabase.com" + heroImage;
const date = "May 2025";
const readTime = "20 min read";
const tag = "Duels";
const author = "Francesco B.";
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1"/>
  <title>{title} – Legends Database</title>
  <meta name="description" content={description}/>
  <meta name="robots" content="index, follow"/>
  <link rel="canonical" href={canonicalUrl}/>
  <meta property="og:type" content="article"/>
  <meta property="og:url" content={canonicalUrl}/>
  <meta property="og:title" content={title}/>
  <meta property="og:description" content={description}/>
  <meta property="og:image" content={ogImage}/>
  <meta property="og:locale" content="en_US"/>
  <meta name="twitter:card" content="summary_large_image"/>
  <meta name="twitter:title" content={title}/>
  <meta name="twitter:description" content={description}/>
  <meta name="twitter:image" content={ogImage}/>
  <link rel="icon" type="image/png" href="/favicon.png"/>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700;1,900&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Messi vs Maradona — The Question That Has No Answer",
    "description": "Two Argentines, one left foot seemingly touched by God, one impossible comparison that divided Italy and united the world.",
    "image": "https://legendsdatabase.com/articles/duel-vanbasten-ronaldo.jpg",
    "datePublished": "2025-05-01",
    "author": { "@type": "Person", "name": "Francesco B." },
    "publisher": { "@type": "Organization", "name": "Legends Database", "url": "https://legendsdatabase.com" }
  }
  </script>
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --diego: #1a1a2e;
      --leo: #0a3d62;
      --gold: #c9a84c;
      --gold-light: #e8d5a3;
      --cream: #f9f6f0;
      --ink: #1a1a1a;
      --muted: #6b6b6b;
      --border: rgba(0,0,0,0.08);
    }

    body {
      font-family: 'Inter', -apple-system, sans-serif;
      background: var(--cream);
      color: var(--ink);
      padding-top: 44px;
      -webkit-font-smoothing: antialiased;
      display: flex;
      flex-direction: column;
      min-height: 100vh;
    }

    /* ── HERO ── */
    .hero {
      position: relative;
      min-height: 92vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      overflow: hidden;
      background: #0a0a14;
      padding: 60px 24px 80px;
    }
    .hero-bg {
      position: absolute;
      inset: 0;
      background:
        radial-gradient(ellipse at 20% 50%, rgba(26,26,46,0.72) 0%, transparent 60%),
        radial-gradient(ellipse at 80% 50%, rgba(10,61,98,0.72) 0%, transparent 60%),
        radial-gradient(ellipse at 50% 100%, rgba(201,168,76,0.12) 0%, transparent 50%),
        linear-gradient(rgba(10,10,20,0.76), rgba(10,10,20,0.86)),
        url("/articles/duel-vanbasten-ronaldo.jpg") center/cover no-repeat;
    }
    .hero-divider {
      position: absolute;
      top: 0; bottom: 0;
      left: 50%;
      width: 1px;
      background: linear-gradient(to bottom, transparent 0%, rgba(201,168,76,0.5) 30%, rgba(201,168,76,0.5) 70%, transparent 100%);
    }
    .hero-noise {
      position: absolute;
      inset: 0;
      opacity: 0.03;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='1'/%3E%3C/svg%3E");
      background-repeat: repeat;
      background-size: 128px;
    }
    .hero-inner {
      position: relative;
      text-align: center;
      max-width: 860px;
      width: 100%;
    }
    .hero-tag {
      display: inline-block;
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--gold);
      border: 1px solid rgba(201,168,76,0.35);
      padding: 5px 14px;
      border-radius: 100px;
      margin-bottom: 32px;
      background: rgba(201,168,76,0.06);
    }
    .hero-names {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0;
      margin-bottom: 16px;
      flex-wrap: wrap;
    }
    .hero-name {
      font-family: 'Playfair Display', serif;
      font-size: clamp(42px, 7vw, 80px);
      font-weight: 900;
      line-height: 0.95;
      letter-spacing: -2px;
    }
    .hero-name.diego { color: #ffffff; }
    .hero-name.leo { color: rgba(255,255,255,0.92); }
    .hero-vs {
      font-family: 'Playfair Display', serif;
      font-size: clamp(18px, 3vw, 28px);
      font-weight: 700;
      font-style: italic;
      color: var(--gold);
      padding: 0 20px;
      position: relative;
      top: -4px;
    }
    .hero-subtitle {
      font-family: 'Playfair Display', serif;
      font-size: clamp(14px, 2vw, 19px);
      font-style: italic;
      color: rgba(255,255,255,0.42);
      max-width: 540px;
      margin: 0 auto 40px;
      line-height: 1.6;
      font-weight: 400;
    }
    .hero-meta {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 16px;
      font-size: 12px;
      font-weight: 500;
      color: rgba(255,255,255,0.32);
      letter-spacing: 0.04em;
    }
    .hero-meta-sep { color: var(--gold); opacity: 0.5; }

    /* ── PLAYER PHOTOS ROW ── */
    .player-photos {
      position: relative;
      display: flex;
      align-items: flex-end;
      justify-content: center;
      gap: 0;
      margin-bottom: 48px;
    }
    .player-photo-wrap {
      position: relative;
      width: 180px;
      height: 200px;
      overflow: hidden;
      flex-shrink: 0;
    }
    .player-photo-wrap.diego-wrap { border-radius: 14px 0 0 14px; }
    .player-photo-wrap.leo-wrap   { border-radius: 0 14px 14px 0; }
    .player-photo-img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: top center;
      filter: grayscale(15%) contrast(1.05);
    }
    .article-author {
      color: rgba(255,255,255,0.56);
      font-weight: 700;
    }
    .player-photo-overlay {
      position: absolute;
      inset: 0;
    }
    .diego-wrap .player-photo-overlay {
      background: linear-gradient(to right, rgba(26,26,46,0.4) 0%, transparent 70%),
                  linear-gradient(to top, rgba(26,26,46,0.7) 0%, transparent 50%);
    }
    .leo-wrap .player-photo-overlay {
      background: linear-gradient(to left, rgba(10,61,98,0.4) 0%, transparent 70%),
                  linear-gradient(to top, rgba(10,61,98,0.7) 0%, transparent 50%);
    }
    .player-photo-name {
      position: absolute;
      bottom: 10px;
      font-size: 10px;
      font-weight: 800;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.7);
    }
    .diego-wrap .player-photo-name { left: 12px; }
    .leo-wrap .player-photo-name { right: 12px; }
    .player-photo-years {
      position: absolute;
      top: 10px;
      font-size: 9px;
      font-weight: 600;
      letter-spacing: 0.06em;
      color: var(--gold);
      opacity: 0.8;
    }
    .diego-wrap .player-photo-years { left: 12px; }
    .leo-wrap .player-photo-years { right: 12px; }

    /* ── ARTICLE WRAPPER ── */
    .article-wrap {
      max-width: 740px;
      margin: 0 auto;
      padding: 72px 24px 100px;
    }

    /* ── PROSE ── */
    .prose p {
      font-size: 17px;
      line-height: 1.82;
      color: #2a2a2a;
      margin-bottom: 28px;
      font-weight: 400;
    }
    .prose h2 {
      font-family: 'Playfair Display', serif;
      font-size: 28px;
      font-weight: 700;
      letter-spacing: -0.5px;
      color: var(--ink);
      margin: 64px 0 20px;
      line-height: 1.2;
    }
    .prose h3 {
      font-family: 'Inter', sans-serif;
      font-size: 13px;
      font-weight: 800;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--gold);
      margin: 48px 0 16px;
    }

    /* ── PULL QUOTE ── */
    .pull-quote {
      margin: 56px -40px;
      padding: 32px 40px;
      border-left: 3px solid var(--gold);
      background: linear-gradient(135deg, rgba(201,168,76,0.04) 0%, transparent 70%);
    }
    .pull-quote p {
      font-family: 'Playfair Display', serif;
      font-size: 22px;
      font-style: italic;
      font-weight: 700;
      color: var(--ink);
      line-height: 1.5;
      margin: 0;
    }
    .pull-quote cite {
      display: block;
      margin-top: 12px;
      font-family: 'Inter', sans-serif;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--gold);
      font-style: normal;
    }

    /* ── SECTION HEADER ── */
    .section-header {
      display: flex;
      align-items: center;
      gap: 16px;
      margin: 72px 0 32px;
    }
    .section-header-line {
      flex: 1;
      height: 1px;
      background: linear-gradient(to right, var(--border), transparent);
    }
    .section-header-label {
      font-size: 10px;
      font-weight: 800;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--muted);
      white-space: nowrap;
    }

    /* ── RADAR CHART INFOGRAPHIC ── */
    .radar-section {
      margin: 64px 0;
      background: #fff;
      border-radius: 20px;
      padding: 40px 32px;
      box-shadow: 0 2px 24px rgba(0,0,0,0.07);
      border: 1px solid var(--border);
    }
    .radar-title {
      font-family: 'Playfair Display', serif;
      font-size: 20px;
      font-weight: 700;
      color: var(--ink);
      text-align: center;
      margin-bottom: 6px;
    }
    .radar-sub {
      font-size: 12px;
      color: var(--muted);
      text-align: center;
      margin-bottom: 32px;
      letter-spacing: 0.02em;
    }
    .radar-legend {
      display: flex;
      justify-content: center;
      gap: 28px;
      margin-bottom: 24px;
    }
    .radar-legend-item {
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: 12px;
      font-weight: 700;
      color: var(--ink);
    }
    .radar-legend-dot {
      width: 10px;
      height: 10px;
      border-radius: 50%;
    }
    .dot-diego { background: #1a1a2e; }
    .dot-leo { background: #0071e3; }
    .radar-svg-wrap {
      display: flex;
      justify-content: center;
    }

    /* ── STAT COMPARISON ── */
    .stat-compare {
      margin: 64px 0;
      background: #fff;
      border-radius: 20px;
      overflow: hidden;
      box-shadow: 0 2px 24px rgba(0,0,0,0.07);
      border: 1px solid var(--border);
    }
    .stat-compare-header {
      display: grid;
      grid-template-columns: 1fr 200px 1fr;
      background: var(--ink);
      padding: 16px 24px;
      gap: 12px;
      align-items: center;
    }
    .sc-team-a {
      font-size: 11px;
      font-weight: 800;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.6);
    }
    .sc-team-b {
      font-size: 11px;
      font-weight: 800;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.6);
      text-align: right;
    }
    .sc-label-center {
      font-size: 9px;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--gold);
      text-align: center;
    }
    .stat-row-item {
      display: grid;
      grid-template-columns: 1fr 200px 1fr;
      padding: 14px 24px;
      border-bottom: 1px solid var(--border);
      align-items: center;
      gap: 12px;
    }
    .stat-row-item:last-child { border-bottom: none; }
    .stat-row-item:hover { background: #fafaf9; }
    .stat-val-a {
      font-size: 18px;
      font-weight: 800;
      color: var(--diego);
      font-variant-numeric: tabular-nums;
    }
    .stat-val-b {
      font-size: 18px;
      font-weight: 800;
      color: var(--leo);
      font-variant-numeric: tabular-nums;
      text-align: right;
    }
    .stat-val-a.winner { font-size: 22px; color: #1a1a1a; }
    .stat-val-b.winner { font-size: 22px; color: #1a1a1a; }
    .stat-label-mid {
      text-align: center;
    }
    .stat-label-name {
      display: block;
      font-size: 11px;
      font-weight: 700;
      color: var(--ink);
      margin-bottom: 4px;
      letter-spacing: 0.02em;
    }
    .stat-bar-track {
      height: 4px;
      background: #f0f0f0;
      border-radius: 2px;
      overflow: hidden;
      display: flex;
    }
    .stat-bar-fill-a {
      height: 100%;
      background: var(--diego);
      border-radius: 2px 0 0 2px;
      transition: width 0.8s ease;
    }
    .stat-bar-fill-b {
      height: 100%;
      background: #0071e3;
      border-radius: 0 2px 2px 0;
      transition: width 0.8s ease;
    }
    .stat-context {
      display: block;
      font-size: 9.5px;
      color: var(--muted);
      margin-top: 3px;
      font-style: italic;
    }

    /* ── DIMENSION CARDS ── */
    .dimension-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
      margin: 48px 0;
    }
    .dim-card {
      background: #fff;
      border-radius: 16px;
      padding: 24px;
      border: 1px solid var(--border);
      box-shadow: 0 1px 8px rgba(0,0,0,0.05);
    }
    .dim-card-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 16px;
    }
    .dim-label {
      font-size: 10px;
      font-weight: 800;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--muted);
    }
    .dim-verdict {
      font-size: 10px;
      font-weight: 700;
      padding: 3px 9px;
      border-radius: 100px;
    }
    .verdict-diego { background: rgba(26,26,46,0.08); color: var(--diego); }
    .verdict-leo { background: rgba(0,113,227,0.08); color: #0057b8; }
    .verdict-draw { background: rgba(201,168,76,0.12); color: #8a6d00; }
    .dim-title {
      font-family: 'Playfair Display', serif;
      font-size: 18px;
      font-weight: 700;
      color: var(--ink);
      margin-bottom: 10px;
      line-height: 1.3;
    }
    .dim-text {
      font-size: 13.5px;
      line-height: 1.7;
      color: #444;
    }
    .dim-score-row {
      display: flex;
      gap: 12px;
      margin-top: 16px;
    }
    .dim-score {
      flex: 1;
      text-align: center;
      padding: 10px 8px;
      border-radius: 10px;
    }
    .dim-score.side-a { background: rgba(26,26,46,0.05); }
    .dim-score.side-b { background: rgba(0,113,227,0.05); }
    .dim-score-name {
      font-size: 9px;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 4px;
    }
    .dim-score-val {
      font-size: 22px;
      font-weight: 900;
      font-variant-numeric: tabular-nums;
      line-height: 1;
    }
    .dim-score-val.a { color: var(--diego); }
    .dim-score-val.b { color: #0071e3; }

    /* ── TIMELINE ── */
    .timeline {
      margin: 64px 0;
      position: relative;
    }
    .timeline-line {
      position: absolute;
      left: 50%;
      top: 0; bottom: 0;
      width: 1px;
      background: linear-gradient(to bottom, transparent, var(--border) 10%, var(--border) 90%, transparent);
      transform: translateX(-50%);
    }
    .timeline-item {
      display: grid;
      grid-template-columns: 1fr 48px 1fr;
      gap: 0;
      margin-bottom: 32px;
      align-items: start;
    }
    .timeline-side {
      padding: 16px 24px 16px 0;
    }
    .timeline-side.right {
      padding: 16px 0 16px 24px;
    }
    .timeline-dot-wrap {
      display: flex;
      justify-content: center;
      padding-top: 18px;
    }
    .timeline-dot {
      width: 12px;
      height: 12px;
      border-radius: 50%;
      border: 2px solid #fff;
      box-shadow: 0 0 0 2px var(--border);
    }
    .tl-dot-diego { background: var(--diego); box-shadow: 0 0 0 2px rgba(26,26,46,0.2); }
    .tl-dot-leo { background: #0071e3; box-shadow: 0 0 0 2px rgba(0,113,227,0.2); }
    .tl-dot-gold { background: var(--gold); box-shadow: 0 0 0 2px rgba(201,168,76,0.3); }
    .timeline-year {
      font-size: 10px;
      font-weight: 800;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 4px;
    }
    .timeline-event {
      font-size: 14px;
      font-weight: 600;
      color: var(--ink);
      margin-bottom: 4px;
      line-height: 1.4;
    }
    .timeline-detail {
      font-size: 12.5px;
      color: var(--muted);
      line-height: 1.55;
    }
    .timeline-side.right .timeline-year,
    .timeline-side.right .timeline-event,
    .timeline-side.right .timeline-detail { text-align: left; }

    /* ── FINAL VERDICT ── */
    .final-verdict {
      margin: 72px 0 0;
      padding: 48px 40px;
      background: linear-gradient(135deg, var(--diego) 0%, #0a1628 50%, var(--leo) 100%);
      border-radius: 24px;
      position: relative;
      overflow: hidden;
    }
    .final-verdict::before {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse at 50% 0%, rgba(201,168,76,0.14) 0%, transparent 60%);
    }
    .fv-inner { position: relative; }
    .fv-tag {
      font-size: 10px;
      font-weight: 800;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 20px;
      display: block;
    }
    .fv-title {
      font-family: 'Playfair Display', serif;
      font-size: 28px;
      font-weight: 900;
      color: #fff;
      margin-bottom: 20px;
      line-height: 1.2;
    }
    .fv-text {
      font-size: 15.5px;
      line-height: 1.8;
      color: rgba(255,255,255,0.72);
      max-width: 580px;
      margin-bottom: 32px;
    }
    .fv-score-row {
      display: flex;
      gap: 1px;
      border-radius: 12px;
      overflow: hidden;
      max-width: 460px;
    }
    .fv-score-block {
      flex: 1;
      padding: 16px 20px;
      text-align: center;
    }
    .fv-score-block.a { background: rgba(255,255,255,0.07); }
    .fv-score-block.b { background: rgba(255,255,255,0.07); }
    .fv-score-name {
      font-size: 9px;
      font-weight: 800;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.45);
      margin-bottom: 6px;
    }
    .fv-score-num {
      font-size: 36px;
      font-weight: 900;
      color: var(--gold);
      line-height: 1;
      font-variant-numeric: tabular-nums;
    }
    .fv-score-label {
      font-size: 10px;
      color: rgba(255,255,255,0.38);
      margin-top: 4px;
    }
    .fv-score-sep {
      display: flex;
      align-items: center;
      justify-content: center;
      background: rgba(255,255,255,0.04);
      padding: 0 16px;
      font-family: 'Playfair Display', serif;
      font-size: 22px;
      font-style: italic;
      color: rgba(255,255,255,0.25);
    }

    /* ── BACK LINK ── */
    .back-link {
      display: inline-flex;
      align-items: center;
      gap: 7px;
      font-size: 12px;
      font-weight: 600;
      color: var(--muted);
      text-decoration: none;
      margin-bottom: 56px;
      letter-spacing: 0.02em;
      transition: color 0.15s;
    }
    .back-link:hover { color: var(--ink); }
    .back-arrow { font-size: 14px; }

    /* ── FOOTNOTE ── */
    .footnote {
      margin-top: 64px;
      padding-top: 32px;
      border-top: 1px solid var(--border);
      font-size: 12px;
      color: var(--muted);
      line-height: 1.7;
    }
    .footnote strong { color: var(--ink); font-weight: 600; }

    /* ── ANIMATE ON SCROLL ── */
    .fade-up {
      opacity: 0;
      transform: translateY(20px);
      transition: opacity 0.6s ease, transform 0.6s ease;
    }
    .fade-up.visible {
      opacity: 1;
      transform: translateY(0);
    }

