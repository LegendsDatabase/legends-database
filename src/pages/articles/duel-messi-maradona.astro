  <div class="prose">
    <div class="footnote">
      <strong>Methodology note.</strong> Scores across all dimensions are qualitative assessments based on available statistics, contextual analysis, and comparative historical record. Statistical figures for Maradona's assists are approximate, as comprehensive tracking was not standard before 1990. Era adjustments for scoring rates reflect the documented shift in goals per game between the 1980s Italian league and the modern game. Player images, where visible, are pulled from the Legends Database player library.
    </div>
  </div>

</div>

<Footer/>

<script>
// ── RADAR CHART ──
(function() {
  const dims = [
    { label: 'Technique', diego: 99, leo: 99 },
    { label: 'Athleticism', diego: 88, leo: 90 },
    { label: 'Goals', diego: 87, leo: 99 },
    { label: 'Leadership', diego: 97, leo: 89 },
    { label: 'Longevity', diego: 82, leo: 97 },
    { label: 'Intl. Peak', diego: 98, leo: 96 },
  ];
  const cx = 170, cy = 165, R = 110, levels = 4;
  const n = dims.length;
  const angle = (i) => (Math.PI * 2 * i / n) - Math.PI / 2;
  const toXY = (val, i) => ({
    x: Math.cos(angle(i)) * (R * val / 100),
    y: Math.sin(angle(i)) * (R * val / 100),
  });

  const grid = document.getElementById('radarGrid');
  const polys = document.getElementById('radarPolygons');
  const labels = document.getElementById('radarLabels');

  // Grid rings
  for (let l = 1; l <= levels; l++) {
    const r = R * l / levels;
    const pts = dims.map((_, i) => {
      const x = Math.cos(angle(i)) * r;
      const y = Math.sin(angle(i)) * r;
      return x + ',' + y;
    }).join(' ');
    const poly = document.createElementNS('http://www.w3.org/2000/svg', 'polygon');
    poly.setAttribute('points', pts);
    poly.setAttribute('fill', 'none');
    poly.setAttribute('stroke', l === levels ? 'rgba(0,0,0,0.12)' : 'rgba(0,0,0,0.06)');
    poly.setAttribute('stroke-width', '1');
    grid.appendChild(poly);
    // Spokes
    dims.forEach((_, i) => {
      if (l === levels) {
        const line = document.createElementNS('http://www.w3.org/2000/svg', 'line');
        line.setAttribute('x1', 0); line.setAttribute('y1', 0);
        line.setAttribute('x2', Math.cos(angle(i)) * R);
        line.setAttribute('y2', Math.sin(angle(i)) * R);
        line.setAttribute('stroke', 'rgba(0,0,0,0.08)');
        line.setAttribute('stroke-width', '1');
        grid.appendChild(line);
      }
    });
  }

  // Polygons
  function makePolygon(data, color, opacity) {
    const pts = data.map((val, i) => {
      const p = toXY(val, i);
      return p.x + ',' + p.y;
    }).join(' ');
    const poly = document.createElementNS('http://www.w3.org/2000/svg', 'polygon');
    poly.setAttribute('points', pts);
    poly.setAttribute('fill', color);
    poly.setAttribute('fill-opacity', opacity);
    poly.setAttribute('stroke', color);
    poly.setAttribute('stroke-width', '2');
    poly.setAttribute('stroke-opacity', '0.9');
    return poly;
  }

  polys.appendChild(makePolygon(dims.map(d => d.diego), '#1a1a2e', 0.18));
  polys.appendChild(makePolygon(dims.map(d => d.leo), '#0071e3', 0.18));

  // Dots
  ['diego', 'leo'].forEach(who => {
    dims.forEach((d, i) => {
      const p = toXY(d[who], i);
      const circle = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
      circle.setAttribute('cx', cx + p.x);
      circle.setAttribute('cy', cy + p.y);
      circle.setAttribute('r', '4');
      circle.setAttribute('fill', who === 'diego' ? '#1a1a2e' : '#0071e3');
      document.getElementById('radarSvg').appendChild(circle);
    });
  });

  // Labels
  dims.forEach((d, i) => {
    const x = cx + Math.cos(angle(i)) * (R + 22);
    const y = cy + Math.sin(angle(i)) * (R + 22);
    const text = document.createElementNS('http://www.w3.org/2000/svg', 'text');
    text.setAttribute('x', x);
    text.setAttribute('y', y + 5);
    text.setAttribute('text-anchor', 'middle');
    text.setAttribute('font-family', 'Inter, sans-serif');
    text.setAttribute('font-size', '11');
    text.setAttribute('font-weight', '700');
    text.setAttribute('fill', '#444');
    text.textContent = d.label;
    labels.appendChild(text);
  });
})();

// ── SCROLL FADE ──
const fadeEls = document.querySelectorAll('.fade-up');
const io = new IntersectionObserver((entries) => {
  entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); io.unobserve(e.target); } });
}, { threshold: 0.1 });
fadeEls.forEach(el => io.observe(el));
</script>

</body>
</html>
