---
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';

const articles = [
  { slug: 'italian-football-culture', title: 'Football as a Cultural Phenomenon: The Italian Soul', description: 'How centuries of history, the Renaissance, and a unique national mentality shaped Italian football into one of the most fascinating traditions in the world.', date: 'May 2025', readTime: '8 min read', tag: 'Football Culture' },
  { slug: 'zico-galinho', title: 'Zico, O Galinho — The Little Rooster Who Conquered the World', description: 'More than just a playmaker — a forward, a midfield maestro, a pure footballing artist. A love letter to one of the most beautiful players who ever lived.', date: 'May 2025', readTime: '11 min read', tag: 'Player Profile' },
  { slug: 'le-tissier-le-god', title: 'Matthew Le Tissier — Le God', description: 'The provincial genius. An Anglo-French anomaly who played like Riquelme in the wrong country and the wrong era — and yet became one of the most beloved players of the 1990s.', date: 'May 2025', readTime: '10 min read', tag: 'Player Profile' },
  { slug: 'magico-gonzalez', title: 'Magico Gonzalez — Poetry Without Rules', description: 'A perpetual fugitive, a man out of time. The Salvadoran maestro who played not to win, but because it was beautiful to do so.', date: 'May 2025', readTime: '10 min read', tag: 'Player Profile' },
  { slug: 'bobby-charlton', title: 'Bobby Charlton — Every Cloud Has a Silver Lining', description: 'He survived Munich at 21. He made a promise to fallen friends. A decade later, he kept it at Wembley. The story of resilience, dignity and the greatest English footballer of all time.', date: 'May 2025', readTime: '12 min read', tag: 'Player Profile' },
  { slug: 'duel-van-basten-ronaldo', title: 'Van Basten vs Ronaldo — The Eternal Duel', description: 'Two of the greatest centre-forwards ever, dissected across every dimension: physical, technical, tactical, mental, club and international. A duel for the ages.', date: 'May 2025', readTime: '18 min read', tag: 'Duels' },
  { slug: 'duel-figueroa-passarella', title: 'Figueroa vs Passarella — The Soul of South American Defending', description: 'Ice and flame. The philosopher and the warrior. A duel between the two greatest defenders South America has ever produced.', date: 'May 2025', readTime: '16 min read', tag: 'Duels' },
{ slug: 'duel-messi-maradona', title: 'Messi vs Maradona — The Question That Has No Answer', description: 'Two Argentines, one left foot touched by God, one impossible comparison that divided Italy and united the world. The deepest duel in football history.', date: 'May 2025', readTime: '20 min read', tag: 'Duels' },
];

const tagCssClass = {
  'Football Culture': 'tc-culture',
  'Player Profile':   'tc-profile',
  'Duels':            'tc-duels',
};

const btnCssClass = {
  'All':             'btn-all',
  'Football Culture':'btn-culture',
  'Player Profile':  'btn-profile',
  'Duels':           'btn-duels',
};

const filterBtns = [
  { tag: 'All',             cls: 'filter-btn btn-all is-active', count: articles.length },
  { tag: 'Player Profile',  cls: 'filter-btn btn-profile',       count: articles.filter(a => a.tag === 'Player Profile').length },
  { tag: 'Football Culture',cls: 'filter-btn btn-culture',       count: articles.filter(a => a.tag === 'Football Culture').length },
  { tag: 'Duels',           cls: 'filter-btn btn-duels',         count: articles.filter(a => a.tag === 'Duels').length },
];

const preparedArticles = articles.map(a => ({
  tag:      a.tag,
  title:    a.title,
  desc:     a.description,
  date:     a.date,
  readTime: a.readTime,
  href:     '/articles/' + a.slug,
  tagCls:   'article-tag ' + (tagCssClass[a.tag] || 'tc-profile'),
}));
---

<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1"/>
  <title>Articles – Legends Database</title>
  <meta name="description" content="In-depth articles on football culture, history, tactics and the greatest legends of the game."/>
  <meta name="robots" content="index, follow"/>
  <link rel="canonical" href="https://legendsdatabase.com/articles"/>
  <meta property="og:type"        content="website"/>
  <meta property="og:url"         content="https://legendsdatabase.com/articles"/>
  <meta property="og:title"       content="Articles – Legends Database"/>
  <meta property="og:description" content="In-depth articles on football culture, history, tactics and the greatest legends of the game."/>
  <meta property="og:image"       content="https://legendsdatabase.com/og-image.jpg"/>
  <meta property="og:locale"      content="en_US"/>
  <meta name="twitter:card"       content="summary_large_image"/>
  <meta name="twitter:title"      content="Articles – Legends Database"/>
  <meta name="twitter:description"content="In-depth articles on football culture, history, tactics and the greatest legends of the game."/>
  <meta name="twitter:image"      content="https://legendsdatabase.com/og-image.jpg"/>
  <link rel="icon" type="image/png" href="/favicon.png"/>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: -apple-system, 'SF Pro Text', 'Inter', sans-serif;
      background: #f2f2f7;
      color: #1d1d1f;
      padding-top: 44px;
      -webkit-font-smoothing: antialiased;
      display: flex;
      flex-direction: column;
      min-height: 100vh;
    }
    .page {
      flex: 1;
      max-width: 860px;
      width: 100%;
      margin: 0 auto;
      padding: 48px 40px 80px;
    }
    .page-eyebrow {
      font-size: 11px;
      font-weight: 700;
      color: #0071e3;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      margin-bottom: 10px;
    }
    .page-title {
      font-size: 40px;
      font-weight: 700;
      letter-spacing: -1.2px;
      color: #1d1d1f;
      margin-bottom: 8px;
      line-height: 1.05;
    }
    .page-sub {
      font-size: 15px;
      color: #6e6e73;
      line-height: 1.6;
      margin-bottom: 28px;
      max-width: 480px;
    }

    /* ── FILTER BUTTONS ── */
    .filter-row {
      display: flex;
      align-items: center;
      gap: 8px;
      flex-wrap: wrap;
      margin-bottom: 32px;
    }
    .filter-btn {
      font-family: inherit;
      font-size: 12.5px;
      font-weight: 600;
      padding: 6px 16px;
      border-radius: 20px;
      border: 1.5px solid transparent;
      cursor: pointer;
      transition: background 0.15s, color 0.15s, border-color 0.15s;
      white-space: nowrap;
      display: inline-flex;
      align-items: center;
      gap: 5px;
    }
    .filter-btn:hover { opacity: 0.85; }
    .filter-btn-count { font-size: 11px; font-weight: 500; opacity: 0.55; }
    .filter-total { font-size: 12px; font-weight: 500; color: #aeaeb2; margin-left: 4px; }

    /* Button colors by type */
    .btn-all             { background: #f5f5f7; color: #1d1d1f; border-color: #f5f5f7; }
    .btn-all.is-active   { background: #1d1d1f; color: #ffffff; border-color: #1d1d1f; }
    .btn-profile             { background: #eef4ff; color: #0071e3; border-color: #eef4ff; }
    .btn-profile.is-active   { background: #0071e3; color: #ffffff; border-color: #0071e3; }
    .btn-culture             { background: #efffee; color: #1a7a1a; border-color: #efffee; }
    .btn-culture.is-active   { background: #1a7a1a; color: #ffffff; border-color: #1a7a1a; }
    .btn-duels             { background: #fff0ee; color: #c0392b; border-color: #fff0ee; }
    .btn-duels.is-active   { background: #c0392b; color: #ffffff; border-color: #c0392b; }

    /* ── GRID ── */
    .articles-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 16px;
    }

    /* ── CARD ── */
    .article-card {
      background: #ffffff;
      border-radius: 20px;
      padding: 28px 26px;
      box-shadow: 0 1px 4px rgba(0,0,0,0.06), 0 4px 20px rgba(0,0,0,0.04);
      text-decoration: none;
      display: flex;
      flex-direction: column;
      gap: 12px;
      transition: transform 0.18s, box-shadow 0.18s;
      position: relative;
      overflow: hidden;
    }
    .article-card::after {
      content: '';
      position: absolute;
      bottom: 0; left: 0; right: 0;
      height: 3px;
      background: linear-gradient(90deg, #0071e3, #34aadc);
      transform: scaleX(0);
      transform-origin: left;
      transition: transform 0.25s ease;
    }
    .article-card:hover { transform: translateY(-4px); box-shadow: 0 8px 32px rgba(0,0,0,0.10); }
    .article-card:hover::after { transform: scaleX(1); }
    .article-card.is-hidden { display: none; }

    /* Tag badge colors */
    .article-tag {
      display: inline-flex;
      align-items: center;
      font-size: 10.5px;
      font-weight: 700;
      padding: 3px 10px;
      border-radius: 8px;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      align-self: flex-start;
    }
    .tc-profile { background: #eef4ff; color: #0071e3; }
    .tc-culture { background: #efffee; color: #1a7a1a; }
    .tc-duels   { background: #fff0ee; color: #c0392b; }

    .article-title {
      font-size: 17px;
      font-weight: 700;
      letter-spacing: -0.3px;
      color: #1d1d1f;
      line-height: 1.3;
    }
    .article-desc {
      font-size: 13px;
      color: #6e6e73;
      line-height: 1.6;
      flex: 1;
    }
    .article-meta {
      display: flex;
      align-items: center;
      gap: 10px;
      font-size: 11.5px;
      color: #aeaeb2;
      font-weight: 500;
      margin-top: 4px;
    }
    .article-meta-sep { color: #d1d1d6; }
    .article-read-more {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      font-size: 12.5px;
      font-weight: 600;
      color: #0071e3;
      margin-top: 4px;
      transition: gap 0.15s;
    }
    .article-card:hover .article-read-more { gap: 8px; }

    .grid-empty {
      grid-column: span 2;
      text-align: center;
      padding: 60px 20px;
      color: #aeaeb2;
      font-size: 14px;
      display: none;
    }
    .grid-empty.visible { display: block; }

    @media (max-width: 640px) {
      .page { padding: 32px 20px 64px; }
      .page-title { font-size: 30px; }
      .page-sub { font-size: 14px; margin-bottom: 20px; }
      .filter-row { gap: 6px; margin-bottom: 24px; }
      .filter-btn { font-size: 12px; padding: 5px 13px; }
      .articles-grid { grid-template-columns: 1fr; gap: 12px; }
      .article-card { padding: 22px 20px; }
      .article-title { font-size: 16px; }
      .grid-empty { grid-column: span 1; }
    }
  </style>
</head>
<body>
  <Navbar/>
  <div class="page">

    <div class="page-eyebrow">Legends Database</div>
    <h1 class="page-title">Articles</h1>
    <p class="page-sub">In-depth essays on football culture, history, tactics and the legends who defined the game.</p>

    <!-- FILTRI — solo classi CSS, zero style={} -->
    <div class="filter-row" id="filterRow">
      {filterBtns.map(b => (
        <button class={b.cls} data-tag={b.tag}>
          {b.tag}
          <span class="filter-btn-count">{b.count}</span>
        </button>
      ))}
      <span class="filter-total" id="filterTotal">{articles.length} articles</span>
    </div>

    <!-- GRID — href e class precomputati, zero style={} -->
    <div class="articles-grid" id="articlesGrid">
      {preparedArticles.map(a => (
        <a href={a.href} class="article-card" data-tag={a.tag}>
          <span class={a.tagCls}>{a.tag}</span>
          <div class="article-title">{a.title}</div>
          <div class="article-desc">{a.desc}</div>
          <div class="article-meta">
            <span>{a.date}</span>
            <span class="article-meta-sep">·</span>
            <span>{a.readTime}</span>
          </div>
          <div class="article-read-more">Read article →</div>
        </a>
      ))}
      <div class="grid-empty" id="gridEmpty">No articles in this category yet.</div>
    </div>

  </div>
  <Footer/>

  <script>
    const btns  = document.querySelectorAll('.filter-btn');
    const cards = document.querySelectorAll('.article-card');
    const total = document.getElementById('filterTotal');
    const empty = document.getElementById('gridEmpty');

    btns.forEach(btn => {
      btn.addEventListener('click', () => {
        const tag = btn.getAttribute('data-tag');

        btns.forEach(b => {
          b.classList.toggle('is-active', b === btn);
        });

        let visible = 0;
        cards.forEach(card => {
          const show = tag === 'All' || card.getAttribute('data-tag') === tag;
          card.classList.toggle('is-hidden', !show);
          if (show) visible++;
        });

        if (total) total.textContent = visible + (visible === 1 ? ' article' : ' articles');
        if (empty) empty.classList.toggle('visible', visible === 0);
      });
    });
  </script>
</body>
</html>