---
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';

const articles = [
  {
    slug: 'italian-football-culture',
    title: 'Football as a Cultural Phenomenon: The Italian Soul',
    description: 'How centuries of history, the Renaissance, and a unique national mentality shaped Italian football into one of the most fascinating traditions in the world.',
    date: 'May 2025',
    readTime: '8 min read',
    tag: 'Football Culture',
  },
 {
  slug: 'zico-galinho',
  title: 'Zico, O Galinho — The Little Rooster Who Conquered the World',
  description: 'More than just a playmaker — a forward, a midfield maestro, a pure footballing artist. A love letter to one of the most beautiful players who ever lived.',
  date: 'May 2025',
  readTime: '11 min read',
  tag: 'Player Profile',
},
{
  slug: 'le-tissier-le-god',
  title: 'Matthew Le Tissier — Le God',
  description: 'The provincial genius. An Anglo-French anomaly who played like Riquelme in the wrong country and the wrong era — and yet became one of the most beloved players of the 1990s.',
  date: 'May 2025',
  readTime: '10 min read',
  tag: 'Player Profile',
},
{
  slug: 'magico-gonzalez',
  title: 'Mágico González — Poetry Without Rules',
  description: 'A perpetual fugitive, a man out of time. The Salvadoran maestro who played not to win, but because it was beautiful to do so — a meditation on the most irrational and sublime talent in football history.',
  date: 'May 2025',
  readTime: '10 min read',
  tag: 'Player Profile',
},
];
---

<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1"/>
  <title>Articles – Legends Database</title>
  <meta name="description" content="In-depth articles on football culture, history, tactics and the greatest legends of the game. Written by Legends Database."/>
  <meta name="robots" content="index, follow"/>
  <link rel="canonical" href="https://legendsdatabase.com/articles"/>
  <meta property="og:type"         content="website"/>
  <meta property="og:url"          content="https://legendsdatabase.com/articles"/>
  <meta property="og:title"        content="Articles – Legends Database"/>
  <meta property="og:description"  content="In-depth articles on football culture, history, tactics and the greatest legends of the game."/>
  <meta property="og:image"        content="https://legendsdatabase.com/og-image.jpg"/>
  <meta property="og:image:width"  content="1200"/>
  <meta property="og:image:height" content="630"/>
  <meta property="og:locale"       content="en_US"/>
  <meta name="twitter:card"        content="summary_large_image"/>
  <meta name="twitter:title"       content="Articles – Legends Database"/>
  <meta name="twitter:description" content="In-depth articles on football culture, history, tactics and the greatest legends of the game."/>
  <meta name="twitter:image"       content="https://legendsdatabase.com/og-image.jpg"/>
  <link rel="icon" type="image/png" href="/favicon.png"/>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: -apple-system, 'SF Pro Text', 'Inter', sans-serif;
      background: #f2f2f7;
      color: #1d1d1f;
      padding-top: 44px;
      -webkit-font-smoothing: antialiased;
      display: flex;
      flex-direction: column;
      min-height: 100vh;
    }
    .page {
      flex: 1;
      max-width: 860px;
      width: 100%;
      margin: 0 auto;
      padding: 48px 40px 80px;
    }

    /* HEADER */
    .page-eyebrow {
      font-size: 11px;
      font-weight: 700;
      color: #0071e3;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      margin-bottom: 10px;
    }
    .page-title {
      font-size: 40px;
      font-weight: 700;
      letter-spacing: -1.2px;
      color: #1d1d1f;
      margin-bottom: 8px;
      line-height: 1.05;
    }
    .page-sub {
      font-size: 15px;
      color: #6e6e73;
      line-height: 1.6;
      margin-bottom: 40px;
      max-width: 480px;
    }

    /* ARTICLE GRID */
    .articles-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 16px;
    }

    /* ARTICLE CARD */
    .article-card {
      background: #ffffff;
      border-radius: 20px;
      padding: 28px 26px;
      box-shadow: 0 1px 4px rgba(0,0,0,0.06), 0 4px 20px rgba(0,0,0,0.04);
      text-decoration: none;
      display: flex;
      flex-direction: column;
      gap: 12px;
      transition: transform 0.18s, box-shadow 0.18s;
      position: relative;
      overflow: hidden;
    }
    .article-card::after {
      content: '';
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      height: 3px;
      background: linear-gradient(90deg, #0071e3, #34aadc);
      transform: scaleX(0);
      transform-origin: left;
      transition: transform 0.25s ease;
    }
    .article-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 8px 32px rgba(0,0,0,0.10);
    }
    .article-card:hover::after {
      transform: scaleX(1);
    }
    .article-tag {
      display: inline-flex;
      align-items: center;
      font-size: 10.5px;
      font-weight: 700;
      padding: 3px 10px;
      border-radius: 8px;
      background: #eef4ff;
      color: #0071e3;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      align-self: flex-start;
    }
    .article-title {
      font-size: 17px;
      font-weight: 700;
      letter-spacing: -0.3px;
      color: #1d1d1f;
      line-height: 1.3;
    }
    .article-desc {
      font-size: 13px;
      color: #6e6e73;
      line-height: 1.6;
      flex: 1;
    }
    .article-meta {
      display: flex;
      align-items: center;
      gap: 10px;
      font-size: 11.5px;
      color: #aeaeb2;
      font-weight: 500;
      margin-top: 4px;
    }
    .article-meta-sep { color: #d1d1d6; }
    .article-read-more {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      font-size: 12.5px;
      font-weight: 600;
      color: #0071e3;
      margin-top: 4px;
      transition: gap 0.15s;
    }
    .article-card:hover .article-read-more {
      gap: 8px;
    }

    /* EMPTY STATE */
    .empty {
      text-align: center;
      padding: 80px 20px;
      color: #aeaeb2;
      font-size: 15px;
    }

    /* MOBILE */
    @media (max-width: 640px) {
      .page { padding: 32px 20px 64px; }
      .page-title { font-size: 30px; }
      .page-sub { font-size: 14px; margin-bottom: 28px; }
      .articles-grid { grid-template-columns: 1fr; gap: 12px; }
      .article-card { padding: 22px 20px; }
      .article-title { font-size: 16px; }
    }
  </style>
</head>
<body>
  <Navbar/>
  <div class="page">
    <div class="page-eyebrow">Legends Database</div>
    <h1 class="page-title">Articles</h1>
    <p class="page-sub">In-depth essays on football culture, history, tactics and the legends who defined the game.</p>

    {articles.length === 0 ? (
      <div class="empty">No articles yet — check back soon.</div>
    ) : (
      <div class="articles-grid">
        {articles.map(a => (
          <a href={'/articles/' + a.slug} class="article-card">
            <span class="article-tag">{a.tag}</span>
            <div class="article-title">{a.title}</div>
            <div class="article-desc">{a.description}</div>
            <div class="article-meta">
              <span>{a.date}</span>
              <span class="article-meta-sep">·</span>
              <span>{a.readTime}</span>
            </div>
            <div class="article-read-more">Read article →</div>
          </a>
        ))}
      </div>
    )}
  </div>
  <Footer/>
</body>
</html>