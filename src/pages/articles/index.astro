---
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';

const articles = [
  {
    slug: 'italian-football-culture',
    title: 'Football as a Cultural Phenomenon: The Italian Soul',
    description: 'How centuries of history, the Renaissance, and a unique national mentality shaped Italian football into one of the most fascinating traditions in the world.',
    date: 'May 2025',
    readTime: '8 min read',
    tag: 'Football Culture',
  },
  {
    slug: 'zico-galinho',
    title: 'Zico, O Galinho — The Little Rooster Who Conquered the World',
    description: 'More than just a playmaker — a forward, a midfield maestro, a pure footballing artist. A love letter to one of the most beautiful players who ever lived.',
    date: 'May 2025',
    readTime: '11 min read',
    tag: 'Player Profile',
  },
  {
    slug: 'le-tissier-le-god',
    title: 'Matthew Le Tissier — Le God',
    description: 'The provincial genius. An Anglo-French anomaly who played like Riquelme in the wrong country and the wrong era — and yet became one of the most beloved players of the 1990s.',
    date: 'May 2025',
    readTime: '10 min read',
    tag: 'Player Profile',
  },
  {
    slug: 'magico-gonzalez',
    title: 'Magico Gonzalez — Poetry Without Rules',
    description: 'A perpetual fugitive, a man out of time. The Salvadoran maestro who played not to win, but because it was beautiful to do so.',
    date: 'May 2025',
    readTime: '10 min read',
    tag: 'Player Profile',
  },
  {
    slug: 'bobby-charlton',
    title: 'Bobby Charlton — Every Cloud Has a Silver Lining',
    description: 'He survived Munich at 21. He made a promise to fallen friends. A decade later, he kept it at Wembley. The story of resilience, dignity and the greatest English footballer of all time.',
    date: 'May 2025',
    readTime: '12 min read',
    tag: 'Player Profile',
  },
  {
    slug: 'duel-van-basten-ronaldo',
    title: 'Van Basten vs Ronaldo — The Eternal Duel',
    description: 'Two of the greatest centre-forwards ever, dissected across every dimension: physical, technical, tactical, mental, club and international. A duel for the ages.',
    date: 'May 2025',
    readTime: '18 min read',
    tag: 'Duels',
  },
  {
    slug: 'duel-figueroa-passarella',
    title: 'Figueroa vs Passarella — The Soul of South American Defending',
    description: 'Ice and flame. The philosopher and the warrior. A duel between the two greatest defenders South America has ever produced.',
    date: 'May 2025',
    readTime: '16 min read',
    tag: 'Duels',
  },
];

// Stili per tag — tutto precomputato qui, zero operazioni nel template
const TAG_BG: Record<string, string> = {
  'All': '#f5f5f7',
  'Player Profile': '#eef4ff',
  'Football Culture': '#efffee',
  'Duels': '#fff0ee',
};
const TAG_COLOR: Record<string, string> = {
  'All': '#1d1d1f',
  'Player Profile': '#0071e3',
  'Football Culture': '#1a7a1a',
  'Duels': '#c0392b',
};
const TAG_ACTIVE: Record<string, string> = {
  'All': '#1d1d1f',
  'Player Profile': '#0071e3',
  'Football Culture': '#1a7a1a',
  'Duels': '#c0392b',
};

const allTags = ['All', 'Player Profile', 'Football Culture', 'Duels'];

// Pulsanti filtro — tutto precomputato
const filterButtons = allTags.map(tag => {
  const count = tag === 'All' ? articles.length : articles.filter(a => a.tag === tag).length;
  const bg     = TAG_BG[tag]     ?? '#f5f5f7';
  const color  = TAG_COLOR[tag]  ?? '#1d1d1f';
  const active = TAG_ACTIVE[tag] ?? '#1d1d1f';
  const isAll  = tag === 'All';
  const styleStr = isAll
    ? 'background:#1d1d1f;color:#ffffff;border-color:#1d1d1f;'
    : `background:${bg};color:${color};border-color:${bg};`;
  return { tag, count, styleStr, bg, color, active };
});

// Card articoli — tutto precomputato incluso href
const articleCards = articles.map(a => {
  const bg    = TAG_BG[a.tag]    ?? '#eef4ff';
  const color = TAG_COLOR[a.tag] ?? '#0071e3';
  return {
    tag:      a.tag,
    title:    a.title,
    desc:     a.description,
    date:     a.date,
    readTime: a.readTime,
    href:     `/articles/${a.slug}`,
    tagStyle: `background:${bg};color:${color};`,
  };
});

const totalCount = articles.length;
---

<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1"/>
  <title>Articles – Legends Database</title>
  <meta name="description" content="In-depth articles on football culture, history, tactics and the greatest legends of the game. Written by Legends Database."/>
  <meta name="robots" content="index, follow"/>
  <link rel="canonical" href="https://legendsdatabase.com/articles"/>
  <meta property="og:type"         content="website"/>
  <meta property="og:url"          content="https://legendsdatabase.com/articles"/>
  <meta property="og:title"        content="Articles – Legends Database"/>
  <meta property="og:description"  content="In-depth articles on football culture, history, tactics and the greatest legends of the game."/>
  <meta property="og:image"        content="https://legendsdatabase.com/og-image.jpg"/>
  <meta property="og:image:width"  content="1200"/>
  <meta property="og:image:height" content="630"/>
  <meta property="og:locale"       content="en_US"/>
  <meta name="twitter:card"        content="summary_large_image"/>
  <meta name="twitter:title"       content="Articles – Legends Database"/>
  <meta name="twitter:description" content="In-depth articles on football culture, history, tactics and the greatest legends of the game."/>
  <meta name="twitter:image"       content="https://legendsdatabase.com/og-image.jpg"/>
  <link rel="icon" type="image/png" href="/favicon.png"/>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: -apple-system, 'SF Pro Text', 'Inter', sans-serif;
      background: #f2f2f7;
      color: #1d1d1f;
      padding-top: 44px;
      -webkit-font-smoothing: antialiased;
      display: flex;
      flex-direction: column;
      min-height: 100vh;
    }
    .page {
      flex: 1;
      max-width: 860px;
      width: 100%;
      margin: 0 auto;
      padding: 48px 40px 80px;
    }
    .page-eyebrow {
      font-size: 11px;
      font-weight: 700;
      color: #0071e3;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      margin-bottom: 10px;
    }
    .page-title {
      font-size: 40px;
      font-weight: 700;
      letter-spacing: -1.2px;
      color: #1d1d1f;
      margin-bottom: 8px;
      line-height: 1.05;
    }
    .page-sub {
      font-size: 15px;
      color: #6e6e73;
      line-height: 1.6;
      margin-bottom: 28px;
      max-width: 480px;
    }
    .filter-row {
      display: flex;
      align-items: center;
      gap: 8px;
      flex-wrap: wrap;
      margin-bottom: 32px;
    }
    .filter-btn {
      font-family: inherit;
      font-size: 12.5px;
      font-weight: 600;
      padding: 6px 16px;
      border-radius: 20px;
      border: 1.5px solid transparent;
      cursor: pointer;
      transition: background 0.15s, color 0.15s, border-color 0.15s, transform 0.12s;
      white-space: nowrap;
      display: inline-flex;
      align-items: center;
      gap: 5px;
    }
    .filter-btn:hover { transform: translateY(-1px); }
    .filter-btn-count { font-size: 11px; font-weight: 500; opacity: 0.55; }
    .filter-total {
      font-size: 12px;
      font-weight: 500;
      color: #aeaeb2;
      margin-left: 4px;
    }
    .articles-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 16px;
    }
    .article-card {
      background: #ffffff;
      border-radius: 20px;
      padding: 28px 26px;
      box-shadow: 0 1px 4px rgba(0,0,0,0.06), 0 4px 20px rgba(0,0,0,0.04);
      text-decoration: none;
      display: flex;
      flex-direction: column;
      gap: 12px;
      transition: transform 0.18s, box-shadow 0.18s;
      position: relative;
      overflow: hidden;
    }
    .article-card::after {
      content: '';
      position: absolute;
      bottom: 0; left: 0; right: 0;
      height: 3px;
      background: linear-gradient(90deg, #0071e3, #34aadc);
      transform: scaleX(0);
      transform-origin: left;
      transition: transform 0.25s ease;
    }
    .article-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 8px 32px rgba(0,0,0,0.10);
    }
    .article-card:hover::after { transform: scaleX(1); }
    .article-card.is-hidden { display: none; }
    .article-tag {
      display: inline-flex;
      align-items: center;
      font-size: 10.5px;
      font-weight: 700;
      padding: 3px 10px;
      border-radius: 8px;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      align-self: flex-start;
    }
    .article-title {
      font-size: 17px;
      font-weight: 700;
      letter-spacing: -0.3px;
      color: #1d1d1f;
      line-height: 1.3;
    }
    .article-desc {
      font-size: 13px;
      color: #6e6e73;
      line-height: 1.6;
      flex: 1;
    }
    .article-meta {
      display: flex;
      align-items: center;
      gap: 10px;
      font-size: 11.5px;
      color: #aeaeb2;
      font-weight: 500;
      margin-top: 4px;
    }
    .article-meta-sep { color: #d1d1d6; }
    .article-read-more {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      font-size: 12.5px;
      font-weight: 600;
      color: #0071e3;
      margin-top: 4px;
      transition: gap 0.15s;
    }
    .article-card:hover .article-read-more { gap: 8px; }
    .grid-empty {
      grid-column: span 2;
      text-align: center;
      padding: 60px 20px;
      color: #aeaeb2;
      font-size: 14px;
      display: none;
    }
    .grid-empty.visible { display: block; }
    @media (max-width: 640px) {
      .page { padding: 32px 20px 64px; }
      .page-title { font-size: 30px; }
      .page-sub { font-size: 14px; margin-bottom: 20px; }
      .filter-row { gap: 6px; margin-bottom: 24px; }
      .filter-btn { font-size: 12px; padding: 5px 13px; }
      .articles-grid { grid-template-columns: 1fr; gap: 12px; }
      .article-card { padding: 22px 20px; }
      .article-title { font-size: 16px; }
      .grid-empty { grid-column: span 1; }
    }
  </style>
</head>
<body>
  <Navbar/>
  <div class="page">

    <div class="page-eyebrow">Legends Database</div>
    <h1 class="page-title">Articles</h1>
    <p class="page-sub">In-depth essays on football culture, history, tactics and the legends who defined the game.</p>

    <!-- FILTRI — zero operazioni nel template, tutto da frontmatter -->
    <div class="filter-row" id="filterRow">
      {filterButtons.map(b => (
        <button
          class="filter-btn"
          data-tag={b.tag}
          data-bg={b.bg}
          data-color={b.color}
          data-active={b.active}
          style={b.styleStr}
        >
          {b.tag}
          <span class="filter-btn-count">{b.count}</span>
        </button>
      ))}
      <span class="filter-total" id="filterTotal">{totalCount} articles</span>
    </div>

    <!-- GRID — href e style precomputati nel frontmatter -->
    <div class="articles-grid" id="articlesGrid">
      {articleCards.map(a => (
        
          href={a.href}
          class="article-card"
          data-tag={a.tag}
        >
          <span class="article-tag" style={a.tagStyle}>{a.tag}</span>
          <div class="article-title">{a.title}</div>
          <div class="article-desc">{a.desc}</div>
          <div class="article-meta">
            <span>{a.date}</span>
            <span class="article-meta-sep">·</span>
            <span>{a.readTime}</span>
          </div>
          <div class="article-read-more">Read article →</div>
        </a>
      ))}
      <div class="grid-empty" id="gridEmpty">No articles in this category yet.</div>
    </div>

  </div>
  <Footer/>

  <script>
    const btns  = document.querySelectorAll('.filter-btn');
    const cards = document.querySelectorAll('.article-card');
    const total = document.getElementById('filterTotal');
    const empty = document.getElementById('gridEmpty');

    btns.forEach(btn => {
      btn.addEventListener('click', () => {
        const tag = btn.getAttribute('data-tag');

        btns.forEach(b => {
          const on = b === btn;
          b.style.background  = on ? b.getAttribute('data-active') : b.getAttribute('data-bg');
          b.style.color       = on ? '#ffffff'                     : b.getAttribute('data-color');
          b.style.borderColor = on ? b.getAttribute('data-active') : b.getAttribute('data-bg');
        });

        let visible = 0;
        cards.forEach(card => {
          const show = tag === 'All' || card.getAttribute('data-tag') === tag;
          card.classList.toggle('is-hidden', !show);
          if (show) visible++;
        });

        if (total) total.textContent = visible + (visible === 1 ? ' article' : ' articles');
        if (empty) empty.classList.toggle('visible', visible === 0);
      });
    });
  </script>
</body>
</html>