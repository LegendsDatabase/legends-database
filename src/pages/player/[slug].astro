      .teams-strip{
        flex-wrap:nowrap;
        overflow-x:auto;
        -webkit-overflow-scrolling:touch;
        scrollbar-width:none;
        padding-bottom:4px;
        gap:6px;
      }
      .teams-strip::-webkit-scrollbar{ display:none; }
      .team-chip{ padding:4px 10px 4px 6px; }
      .team-chip-text{ font-size:11px; }
      .team-chip-badge{ font-size:9px; }

      /* STATS — 3 cols x 2 rows */
      .stats-row{
        grid-template-columns:repeat(3,1fr);
        gap:8px;
        margin-bottom:12px;
      }
      .stat-card{ padding:10px 8px; border-radius:10px; }
      .stat-card .sv{ font-size:16px; }
      .stat-card .sl{ font-size:9px; }

      /* VIZ — hide heatmap, radar full width */
      .viz-row{
        grid-template-columns:1fr;
        gap:10px;
        margin-bottom:14px;
      }
      .heatmap-card{ display:none; }
      .radar-card{ border-radius:12px; }
      .radar-svg{ max-width:220px; }

      /* GAUGES — compact */
      .gauge-section{ gap:8px; margin-bottom:14px; }
      .gauge-item{ padding:14px 6px 10px; border-radius:12px; }
      .gauge-item svg{ max-width:100px; }
      .gauge-label{ font-size:9px; margin-top:4px; }

      .gk-gauge-section{ gap:8px; margin-bottom:14px; }
      .gk-gauge-item{ padding:14px 8px 10px; border-radius:12px; }
      .gk-gauge-item svg{ max-width:100px; }
      .gk-gauge-label{ font-size:9px; margin-top:4px; }
      .gk-spectrum-item{ padding:14px 12px 14px; border-radius:12px; }
      .gk-type-label{ font-size:13px; }
      .gk-type-desc{ font-size:9px; margin-bottom:12px; }
      .gk-score-val{ font-size:15px; }
      .gk-score-sub{ font-size:8px; }

      /* SKILLS — single column */
      .skills-grid{ grid-template-columns:1fr; gap:10px; }
      .skill-card.full-width{ grid-column:auto; }
      .skill-card{ padding:16px 14px 12px; border-radius:12px; }
      .skill-cat{ margin-bottom:12px; }
      .skill-row{ margin-bottom:8px; gap:8px; }
      .skill-abbr{ min-width:34px; font-size:9.5px; }
      .skill-val{ font-size:11px; min-width:22px; }

      /* TRAITS */
      .traits-section{ padding:16px 14px 18px; border-radius:12px; }
      .traits-grid{ grid-template-columns:repeat(5,50px); gap:10px; }
      .trait-icon,.trait-icon img{ width:50px; height:50px; }

      /* SEE ALSO — horizontal scroll */
      .see-also{ margin-top:28px; }
      .see-also-grid{
        flex-wrap:nowrap;
        overflow-x:auto;
        -webkit-overflow-scrolling:touch;
        scrollbar-width:none;
        padding-bottom:6px;
        gap:8px;
      }
      .see-also-grid::-webkit-scrollbar{ display:none; }
      .see-also-card{
        min-width:152px;
        max-width:152px;
        flex-shrink:0;
        padding:12px 14px;
        border-radius:12px;
      }
      .sa-avatar{ width:32px; height:32px; font-size:11px; }
      .sa-name{ font-size:11.5px; }
    }

  </style>
<script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Person",
    "name": p.name,
    "url": "https://legendsdatabase.com/player/" + p.slug,
    "nationality": p.nation ?? undefined,
    "birthDate": p.birth_year ? String(p.birth_year) : undefined,
    "height": p.height ? { "@type": "QuantitativeValue", "value": p.height, "unitCode": "CMT" } : undefined,
    "jobTitle": "Professional Footballer",
    "description": (p.role ?? '') + ' · ' + (p.nation ?? '') + ' · ' + (p.iconic_club ?? '') + '. Overall rating ' + p.overall_rating + '/99 on Legends Database.',
    "sameAs": ["https://legendsdatabase.com/player/" + p.slug]
  })}></script>
</head>

<body>
<Navbar/>
<div class="page">

  <a href="/" class="back">← Database</a>

  <!-- ─── HERO ─── -->
  <div class="hero">
    <div class="hero-top">
      {hasGradientBorder ? (
        <div class="avatar-ring" style={`background:conic-gradient(${gradientStops});border-radius:50%;`}>
          <div class="avatar">{initials}</div>
        </div>
      ) : hasSolidBorder ? (
        <div class="avatar-ring" style={`background:${solidColor};`}>
          <div class="avatar">{initials}</div>
        </div>
      ) : (
        <div class="avatar-ring" style="background:#e8e8ed;">
          <div class="avatar">{initials}</div>
        </div>
      )}

      <div class="hero-info">
        <div class="hero-name">{p.name}</div>
        <div class="hero-tags">
          <a href={tagRoleUrl} class="tag" style={`background:${rc.bg};color:${rc.text};`}>{fullRoleName}</a>
          <a href={tagNatUrl}  class="tag" style="background:#f5f5f7;color:#6e6e73;">{p.nation}</a>
          <a href={tagClubUrl} class="tag" style="background:#f5f5f7;color:#6e6e73;">{p.iconic_club}</a>
          <a href={tagDecadeUrl} class="tag" style="background:#f5f5f7;color:#6e6e73;">{p.decade}s</a>
        </div>
      </div>

      <div class="ovr-col">
        <div class="ovr-badge" style={`color:${ovrColor(p.overall_rating)};`}>{p.overall_rating}</div>
        <div class="ovr-label">Overall</div>
        <button class="compare-btn" id="openCompare">&#x21C4; Compare</button>
      </div>
    </div>

    <div class="bio-grid">
      <div class="bio-item"><span class="bio-label">Born</span><span class="bio-value">{p.birth_year}</span></div>
      <div class="bio-item"><span class="bio-label">Height</span><span class="bio-value">{p.height} cm</span></div>
      <div class="bio-item"><span class="bio-label">Weight</span><span class="bio-value">{p.weight} kg</span></div>
      <div class="bio-item"><span class="bio-label">Foot</span><span class="bio-value">{p.preferred_foot}</span></div>
    </div>
  </div>

  <!-- ─── TEAMS STRIP ─── -->
  {(playerTeams.length>0||playerDecades.length>0||playerContinents.length>0) && (
    <div class="teams-strip">
      <span class="teams-strip-label">All-Time</span>
      {playerTeams.map(t=>(
        <a href={`/team/${t.slug}`} class="team-chip">
          <img src={`/teams/${t.slug}.svg`} class="team-chip-logo" alt={t.displayName} onerror="this.style.display='none'"/>
          <span class="team-chip-text">{t.displayName}</span>
          <span class={`team-chip-badge ${t.isNational?'badge-nat':'badge-club'}`}>{t.isNational?'NT':'Club'}</span>
        </a>
      ))}
      {playerDecades.map(d=>(
        <a href={d.href} class="team-chip">
          <span class="team-chip-text">{d.displayName}</span>
          <span class="team-chip-badge badge-decade">{d.badge}</span>
        </a>
      ))}
      {playerContinents.map(c=>(
        <a href={c.href} class="team-chip">
          <span class="team-chip-text">{c.displayName}</span>
          <span class="team-chip-badge badge-continent">{c.badge}</span>
        </a>
      ))}
    </div>
  )}

  <!-- ─── STATS ROW ─── -->
  <div class="stats-row">
    <div class="stat-card"><div class="sv">{p.club_apps}</div><div class="sl">Club Apps</div></div>
    <div class="stat-card"><div class="sv">{p.club_goals}</div><div class="sl">Club Goals</div></div>
    <div class="stat-card"><div class="sv">{p.club_goal_ratio}</div><div class="sl">Club Ratio</div></div>
    <div class="stat-card"><div class="sv">{p.nat_apps}</div><div class="sl">Nat Apps</div></div>
    <div class="stat-card"><div class="sv">{p.nat_goals}</div><div class="sl">Nat Goals</div></div>
    <div class="stat-card"><div class="sv">{p.nat_goal_ratio}</div><div class="sl">Nat Ratio</div></div>
  </div>

  <!-- ─── VIZ ROW: heatmap (desktop) + radar ─── -->
  <div class="viz-row">

    <!-- HEATMAP (hidden on mobile via CSS) -->
    <div class="heatmap-card">
      <div class="viz-header">
        <span class="viz-title">Positional Heatmap</span>
        <span class="viz-note">Illustrative · role &amp; skills data</span>
      </div>
      <svg class="heatmap-svg" viewBox="0 0 105 68" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <linearGradient id="pitchG" x1="0" y1="0" x2="1" y2="0">
            <stop offset="0%"   stop-color="#185c2e"/>
            <stop offset="50%"  stop-color="#1e6e36"/>
            <stop offset="100%" stop-color="#185c2e"/>
          </linearGradient>
          <radialGradient id="hmMain" cx="50%" cy="50%" r="50%">
            <stop offset="0%"   stop-color="#ff0000" stop-opacity="1"/>
            <stop offset="18%"  stop-color="#ff3300" stop-opacity="1"/>
            <stop offset="38%"  stop-color="#ff7700" stop-opacity="0.95"/>
            <stop offset="58%"  stop-color="#ffbb00" stop-opacity="0.78"/>
            <stop offset="78%"  stop-color="#ffee00" stop-opacity="0.40"/>
            <stop offset="100%" stop-color="#ffff55" stop-opacity="0"/>
          </radialGradient>
          <radialGradient id="hmAlt" cx="50%" cy="50%" r="50%">
            <stop offset="0%"   stop-color="#ff5500" stop-opacity="0.85"/>
            <stop offset="42%"  stop-color="#ffaa00" stop-opacity="0.55"/>
            <stop offset="78%"  stop-color="#ffdd00" stop-opacity="0.22"/>
            <stop offset="100%" stop-color="#ffee88" stop-opacity="0"/>
          </radialGradient>
          {heatBlobs.map((b,i)=>(
            <filter id={`hf${i}`} x="-80%" y="-80%" width="260%" height="260%">
              <feGaussianBlur stdDeviation={b.blur * 0.22}/>
            </filter>
          ))}
        </defs>
        <rect width="105" height="68" fill="url(#pitchG)"/>
        <rect x="0"  y="0" width="21" height="68" fill="#164f28" opacity="0.4"/>
        <rect x="42" y="0" width="21" height="68" fill="#164f28" opacity="0.4"/>
        <rect x="84" y="0" width="21" height="68" fill="#164f28" opacity="0.4"/>
        <rect x="2" y="2" width="101" height="64" fill="none" stroke="rgba(255,255,255,0.28)" stroke-width="0.35"/>
        <line x1="52.5" y1="2" x2="52.5" y2="66" stroke="rgba(255,255,255,0.28)" stroke-width="0.32"/>
        <circle cx="52.5" cy="34" r="9.15" fill="none" stroke="rgba(255,255,255,0.22)" stroke-width="0.3"/>
        <circle cx="52.5" cy="34" r="0.55" fill="rgba(255,255,255,0.45)"/>
        <rect x="2"    y="13.84" width="16.5"  height="40.32" fill="none" stroke="rgba(255,255,255,0.18)" stroke-width="0.3"/>
        <rect x="2"    y="24.84" width="5.5"   height="18.32" fill="none" stroke="rgba(255,255,255,0.14)" stroke-width="0.3"/>
        <rect x="86.5" y="13.84" width="16.5"  height="40.32" fill="none" stroke="rgba(255,255,255,0.18)" stroke-width="0.3"/>
        <rect x="97.5" y="24.84" width="5.5"   height="18.32" fill="none" stroke="rgba(255,255,255,0.14)" stroke-width="0.3"/>
        {[...heatBlobs].reverse().map((b,i)=>{
          const ri=heatBlobs.length-1-i;
          const isMain=ri===0;
          const svgX=(b.cy/100)*105;
          const svgY=(b.cx/100)*68;
          const svgRx=b.ry*1.05;
          const svgRy=b.rx*0.68;
          return(
            <ellipse
              cx={svgX} cy={svgY}
              rx={svgRx} ry={svgRy}
              fill={isMain?'url(#hmMain)':'url(#hmAlt)'}
              opacity={b.opacity}
              filter={`url(#hf${ri})`}
            />
          );
        })}
        <text x="103" y="66" text-anchor="end"
          font-family="-apple-system,'SF Pro Text',sans-serif"
          font-size="3.2" font-weight="700"
          fill="rgba(255,255,255,0.5)" letter-spacing="0.05em">
          {p.role}{altList.length>0?` · ${altList.slice(0,2).join(' · ')}`:''}
        </text>
      </svg>
    </div>

    <!-- RADAR -->
    <div class="radar-card">
      <div class="viz-header">
        <span class="viz-title">Skill Radar</span>
        <span class="viz-note">{isGK?'GK profile':'Weighted by role'}</span>
      </div>
      <div class="radar-svg-wrap">
        <svg class="radar-svg" viewBox="0 0 220 210" xmlns="http://www.w3.org/2000/svg">
          <defs>
            <radialGradient id="radarFill" cx="50%" cy="50%" r="50%">
              <stop offset="0%"   stop-color={ovrColor(p.overall_rating)} stop-opacity="0.18"/>
              <stop offset="100%" stop-color={ovrColor(p.overall_rating)} stop-opacity="0.06"/>
            </radialGradient>
          </defs>
          {gridLevels.map(level=>(
            <polygon
              points={Array.from({length:N_AXES},(_,i)=>{const g=radarGrid(i,RADAR_R*level);return`${g.x},${g.y}`;}).join(' ')}
              fill="none"
              stroke="#e5e5ea"
              stroke-width={level===1.0?"0.8":"0.5"}
            />
          ))}
          {radarAxes.map((_,i)=>{
            const outer=radarGrid(i,RADAR_R);
            return <line x1={RADAR_CX} y1={RADAR_CY} x2={outer.x} y2={outer.y} stroke="#e5e5ea" stroke-width="0.5"/>;
          })}
          <polygon
            points={radarShape}
            fill="url(#radarFill)"
            stroke={ovrColor(p.overall_rating)}
            stroke-width="1.8"
            stroke-linejoin="round"
          />
          {radarLabelData.map(d=>(
            <circle cx={d.ptx} cy={d.pty} r="2.5" fill={ovrColor(p.overall_rating)} stroke="#ffffff" stroke-width="1.2"/>
          ))}
          {radarLabelData.map(d=>(
            <text x={d.lx} y={d.ly+1} text-anchor={d.anchor} dominant-baseline="middle" font-family="-apple-system,'SF Pro Text',sans-serif" font-size="8.5" font-weight="700" fill="#6e6e73" letter-spacing="0.04em">{d.label}</text>
          ))}
          {radarLabelData.map(d=>(
            <text x={d.lx} y={d.ly+10} text-anchor={d.anchor} dominant-baseline="middle" font-family="-apple-system,'SF Pro Text',sans-serif" font-size="8" font-weight="700" fill={d.color}>{d.value}</text>
          ))}
          <text x={RADAR_CX} y={RADAR_CY-4}
            text-anchor="middle" dominant-baseline="middle"
            font-family="-apple-system,'SF Pro Text',sans-serif"
            font-size="18" font-weight="800" letter-spacing="-0.5"
            fill={ovrColor(p.overall_rating)}
          >{p.overall_rating}</text>
          <text x={RADAR_CX} y={RADAR_CY+11}
            text-anchor="middle" dominant-baseline="middle"
            font-family="-apple-system,'SF Pro Text',sans-serif"
            font-size="6.5" font-weight="700" letter-spacing="0.08em"
            fill="#aeaeb2"
          >OVERALL</text>
        </svg>
      </div>
    </div>

  </div>

  <!-- ─── GAUGES OUTFIELD ─── -->
  {!isGK && (
    <div class="gauge-section">
      <div class="gauge-item">
        <svg viewBox="0 0 120 66" xmlns="http://www.w3.org/2000/svg">
          <circle cx="60" cy="62" r={GAUGE_R} fill="none" stroke="#f0f0f5" stroke-width="9" stroke-dasharray={`${HALF_CIRC} ${FULL_CIRC}`} transform="rotate(180 60 62)"/>
          <circle cx="60" cy="62" r={GAUGE_R} fill="none" stroke={skillColor(attAvg)} stroke-width="9" stroke-dasharray={gaugeDash(attAvg)} transform="rotate(180 60 62)" stroke-linecap="round"/>
          <text x="60" y="57" text-anchor="middle" font-size="22" font-weight="700" fill="#1d1d1f" font-family="-apple-system,'SF Pro Text',sans-serif">{attAvg}</text>
        </svg>
        <div class="gauge-label">Att. Skills</div>
      </div>
      <div class="gauge-item">
        <svg viewBox="0 0 120 66" xmlns="http://www.w3.org/2000/svg">
          <circle cx="60" cy="62" r={GAUGE_R} fill="none" stroke="#f0f0f5" stroke-width="9" stroke-dasharray={`${HALF_CIRC} ${FULL_CIRC}`} transform="rotate(180 60 62)"/>
          <circle cx="60" cy="62" r={GAUGE_R} fill="none" stroke={skillColor(playmakingAvg)} stroke-width="9" stroke-dasharray={gaugeDash(playmakingAvg)} transform="rotate(180 60 62)" stroke-linecap="round"/>
          <text x="60" y="57" text-anchor="middle" font-size="22" font-weight="700" fill="#1d1d1f" font-family="-apple-system,'SF Pro Text',sans-serif">{playmakingAvg}</text>
        </svg>
        <div class="gauge-label">Playmaking</div>
      </div>
      <div class="gauge-item">
        <svg viewBox="0 0 120 66" xmlns="http://www.w3.org/2000/svg">
          <circle cx="60" cy="62" r={GAUGE_R} fill="none" stroke="#f0f0f5" stroke-width="9" stroke-dasharray={`${HALF_CIRC} ${FULL_CIRC}`} transform="rotate(180 60 62)"/>
          <circle cx="60" cy="62" r={GAUGE_R} fill="none" stroke={skillColor(defAvg)} stroke-width="9" stroke-dasharray={gaugeDash(defAvg)} transform="rotate(180 60 62)" stroke-linecap="round"/>
          <text x="60" y="57" text-anchor="middle" font-size="22" font-weight="700" fill="#1d1d1f" font-family="-apple-system,'SF Pro Text',sans-serif">{defAvg}</text>
        </svg>
        <div class="gauge-label">Def. Skills</div>
      </div>
    </div>
  )}

  <!-- ─── GAUGES GK ─── -->
  {isGK && (
    <div class="gk-gauge-section">
      <div class="gk-gauge-item">
        <svg viewBox="0 0 120 66" xmlns="http://www.w3.org/2000/svg">
          <circle cx="60" cy="62" r={GAUGE_R} fill="none" stroke="#f0f0f5" stroke-width="9" stroke-dasharray={`${HALF_CIRC} ${FULL_CIRC}`} transform="rotate(180 60 62)"/>
          <circle cx="60" cy="62" r={GAUGE_R} fill="none" stroke={skillColor(gkSkillsAvg)} stroke-width="9" stroke-dasharray={gaugeDash(gkSkillsAvg)} transform="rotate(180 60 62)" stroke-linecap="round"/>
          <text x="60" y="57" text-anchor="middle" font-size="22" font-weight="700" fill="#1d1d1f" font-family="-apple-system,'SF Pro Text',sans-serif">{gkSkillsAvg}</text>
        </svg>
        <div class="gk-gauge-label">GK Skills</div>
      </div>
      <div class="gk-spectrum-item">
        <div class="gk-type-label" style={`color:${gkTypeColor};`}>{gkType}</div>
        <div class="gk-type-desc">{gkTypeDesc}</div>
        <div class="gk-spectrum-track">
          <div class="gk-spectrum-dot" style={`left:${gkSpectrum}%;background:${gkTypeColor};`}></div>
        </div>
        <div class="gk-spectrum-ends">
          <span class="gk-spectrum-end" style="color:#c0392b;">Reactive</span>
          <span class="gk-spectrum-end" style="color:#0071e3;">Cold</span>
        </div>
        <div class="gk-scores-row">
          <div class="gk-score-item">
            <div class="gk-score-val" style="color:#c0392b;">{reactiveScore}</div>
            <div class="gk-score-sub">REF+AGI</div>
          </div>
          <div class="gk-score-item">
            <div class="gk-score-val" style="color:#0071e3;">{coldScore}</div>
            <div class="gk-score-sub">COM+POS</div>
          </div>
        </div>
      </div>
      <div class="gk-gauge-item">
        <svg viewBox="0 0 120 66" xmlns="http://www.w3.org/2000/svg">
          <circle cx="60" cy="62" r={GAUGE_R} fill="none" stroke="#f0f0f5" stroke-width="9" stroke-dasharray={`${HALF_CIRC} ${FULL_CIRC}`} transform="rotate(180 60 62)"/>
          <circle cx="60" cy="62" r={GAUGE_R} fill="none" stroke={skillColor(gkTechAvg)} stroke-width="9" stroke-dasharray={gaugeDash(gkTechAvg)} transform="rotate(180 60 62)" stroke-linecap="round"/>
          <text x="60" y="57" text-anchor="middle" font-size="22" font-weight="700" fill="#1d1d1f" font-family="-apple-system,'SF Pro Text',sans-serif">{gkTechAvg}</text>
        </svg>
        <div class="gk-gauge-label">Tech. Skills</div>
      </div>
    </div>
  )}

  <!-- ─── SKILLS GRID ─── -->
  <div class="skills-grid">
    <div class="skill-card">
      <div class="skill-cat" style="display:flex;justify-content:space-between;align-items:center;">
        <span>Athletic</span>
        <span style={`font-weight:600;font-size:13px;color:${skillColor(athleticAvg)};`}>{athleticAvg}</span>
      </div>
      {athleticSkills.map(s=>(
        <div class="skill-row">
          <span class="skill-abbr" title={s.full}>{s.label}</span>
          <div class="skill-bar-wrap"><div class="skill-bar-fill" style={`width:${p[s.key]}%;background:${skillColor(p[s.key])};`}></div></div>
          <span class="skill-val">{p[s.key]}</span>
        </div>
      ))}
    </div>
    <div class="skill-card">
      <div class="skill-cat" style="display:flex;justify-content:space-between;align-items:center;">
        <span>Technical</span>
        <span style={`font-weight:600;font-size:13px;color:${skillColor(technicalAvg)};`}>{technicalAvg}</span>
      </div>
      {technicalSkills.map(s=>(
        <div class="skill-row">
          <span class="skill-abbr" title={s.full}>{s.label}</span>
          <div class="skill-bar-wrap"><div class="skill-bar-fill" style={`width:${p[s.key]}%;background:${skillColor(p[s.key])};`}></div></div>
          <span class="skill-val">{p[s.key]}</span>
        </div>
      ))}
    </div>
    <div class="skill-card">
      <div class="skill-cat" style="display:flex;justify-content:space-between;align-items:center;">
        <span>Mental</span>
        <span style={`font-weight:600;font-size:13px;color:${skillColor(mentalAvg)};`}>{mentalAvg}</span>
      </div>
      {mentalSkills.map(s=>(
        <div class="skill-row">
          <span class="skill-abbr" title={s.full}>{s.label}</span>
          <div class="skill-bar-wrap"><div class="skill-bar-fill" style={`width:${p[s.key]}%;background:${skillColor(p[s.key])};`}></div></div>
          <span class="skill-val">{p[s.key]}</span>
        </div>
      ))}
    </div>
    <div class="skill-card">
      <div class="skill-cat" style="display:flex;justify-content:space-between;align-items:center;">
        <span>Tactical</span>
        <span style={`font-weight:600;font-size:13px;color:${skillColor(tacticalAvg)};`}>{tacticalAvg}</span>
      </div>
      {tacticalSkills.map(s=>(
        <div class="skill-row">
          <span class="skill-abbr" title={s.full}>{s.label}</span>
          <div class="skill-bar-wrap"><div class="skill-bar-fill" style={`width:${p[s.key]}%;background:${skillColor(p[s.key])};`}></div></div>
          <span class="skill-val">{p[s.key]}</span>
        </div>
      ))}
    </div>
    {isGK && (
      <div class="skill-card full-width">
        <div class="skill-cat" style="display:flex;justify-content:space-between;align-items:center;">
          <span>Goalkeeping</span>
          <span style={`font-weight:600;font-size:13px;color:${skillColor(gkAvg)};`}>{gkAvg}</span>
        </div>
        {gkSkills.map(s=>(
          <div class="skill-row">
            <span class="skill-abbr" title={s.full}>{s.label}</span>
            <div class="skill-bar-wrap"><div class="skill-bar-fill" style={`width:${p[s.key]}%;background:${skillColor(p[s.key])};`}></div></div>
            <span class="skill-val">{p[s.key]}</span>
          </div>
        ))}
      </div>
    )}
  </div>

  <!-- ─── TRAITS ─── -->
  {!isGK && activeTraits.length>0 && (
    <div class="traits-section">
      <div class="traits-title">Player Traits</div>
      <div class="traits-grid">
        {activeTraits.map(t=>(
          <div class="trait-icon" data-tip={t.tooltip} title={t.tooltip}>
            <img src={t.file} alt={t.tooltip}/>
          </div>
        ))}
      </div>
    </div>
  )}

  <!-- ─── SEE ALSO ─── -->
  {related.length>0 && (
    <div class="see-also">
      <div class="see-also-label">See also</div>
      <div class="see-also-grid">
        {related.map(q=>{
          const qi=q.name.split(',').map(s=>s.trim()[0]).join('').toUpperCase().slice(0,2);
          const qr=roleColor(q.role);
          return(
            <a href={`/player/${q.slug}`} class="see-also-card">
              <div class="sa-avatar">{qi}</div>
              <div class="sa-body">
                <div class="sa-name">{q.name}</div>
                <div class="sa-meta">
                  <span class="sa-role" style={`background:${qr.bg};color:${qr.text};`}>{q.role}</span>
                  <span class="sa-ovr" style={`color:${ovrColor(q.overall_rating)};`}>{q.overall_rating}</span>
                </div>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  )}

</div>

<!-- ─── COMPARE MODAL ─── -->
<div class="cmp-overlay" id="cmpOverlay">
  <div class="cmp-sheet">
    <div class="cmp-handle"></div>
    <div class="cmp-header">
      <div style="display:flex;align-items:center;gap:10px;">
        <button class="cmp-back-btn" id="cmpBack" style="display:none;">&#8592; back</button>
        <span class="cmp-title" id="cmpTitleText">Compare with</span>
      </div>
      <button class="cmp-close" id="cmpClose">&#x2715;</button>
    </div>
    <div class="cmp-search-phase" id="cmpSearchPhase">
      <div class="cmp-search-wrap">
        <input class="cmp-search-input" id="cmpSearch" type="text" placeholder="Search by name…" autocomplete="off"/>
      </div>
      <div class="cmp-search-hint" id="cmpHint"></div>
      <div class="cmp-list" id="cmpList"></div>
    </div>
    <div class="cmp-compare-phase" id="cmpComparePhase">
      <div id="cmpPlayersHeader" class="cmp-players-header"></div>
      <div id="cmpScoreBar" class="cmp-score-bar"></div>
      <div id="cmpSkillsScroll" class="cmp-skills-scroll"></div>
    </div>
  </div>
</div>

<script define:vars={{ currentPlayerData, comparePool, playerMacro }}>
function ovrColor(v){if(v>=95)return'#0071e3';if(v>=90)return'#1a5e1a';if(v>=80)return'#2e8b2e';if(v>=70)return'#6aaa2a';if(v>=60)return'#c8a800';if(v>=50)return'#e07800';if(v>=40)return'#cc4400';return'#c0392b';}
function skillColor(v){if(v>=95)return'#5aabff';if(v>=90)return'#1a5e1a';if(v>=80)return'#2e8b2e';if(v>=70)return'#6aaa2a';if(v>=60)return'#c8a800';if(v>=40)return'#e07800';return'#c0392b';}
function rcFor(role){const att=['ST','FW','RW','LW'],mid=['AM','CM','DM','RM','LM'],def=['CB','SW','RB','LB'];if(att.includes(role))return{bg:'#fff0ee',text:'#c0392b'};if(mid.includes(role))return{bg:'#eef4ff',text:'#0071e3'};if(def.includes(role))return{bg:'#eeffee',text:'#1a7a1a'};return{bg:'#f5f0e8',text:'#b07800'};}
function inits(name){return(name||'').split(',').map(s=>s.trim()[0]).join('').toUpperCase().slice(0,2);}
const SKILL_SECTIONS=[
  {label:'Athletic',skills:[{key:'acceleration',label:'ACC'},{key:'pace',label:'PAC'},{key:'agility',label:'AGI'},{key:'strength',label:'STR'},{key:'balance',label:'BAL'},{key:'jumping',label:'JMP'},{key:'stamina',label:'STA'},{key:'fitness',label:'FIT'}]},
  {label:'Technical',skills:[{key:'dribbling',label:'DRI'},{key:'short_passing',label:'S-PAS'},{key:'long_passing',label:'L-PAS'},{key:'finishing',label:'FIN'},{key:'shot_accuracy',label:'SHO-A'},{key:'shot_power',label:'SHO-P'},{key:'heading',label:'HEA'},{key:'tackling',label:'TAC'},{key:'free_kick',label:'FRK'},{key:'penalties',label:'PEN'},{key:'first-touch',label:'1-TCH'}]},
  {label:'Mental',skills:[{key:'composure',label:'COM'},{key:'aggression',label:'AGG'},{key:'consistency',label:'CON'},{key:'creativity',label:'CREA'},{key:'work_rate',label:'WRT'}]},
  {label:'Tactical',skills:[{key:'vision',label:'VIS'},{key:'off_the_ball',label:'OFB'},{key:'def_positioning',label:'DEF'},{key:'teamwork',label:'TMW'},{key:'anticipation',label:'ANT'},{key:'marking',label:'MAR'}]},
  {label:'Goalkeeping',skills:[{key:'reflexes',label:'REF'},{key:'positioning',label:'POS'},{key:'handling',label:'HAN'},{key:'kicking',label:'KIC'}]},
];
const overlay=document.getElementById('cmpOverlay');
const searchPhase=document.getElementById('cmpSearchPhase');
const comparePhase=document.getElementById('cmpComparePhase');
const searchInput=document.getElementById('cmpSearch');
const listEl=document.getElementById('cmpList');
const hintEl=document.getElementById('cmpHint');
const backBtn=document.getElementById('cmpBack');
const titleText=document.getElementById('cmpTitleText');
const playersHeader=document.getElementById('cmpPlayersHeader');
const scoreBar=document.getElementById('cmpScoreBar');
const skillsScroll=document.getElementById('cmpSkillsScroll');
document.getElementById('openCompare').addEventListener('click',()=>{overlay.classList.add('open');resetToSearch();searchInput.focus();});
document.getElementById('cmpClose').addEventListener('click',closeModal);
overlay.addEventListener('click',e=>{if(e.target===overlay)closeModal();});
document.addEventListener('keydown',e=>{if(e.key==='Escape')closeModal();});
function closeModal(){overlay.classList.remove('open');searchInput.value='';}
function resetToSearch(){
  searchPhase.style.display='flex';comparePhase.classList.remove('active');
  backBtn.style.display='none';titleText.textContent='Compare with';
  hintEl.textContent=`${comparePool.length} players in this area`;
  renderList('');searchInput.value='';
}
backBtn.addEventListener('click',resetToSearch);
function renderList(query){
  const q=query.toLowerCase().trim();
  const filtered=q?comparePool.filter(pl=>pl.name.toLowerCase().includes(q)):comparePool.slice(0,30);
  listEl.innerHTML='';
  if(!filtered.length){listEl.innerHTML='<div style="padding:20px;text-align:center;color:#aeaeb2;font-size:13px;">No players found</div>';return;}
  filtered.forEach(pl=>{
    const rc=rcFor(pl.role);
    const row=document.createElement('div');row.className='cmp-player-row';
    row.innerHTML=`<div class="cmp-p-init">${inits(pl.name)}</div><span class="cmp-p-name">${pl.name}</span><span class="cmp-p-role" style="background:${rc.bg};color:${rc.text};">${pl.role}</span><span class="cmp-p-ovr" style="color:${ovrColor(pl.overall_rating??0)};">${pl.overall_rating??'—'}</span>`;
    row.addEventListener('click',()=>showComparison(pl));
    listEl.appendChild(row);
  });
}
searchInput.addEventListener('input',e=>renderList(e.target.value));
function showComparison(p2){
  const p1=currentPlayerData;
  searchPhase.style.display='none';comparePhase.classList.add('active');
  backBtn.style.display='flex';titleText.textContent='Comparison';
  const rc1=rcFor(p1.role),rc2=rcFor(p2.role);
  playersHeader.innerHTML=`<div class="cmp-ph-player"><div class="cmp-ph-name">${p1.name}</div><span class="cmp-ph-role-badge" style="background:${rc1.bg};color:${rc1.text};">${p1.role}</span><div class="cmp-ph-ovr" style="color:${ovrColor(p1.overall_rating??0)};">${p1.overall_rating??'—'}</div></div><div class="cmp-vs">VS</div><div class="cmp-ph-player"><div class="cmp-ph-name">${p2.name}</div><span class="cmp-ph-role-badge" style="background:${rc2.bg};color:${rc2.text};">${p2.role}</span><div class="cmp-ph-ovr" style="color:${ovrColor(p2.overall_rating??0)};">${p2.overall_rating??'—'}</div></div>`;
  let w1=0,w2=0,draws=0;
  SKILL_SECTIONS.forEach(sec=>sec.skills.forEach(sk=>{const v1=p1[sk.key]??0,v2=p2[sk.key]??0;if(v1>v2)w1++;else if(v2>v1)w2++;else draws++;}));
  scoreBar.innerHTML=`<span class="cmp-score-num" style="color:${w1>w2?'#1a7a1a':w2>w1?'#c0392b':'#6e6e73'};">${w1}</span><span class="cmp-score-label">wins</span><span class="cmp-score-sep">·</span><span class="cmp-score-num" style="color:#6e6e73;">${draws}</span><span class="cmp-score-label">draws</span><span class="cmp-score-sep">·</span><span class="cmp-score-num" style="color:${w2>w1?'#1a7a1a':w1>w2?'#c0392b':'#6e6e73'};">${w2}</span><span class="cmp-score-label">wins</span>`;
  skillsScroll.innerHTML='';
  SKILL_SECTIONS.forEach(sec=>{
    const hasData=sec.skills.some(sk=>p1[sk.key]!=null||p2[sk.key]!=null);
    if(!hasData)return;
    const titleEl=document.createElement('div');titleEl.className='cmp-section-title';titleEl.textContent=sec.label;skillsScroll.appendChild(titleEl);
    sec.skills.forEach(sk=>{
      const v1=p1[sk.key]??0,v2=p2[sk.key]??0;
      if(p1[sk.key]==null&&p2[sk.key]==null)return;
      const c1=v1>v2?'#1a7a1a':v1<v2?'#c0392b':'#6e6e73';
      const c2=v2>v1?'#1a7a1a':v2<v1?'#c0392b':'#6e6e73';
      const row=document.createElement('div');
      row.style.cssText='display:grid;grid-template-columns:1fr 44px 1fr;align-items:center;gap:6px;margin-bottom:7px;';
      row.innerHTML=`<div style="display:flex;align-items:center;justify-content:flex-end;gap:6px;"><span style="font-size:11px;font-weight:700;color:${c1};font-variant-numeric:tabular-nums;min-width:22px;text-align:right;">${v1||'—'}</span><div style="width:${v1}px;max-width:90px;min-width:2px;height:5px;border-radius:3px;background:${skillColor(v1)};"></div></div><span style="font-size:9px;font-weight:700;color:#6e6e73;text-align:center;text-transform:uppercase;letter-spacing:0.03em;">${sk.label}</span><div style="display:flex;align-items:center;gap:6px;"><div style="width:${v2}px;max-width:90px;min-width:2px;height:5px;border-radius:3px;background:${skillColor(v2)};"></div><span style="font-size:11px;font-weight:700;color:${c2};font-variant-numeric:tabular-nums;min-width:22px;">${v2||'—'}</span></div>`;
      skillsScroll.appendChild(row);
    });
  });
}
renderList('');
</script>

<Footer/>
</body>
</html>
