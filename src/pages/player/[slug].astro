function getAvatarBorder(nation: string): string {
  const colors = NATION_COLORS[nation];
  if (!colors) return 'border: 3px solid #e8e8ed;';
  if (colors.length === 1) return `border: 3px solid ${colors[0]};`;
  const stops = colors.map((c, i) => `${c} ${Math.round((i / (colors.length - 1)) * 100)}%`).join(', ');
  return `background: conic-gradient(${stops}); padding: 3px;`;
}

const avatarBorderStyle = getAvatarBorder(p.nation);
const useGradientBorder = (NATION_COLORS[p.nation] ?? []).length >= 2;

function ovrColor(v) {
  if (v >= 95) return '#0071e3';
  if (v >= 90) return '#1a5e1a';
  if (v >= 80) return '#2e8b2e';
  if (v >= 70) return '#6aaa2a';
  if (v >= 60) return '#c8a800';
  if (v >= 50) return '#e07800';
  if (v >= 40) return '#cc4400';
  return '#c0392b';
}

function skillColor(v) {
  if (v >= 95) return '#5aabff';
  if (v >= 90) return '#1a5e1a';
  if (v >= 80) return '#2e8b2e';
  if (v >= 70) return '#6aaa2a';
  if (v >= 60) return '#c8a800';
  if (v >= 40) return '#e07800';
  return '#c0392b';
}

function avg(arr) {
  const valid = arr.filter(v => typeof v === 'number' && !isNaN(v));
  if (valid.length === 0) return 0;
  return Math.round(valid.reduce((a, b) => a + b, 0) / valid.length);
}

function roleColor(role) {
  const att = ['ST','FW','RW','LW'];
  const mid = ['AM','CM','DM','RM','LM'];
  const def = ['CB','SW','RB','LB'];
  if (att.includes(role)) return { bg: '#fff0ee', text: '#c0392b' };
  if (mid.includes(role)) return { bg: '#eef4ff', text: '#0071e3' };
  if (def.includes(role)) return { bg: '#eeffee', text: '#1a7a1a' };
  return { bg: '#f5f0e8', text: '#b07800' };
}

const rc = roleColor(p.role);
const initials = p.name.split(',').map(s => s.trim()[0]).join('').toUpperCase().slice(0, 2);

const athleticSkills = [
