function ovrColor(v) {
  if(v>=95)return'#0071e3';if(v>=90)return'#1a5e1a';if(v>=80)return'#2e8b2e';
  if(v>=70)return'#6aaa2a';if(v>=60)return'#c8a800';if(v>=50)return'#e07800';
  if(v>=40)return'#cc4400';return'#c0392b';
}
function skillColor(v) {
  if(v>=95)return'#5aabff';if(v>=90)return'#1a5e1a';if(v>=80)return'#2e8b2e';
  if(v>=70)return'#6aaa2a';if(v>=60)return'#c8a800';if(v>=40)return'#e07800';
  return'#c0392b';
}
function avg(vals) {
  const v=vals.filter(x=>x!=null&&!isNaN(Number(x)));
  return v.length?Math.round(v.reduce((a,b)=>a+Number(b),0)/v.length):0;
}
function weightedAvg(values,weights) {
  let sum=0,totalW=0;
  for(let i=0;i<values.length;i++){
    const v=Number(values[i]),w=weights[i]??0;
    if(!isNaN(v)&&values[i]!=null&&w>0){sum+=v*w;totalW+=w;}
  }
  return totalW>0?Math.round(sum/totalW):0;
}

