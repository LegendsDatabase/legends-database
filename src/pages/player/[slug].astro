const paceVal=avg([p.pace??70,p.acceleration??70]);
let primaryShift=0;
if(isGK){
  const gkTech2=avg([p.kicking??60,p['first-touch']??60]);
  primaryShift=(gkTech2-60)/100*6;
}else{
  const netBias=(offSkill-defSkill)/100;
  const speedBonus=(paceVal-70)/100*3;
  primaryShift=netBias*10+speedBonus;
}
function getBlob(role,shift,opacity){
  const base=ROLE_POS[role]??ROLE_POS['CM'];
  const cy=Math.max(5,Math.min(95,base.y+shift));
  return{cx:base.x,cy,rx:base.sx,ry:base.sy+Math.abs(shift)*0.4,blur:base.sx*0.55,opacity};
}
const mainBlob=getBlob(p.role,primaryShift,1.0);
const altList=(p.alt_roles??'').split(',').map(s=>s.trim()).filter(Boolean);
const altWeights=[0.60,0.38,0.20];
const altBlobs=altList.slice(0,3).map((role,i)=>{
  if(!ROLE_POS[role.trim()])return null;
  return getBlob(role.trim(),primaryShift*0.5,altWeights[i]);
}).filter(Boolean);
const heatBlobs=[mainBlob,...altBlobs];

const radarAxes=isGK
  ? [
      {label:'REF',value:p.reflexes??0},
      {label:'POS',value:p.positioning??0},
      {label:'HAN',value:p.handling??0},
      {label:'TEC',value:gkTechAvg},
      {label:'MEN',value:mentalAvg},
      {label:'ATH',value:athleticAvg},
    ]
  : [
      {label:'ATH',value:athleticAvg},
      {label:'TEC',value:technicalAvg},
      {label:'MEN',value:mentalAvg},
      {label:'TAC',value:tacticalAvg},
      {label:'DEF',value:defAvg},
      {label:'ATT',value:attAvg},
    ];

const RADAR_CX=110,RADAR_CY=105,RADAR_R=72;
const N_AXES=6;
function radarPoint(i,val,maxVal=99){
  const angle=(Math.PI*2/N_AXES)*i-Math.PI/2;
  const r=(val/maxVal)*RADAR_R;
  return{x:RADAR_CX+r*Math.cos(angle),y:RADAR_CY+r*Math.sin(angle)};
}
function radarGrid(i,r){
  const angle=(Math.PI*2/N_AXES)*i-Math.PI/2;
  return{x:RADAR_CX+r*Math.cos(angle),y:RADAR_CY+r*Math.sin(angle)};
}
const radarShape=radarAxes.map((ax,i)=>radarPoint(i,ax.value)).map(pt=>`${pt.x},${pt.y}`).join(' ');
const gridLevels=[0.25,0.5,0.75,1.0];
const radarLabelData=radarAxes.map((ax,i)=>{
  const labelR=RADAR_R+14;
  const angle=(Math.PI*2/N_AXES)*i-Math.PI/2;
  const lx=RADAR_CX+labelR*Math.cos(angle);
  const ly=RADAR_CY+labelR*Math.sin(angle);
  const anchor=lx<RADAR_CX-4?'end':lx>RADAR_CX+4?'start':'middle';
  const pt=radarPoint(i,ax.value);
  return{lx,ly,anchor,label:ax.label,value:ax.value,color:ovrColor(ax.value),ptx:pt.x,pty:pt.y};
});
