import { supabase } from '../../lib/supabase.js';
import Navbar from '../../components/Navbar.astro';

export async function getStaticPaths() {
  const { data: players } = await supabase
    .from('players')
    .select('*');

  return players.map((p) => ({
    params: { slug: p.slug },
    props: { player: p },
  }));
}

const { player: p } = Astro.props;

