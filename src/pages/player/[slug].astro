function sortByOvr(arr){return[...arr].sort((a,b)=>(b.overall_rating??0)-(a.overall_rating??0)||(a.name??'').localeCompare(b.name??''));}
function pickR(pool,n,usedIds){return sortByOvr(pool.filter(q=>!usedIds.has(q.id))).slice(0,n);}
function buildRoster(pool){
  const used=new Set();
  const gkR=pickR(pool.filter(q=>q.role==='GK'),3,used);gkR.forEach(q=>used.add(q.id));
  const rbR=pickR(pool.filter(q=>q.role==='RB'),2,used);rbR.forEach(q=>used.add(q.id));
  const lbR=pickR(pool.filter(q=>q.role==='LB'),2,used);lbR.forEach(q=>used.add(q.id));
  const swA=sortByOvr(pool.filter(q=>q.role==='SW'&&!used.has(q.id)));
  const cbA=sortByOvr(pool.filter(q=>q.role==='CB'&&!used.has(q.id)));
  const swSlot=swA.length?[swA[0]]:[];swSlot.forEach(q=>used.add(q.id));
  const cPool=sortByOvr([...cbA.filter(q=>!used.has(q.id)),...swA.filter(q=>!used.has(q.id))]);
  const cR=[...swSlot,...pickR(cPool,4-swSlot.length,used)];cR.forEach(q=>used.add(q.id));
  const dmR=pickR(pool.filter(q=>q.role==='DM'),2,used);dmR.forEach(q=>used.add(q.id));
  const cmamR=pickR(pool.filter(q=>['CM','AM'].includes(q.role)),4,used);cmamR.forEach(q=>used.add(q.id));
  const rmlmR=pickR(pool.filter(q=>['RM','LM','CM','AM','DM'].includes(q.role)),2,used);rmlmR.forEach(q=>used.add(q.id));
  const stR=pickR(pool.filter(q=>q.role==='ST'),4,used);stR.forEach(q=>used.add(q.id));
  const wingS=pickR(pool.filter(q=>['RW','LW'].includes(q.role)&&!used.has(q.id)),1,used);wingS.forEach(q=>used.add(q.id));
  const attFill=pickR(pool.filter(q=>['ST','FW','RW','LW'].includes(q.role)&&!used.has(q.id)),6-wingS.length,used);attFill.forEach(q=>used.add(q.id));
  return used;
}

const playerTeams=allTeams.filter(t=>{
  const isNat=t.type==='national team'||t.type==='national';
  const inPool=isNat?(p.nation??'').toLowerCase()===(t.name??'').toLowerCase():(p.iconic_club??'').toLowerCase()===(t.name??'').toLowerCase();
  if(!inPool)return false;
  const pool=allPlayers.filter(q=>isNat?(q.nation??'').toLowerCase()===(t.name??'').toLowerCase():(q.iconic_club??'').toLowerCase()===(t.name??'').toLowerCase());
  return buildRoster(pool).has(p.id);
}).map(t=>({slug:t.slug,displayName:t.slug.split('-').map(w=>w.charAt(0).toUpperCase()+w.slice(1)).join(' '),type:t.type,isNational:t.type==='national team'||t.type==='national'}));

const DECADES=[1950,1960,1970,1980,1990,2000,2010];
const playerDecades=DECADES.filter(d=>{
  if(p.decade!==d)return false;
  return buildRoster(allPlayers.filter(q=>q.decade===d)).has(p.id);
}).map(d=>({href:`/best/decade/${d}`,displayName:`All-Time ${d}s`,badge:`${d}s`}));

