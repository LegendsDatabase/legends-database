import { supabase } from '../../lib/supabase.js';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';

const { data: players } = await supabase.from('players').select('*');
const all = (players ?? []).filter(p => p.slug && p.overall_rating != null);

function ovrColor(v){if(v>=95)return'#0071e3';if(v>=90)return'#1a5e1a';if(v>=80)return'#2e8b2e';if(v>=70)return'#6aaa2a';if(v>=60)return'#c8a800';if(v>=50)return'#e07800';if(v>=40)return'#cc4400';return'#c0392b';}
function skillColor(v){if(v>=95)return'#5aabff';if(v>=90)return'#1a5e1a';if(v>=80)return'#2e8b2e';if(v>=70)return'#6aaa2a';if(v>=60)return'#c8a800';if(v>=40)return'#e07800';return'#c0392b';}
function avg(vals){const v=vals.filter(x=>x!=null&&!isNaN(Number(x)));return v.length?Math.round(v.reduce((a,b)=>a+Number(b),0)/v.length):0;}
function sortByOvr(arr){return[...arr].sort((a,b)=>(b.overall_rating??0)-(a.overall_rating??0)||(a.name??'').localeCompare(b.name??''));}
function pick(pool,n,usedIds){return sortByOvr(pool.filter(p=>!usedIds.has(p.id))).slice(0,n);}
function sortBy(arr,fn){return[...arr].sort((a,b)=>fn(b)-fn(a)||(a.name??'').localeCompare(b.name??''));}
function hAvg(arr){const v=arr.map(p=>p.height).filter(Boolean);return v.length?Math.round(v.reduce((a,b)=>a+b,0)/v.length):null;}
function pAtt(p){return avg([p.finishing,p.off_the_ball,p.composure,p.anticipation,p.shot_accuracy]);}
function pPlay(p){return avg([p.short_passing,p.long_passing,p.vision,p.composure]);}
function pDef(p){return avg([p.marking,p.tackling,p.def_positioning,p.anticipation,p.heading,p.composure]);}
function pSpd(p){return avg([p.pace,p.acceleration]);}

// ─── ROSTER ───────────────────────────────────────────────────────────────
const used = new Set();
const gkR = pick(all.filter(p=>p.role==='GK'),3,used); gkR.forEach(p=>used.add(p.id));
const rbR = pick(all.filter(p=>p.role==='RB'),2,used); rbR.forEach(p=>used.add(p.id));
const lbR = pick(all.filter(p=>p.role==='LB'),2,used); lbR.forEach(p=>used.add(p.id));
const swAvail = sortByOvr(all.filter(p=>p.role==='SW'&&!used.has(p.id)));
const cbAvail = sortByOvr(all.filter(p=>p.role==='CB'&&!used.has(p.id)));
const swSlot = swAvail.length?[swAvail[0]]:[];
swSlot.forEach(p=>used.add(p.id));
const centerPool = sortByOvr([...cbAvail.filter(p=>!used.has(p.id)),...swAvail.filter(p=>!used.has(p.id))]);
const centerR = [...swSlot,...pick(centerPool,4-swSlot.length,used)]; centerR.forEach(p=>used.add(p.id));
const defR = [...rbR,...lbR,...centerR];
const dmR = pick(all.filter(p=>p.role==='DM'),2,used); dmR.forEach(p=>used.add(p.id));
const cmamR = pick(all.filter(p=>['CM','AM'].includes(p.role)),4,used); cmamR.forEach(p=>used.add(p.id));
const rmlmR = pick(all.filter(p=>['RM','LM','CM','AM','DM'].includes(p.role)),2,used); rmlmR.forEach(p=>used.add(p.id));
const midR = [...dmR,...cmamR,...rmlmR];
const stR = pick(all.filter(p=>p.role==='ST'),4,used); stR.forEach(p=>used.add(p.id));
const wingS = pick(all.filter(p=>['RW','LW'].includes(p.role)&&!used.has(p.id)),1,used); wingS.forEach(p=>used.add(p.id));
const attFill = pick(all.filter(p=>['ST','FW','RW','LW'].includes(p.role)&&!used.has(p.id)),6-wingS.length,used); attFill.forEach(p=>used.add(p.id));
const attR = [...stR,...wingS,...attFill];
const roster = [...gkR,...defR,...midR,...attR];

const teamOvr = avg(roster.map(p=>p.overall_rating));
const gkOvr   = avg(gkR.map(p=>p.overall_rating));
const defOvr  = avg(defR.map(p=>p.overall_rating));
const midOvr  = avg(midR.map(p=>p.overall_rating));
const attOvr  = avg(attR.map(p=>p.overall_rating));

// ─── TIER 1 AWARDS ────────────────────────────────────────────────────────
const bestPlayer  = sortBy(roster,p=>p.overall_rating??0)[0];
const mostAppsP   = sortBy(roster,p=>p.nat_apps??0)[0];
const mostGoalsP  = sortBy(roster,p=>p.nat_goals??0)[0];
const bestRatioP  = sortBy(roster.filter(p=>(p.nat_apps??0)>=5),p=>parseFloat(p.nat_goal_ratio??0))[0];
const fastestP    = sortBy(roster,p=>pSpd(p))[0];
const strongestP  = sortBy(roster,p=>p.strength??0)[0];
const bestTech    = sortBy(roster,p=>p['first-touch']??0)[0];
const bestHeader  = sortBy(roster,p=>p.heading??0)[0];

// ─── TIER 2 AWARDS ────────────────────────────────────────────────────────
const outfield       = roster.filter(p=>p.role!=='GK');
const mostComposed   = sortBy(roster,p=>p.composure??0)[0];
const mostStamina    = sortBy(roster,p=>p.stamina??0)[0];
const bestShooter    = outfield.length?sortBy(outfield,p=>avg([p.shot_power,p.shot_accuracy]))[0]:null;
const bestPasser     = sortBy(roster,p=>avg([p.short_passing,p.long_passing]))[0];
const bestTeamPlayer = sortBy(roster,p=>p.teamwork??0)[0];
const mostCreative   = outfield.length?sortBy(outfield,p=>p.creativity??0)[0]:null;
const bestDribbler   = outfield.length?sortBy(outfield,p=>p.dribbling??0)[0]:null;
const bestVision     = sortBy(roster,p=>p.vision??0)[0];
const bestAerial     = outfield.length?sortBy(outfield,p=>avg([p.heading,p.jumping]))[0]:null;
const mostConsistent = sortBy(roster,p=>p.consistency??0)[0];
const bestFreekick   = outfield.length?sortBy(outfield,p=>p.free_kick??0)[0]:null;
const bestPenalty    = outfield.length?sortBy(outfield,p=>p.penalties??0)[0]:null;

// Precomputed compound values
const bestSpeedVal   = fastestP?pSpd(fastestP):0;
const bestSpeedSub   = fastestP?`PAC ${fastestP.pace} · ACC ${fastestP.acceleration}`:'';
const bestShooterVal = bestShooter?avg([bestShooter.shot_power,bestShooter.shot_accuracy]):0;
const bestShooterSub = bestShooter?`SHO-P ${bestShooter.shot_power} · SHO-A ${bestShooter.shot_accuracy}`:'';
const bestPasserVal  = bestPasser?avg([bestPasser.short_passing,bestPasser.long_passing]):0;
const bestPasserSub  = bestPasser?`S-PAS ${bestPasser.short_passing} · L-PAS ${bestPasser.long_passing}`:'';
const bestAerialVal  = bestAerial?avg([bestAerial.heading,bestAerial.jumping]):0;
const bestAerialSub  = bestAerial?`HEA ${bestAerial.heading} · JMP ${bestAerial.jumping}`:'';

// ─── PHYSICAL ─────────────────────────────────────────────────────────────
const hGK=hAvg(gkR),hDEF=hAvg(defR),hMID=hAvg(midR),hATT=hAvg(attR),hTOT=hAvg(roster);

// ─── DNA ANALYSIS ─────────────────────────────────────────────────────────
function countBy(arr,fn){
  const counts={};
  arr.forEach(p=>{const k=fn(p);if(k!=null&&k!=='')counts[k]=(counts[k]||0)+1;});
  return Object.entries(counts).sort((a,b)=>b[1]-a[1]);
}
const nationData    = countBy(roster,p=>p.nation).slice(0,8);
const decadeData    = countBy(roster,p=>p.decade?String(p.decade)+'s':null);
const continentData = countBy(roster,p=>p['Continent']);
const leftCount     = roster.filter(p=>p.preferred_foot==='Left').length;
const rightCount    = roster.filter(p=>p.preferred_foot==='Right').length;
const totalFoot     = Math.max(leftCount+rightCount,1);
const leftPct       = Math.round(leftCount/totalFoot*100);
const rightPct      = Math.round(rightCount/totalFoot*100);
const maxNation     = nationData.length?nationData[0][1]:1;
const maxDecade     = decadeData.length?decadeData[0][1]:1;
const maxContinent  = continentData.length?continentData[0][1]:1;

const CONTINENT_COLORS = {'Europe':'#0071e3','South America':'#30d158','Africa':'#ff9f0a','North America':'#ff6b35','Asia':'#bf5af2','Oceania':'#64d2ff'};
const DECADE_COLORS    = {'1950s':'#ff9f0a','1960s':'#ff6b35','1970s':'#30d158','1980s':'#0071e3','1990s':'#bf5af2','2000s':'#ff375f','2010s':'#64d2ff','2020s':'#aeaeb2'};

const rosterData = roster.map(p=>({
  name:p.name??'', slug:p.slug??'', role:p.role??'', alt_roles:p.alt_roles??'',
  section:gkR.some(g=>g.id===p.id)?'GK':defR.some(d=>d.id===p.id)?'DEF':midR.some(m=>m.id===p.id)?'MID':'ATT',
  ovr:p.overall_rating??0, def:pDef(p), play:pPlay(p), att:pAtt(p),
}));
