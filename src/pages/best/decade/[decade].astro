            <th class="col-stat" data-col="def">DEF <span></span></th>
            <th class="col-stat" data-col="play">PLAY <span></span></th>
            <th class="col-stat" data-col="att">ATT <span></span></th>
          </tr></thead>
          <tbody id="rosterBody"></tbody>
        </table>
      </div>

      <div class="highlights-grid">
        {bestPlayer&&<div class="hl-card"><div class="hl-label">Best Player</div><div class="hl-name"><a href={`/player/${bestPlayer.slug}`}>{bestPlayer.name}</a></div><div class="hl-val" style={`color:${ovrColor(bestPlayer.overall_rating)}`}>{bestPlayer.overall_rating}</div></div>}
        {fastestP&&<div class="hl-card"><div class="hl-label">Fastest</div><div class="hl-name"><a href={`/player/${fastestP.slug}`}>{fastestP.name}</a></div><div class="hl-val" style={`color:${skillColor(pSpd(fastestP))}`}>{pSpd(fastestP)} <span class="hl-unit">SPD</span></div></div>}
        {bestTech&&<div class="hl-card"><div class="hl-label">Most Technical</div><div class="hl-name"><a href={`/player/${bestTech.slug}`}>{bestTech.name}</a></div><div class="hl-val" style={`color:${skillColor(bestTech['first-touch']??0)}`}>{bestTech['first-touch']} <span class="hl-unit">1-TCH</span></div></div>}
        {strongestP&&<div class="hl-card"><div class="hl-label">Strongest</div><div class="hl-name"><a href={`/player/${strongestP.slug}`}>{strongestP.name}</a></div><div class="hl-val" style={`color:${skillColor(strongestP.strength??0)}`}>{strongestP.strength} <span class="hl-unit">STR</span></div></div>}
      </div>

      <div class="records-grid">
