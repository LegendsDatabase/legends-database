        <div class="ovr-sub">Overall</div>
      </div>
    </div>

    {roster.length===0&&<div class="card" style="text-align:center;color:#aeaeb2;padding:40px;">No players found for the {decade}s.</div>}

    {roster.length>=11&&(
      <div class="card lineup-card">
