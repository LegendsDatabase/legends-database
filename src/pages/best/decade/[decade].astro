            <circle cx="50" cy="13" r="0.7" fill="rgba(255,255,255,0.35)"/>
            <rect x="25" y="83" width="50" height="15" fill="none" stroke="rgba(255,255,255,0.22)" stroke-width="0.4"/>
            <rect x="37" y="92.5" width="26" height="5.5" fill="none" stroke="rgba(255,255,255,0.22)" stroke-width="0.4"/>
            <circle cx="50" cy="87" r="0.7" fill="rgba(255,255,255,0.35)"/>
          </svg>
