};

function buildLineup(slots, roster) {
  const used = new Set();
  const result = new Array(slots.length).fill(null);
  const order = slots.map((s,i) => [i,s]).sort((a,b) => a[1].roles.length - b[1].roles.length);
  for (const [idx, slot] of order) {
    let best = null, bestOvr = -1, bestIsPrimary = false;
    for (const p of roster) {
      if (used.has(p.slug)) continue;
      if (p.role === 'SW' && !slot.sw) continue;
      const acceptable = slot.sw ? slot.roles : slot.roles.filter(r => r !== 'SW');
      const altList = (p.alt_roles || '').split(',').map(r => r.trim()).filter(Boolean);
      const allRoles = [p.role, ...altList];
      if (allRoles.some(r => acceptable.includes(r))) {
        const isPrimary = acceptable.includes(p.role);
        if ((!bestIsPrimary && isPrimary) || (isPrimary === bestIsPrimary && p.ovr > bestOvr)) {
          best = p; bestOvr = p.ovr; bestIsPrimary = isPrimary;
        }
      }
    }
    if (best) { used.add(best.slug); result[idx] = best; }
  }
  return result;
}

function renderLineup(formKey){
  const pitch=document.getElementById('lineupPitch');
  const formation=FORMATIONS[formKey];
  if(!pitch||!formation)return;
  const assignment=buildLineup(formation.slots,rosterData);
  pitch.querySelectorAll('.player-token').forEach(el=>el.remove());
  formation.slots.forEach((slot,i)=>{
    const player=assignment[i];
    const token=document.createElement('div');
    token.className='player-token';
    token.style.left=slot.x+'%';token.style.top=slot.y+'%';
    if(player){
      const bg=ROLE_BG[getRoleGroup(player.role)];
      token.innerHTML=`<a href="/player/${player.slug}" class="token-link" title="${player.name} · ${player.ovr}"><div class="token-circle" style="background:${bg};"><span class="token-init">${getInitials(player.name)}</span></div><div class="token-name">${getSurname(player.name)}</div><div class="token-ovr">${player.ovr}</div></a>`;
    } else {
      token.innerHTML=`<div class="token-link"><div class="token-circle token-empty-circle"><span class="token-init" style="color:rgba(255,255,255,0.35);">—</span></div><div class="token-name" style="color:rgba(255,255,255,0.3);">${slot.roles[0]}</div></div>`;
    }
    pitch.appendChild(token);
  });
}

let currentSort={col:null,dir:1};
function renderRoster(data){
  const tbody=document.getElementById('rosterBody');if(!tbody)return;tbody.innerHTML='';
  if(currentSort.col){[...data].sort((a,b)=>{let va=a[currentSort.col],vb=b[currentSort.col];if(typeof va==='string')return va.localeCompare(vb)*currentSort.dir;return(vb-va)*currentSort.dir;}).forEach(p=>tbody.appendChild(makeRow(p)));}
  else{['GK','DEF','MID','ATT'].forEach(sec=>{const group=data.filter(p=>p.section===sec);if(!group.length)return;const labels={GK:'Goalkeepers',DEF:'Defenders',MID:'Midfielders',ATT:'Attackers'};const hr=document.createElement('tr');hr.className='section-row';hr.innerHTML=`<td colspan="6">${labels[sec]}</td>`;tbody.appendChild(hr);group.forEach(p=>tbody.appendChild(makeRow(p)));});}
}
function makeRow(p){
  const tr=document.createElement('tr');tr.className='player-row';const isGK=p.role==='GK';
  tr.innerHTML=`<td><span class="player-cell"><span class="player-mini-avatar"><img class="player-mini-photo" src="/players/${p.slug}.jpg" alt="" loading="lazy" decoding="async" width="30" height="30" onerror="this.hidden=true"></span><a href="/player/${p.slug}" class="player-link">${p.name}</a></span></td><td><span class="role-badge ${roleCls(p.role)}">${p.role}</span></td><td class="col-ovr" style="color:${ovrColor(p.ovr)}">${p.ovr}</td><td class="col-stat${isGK?' muted':''}" style="${isGK?'':` color:${skillColor(p.def)}`}">${isGK?'—':p.def}</td><td class="col-stat${isGK?' muted':''}" style="${isGK?'':` color:${skillColor(p.play)}`}">${isGK?'—':p.play}</td><td class="col-stat${isGK?' muted':''}" style="${isGK?'':` color:${skillColor(p.att)}`}">${isGK?'—':p.att}</td>`;
  return tr;
}
document.querySelectorAll('#rosterTable thead th').forEach(th=>{th.addEventListener('click',()=>{const col=th.getAttribute('data-col');if(!col)return;if(currentSort.col===col){currentSort.dir===1?currentSort.dir=-1:(currentSort={col:null,dir:1});}else{currentSort={col,dir:1};}document.querySelectorAll('#rosterTable thead th').forEach(h=>{const c=h.getAttribute('data-col');const s=h.querySelector('span');h.classList.remove('sorted');if(s)s.textContent='';if(c===currentSort.col){h.classList.add('sorted');if(s)s.textContent=currentSort.dir===1?' ↑':' ↓';}});renderRoster(rosterData);});});
document.querySelectorAll('.form-btn').forEach(btn=>{btn.addEventListener('click',()=>{document.querySelectorAll('.form-btn').forEach(b=>b.classList.remove('active'));btn.classList.add('active');renderLineup(btn.getAttribute('data-form'));});});
renderRoster(rosterData);
if(document.getElementById('lineupPitch'))renderLineup('4-3-3');

// ─── ERA CLASH LOGIC ─────────────────────────────────────────────────────

const DECADE_COLORS = {
  1950:'#ff9500', 1960:'#ff2d55', 1970:'#30d158',
  1980:'#0071e3', 1990:'#bf5af2', 2000:'#64d2ff', 2010:'#ffd700'
};

const METRICS = [
  { key:'avgOvr',  label:'Avg OVR' },
  { key:'avgSpd',  label:'Speed' },
  { key:'avgStr',  label:'Strength' },
  { key:'avgTch',  label:'First Touch' },
  { key:'avgPas',  label:'Passing' },
  { key:'avgFin',  label:'Finishing' },
  { key:'avgCom',  label:'Composure' },
  { key:'avgVis',  label:'Vision' },
  { key:'avgDef',  label:'Defending' },
  { key:'avgSta',  label:'Stamina' },
];

const statsMap = {};
allDecadeStats.forEach(s => { statsMap[s.decade] = s; });

let selectedDecade = null;

document.getElementById('clashChips').addEventListener('click', e => {
  const btn = e.target.closest('.clash-chip');
  if (!btn) return;
  const d = Number(btn.getAttribute('data-decade'));
  document.querySelectorAll('.clash-chip').forEach(b => b.classList.remove('selected'));
  btn.classList.add('selected');
  selectedDecade = d;
  renderClash(d);
});

function renderClash(rivalDecade) {
  const A = currentStats;
  const B = statsMap[rivalDecade];
  if (!A || !B) return;

  const clashEmpty = document.getElementById('clashEmpty');
  const clashContent = document.getElementById('clashContent');
  clashEmpty.style.display = 'none';
  clashContent.style.display = 'block';

  const colorA = DECADE_COLORS[decadeNum] || '#0071e3';
  const colorB = DECADE_COLORS[rivalDecade] || '#c0392b';

  // Score: count wins per metric
  let winsA = 0, winsB = 0;
  METRICS.forEach(m => {
    const va = A[m.key] ?? 0, vb = B[m.key] ?? 0;
    if (va > vb) winsA++;
    else if (vb > va) winsB++;
  });
  // Extra: total legends
  if (A.total > B.total) winsA++;
  else if (B.total > A.total) winsB++;
  // Peak OVR
  if (A.peakOvr > B.peakOvr) winsA++;
  else if (B.peakOvr > A.peakOvr) winsB++;

  // VS banner
  const banner = document.getElementById('clashBanner');
  const aWinner = winsA > winsB;
  const bWinner = winsB > winsA;
  banner.innerHTML = `
    <div class="clash-vs-side">
      <div class="clash-vs-decade" style="color:${colorA};">${A.decade}s</div>
      <div class="clash-vs-label">This era</div>
      <div class="clash-vs-ovr">avg ${A.avgOvr} OVR · ${A.total} legends</div>
    </div>
    <div class="clash-vs-mid">
      <div class="clash-vs-text">VS</div>
      <div class="clash-score">
        <span class="clash-score-num" style="color:${aWinner?colorA:'rgba(255,255,255,0.4)'};">${winsA}</span>
        <span class="clash-score-sep">—</span>
        <span class="clash-score-num" style="color:${bWinner?colorB:'rgba(255,255,255,0.4)'};">${winsB}</span>
      </div>
    </div>
    <div class="clash-vs-side">
      <div class="clash-vs-decade" style="color:${colorB};">${B.decade}s</div>
      <div class="clash-vs-label">Rival era</div>
      <div class="clash-vs-ovr">avg ${B.avgOvr} OVR · ${B.total} legends</div>
    </div>
  `;

  // Metrics bars
  const metricsEl = document.getElementById('clashMetrics');
  metricsEl.innerHTML = '';

  METRICS.forEach(m => {
    const va = A[m.key] ?? 0;
    const vb = B[m.key] ?? 0;
    const maxVal = Math.max(va, vb, 1);
    const pctA = Math.round((va / maxVal) * 100);
    const pctB = Math.round((vb / maxVal) * 100);
    const aWins = va > vb;
    const bWins = vb > va;

    const row = document.createElement('div');
    row.className = 'clash-metric';
    row.innerHTML = `
      <div class="clash-bar-left">
        <span class="clash-val clash-val-left${aWins?' clash-win':''}" style="color:${aWins?colorA:'#6e6e73'};">${va}</span>
        <div class="clash-track">
          <div class="clash-fill clash-fill-left" style="width:0%;background:${colorA};" data-pct="${pctA}"></div>
        </div>
      </div>
      <span class="clash-metric-label">${m.label}</span>
      <div class="clash-bar-right">
        <div class="clash-track">
          <div class="clash-fill" style="width:0%;background:${colorB};" data-pct="${pctB}"></div>
        </div>
        <span class="clash-val clash-val-right${bWins?' clash-win':''}" style="color:${bWins?colorB:'#6e6e73'};">${vb}</span>
      </div>
    `;
    metricsEl.appendChild(row);
  });

  // Animate bars after a frame
  requestAnimationFrame(() => {
    requestAnimationFrame(() => {
      metricsEl.querySelectorAll('.clash-fill').forEach(el => {
        el.style.width = el.getAttribute('data-pct') + '%';
      });
    });
  });
}
</script>
  <Footer/>
