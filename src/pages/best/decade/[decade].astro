        </table>
      </div>

      <div class="highlights-grid">
        {bestPlayer&&<div class="hl-card"><div class="hl-head"><div><div class="hl-label">Best Player</div><div class="hl-name"><a href={`/player/${bestPlayer.slug}`}>{bestPlayer.name}</a></div></div><img class="hl-photo" src={`/players/${bestPlayer.slug}.jpg`} alt="" loading="lazy" decoding="async" width="40" height="40" onerror="this.style.display='none'"/></div><div class="hl-val" style={`color:${ovrColor(bestPlayer.overall_rating)}`}>{bestPlayer.overall_rating}</div></div>}
        {fastestP&&<div class="hl-card"><div class="hl-head"><div><div class="hl-label">Fastest</div><div class="hl-name"><a href={`/player/${fastestP.slug}`}>{fastestP.name}</a></div></div><img class="hl-photo" src={`/players/${fastestP.slug}.jpg`} alt="" loading="lazy" decoding="async" width="40" height="40" onerror="this.style.display='none'"/></div><div class="hl-val" style={`color:${skillColor(pSpd(fastestP))}`}>{pSpd(fastestP)} <span class="hl-unit">SPD</span></div></div>}
        {bestTech&&<div class="hl-card"><div class="hl-head"><div><div class="hl-label">Most Technical</div><div class="hl-name"><a href={`/player/${bestTech.slug}`}>{bestTech.name}</a></div></div><img class="hl-photo" src={`/players/${bestTech.slug}.jpg`} alt="" loading="lazy" decoding="async" width="40" height="40" onerror="this.style.display='none'"/></div><div class="hl-val" style={`color:${skillColor(bestTech['first-touch']??0)}`}>{bestTech['first-touch']} <span class="hl-unit">1-TCH</span></div></div>}
