    .decade-nav-btn:hover{border-color:#0071e3;color:#0071e3;}
    .decade-nav-btn.active{background:#0071e3;border-color:#0071e3;color:#ffffff;}

    /* ─── ERA CLASH ─── */
    .clash-section{margin-top:8px;}
    .clash-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;flex-wrap:wrap;gap:10px;}
    .clash-title-block{display:flex;align-items:center;gap:10px;}
    .clash-title{font-size:18px;font-weight:700;letter-spacing:-0.3px;color:#1d1d1f;}
    .clash-badge{font-size:10px;font-weight:700;padding:3px 9px;border-radius:6px;background:#fff0ee;color:#c0392b;letter-spacing:0.04em;text-transform:uppercase;}
