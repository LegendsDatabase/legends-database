        <div class="clash-vs-banner" id="clashBanner"></div>
        <div class="clash-metrics" id="clashMetrics"></div>
      </div>
    </div>

  </div>

<script define:vars={{ rosterData, allDecadeStats, currentStats, decadeNum }}>

// ─── EXISTING LINEUP/ROSTER LOGIC ────────────────────────────────────────
function ovrColor(v){if(v>=95)return'#0071e3';if(v>=90)return'#1a5e1a';if(v>=80)return'#2e8b2e';if(v>=70)return'#6aaa2a';if(v>=60)return'#c8a800';if(v>=50)return'#e07800';if(v>=40)return'#cc4400';return'#c0392b';}
function skillColor(v){if(v>=95)return'#5aabff';if(v>=90)return'#1a5e1a';if(v>=80)return'#2e8b2e';if(v>=70)return'#6aaa2a';if(v>=60)return'#c8a800';if(v>=40)return'#e07800';return'#c0392b';}
function roleCls(r){if(r==='GK')return'role-gk';if(['CB','SW','RB','LB'].includes(r))return'role-def';if(['DM','CM','AM','RM','LM'].includes(r))return'role-mid';return'role-att';}
const ROLE_BG={GK:'rgba(160,90,0,0.92)',DEF:'rgba(22,110,22,0.92)',MID:'rgba(0,90,200,0.92)',ATT:'rgba(175,35,35,0.92)'};
function getRoleGroup(r){if(r==='GK')return'GK';if(['CB','SW','RB','LB'].includes(r))return'DEF';if(['DM','CM','AM','RM','LM'].includes(r))return'MID';return'ATT';}
function getSurname(n){if(!n)return'?';const c=n.indexOf(',');return c>-1?n.substring(0,c).trim():n.trim();}
function getInitials(n){return getSurname(n).slice(0,2).toUpperCase();}

