---
import { supabase } from '../lib/supabase.js';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const { data: nations }  = await supabase.from('nations').select('*');
const { data: players }  = await supabase.from('players').select('nation, overall_rating');

const nationStats: Record<string, { count: number; avgOvr: number }> = {};
(players ?? []).forEach(p => {
  if (!p.nation || p.overall_rating == null) return;
  if (!nationStats[p.nation]) nationStats[p.nation] = { count: 0, avgOvr: 0 };
  nationStats[p.nation].count++;
  nationStats[p.nation].avgOvr += p.overall_rating;
});
Object.keys(nationStats).forEach(k => {
  nationStats[k].avgOvr = Math.round(nationStats[k].avgOvr / nationStats[k].count);
});

const FLAG_SVGS: Record<string,string> = {
  'Italy':          `<svg viewBox="0 0 30 20"><rect width="10" height="20" fill="#009246"/><rect x="10" width="10" height="20" fill="#fff"/><rect x="20" width="10" height="20" fill="#ce2b37"/></svg>`,
  'Germany':        `<svg viewBox="0 0 30 20"><rect width="30" height="7" fill="#000"/><rect y="7" width="30" height="6" fill="#dd0000"/><rect y="13" width="30" height="7" fill="#ffce00"/></svg>`,
  'France':         `<svg viewBox="0 0 30 20"><rect width="10" height="20" fill="#002395"/><rect x="10" width="10" height="20" fill="#fff"/><rect x="20" width="10" height="20" fill="#ed2939"/></svg>`,
  'Spain':          `<svg viewBox="0 0 30 20"><rect width="30" height="4" fill="#aa151b"/><rect y="4" width="30" height="12" fill="#f1bf00"/><rect y="16" width="30" height="4" fill="#aa151b"/></svg>`,
  'England':        `<svg viewBox="0 0 30 20"><rect width="30" height="20" fill="#fff"/><rect x="13" width="4" height="20" fill="#cf142b"/><rect y="8" width="30" height="4" fill="#cf142b"/></svg>`,
  'Brazil':         `<svg viewBox="0 0 30 20"><rect width="30" height="20" fill="#009c3b"/><polygon points="15,2 27,10 15,18 3,10" fill="#ffdf00"/><circle cx="15" cy="10" r="4" fill="#002776"/></svg>`,
  'Argentina':      `<svg viewBox="0 0 30 20"><rect width="30" height="7" fill="#74acdf"/><rect y="7" width="30" height="6" fill="#fff"/><rect y="13" width="30" height="7" fill="#74acdf"/><circle cx="15" cy="10" r="2.5" fill="#F6B40E"/></svg>`,
  'Netherlands':    `<svg viewBox="0 0 30 20"><rect width="30" height="7" fill="#ae1c28"/><rect y="7" width="30" height="6" fill="#fff"/><rect y="13" width="30" height="7" fill="#21468b"/></svg>`,
