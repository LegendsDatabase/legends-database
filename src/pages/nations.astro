  'Croatia':        `<svg viewBox="0 0 30 20"><rect width="30" height="7" fill="#ff0000"/><rect y="7" width="30" height="6" fill="#fff"/><rect y="13" width="30" height="7" fill="#0000cc"/></svg>`,
  'Uruguay':        `<svg viewBox="0 0 30 20"><rect width="30" height="20" fill="#fff"/><rect y="0" width="30" height="2.2" fill="#5aaae7"/><rect y="4.4" width="30" height="2.2" fill="#5aaae7"/><rect y="8.8" width="30" height="2.2" fill="#5aaae7"/><rect y="13.2" width="30" height="2.2" fill="#5aaae7"/><rect y="17.6" width="30" height="2.2" fill="#5aaae7"/></svg>`,
