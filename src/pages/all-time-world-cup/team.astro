<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover"/>
  <title>All-Time World Cup Team Presentation - Legends Database</title>
  <meta name="description" content="A cinematic presentation of your selected All-Time World Cup national team."/>
  <meta name="robots" content="noindex, nofollow, noarchive"/>
  <link rel="canonical" href="https://legendsdatabase.com/all-time-world-cup/team"/>
  <link rel="icon" type="image/png" href="/favicon.png"/>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet"/>
  <style is:global>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
    :root{--ink:#f7f4ee;--muted:rgba(247,244,238,.62);--dim:rgba(247,244,238,.36);--gold:#d8b76a;--blue:#0071e3;--green:#1a7a1a;--red:#c0392b;}
    body{font-family:-apple-system,'SF Pro Text','Inter',sans-serif;background:#05050a;color:#1d1d1f;padding-top:44px;-webkit-font-smoothing:antialiased;min-height:100vh;display:flex;flex-direction:column;}
    .team-page{position:relative;overflow:hidden;min-height:calc(100vh - 44px);background:
      radial-gradient(circle at 16% 4%,rgba(216,183,106,.26),transparent 30%),
      radial-gradient(circle at 84% 11%,rgba(0,113,227,.16),transparent 26%),
      linear-gradient(180deg,#070711 0%,#11111d 50%,#f2f2f7 50%,#f2f2f7 100%);
    }
    .team-page::before{content:'';position:absolute;inset:0;background:
      linear-gradient(rgba(255,255,255,.033) 1px,transparent 1px),
      linear-gradient(90deg,rgba(255,255,255,.033) 1px,transparent 1px);
      background-size:72px 72px;mask-image:linear-gradient(to bottom,#000,transparent 62%);pointer-events:none;
    }
    .team-shell{position:relative;max-width:1220px;margin:0 auto;padding:38px 32px 72px;}
    .topbar{display:flex;align-items:center;justify-content:space-between;gap:14px;margin-bottom:24px;}
    .back-link{color:rgba(255,255,255,.58);text-decoration:none;font-size:12px;font-weight:800;}
    .back-link:hover{color:#fff;}
    .team-select{border:1px solid rgba(255,255,255,.16);background:rgba(255,255,255,.08);color:#fff;border-radius:999px;padding:10px 12px;font-family:inherit;font-size:12px;font-weight:900;outline:none;backdrop-filter:blur(18px);}
    .team-select option{color:#1d1d1f;background:#fff;}
    .hero{display:grid;grid-template-columns:minmax(0,1fr) 420px;gap:34px;align-items:center;color:var(--ink);padding:10px 0 36px;}
    .kicker{font-size:10px;font-weight:900;letter-spacing:.18em;text-transform:uppercase;color:var(--dim);margin-bottom:14px;}
    .hero-title{font-size:clamp(46px,7vw,96px);line-height:.86;letter-spacing:-.08em;font-weight:900;max-width:780px;}
    .hero-title span{display:block;color:var(--gold);}
    .hero-copy{font-size:18px;line-height:1.62;color:var(--muted);max-width:700px;margin-top:20px;font-weight:520;}
    .hero-tags{display:flex;gap:8px;flex-wrap:wrap;margin-top:22px;}
    .hero-tag{border-radius:999px;border:1px solid rgba(255,255,255,.15);background:rgba(255,255,255,.08);color:rgba(255,255,255,.78);padding:8px 10px;font-size:10px;font-weight:900;letter-spacing:.11em;text-transform:uppercase;}
    .crest-card{position:relative;min-height:382px;border-radius:36px;overflow:hidden;background:radial-gradient(circle at 50% 34%,rgba(216,183,106,.18),transparent 42%),linear-gradient(145deg,#10111b,#1b1b29);box-shadow:0 34px 90px rgba(0,0,0,.42),inset 0 0 0 1px rgba(255,255,255,.13);}
    .crest-card::after{content:'';position:absolute;inset:0;background:linear-gradient(180deg,rgba(0,0,0,0),rgba(0,0,0,.26) 54%,rgba(0,0,0,.78));}
    .crest-img{position:absolute;inset:44px 60px 96px;width:calc(100% - 120px);height:calc(100% - 140px);object-fit:contain;filter:drop-shadow(0 28px 42px rgba(0,0,0,.32));}
    .crest-caption{position:absolute;z-index:2;left:24px;right:24px;bottom:22px;display:flex;align-items:flex-end;justify-content:space-between;gap:18px;color:#fff;}
    .crest-caption strong{display:block;font-size:28px;font-weight:900;letter-spacing:-.06em;line-height:.95;}
    .crest-caption span{font-size:9px;font-weight:900;letter-spacing:.16em;text-transform:uppercase;color:rgba(255,255,255,.48);}
    .seed-pill{text-align:right;border-radius:20px;background:rgba(255,255,255,.11);border:1px solid rgba(255,255,255,.16);backdrop-filter:blur(18px);padding:12px 14px;}
    .seed-pill b{display:block;font-size:34px;line-height:1;color:var(--gold);}
    .seed-pill small{font-size:8px;font-weight:900;letter-spacing:.14em;text-transform:uppercase;color:rgba(255,255,255,.52);}
    .content{display:grid;gap:18px;}
    .panel{background:rgba(255,255,255,.90);border:1px solid rgba(225,225,232,.92);border-radius:30px;box-shadow:0 22px 64px rgba(20,20,30,.10);backdrop-filter:blur(22px);overflow:hidden;}
    .panel-pad{padding:22px;}
    .panel-head{display:flex;align-items:flex-start;justify-content:space-between;gap:16px;margin-bottom:18px;}
    .step{font-size:9px;font-weight:900;letter-spacing:.16em;text-transform:uppercase;color:#aeaeb2;margin-bottom:8px;}
    .panel-title{font-size:28px;font-weight:900;letter-spacing:-.06em;line-height:1;}
    .panel-copy{font-size:13px;line-height:1.55;color:#6e6e73;font-weight:600;margin-top:8px;max-width:720px;}
    .metrics-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;}
    .metric-card{border-radius:22px;background:#fff;border:1px solid #ececf1;padding:16px;min-height:112px;position:relative;overflow:hidden;}
    .metric-card::before{content:'';position:absolute;right:-34px;top:-42px;width:100px;height:100px;border-radius:50%;background:rgba(0,113,227,.09);}
    .metric-value{position:relative;font-size:36px;font-weight:900;letter-spacing:-.065em;line-height:1;color:#1a7a1a;}
    .metric-label{position:relative;font-size:9px;font-weight:900;letter-spacing:.14em;text-transform:uppercase;color:#aeaeb2;margin-top:6px;}
    .metric-sub{position:relative;font-size:12px;color:#6e6e73;font-weight:650;margin-top:8px;}
    .split-grid{display:grid;grid-template-columns:1fr 1fr;gap:18px;}
    .dna-card{background:linear-gradient(135deg,#11121d,#1b1b29);color:#fff;border-radius:30px;padding:24px;position:relative;overflow:hidden;min-height:320px;}
    .dna-card::before{content:'';position:absolute;right:-90px;top:-90px;width:260px;height:260px;border-radius:50%;background:radial-gradient(circle,rgba(216,183,106,.20),transparent 68%);}
    .dna-title{position:relative;font-size:34px;font-weight:900;letter-spacing:-.065em;line-height:1;margin-bottom:12px;}
    .dna-text{position:relative;font-size:14px;line-height:1.7;color:rgba(255,255,255,.66);font-weight:550;}
    .dna-tags{position:relative;display:flex;gap:7px;flex-wrap:wrap;margin-top:18px;}
    .dna-tags span{font-size:9px;font-weight:900;letter-spacing:.12em;text-transform:uppercase;border-radius:999px;padding:7px 9px;background:rgba(216,183,106,.14);color:#e8ce8f;border:1px solid rgba(216,183,106,.18);}
    .bars{display:grid;gap:12px;margin-top:18px;position:relative;}
    .bar-row{display:grid;grid-template-columns:94px 1fr 34px;gap:10px;align-items:center;}
    .bar-label{font-size:10px;font-weight:900;letter-spacing:.12em;text-transform:uppercase;color:rgba(255,255,255,.46);}
    .bar-track{height:8px;border-radius:999px;background:rgba(255,255,255,.10);overflow:hidden;}
    .bar-fill{height:100%;border-radius:999px;background:linear-gradient(90deg,#d8b76a,#fff1bd);}
    .bar-val{font-size:11px;font-weight:900;color:rgba(255,255,255,.66);text-align:right;}
    .captain-card{border-radius:30px;background:#fff;border:1px solid #ececf1;padding:20px;display:grid;grid-template-columns:92px 1fr;gap:18px;align-items:center;min-height:320px;}
    .portrait{width:92px;height:92px;border-radius:50%;background:linear-gradient(145deg,#eef4ff,#f8f8fb);border:1px solid #e5e5ea;display:flex;align-items:center;justify-content:center;overflow:hidden;box-shadow:0 14px 28px rgba(20,20,30,.10);}
    .portrait img{width:100%;height:100%;object-fit:cover;display:block;}
    .portrait span{font-size:26px;font-weight:900;color:#0071e3;}
    .captain-kicker{font-size:9px;font-weight:900;letter-spacing:.15em;text-transform:uppercase;color:#d8a100;margin-bottom:6px;}
    .captain-name{font-size:30px;font-weight:900;letter-spacing:-.06em;line-height:1;}
    .captain-copy{font-size:13px;line-height:1.55;color:#6e6e73;font-weight:600;margin-top:8px;}
    .captain-stats{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-top:16px;}
    .mini-stat{background:#f5f5f7;border-radius:16px;padding:10px;text-align:center;}
    .mini-stat b{display:block;font-size:20px;line-height:1;color:#1a7a1a;}
    .mini-stat span{display:block;font-size:8px;font-weight:900;letter-spacing:.12em;text-transform:uppercase;color:#aeaeb2;margin-top:4px;}
    .key-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:10px;}
    .key-card{display:flex;flex-direction:column;gap:10px;text-decoration:none;color:#1d1d1f;background:#fff;border:1px solid #ececf1;border-radius:22px;padding:14px;min-height:206px;transition:transform .16s,box-shadow .16s,border-color .16s;}
    .key-card:hover{transform:translateY(-3px);box-shadow:0 18px 38px rgba(20,20,30,.10);border-color:#d6d6df;}
    .key-top{display:flex;align-items:center;justify-content:space-between;gap:8px;}
    .key-label{font-size:9px;font-weight:900;letter-spacing:.14em;text-transform:uppercase;color:#0071e3;}
    .role-pill{font-size:9px;font-weight:900;border-radius:999px;padding:5px 7px;background:#f5f5f7;color:#6e6e73;}
    .key-photo{width:64px;height:64px;border-radius:50%;background:linear-gradient(145deg,#eef4ff,#f8f8fb);border:1px solid #e5e5ea;display:flex;align-items:center;justify-content:center;overflow:hidden;}
    .key-photo img{width:100%;height:100%;object-fit:cover;}
    .key-photo span{font-size:19px;font-weight:900;color:#0071e3;}
    .key-name{font-size:17px;font-weight:900;letter-spacing:-.04em;line-height:1.08;}
    .key-detail{font-size:12px;line-height:1.4;color:#6e6e73;font-weight:650;}
    .key-score{margin-top:auto;display:flex;align-items:center;justify-content:space-between;font-size:11px;font-weight:900;color:#aeaeb2;}
    .key-score b{font-size:25px;letter-spacing:-.06em;color:#1a7a1a;}
    .roster-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:12px;}
    .role-section{background:#fff;border:1px solid #ececf1;border-radius:24px;overflow:hidden;}
    .section-title{padding:12px 14px;background:#f9f9fb;border-bottom:1px solid #f0f0f5;font-size:10px;font-weight:900;letter-spacing:.15em;text-transform:uppercase;color:#8e8e93;}
    .player-row{display:grid;grid-template-columns:42px minmax(0,1fr) auto;gap:10px;align-items:center;padding:10px 12px;text-decoration:none;color:#1d1d1f;border-bottom:1px solid #f5f5f7;position:relative;}
    .player-row:last-child{border-bottom:none;}
    .player-row:hover{background:#fbfbfd;}
    .row-photo{width:36px;height:36px;border-radius:50%;background:linear-gradient(145deg,#eef4ff,#f8f8fb);border:1px solid #e5e5ea;display:flex;align-items:center;justify-content:center;overflow:hidden;}
    .row-photo img{width:100%;height:100%;object-fit:cover;}
    .row-photo span{font-size:12px;font-weight:900;color:#0071e3;}
    .row-name{font-size:13px;font-weight:850;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
    .row-meta{font-size:9px;font-weight:900;letter-spacing:.10em;text-transform:uppercase;color:#aeaeb2;margin-top:2px;}
    .row-ovr{font-size:18px;font-weight:900;color:#1a7a1a;letter-spacing:-.04em;}
    .hover-stats{position:absolute;left:58px;right:12px;bottom:calc(100% - 3px);display:none;grid-template-columns:repeat(4,1fr);gap:5px;background:rgba(20,20,28,.94);border:1px solid rgba(255,255,255,.10);border-radius:14px;padding:8px;z-index:12;box-shadow:0 20px 44px rgba(0,0,0,.24);pointer-events:none;}
    .player-row:hover .hover-stats{display:grid;}
    .hover-stat{text-align:center;color:#fff;}
    .hover-stat b{display:block;font-size:13px;}
    .hover-stat span{display:block;font-size:7px;font-weight:900;letter-spacing:.12em;text-transform:uppercase;color:rgba(255,255,255,.46);margin-top:2px;}
    .rivals-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
    .rival-box,.warning-box{border-radius:24px;background:#fff;border:1px solid #ececf1;padding:18px;min-height:150px;}
    .rival-list{display:flex;gap:8px;flex-wrap:wrap;margin-top:14px;}
    .rival-pill{border-radius:999px;background:#fff0ee;color:#c0392b;border:1px solid #f5c6bc;padding:8px 10px;font-size:11px;font-weight:900;}
    .warning-list{display:grid;gap:8px;margin-top:14px;}
    .warning-item{font-size:12px;line-height:1.45;color:#6e6e73;font-weight:650;background:#f9f9fb;border-radius:14px;padding:10px;}
    .next-bar{display:grid;grid-template-columns:1fr auto;gap:16px;align-items:center;background:linear-gradient(135deg,#11121d,#1b1b29);border:1px solid rgba(255,255,255,.10);border-radius:30px;color:#fff;padding:22px;box-shadow:0 24px 70px rgba(20,20,30,.16);}
    .next-title{font-size:25px;font-weight:900;letter-spacing:-.055em;margin-bottom:5px;}
    .next-copy{font-size:13px;line-height:1.55;color:rgba(255,255,255,.60);font-weight:600;}
    .next-btn{display:inline-flex;align-items:center;justify-content:center;text-decoration:none;border-radius:999px;background:linear-gradient(135deg,#c0392b,#e85d4f);color:#fff;padding:13px 16px;font-size:12px;font-weight:900;white-space:nowrap;box-shadow:0 18px 40px rgba(192,57,43,.24);}
    @media(max-width:1060px){
      .team-shell{padding:30px 20px 58px;}
      .hero{grid-template-columns:1fr;}
      .crest-card{min-height:320px;}
      .key-grid{grid-template-columns:repeat(3,1fr);}
      .metrics-grid{grid-template-columns:repeat(2,1fr);}
      .split-grid{grid-template-columns:1fr;}
    }
    @media(max-width:720px){
      .team-shell{padding:24px 16px 46px;}
      .topbar{align-items:flex-start;flex-direction:column;}
      .team-select{width:100%;}
      .hero-title{font-size:48px;}
      .hero-copy{font-size:15px;}
      .crest-card{min-height:246px;border-radius:28px;}
      .crest-img{inset:30px 48px 80px;width:calc(100% - 96px);height:calc(100% - 110px);}
      .metrics-grid,.key-grid,.roster-grid,.rivals-grid{grid-template-columns:1fr;}
      .captain-card{grid-template-columns:1fr;text-align:left;}
      .captain-stats{grid-template-columns:repeat(3,1fr);}
      .panel-head,.next-bar{display:grid;grid-template-columns:1fr;}
      .hover-stats{display:none!important;}
    }
  </style>
</head>
<body>
<Navbar/>
<main class="team-page">
  <div class="team-shell">
    <div class="topbar">
      <a class="back-link" href="/all-time-world-cup/draw">&larr; Back to draw</a>
      <select class="team-select" id="teamSelect" aria-label="Change team presentation">
        {teams.map(team => <option value={team.slug}>{team.name}</option>)}
      </select>
    </div>

    <section class="hero">
      <div>
        <div class="kicker">National team presentation</div>
        <h1 class="hero-title" id="heroTitle">Your <span>World Cup side</span></h1>
        <p class="hero-copy" id="heroCopy">Loading the identity of your selected nation.</p>
        <div class="hero-tags" id="heroTags"></div>
      </div>
      <aside class="crest-card">
        <img class="crest-img" id="crestImg" src="/teams/all-time-brazil.svg" alt=""/>
        <div class="crest-caption">
          <div>
            <span id="crestSmall">Tournament seed</span>
            <strong id="crestName">Brazil</strong>
          </div>
          <div class="seed-pill"><b id="seedValue">90</b><small>seed</small></div>
        </div>
      </aside>
    </section>

    <section class="content">
      <div class="panel panel-pad">
        <div class="panel-head">
          <div>
            <div class="step">Squad snapshot</div>
            <h2 class="panel-title">The team at a glance</h2>
            <p class="panel-copy">A fast read of quality, balance and tournament readiness before the fixtures are generated.</p>
          </div>
        </div>
        <div class="metrics-grid" id="metricsGrid"></div>
      </div>

      <div class="split-grid">
        <div class="dna-card">
          <div class="step">Identity</div>
          <h2 class="dna-title" id="dnaTitle">Team DNA</h2>
          <p class="dna-text" id="dnaText"></p>
          <div class="dna-tags" id="dnaTags"></div>
          <div class="bars" id="dnaBars"></div>
        </div>
        <div class="captain-card" id="captainCard"></div>
      </div>

      <div class="panel panel-pad">
        <div class="panel-head">
          <div>
            <div class="step">Key figures</div>
            <h2 class="panel-title">Players who define the story</h2>
            <p class="panel-copy">The captain, icon, creator, finisher and defensive reference. Click a card to open the player profile; browser back returns here with tournament data intact.</p>
          </div>
        </div>
        <div class="key-grid" id="keyGrid"></div>
      </div>

      <div class="panel panel-pad">
        <div class="panel-head">
          <div>
            <div class="step">Roster</div>
            <h2 class="panel-title">The all-time squad</h2>
            <p class="panel-copy">Player photos appear where available; missing portraits keep the same layout with clean initials placeholders. Hover rows on desktop for a quick stat read.</p>
          </div>
        </div>
        <div class="roster-grid" id="rosterGrid"></div>
      </div>

      <div class="rivals-grid">
        <div class="rival-box">
          <div class="step">Rivalries</div>
          <h2 class="panel-title">Historic heat</h2>
          <p class="panel-copy">These matchups will matter later for pressure, crowd tone and narrative weight.</p>
          <div class="rival-list" id="rivalList"></div>
        </div>
        <div class="warning-box">
          <div class="step">Manager notes</div>
          <h2 class="panel-title">What to watch</h2>
          <div class="warning-list" id="warningList"></div>
        </div>
      </div>

      <div class="next-bar">
        <div>
          <div class="next-title">Next: fixtures</div>
          <p class="next-copy">The next screen turns the draw into dates, venues, rest days and the first clear route through the tournament.</p>
        </div>
        <a class="next-btn" href="/all-time-world-cup/fixtures">View fixtures</a>
      </div>
    </section>
  </div>
</main>
<Footer/>
<script type="application/json" id="teamData" set:html={pageData}></script>
<script>
  const data = JSON.parse(document.getElementById('teamData')?.textContent || '{}');
  const teams = data.teams || [];
  const teamMap = new Map(teams.map(team => [team.slug, team]));
  const setup = readJson('ld_world_cup_setup') || {};
  const draw = readJson('ld_world_cup_draw') || {};
  let currentSlug = teamMap.has(draw.userSlug) ? draw.userSlug : (teamMap.has(setup.teamSlug) ? setup.teamSlug : (teams[0]?.slug || ''));

  function readJson(key) {
    try { return JSON.parse(localStorage.getItem(key) || 'null'); } catch { return null; }
  }

  function esc(value) {
    return String(value ?? '').replace(/[&<>"']/g, c => ({ '&':'&amp;', '<':'&lt;', '>':'&gt;', '"':'&quot;', "'":'&#039;' }[c]));
  }

  function portrait(player, cls = 'portrait') {
    if (!player) return `<div class="${cls}"><span>-</span></div>`;
    const content = player.photo ? `<img src="${player.photo}" alt="" loading="lazy"/>` : `<span>${esc(player.initials)}</span>`;
    return `<div class="${cls}">${content}</div>`;
  }

  function playerUrl(player) {
    return player?.slug ? `/player/${player.slug}` : '#';
  }

  function renderMetrics(team) {
    const metrics = [
      ['OVR', team.metrics.ovr, 'Total squad level'],
      ['GK', team.metrics.gk, 'Goalkeeper room'],
      ['DEF', team.metrics.def, 'Back-line security'],
      ['MID', team.metrics.mid, 'Control and passing'],
      ['ATT', team.metrics.att, 'Chance creation'],
      ['SPD', team.metrics.speed, 'Vertical threat'],
      ['MNT', team.metrics.mental, 'Composure under heat'],
      ['STA', team.metrics.stamina, 'Tournament legs'],
    ];
    document.getElementById('metricsGrid').innerHTML = metrics.map(([label, value, sub]) => `
      <div class="metric-card">
        <div class="metric-value">${value}</div>
        <div class="metric-label">${label}</div>
        <div class="metric-sub">${esc(sub)}</div>
      </div>
    `).join('');
  }

  function renderBars(team) {
    const bars = [
      ['Pressure', team.pressure],
      ['Tempo', team.tempo],
      ['Risk', team.risk],
      ['Possession', team.possession],
      ['Pressing', team.pressing],
      ['Knockout nerve', team.knockoutNerve],
    ];
    document.getElementById('dnaBars').innerHTML = bars.map(([label, value]) => `
      <div class="bar-row">
        <div class="bar-label">${esc(label)}</div>
        <div class="bar-track"><div class="bar-fill" style="width:${Math.max(8, Math.min(100, value))}%"></div></div>
        <div class="bar-val">${value}</div>
      </div>
    `).join('');
  }

  function renderCaptain(team) {
    const p = team.captain;
    document.getElementById('captainCard').innerHTML = `
      ${portrait(p, 'portrait')}
      <div>
        <div class="captain-kicker">Suggested captain</div>
        <div class="captain-name">${esc(p?.name || 'Captain')}</div>
        <p class="captain-copy">Suggested by leadership profile: work rate, teamwork, composure and consistency. For now it is a narrative role; later it can influence morale.</p>
        <div class="captain-stats">
          <div class="mini-stat"><b>${p?.workRate ?? '-'}</b><span>Work rate</span></div>
          <div class="mini-stat"><b>${p?.teamwork ?? '-'}</b><span>Teamwork</span></div>
          <div class="mini-stat"><b>${p?.composure ?? '-'}</b><span>Composure</span></div>
        </div>
      </div>
    `;
  }

  function renderKeyPlayers(team) {
    document.getElementById('keyGrid').innerHTML = team.keyPlayers.map(item => {
      const p = item.player;
      return `
        <a class="key-card" href="${playerUrl(p)}">
          <div class="key-top"><span class="key-label">${esc(item.label)}</span><span class="role-pill">${esc(p.role)}</span></div>
          ${portrait(p, 'key-photo')}
          <div>
            <div class="key-name">${esc(p.name)}</div>
            <div class="key-detail">${esc(item.detail)}</div>
          </div>
          <div class="key-score"><span>OVR</span><b>${p.ovr}</b></div>
        </a>
      `;
    }).join('');
  }

  function renderRoster(team) {
    const sections = ['Goalkeepers', 'Defenders', 'Midfielders', 'Attackers'];
    document.getElementById('rosterGrid').innerHTML = sections.map(section => {
      const players = team.roster.filter(p => p.section === section);
      return `
        <div class="role-section">
          <div class="section-title">${section}</div>
          ${players.map(p => `
            <a class="player-row" href="${playerUrl(p)}">
              ${portrait(p, 'row-photo')}
              <div>
                <div class="row-name">${esc(p.name)}</div>
                <div class="row-meta">${esc(p.role)} · ${esc(p.decade ? `${p.decade}s` : 'All-time')} · ${esc(p.foot || 'Foot n/a')}</div>
              </div>
              <div class="row-ovr">${p.ovr}</div>
              <div class="hover-stats">
                <div class="hover-stat"><b>${p.att}</b><span>ATT</span></div>
                <div class="hover-stat"><b>${p.play}</b><span>PLAY</span></div>
                <div class="hover-stat"><b>${p.def}</b><span>DEF</span></div>
                <div class="hover-stat"><b>${p.mental}</b><span>MNT</span></div>
              </div>
            </a>
          `).join('')}
        </div>
      `;
    }).join('');
  }

  function renderRivals(team) {
    const rivals = team.rivalries?.length ? team.rivalries : ['Historic rivals coming soon'];
    document.getElementById('rivalList').innerHTML = rivals.map(r => `<span class="rival-pill">${esc(r)}</span>`).join('');
    const warnings = [
      ...(team.strengths || []).slice(0, 2).map(x => `Strength: ${x}`),
      ...(team.vulnerabilities || []).slice(0, 2).map(x => `Risk: ${x}`),
    ];
    document.getElementById('warningList').innerHTML = (warnings.length ? warnings : ['No special notes yet.']).map(w => `<div class="warning-item">${esc(w)}</div>`).join('');
  }

  function renderTeam(slug) {
    const team = teamMap.get(slug) || teams[0];
    if (!team) return;
    currentSlug = team.slug;
    document.getElementById('teamSelect').value = team.slug;
    document.getElementById('heroTitle').innerHTML = `${esc(team.name)} <span>${esc(team.shortLabel)}</span>`;
    document.getElementById('heroCopy').textContent = team.style;
    document.getElementById('heroTags').innerHTML = [
      team.confederation,
      team.formation,
      team.coachName,
      team.coachStyle,
      ...(team.tags || []).slice(0, 3),
    ].filter(Boolean).map(tag => `<span class="hero-tag">${esc(tag)}</span>`).join('');
    document.getElementById('crestImg').src = team.logo;
    document.getElementById('crestName').textContent = team.name;
    document.getElementById('crestSmall').textContent = team.identity;
    document.getElementById('seedValue').textContent = team.seed;
    document.getElementById('dnaTitle').textContent = team.identity;
    document.getElementById('dnaText').textContent = team.style;
    document.getElementById('dnaTags').innerHTML = (team.tags || []).map(tag => `<span>${esc(tag)}</span>`).join('');
    renderMetrics(team);
    renderBars(team);
    renderCaptain(team);
    renderKeyPlayers(team);
    renderRoster(team);
    renderRivals(team);
    localStorage.setItem('ld_world_cup_selected_team_view', team.slug);
  }

  document.getElementById('teamSelect')?.addEventListener('change', event => renderTeam(event.target.value));
  const remembered = localStorage.getItem('ld_world_cup_selected_team_view');
  renderTeam(teamMap.has(currentSlug) ? currentSlug : (teamMap.has(remembered) ? remembered : teams[0]?.slug));
</script>
</body>
</html>
