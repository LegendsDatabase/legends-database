---
import { existsSync } from 'node:fs';
import { join } from 'node:path';
import { supabase } from '../../lib/supabase.js';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import { COACHES } from '../../lib/match-simulator/coaches.js';

const { data: rawTeams } = await supabase
  .from('teams')
  .select('id,name,slug,type,confederation,rivalries,world_cup_enabled,default_formation,default_tactic,default_coach_id,seed_weight,sim_profile')
  .eq('world_cup_enabled', true)
  .order('seed_weight', { ascending: false });

const { data: rawPlayers } = await supabase
  .from('players')
  .select(`id,slug,name,role,nation,iconic_club,overall_rating,decade,height,preferred_foot,
           acceleration,pace,agility,strength,balance,jumping,stamina,fitness,
           dribbling,short_passing,long_passing,finishing,shot_accuracy,shot_power,
           heading,tackling,free_kick,penalties,composure,aggression,consistency,
           creativity,work_rate,vision,off_the_ball,def_positioning,teamwork,
           anticipation,marking,reflexes,positioning,handling,kicking,alt_roles,
           nat_apps,nat_goals,nat_goal_ratio`);

const photoRoot = join(process.cwd(), 'public', 'players');

function titleName(name = '') {
  return name
    .split(/[\s-]+/)
    .filter(Boolean)
    .map(w => w.charAt(0).toUpperCase() + w.slice(1))
    .join(' ');
}

function profileOf(team) {
  const raw = team?.sim_profile ?? {};
  if (typeof raw === 'string') {
    try { return JSON.parse(raw); } catch { return {}; }
  }
  return raw || {};
}

function avg(vals) {
  const v = vals.filter(x => x != null && !Number.isNaN(Number(x))).map(Number);
  return v.length ? Math.round(v.reduce((a, b) => a + b, 0) / v.length) : 0;
}

function sortByOvr(arr) {
  return [...arr].sort((a, b) => (b.overall_rating ?? 0) - (a.overall_rating ?? 0) || (a.name ?? '').localeCompare(b.name ?? ''));
}

function sortBy(arr, fn) {
  return [...arr].sort((a, b) => fn(b) - fn(a) || (a.name ?? '').localeCompare(b.name ?? ''));
}

function pick(pool, n, usedIds) {
  return sortByOvr(pool.filter(p => !usedIds.has(p.id))).slice(0, n);
}

function hasPhoto(slug) {
  return !!slug && existsSync(join(photoRoot, `${slug}.jpg`));
}

function initials(name = '') {
  return name
    .replace(',', ' ')
    .split(/\s+/)
    .filter(Boolean)
    .slice(0, 2)
    .map(w => w.charAt(0).toUpperCase())
    .join('');
}

function pAtt(p) { return avg([p.finishing, p.off_the_ball, p.composure, p.anticipation, p.shot_accuracy]); }
function pPlay(p) { return avg([p.short_passing, p.long_passing, p.vision, p.composure, p.creativity]); }
function pDef(p) { return avg([p.marking, p.tackling, p.def_positioning, p.anticipation, p.heading, p.composure]); }
function pSpeed(p) { return avg([p.pace, p.acceleration]); }
function pMental(p) { return avg([p.composure, p.consistency, p.work_rate, p.teamwork]); }
function pCaptain(p) { return (p.work_rate ?? 70) * 1.35 + (p.teamwork ?? 70) + (p.composure ?? 70) * 0.9 + (p.consistency ?? 70) * 0.8; }

function buildRoster(team, allPlayers) {
  const teamPlayers = allPlayers.filter(p => (p.nation ?? '').toLowerCase() === (team.name ?? '').toLowerCase());
  const used = new Set();
  const gkR = pick(teamPlayers.filter(p => p.role === 'GK'), 3, used);
  gkR.forEach(p => used.add(p.id));
  const rbR = pick(teamPlayers.filter(p => p.role === 'RB'), 2, used);
  rbR.forEach(p => used.add(p.id));
  const lbR = pick(teamPlayers.filter(p => p.role === 'LB'), 2, used);
  lbR.forEach(p => used.add(p.id));
  const swAvail = sortByOvr(teamPlayers.filter(p => p.role === 'SW' && !used.has(p.id)));
  const cbAvail = sortByOvr(teamPlayers.filter(p => p.role === 'CB' && !used.has(p.id)));
  const swSlot = swAvail.length ? [swAvail[0]] : [];
  swSlot.forEach(p => used.add(p.id));
  const centerPool = sortByOvr([...cbAvail.filter(p => !used.has(p.id)), ...swAvail.filter(p => !used.has(p.id))]);
  const centerR = [...swSlot, ...pick(centerPool, 4 - swSlot.length, used)];
  centerR.forEach(p => used.add(p.id));
  const defR = [...rbR, ...lbR, ...centerR];
  const dmR = pick(teamPlayers.filter(p => p.role === 'DM'), 2, used);
  dmR.forEach(p => used.add(p.id));
  const cmamR = pick(teamPlayers.filter(p => ['CM', 'AM'].includes(p.role)), 4, used);
  cmamR.forEach(p => used.add(p.id));
  const rmlmR = pick(teamPlayers.filter(p => ['RM', 'LM', 'CM', 'AM', 'DM'].includes(p.role)), 2, used);
  rmlmR.forEach(p => used.add(p.id));
  const midR = [...dmR, ...cmamR, ...rmlmR];
  const stR = pick(teamPlayers.filter(p => p.role === 'ST'), 4, used);
  stR.forEach(p => used.add(p.id));
  const wingS = pick(teamPlayers.filter(p => ['RW', 'LW'].includes(p.role) && !used.has(p.id)), 1, used);
  wingS.forEach(p => used.add(p.id));
  const attFill = pick(teamPlayers.filter(p => ['ST', 'FW', 'RW', 'LW'].includes(p.role) && !used.has(p.id)), 6 - wingS.length, used);
  attFill.forEach(p => used.add(p.id));
  const attR = [...stR, ...wingS, ...attFill];
  return { gkR, defR, midR, attR, roster: [...gkR, ...defR, ...midR, ...attR] };
}

function playerPayload(p, section) {
  return {
    id: p.id,
    slug: p.slug ?? '',
    name: p.name ?? '',
    role: (p.role ?? '').toUpperCase(),
    alt: p.alt_roles ?? '',
    section,
    nation: p.nation ?? '',
    club: p.iconic_club ?? '',
    decade: p.decade ?? '',
    ovr: p.overall_rating ?? 0,
    photo: hasPhoto(p.slug) ? `/players/${p.slug}.jpg` : '',
    initials: initials(p.name),
    apps: p.nat_apps ?? 0,
    goals: p.nat_goals ?? 0,
    foot: p.preferred_foot ?? '',
    height: p.height ?? null,
    pace: p.pace ?? 70,
    acc: p.acceleration ?? 70,
    stamina: p.stamina ?? 70,
    fitnessBase: p.fitness ?? 80,
    workRate: p.work_rate ?? 70,
    composure: p.composure ?? 70,
    consistency: p.consistency ?? 70,
    teamwork: p.teamwork ?? 70,
    aggression: p.aggression ?? 70,
    vision: p.vision ?? 70,
    creativity: p.creativity ?? 70,
    shortPassing: p.short_passing ?? 70,
    longPassing: p.long_passing ?? 70,
    finishing: p.finishing ?? 70,
    shotAccuracy: p.shot_accuracy ?? 70,
    shotPower: p.shot_power ?? 70,
    freeKick: p.free_kick ?? 70,
    penalties: p.penalties ?? 70,
    tackling: p.tackling ?? 70,
    marking: p.marking ?? 70,
    defPositioning: p.def_positioning ?? 70,
    anticipation: p.anticipation ?? 70,
    heading: p.heading ?? 70,
    reflexes: p.reflexes ?? 70,
    handling: p.handling ?? 70,
    positioning: p.positioning ?? 70,
    att: pAtt(p),
    play: pPlay(p),
    def: pDef(p),
    speed: pSpeed(p),
    mental: pMental(p),
    captainScore: pCaptain(p),
  };
}

const teams = (rawTeams ?? []).map(team => {
  const profile = profileOf(team);
  const rosterParts = buildRoster(team, rawPlayers ?? []);
  const roster = [
    ...rosterParts.gkR.map(p => playerPayload(p, 'Goalkeepers')),
    ...rosterParts.defR.map(p => playerPayload(p, 'Defenders')),
    ...rosterParts.midR.map(p => playerPayload(p, 'Midfielders')),
    ...rosterParts.attR.map(p => playerPayload(p, 'Attackers')),
  ];
  const coach = COACHES.find(c => c.id === team.default_coach_id);
  return {
    id: team.id,
    name: titleName(team.name),
    rawName: team.name ?? '',
    slug: team.slug,
    confederation: team.confederation ?? '',
    logo: `/teams/${team.slug}.svg`,
    formation: team.default_formation ?? '4-3-3',
    tactic: team.default_tactic ?? 'balanced',
    coachId: team.default_coach_id ?? '',
    coachName: coach?.name ?? 'Tournament manager',
    coachStyle: coach?.style ?? 'National identity',
    seed: team.seed_weight ?? 50,
    identity: profile.identity ?? 'All-time national identity',
    shortLabel: profile.short_label ?? 'Tournament profile',
    style: profile.style ?? 'A legendary side built for the biggest stage.',
    pressure: profile.pressure ?? 80,
    tempo: profile.tempo ?? 70,
    risk: profile.risk ?? 55,
    possession: profile.possession ?? 55,
    pressing: profile.pressing ?? 55,
    defensiveLine: profile.defensive_line ?? 55,
    strengths: Array.isArray(profile.strengths) ? profile.strengths : [],
    vulnerabilities: Array.isArray(profile.vulnerabilities) ? profile.vulnerabilities : [],
    tags: Array.isArray(profile.tags) ? profile.tags : [],
    roster,
    metrics: {
      ovr: avg(roster.map(p => p.ovr)),
      mental: avg(roster.map(p => p.mental)),
      stamina: avg(roster.map(p => p.stamina)),
      speed: avg(roster.map(p => p.speed)),
      creators: avg(roster.filter(p => p.section === 'Midfielders').map(p => p.play)),
      finishers: avg(roster.filter(p => p.section === 'Attackers').map(p => p.att)),
      defenders: avg(roster.filter(p => p.section === 'Defenders').map(p => p.def)),
    },
  };
});

const pageData = JSON.stringify({ teams }).replace(/</g, '\\u003c');
