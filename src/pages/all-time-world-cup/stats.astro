---
import { existsSync } from 'node:fs';
import { join } from 'node:path';
import { supabase } from '../../lib/supabase.js';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';

const { data: rawTeams } = await supabase
  .from('teams')
  .select('id,name,slug,type,confederation,world_cup_enabled,seed_weight,sim_profile')
  .eq('world_cup_enabled', true)
  .order('seed_weight', { ascending: false });

const { data: rawPlayers } = await supabase
  .from('players')
  .select(`id,slug,name,role,nation,iconic_club,overall_rating,decade,height,preferred_foot,
           acceleration,pace,agility,strength,balance,jumping,stamina,fitness,
           dribbling,short_passing,long_passing,finishing,shot_accuracy,shot_power,
           heading,tackling,free_kick,penalties,composure,aggression,consistency,
           creativity,work_rate,vision,off_the_ball,def_positioning,teamwork,
           anticipation,marking,reflexes,positioning,handling,kicking,alt_roles,
           nat_apps,nat_goals,nat_goal_ratio`);

const photoRoot = join(process.cwd(), 'public', 'players');

function profileOf(team) {
  const raw = team?.sim_profile ?? {};
  if (typeof raw === 'string') {
    try { return JSON.parse(raw); } catch { return {}; }
  }
  return raw || {};
}

function avg(vals) {
  const v = vals.filter(x => x != null && !Number.isNaN(Number(x))).map(Number);
  return v.length ? Math.round(v.reduce((a, b) => a + b, 0) / v.length) : 0;
}

function sortByOvr(arr) {
  return [...arr].sort((a, b) => (b.overall_rating ?? 0) - (a.overall_rating ?? 0) || (a.name ?? '').localeCompare(b.name ?? ''));
}

function pick(pool, n, usedIds) {
  return sortByOvr(pool.filter(p => !usedIds.has(p.id))).slice(0, n);
}

function hasPhoto(slug) {
  return !!slug && existsSync(join(photoRoot, `${slug}.jpg`));
}

function initials(name = '') {
  return name
    .replace(',', ' ')
    .split(/\s+/)
    .filter(Boolean)
    .slice(0, 2)
    .map(w => w.charAt(0).toUpperCase())
    .join('');
}

function pAtt(p) { return avg([p.finishing, p.off_the_ball, p.composure, p.anticipation, p.shot_accuracy]); }
function pPlay(p) { return avg([p.short_passing, p.long_passing, p.vision, p.composure, p.creativity]); }
function pDef(p) { return avg([p.marking, p.tackling, p.def_positioning, p.anticipation, p.heading, p.composure]); }
function pSpeed(p) { return avg([p.pace, p.acceleration]); }
function pMental(p) { return avg([p.composure, p.consistency, p.work_rate, p.teamwork]); }
function pKeeper(p) { return avg([p.reflexes, p.positioning, p.handling, p.kicking, p.composure]); }

function buildRoster(team, allPlayers) {
  const teamPlayers = allPlayers.filter(p => (p.nation ?? '').toLowerCase() === (team.name ?? '').toLowerCase());
  const used = new Set();
  const gkR = pick(teamPlayers.filter(p => p.role === 'GK'), 3, used);
  gkR.forEach(p => used.add(p.id));
  const rbR = pick(teamPlayers.filter(p => p.role === 'RB'), 2, used);
  rbR.forEach(p => used.add(p.id));
  const lbR = pick(teamPlayers.filter(p => p.role === 'LB'), 2, used);
  lbR.forEach(p => used.add(p.id));
  const swAvail = sortByOvr(teamPlayers.filter(p => p.role === 'SW' && !used.has(p.id)));
  const cbAvail = sortByOvr(teamPlayers.filter(p => p.role === 'CB' && !used.has(p.id)));
  const swSlot = swAvail.length ? [swAvail[0]] : [];
  swSlot.forEach(p => used.add(p.id));
  const centerPool = sortByOvr([...cbAvail.filter(p => !used.has(p.id)), ...swAvail.filter(p => !used.has(p.id))]);
  const centerR = [...swSlot, ...pick(centerPool, 4 - swSlot.length, used)];
  centerR.forEach(p => used.add(p.id));
  const defR = [...rbR, ...lbR, ...centerR];
  const dmR = pick(teamPlayers.filter(p => p.role === 'DM'), 2, used);
  dmR.forEach(p => used.add(p.id));
  const cmamR = pick(teamPlayers.filter(p => ['CM', 'AM'].includes(p.role)), 4, used);
  cmamR.forEach(p => used.add(p.id));
  const wideMidR = pick(teamPlayers.filter(p => ['RM', 'LM', 'CM', 'AM', 'DM'].includes(p.role)), 2, used);
  wideMidR.forEach(p => used.add(p.id));
  const midR = [...dmR, ...cmamR, ...wideMidR];
  const stR = pick(teamPlayers.filter(p => p.role === 'ST'), 4, used);
  stR.forEach(p => used.add(p.id));
  const wingR = pick(teamPlayers.filter(p => ['RW', 'LW'].includes(p.role)), 1, used);
  wingR.forEach(p => used.add(p.id));
  const attFill = pick(teamPlayers.filter(p => ['ST', 'FW', 'RW', 'LW'].includes(p.role)), 6 - wingR.length, used);
  attFill.forEach(p => used.add(p.id));
  return [...gkR, ...defR, ...midR, ...stR, ...wingR, ...attFill];
}

function sectionFor(role) {
  if (role === 'GK') return 'GK';
  if (['RB', 'LB', 'CB', 'SW'].includes(role)) return 'DEF';
  if (['DM', 'CM', 'AM', 'RM', 'LM'].includes(role)) return 'MID';
  return 'ATT';
}

function projectedLine(p, team) {
  const ovr = p.overall_rating ?? 70;
  const section = sectionFor(p.role);
  const att = pAtt(p);
  const play = pPlay(p);
  const def = pDef(p);
  const mental = pMental(p);
  const speed = pSpeed(p);
  const keeper = pKeeper(p);
  const appsWeight = Math.min(1.15, 0.86 + ((p.nat_apps ?? 0) / 280));
  const goalBias = Math.min(1.25, 0.88 + ((p.nat_goal_ratio ?? 0) * 0.34));
  const gk = p.role === 'GK';
  const goals = gk ? 0 : Number(Math.max(0, ((att - 68) * (section === 'ATT' ? 0.115 : section === 'MID' ? 0.052 : 0.014) * appsWeight * goalBias)).toFixed(1));
  const assists = gk ? 0 : Number(Math.max(0, ((play - 66) * (section === 'ATT' ? 0.052 : section === 'MID' ? 0.082 : 0.024) * appsWeight)).toFixed(1));
  const xg = gk ? 0 : Number(Math.max(0, goals * 0.82 + ((p.shot_accuracy ?? 70) - 70) * 0.015).toFixed(1));
  const xa = gk ? 0 : Number(Math.max(0, assists * 0.78 + ((p.vision ?? 70) - 70) * 0.018).toFixed(1));
  const yellows = Number(Math.max(0.1, ((p.aggression ?? 70) - 52) * 0.024 + (section === 'DEF' ? 0.34 : section === 'MID' ? 0.22 : 0.08)).toFixed(1));
  const reds = Number(Math.max(0, ((p.aggression ?? 70) - 78) * 0.006).toFixed(2));
  const saves = gk ? Number(Math.max(4.4, (keeper - 65) * 0.34).toFixed(1)) : 0;
  const cleanSheets = gk ? Number(Math.max(0.6, (keeper - 72) * 0.075 + ((team.metrics.def ?? 80) - 78) * 0.045).toFixed(1)) : 0;
  const ballWins = gk ? Number(Math.max(0.4, ((p.handling ?? 70) - 60) * 0.04).toFixed(1)) : Number(Math.max(0.4, (def - 58) * (section === 'DEF' ? 0.115 : section === 'MID' ? 0.102 : 0.035)).toFixed(1));
  const carries = gk ? Number(Math.max(0.2, ((p.kicking ?? 70) - 62) * 0.035).toFixed(1)) : Number(Math.max(0.2, (((p.dribbling ?? 70) + speed) / 2 - 62) * (section === 'ATT' ? 0.098 : section === 'MID' ? 0.072 : 0.038)).toFixed(1));
  const rating = Number(Math.max(5.8, Math.min(8.9, 6.18 + (ovr - 78) * 0.062 + (mental - 74) * 0.012 + (gk ? (keeper - 76) * 0.014 : 0))).toFixed(2));
  const impact = Number((rating * 8.5 + goals * 9 + assists * 6 + ballWins * 2.2 + saves * 1.9 - yellows * 1.2 - reds * 5).toFixed(1));
  return { goals, assists, xg, xa, yellows, reds, saves, cleanSheets, ballWins, carries, rating, impact };
}

const players = (rawPlayers ?? []).map(p => ({ ...p, role: (p.role ?? '').toUpperCase() }));
const teams = (rawTeams ?? []).map(team => {
  const profile = profileOf(team);
  const roster = buildRoster(team, players);
  const metrics = {
    ovr: avg(roster.map(p => p.overall_rating)),
    att: avg(roster.filter(p => sectionFor(p.role) === 'ATT').map(pAtt)),
    mid: avg(roster.filter(p => sectionFor(p.role) === 'MID').map(pPlay)),
    def: avg(roster.filter(p => ['DEF', 'GK'].includes(sectionFor(p.role))).map(p => p.role === 'GK' ? pKeeper(p) : pDef(p))),
    tempo: profile.tempo ?? avg(roster.map(p => avg([p.pace, p.stamina, p.work_rate]))),
  };
  return {
    slug: team.slug,
    name: team.name,
    logo: `/teams/${team.slug}.svg`,
    confederation: team.confederation ?? '',
    identity: profile.identity ?? 'Tournament identity',
    style: profile.style ?? '',
    metrics,
    roster: roster.map(p => {
      const line = projectedLine(p, { metrics });
      return {
        id: p.id,
        slug: p.slug ?? '',
        name: p.name ?? '',
        role: p.role ?? '',
        section: sectionFor(p.role),
        nation: p.nation ?? team.name,
        club: p.iconic_club ?? '',
        decade: p.decade ?? '',
        ovr: p.overall_rating ?? 0,
        apps: p.nat_apps ?? 0,
        natGoals: p.nat_goals ?? 0,
        foot: p.preferred_foot ?? '',
        photo: hasPhoto(p.slug) ? `/players/${p.slug}.jpg` : '',
        initials: initials(p.name),
        att: pAtt(p),
        play: pPlay(p),
        def: pDef(p),
        mental: pMental(p),
        keeper: pKeeper(p),
        ...line,
      };
    }),
  };
});

const pageData = JSON.stringify({ teams }).replace(/</g, '\\u003c');
