<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover"/>
  <title>All-Time World Cup Stats Hub - Legends Database</title>
  <meta name="description" content="Technical All-Time World Cup statistics hub for players, teams, leaders and form."/>
  <meta name="robots" content="noindex, nofollow, noarchive"/>
  <link rel="canonical" href="https://legendsdatabase.com/all-time-world-cup/stats"/>
  <link rel="icon" type="image/png" href="/favicon.png"/>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet"/>
  <style is:global>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
    body{font-family:-apple-system,'SF Pro Text','Inter',sans-serif;background:#f2f2f7;color:#1d1d1f;padding-top:44px;-webkit-font-smoothing:antialiased;min-height:100vh;display:flex;flex-direction:column;}
    .stats-page{position:relative;overflow:hidden;min-height:calc(100vh - 44px);background:
      radial-gradient(circle at 14% 4%,rgba(0,113,227,.16),transparent 28%),
      radial-gradient(circle at 90% 0%,rgba(216,183,106,.18),transparent 30%),
      linear-gradient(180deg,#f7f7fb 0%,#ececf2 100%);
    }
    .stats-page::before{content:'';position:absolute;inset:0;background:
      linear-gradient(rgba(29,29,31,.035) 1px,transparent 1px),
      linear-gradient(90deg,rgba(29,29,31,.035) 1px,transparent 1px);
      background-size:56px 56px;mask-image:linear-gradient(to bottom,#000,transparent 72%);pointer-events:none;
    }
    .stats-shell{position:relative;max-width:1260px;margin:0 auto;padding:34px 32px 72px;}
    .topbar{display:flex;align-items:center;justify-content:space-between;gap:14px;margin-bottom:24px;}
    .back-link{color:#6e6e73;text-decoration:none;font-size:12px;font-weight:850;}
    .back-link:hover{color:#1d1d1f;}
    .nav-pill{display:flex;align-items:center;gap:4px;background:rgba(255,255,255,.72);border:1px solid rgba(225,225,232,.9);border-radius:999px;padding:5px;box-shadow:0 14px 34px rgba(20,20,30,.08);backdrop-filter:blur(18px);}
    .nav-pill a{color:#6e6e73;text-decoration:none;font-size:11px;font-weight:900;padding:8px 10px;border-radius:999px;white-space:nowrap;}
    .nav-pill a.active{background:#1d1d1f;color:#fff;}
    .hero{display:grid;grid-template-columns:minmax(0,1fr) 360px;gap:22px;align-items:end;margin-bottom:18px;}
    .kicker{font-size:10px;font-weight:950;letter-spacing:.18em;text-transform:uppercase;color:#0071e3;margin-bottom:10px;}
    .hero-title{font-size:72px;line-height:.92;font-weight:950;letter-spacing:-.082em;}
    .hero-title span{color:#0071e3;}
    .hero-copy{font-size:15px;line-height:1.65;color:#6e6e73;max-width:760px;margin-top:18px;font-weight:620;}
    .hero-card{border-radius:30px;background:rgba(255,255,255,.82);border:1px solid rgba(225,225,232,.92);padding:20px;box-shadow:0 24px 70px rgba(20,20,30,.10);backdrop-filter:blur(22px);}
    .hero-label{font-size:9px;font-weight:950;letter-spacing:.16em;text-transform:uppercase;color:#aeaeb2;margin-bottom:12px;}
    .team-line{display:flex;align-items:center;gap:12px;}
    .team-logo{width:58px;height:58px;object-fit:contain;filter:drop-shadow(0 8px 14px rgba(0,0,0,.10));}
    .team-name{font-size:19px;font-weight:950;letter-spacing:-.045em;}
    .team-sub{font-size:12px;color:#6e6e73;font-weight:700;margin-top:4px;}
    .snapshot{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-top:16px;}
    .snap{border-radius:18px;background:#f7f7fa;padding:11px;text-align:center;border:1px solid #ececf1;}
    .snap b{display:block;font-size:21px;font-weight:950;color:#0071e3;line-height:1;font-variant-numeric:tabular-nums;}
    .snap span{display:block;font-size:8px;font-weight:950;letter-spacing:.12em;text-transform:uppercase;color:#aeaeb2;margin-top:5px;}
    .filters{display:grid;grid-template-columns:1.2fr repeat(4, minmax(120px, .55fr));gap:10px;margin-bottom:14px;background:rgba(255,255,255,.78);border:1px solid rgba(225,225,232,.92);border-radius:24px;padding:12px;box-shadow:0 16px 44px rgba(20,20,30,.08);backdrop-filter:blur(20px);}
    .filter-field{display:flex;flex-direction:column;gap:5px;}
    .filter-field label{font-size:8px;font-weight:950;letter-spacing:.13em;text-transform:uppercase;color:#aeaeb2;}
    .filter-field input,.filter-field select{width:100%;border:1px solid #e5e5ea;background:#fff;border-radius:14px;padding:10px 11px;font-family:inherit;font-size:12px;font-weight:800;color:#1d1d1f;outline:none;}
    .filter-field input:focus,.filter-field select:focus{border-color:#0071e3;box-shadow:0 0 0 4px rgba(0,113,227,.10);}
    .grid{display:grid;grid-template-columns:330px minmax(0,1fr);gap:16px;align-items:start;}
    .side-stack{display:grid;gap:14px;position:sticky;top:62px;}
    .panel{background:rgba(255,255,255,.90);border:1px solid rgba(225,225,232,.92);border-radius:26px;box-shadow:0 18px 52px rgba(20,20,30,.08);backdrop-filter:blur(22px);overflow:hidden;}
    .panel-pad{padding:18px;}
    .panel-step{font-size:8.5px;font-weight:950;letter-spacing:.16em;text-transform:uppercase;color:#aeaeb2;margin-bottom:7px;}
    .panel-title{font-size:22px;font-weight:950;letter-spacing:-.055em;line-height:1.05;}
    .panel-copy{font-size:12px;line-height:1.55;color:#6e6e73;font-weight:650;margin-top:8px;}
    .team-table{display:grid;gap:8px;margin-top:14px;}
    .team-row{display:grid;grid-template-columns:32px 1fr 44px;gap:8px;align-items:center;padding:8px;border-radius:16px;background:#f8f8fb;border:1px solid #f0f0f4;}
    .team-row img{width:28px;height:28px;object-fit:contain;}
    .team-row b{font-size:12px;font-weight:900;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
    .team-row span{font-size:10px;color:#aeaeb2;font-weight:900;}
    .team-row strong{font-size:15px;font-weight:950;color:#1a7a1a;text-align:right;font-variant-numeric:tabular-nums;}
    .leader-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:14px;}
    .leader-card{border-radius:26px;background:rgba(255,255,255,.92);border:1px solid rgba(225,225,232,.95);padding:16px;box-shadow:0 18px 52px rgba(20,20,30,.08);min-height:218px;}
    .leader-head{display:flex;align-items:center;justify-content:space-between;gap:10px;margin-bottom:12px;}
    .leader-head h3{font-size:13px;font-weight:950;letter-spacing:-.025em;}
    .leader-head span{font-size:8px;font-weight:950;letter-spacing:.12em;text-transform:uppercase;color:#aeaeb2;}
    .leader-list{display:grid;gap:8px;}
    .leader-item{display:grid;grid-template-columns:26px 1fr auto;gap:8px;align-items:center;}
    .rank{width:24px;height:24px;border-radius:50%;background:#f2f2f7;color:#6e6e73;display:grid;place-items:center;font-size:10px;font-weight:950;}
    .leader-player{display:flex;align-items:center;gap:8px;min-width:0;}
    .avatar{width:30px;height:30px;border-radius:50%;object-fit:cover;background:linear-gradient(135deg,#f1f2f6,#fff);border:1px solid #e5e5ea;display:grid;place-items:center;font-size:9px;font-weight:950;color:#8e8e93;flex-shrink:0;overflow:hidden;}
    .avatar img{width:100%;height:100%;object-fit:cover;display:block;}
    .lp-name{font-size:11px;font-weight:900;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
    .lp-meta{font-size:9px;color:#aeaeb2;font-weight:850;margin-top:1px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
    .leader-value{font-size:18px;font-weight:950;color:#0071e3;font-variant-numeric:tabular-nums;}
    .main-stack{display:grid;gap:14px;}
    details.panel summary{list-style:none;cursor:pointer;padding:18px;display:flex;align-items:center;justify-content:space-between;gap:12px;}
    details.panel summary::-webkit-details-marker{display:none;}
    .summary-left{min-width:0;}
    .summary-title{font-size:18px;font-weight:950;letter-spacing:-.045em;}
    .summary-copy{font-size:11px;color:#6e6e73;font-weight:650;margin-top:5px;}
    .chev{width:28px;height:28px;border-radius:50%;background:#f2f2f7;display:grid;place-items:center;font-size:15px;font-weight:950;color:#6e6e73;transition:transform .18s;}
    details[open] .chev{transform:rotate(45deg);}
    .table-wrap{overflow:auto;border-top:1px solid #ececf1;}
    table{width:100%;border-collapse:collapse;min-width:920px;}
    th{position:sticky;top:0;background:#f9f9fb;z-index:2;text-align:left;font-size:8px;font-weight:950;letter-spacing:.14em;text-transform:uppercase;color:#aeaeb2;padding:11px 12px;border-bottom:1px solid #ececf1;white-space:nowrap;}
    td{font-size:11.5px;font-weight:750;color:#1d1d1f;padding:10px 12px;border-bottom:1px solid #f1f1f4;vertical-align:middle;font-variant-numeric:tabular-nums;}
    tr.user-row{background:linear-gradient(90deg,rgba(0,113,227,.10),rgba(255,255,255,0));}
    .name-cell{display:flex;align-items:center;gap:9px;min-width:210px;}
    .name-text b{display:block;font-size:12px;font-weight:900;white-space:nowrap;}
    .name-text span{display:block;font-size:9.5px;color:#8e8e93;font-weight:800;margin-top:2px;}
    .role-chip{display:inline-flex;align-items:center;justify-content:center;min-width:28px;border-radius:7px;padding:3px 6px;font-size:9px;font-weight:950;background:#eef4ff;color:#0071e3;}
    .role-chip.gk{background:#fef9e7;color:#b7950b;}
    .role-chip.def{background:#efffee;color:#1a7a1a;}
    .role-chip.att{background:#fff0ee;color:#c0392b;}
    .metric-hot{color:#0071e3;font-weight:950;}
    .metric-good{color:#1a7a1a;font-weight:950;}
    .metric-warn{color:#c0392b;font-weight:950;}
    .note-strip{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;padding:16px;border-top:1px solid #ececf1;background:#fbfbfd;}
    .note{border-radius:18px;background:#fff;border:1px solid #ececf1;padding:13px;}
    .note b{display:block;font-size:11px;font-weight:950;margin-bottom:5px;}
    .note span{font-size:11px;line-height:1.5;color:#6e6e73;font-weight:650;}
    .empty{padding:28px;text-align:center;}
    .empty h2{font-size:28px;font-weight:950;letter-spacing:-.06em;margin-bottom:8px;}
    .empty p{font-size:13px;line-height:1.55;color:#6e6e73;font-weight:650;max-width:560px;margin:0 auto 16px;}
    .empty a{display:inline-flex;text-decoration:none;border-radius:999px;background:#111827;color:#fff;padding:12px 16px;font-size:12px;font-weight:900;}
    @media(max-width:1160px){
      .stats-shell{padding:30px 20px 58px;}
      .hero{grid-template-columns:1fr;}
      .grid{grid-template-columns:1fr;}
      .side-stack{position:relative;top:auto;}
      .leader-grid{grid-template-columns:repeat(2,1fr);}
      .filters{grid-template-columns:1fr 1fr;}
    }
    @media(max-width:720px){
      .stats-shell{padding:24px 16px 46px;}
      .topbar{flex-direction:column;align-items:flex-start;}
      .nav-pill{width:100%;overflow-x:auto;}
      .hero-title{font-size:48px;}
      .leader-grid{grid-template-columns:1fr;}
      .filters{grid-template-columns:1fr;}
      .snapshot,.note-strip{grid-template-columns:1fr;}
    }
  </style>
</head>
<body>
<Navbar/>
<main class="stats-page">
  <div class="stats-shell">
    <div class="topbar">
      <a class="back-link" href="/all-time-world-cup/hub">&larr; Back to campaign hub</a>
      <nav class="nav-pill" aria-label="Tournament navigation">
        <a href="/all-time-world-cup/hub">Hub</a>
        <a href="/all-time-world-cup/team-hq">Team HQ</a>
        <a href="/all-time-world-cup/opponent">Opponent</a>
        <a class="active" href="/all-time-world-cup/stats">Stats</a>
        <a href="/all-time-world-cup/team">Team DNA</a>
        <a href="/all-time-world-cup/fixtures">Fixtures</a>
      </nav>
    </div>

    <section class="hero">
      <div>
        <div class="kicker">Tournament analytics</div>
        <h1 class="hero-title">Stats <span>Hub</span></h1>
        <p class="hero-copy">A compact technical room for the numbers people: ratings, goals, assists, xG, xA, cards, ball-winning, keeper impact and team trends. Your players are highlighted automatically.</p>
      </div>
      <aside class="hero-card">
        <div class="hero-label">Your statistical lens</div>
        <div class="team-line">
          <img class="team-logo" id="heroLogo" src="/teams/all-time-brazil.svg" alt=""/>
          <div>
            <div class="team-name" id="heroTeam">Your team</div>
            <p class="team-sub" id="heroSub">Projection mode until matches are played.</p>
          </div>
        </div>
        <div class="snapshot">
          <div class="snap"><b id="snapPlayers">0</b><span>Players</span></div>
          <div class="snap"><b id="snapAvg">--</b><span>Avg OVR</span></div>
          <div class="snap"><b id="snapData">PRE</b><span>Mode</span></div>
        </div>
      </aside>
    </section>

    <section class="filters" aria-label="Statistics filters">
      <div class="filter-field">
        <label for="searchInput">Search player or team</label>
        <input id="searchInput" type="search" placeholder="Type a name, nation, role..."/>
      </div>
      <div class="filter-field">
        <label for="scopeSelect">Scope</label>
        <select id="scopeSelect">
          <option value="all">All tournament</option>
          <option value="mine">My players</option>
          <option value="rivals">Other teams</option>
        </select>
      </div>
      <div class="filter-field">
        <label for="sectionSelect">Unit</label>
        <select id="sectionSelect">
          <option value="all">All roles</option>
          <option value="GK">Goalkeepers</option>
          <option value="DEF">Defenders</option>
          <option value="MID">Midfielders</option>
          <option value="ATT">Attackers</option>
        </select>
      </div>
      <div class="filter-field">
        <label for="sortSelect">Sort by</label>
        <select id="sortSelect">
          <option value="impact">Impact index</option>
          <option value="rating">Avg rating</option>
          <option value="goals">Goals</option>
          <option value="assists">Assists</option>
          <option value="xg">xG</option>
          <option value="xa">xA</option>
          <option value="ballWins">Ball wins</option>
          <option value="cards">Cards</option>
        </select>
      </div>
      <div class="filter-field">
        <label for="minSelect">Minimum OVR</label>
        <select id="minSelect">
          <option value="0">Any</option>
          <option value="85">85+</option>
          <option value="88">88+</option>
          <option value="90">90+</option>
          <option value="93">93+</option>
        </select>
      </div>
    </section>

    <section id="app"></section>
  </div>
</main>
<Footer/>
<script id="stats-data" type="application/json" set:html={pageData}></script>
<script>
  const DATA = JSON.parse(document.getElementById('stats-data').textContent);
  const app = document.getElementById('app');
  const TEAM_COLORS = {
    brazil:['#f7d14a','#1f8f43'], italy:['#1d9bf0','#ffffff'], germany:['#111827','#d8b76a'], spain:['#c0392b','#f1c232'],
    france:['#1f4ed8','#c0392b'], argentina:['#75aadb','#ffffff'], portugal:['#b51f2d','#1a7a1a'], netherlands:['#f47b20','#111827'],
    england:['#ffffff','#c0392b'], uruguay:['#77b5e8','#111827'], croatia:['#c0392b','#ffffff'], denmark:['#c0392b','#ffffff'],
    belgium:['#111827','#f1c232'], serbia:['#c0392b','#1f4ed8'], scotland:['#1f4ed8','#ffffff'], sweden:['#f1c232','#1f4ed8'],
  };

  function esc(v) {
    return String(v ?? '').replace(/[&<>"']/g, ch => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[ch]));
  }

  function readJson(key) {
    try { return JSON.parse(localStorage.getItem(key) || 'null'); } catch { return null; }
  }

  function roleClass(section) {
    if (section === 'GK') return 'gk';
    if (section === 'DEF') return 'def';
    if (section === 'ATT') return 'att';
    return 'mid';
  }

  function teamBySlug(slug) {
    return DATA.teams.find(t => t.slug === slug) || DATA.teams[0];
  }

  function avatar(p) {
    return `<span class="avatar">${p.photo ? `<img src="${esc(p.photo)}" alt=""/>` : esc(p.initials || '?')}</span>`;
  }

  function hydrateRealStats(rows) {
    const stored = readJson('ld_world_cup_stats');
    const playerStats = stored?.players || {};
    return rows.map(row => {
      const real = playerStats[row.slug] || playerStats[row.id];
      if (!real) return row;
      return {
        ...row,
        goals: Number(real.goals ?? row.goals),
        assists: Number(real.assists ?? row.assists),
        rating: Number(real.rating ?? real.avgRating ?? row.rating),
        yellows: Number(real.yellows ?? row.yellows),
        reds: Number(real.reds ?? row.reds),
        xg: Number(real.xg ?? row.xg),
        xa: Number(real.xa ?? row.xa),
        saves: Number(real.saves ?? row.saves),
        cleanSheets: Number(real.cleanSheets ?? row.cleanSheets),
        ballWins: Number(real.ballWins ?? row.ballWins),
        carries: Number(real.carries ?? row.carries),
        played: Number(real.played ?? 0),
        dataMode: 'live',
      };
    });
  }

  function baseRows(userSlug) {
    const rows = DATA.teams.flatMap(team => team.roster.map(p => ({
      ...p,
      teamSlug: team.slug,
      teamName: team.name,
      teamLogo: team.logo,
      teamOvr: team.metrics.ovr,
      isMine: team.slug === userSlug,
      dataMode: 'projection',
    })));
    return hydrateRealStats(rows);
  }

  function applyColors(team) {
    const key = (team?.name || '').toLowerCase().replace(/\s+/g, '-');
    const colors = TEAM_COLORS[key] || ['#0071e3', '#111827'];
    document.querySelector('.stats-page').style.background =
      `radial-gradient(circle at 14% 4%, ${colors[0]}33, transparent 28%), radial-gradient(circle at 90% 0%, ${colors[1]}24, transparent 30%), linear-gradient(180deg,#f7f7fb 0%,#ececf2 100%)`;
  }

  function getFilters() {
    return {
      query: document.getElementById('searchInput').value.trim().toLowerCase(),
      scope: document.getElementById('scopeSelect').value,
      section: document.getElementById('sectionSelect').value,
      sort: document.getElementById('sortSelect').value,
      min: Number(document.getElementById('minSelect').value || 0),
    };
  }

  function filteredRows(rows) {
    const f = getFilters();
    return rows.filter(row => {
      if (f.scope === 'mine' && !row.isMine) return false;
      if (f.scope === 'rivals' && row.isMine) return false;
      if (f.section !== 'all' && row.section !== f.section) return false;
      if (row.ovr < f.min) return false;
      if (f.query) {
        const hay = `${row.name} ${row.teamName} ${row.role} ${row.section} ${row.club} ${row.decade}`.toLowerCase();
        if (!hay.includes(f.query)) return false;
      }
      return true;
    }).sort((a, b) => {
      const sort = f.sort;
      if (sort === 'cards') return ((b.yellows || 0) + (b.reds || 0) * 3) - ((a.yellows || 0) + (a.reds || 0) * 3) || b.ovr - a.ovr;
      return (Number(b[sort]) || 0) - (Number(a[sort]) || 0) || b.ovr - a.ovr;
    });
  }

  function top(rows, key, n = 5, predicate = () => true) {
    return [...rows].filter(predicate).sort((a, b) => (Number(b[key]) || 0) - (Number(a[key]) || 0) || b.ovr - a.ovr).slice(0, n);
  }

  function leaderList(rows, key, decimals = 1) {
    return rows.map((p, i) => `
      <div class="leader-item">
        <span class="rank">${i + 1}</span>
        <div class="leader-player">
          ${avatar(p)}
          <div class="lp-text">
            <div class="lp-name">${esc(p.name)}</div>
            <div class="lp-meta">${esc(p.teamName)} · ${esc(p.role)}</div>
          </div>
        </div>
        <div class="leader-value">${Number(p[key] || 0).toFixed(decimals)}</div>
      </div>
    `).join('');
  }

  function tableRows(rows) {
    return rows.slice(0, 160).map((p, i) => {
      const cards = `${Number(p.yellows || 0).toFixed(1)} / ${Number(p.reds || 0).toFixed(2)}`;
      return `
        <tr class="${p.isMine ? 'user-row' : ''}">
          <td>${i + 1}</td>
          <td>
            <div class="name-cell">
              ${avatar(p)}
              <div class="name-text"><b>${esc(p.name)}</b><span>${esc(p.teamName)} · ${esc(p.club || p.decade || '')}</span></div>
            </div>
          </td>
          <td><span class="role-chip ${roleClass(p.section)}">${esc(p.role)}</span></td>
          <td>${p.ovr}</td>
          <td class="metric-hot">${Number(p.rating || 0).toFixed(2)}</td>
          <td class="metric-good">${Number(p.impact || 0).toFixed(1)}</td>
          <td>${Number(p.goals || 0).toFixed(1)}</td>
          <td>${Number(p.assists || 0).toFixed(1)}</td>
          <td>${Number(p.xg || 0).toFixed(1)}</td>
          <td>${Number(p.xa || 0).toFixed(1)}</td>
          <td>${Number(p.ballWins || 0).toFixed(1)}</td>
          <td>${Number(p.carries || 0).toFixed(1)}</td>
          <td class="${Number(p.reds || 0) > .05 ? 'metric-warn' : ''}">${cards}</td>
        </tr>
      `;
    }).join('');
  }

  function teamRows(teams, userSlug) {
    return [...teams]
      .sort((a, b) => b.metrics.ovr - a.metrics.ovr)
      .map(t => `
        <div class="team-row">
          <img src="${esc(t.logo)}" alt=""/>
          <div><b>${esc(t.name)}</b><span>${t.slug === userSlug ? 'Your team' : esc(t.confederation || 'All-Time')}</span></div>
          <strong>${t.metrics.ovr}</strong>
        </div>
      `).join('');
  }

  function renderEmpty() {
    app.innerHTML = `
      <div class="panel empty">
        <h2>No tournament context yet</h2>
        <p>Pick a team, run the draw and generate fixtures first. Then the Stats Hub will lock onto your campaign and highlight your players automatically.</p>
        <a href="/all-time-world-cup">Start World Cup setup</a>
      </div>
    `;
  }

  function render(rows, userTeam, userSlug) {
    const filtered = filteredRows(rows);
    const mode = rows.some(r => r.dataMode === 'live') ? 'LIVE' : 'PRE';
    const mine = rows.filter(r => r.isMine);
    document.getElementById('heroLogo').src = userTeam.logo;
    document.getElementById('heroTeam').textContent = userTeam.name;
    document.getElementById('heroSub').textContent = mode === 'LIVE' ? 'Live tournament stats loaded.' : 'Projection mode until matches are played.';
    document.getElementById('snapPlayers').textContent = mine.length || userTeam.roster.length;
    document.getElementById('snapAvg').textContent = userTeam.metrics.ovr;
    document.getElementById('snapData').textContent = mode;

    app.innerHTML = `
      <div class="grid">
        <aside class="side-stack">
          <div class="panel panel-pad">
            <div class="panel-step">Ranking model</div>
            <h2 class="panel-title">Impact index</h2>
            <p class="panel-copy">A compact synthetic score blending rating, goals, assists, defensive output, keeper work and discipline. It is deliberately nerdy, but readable.</p>
          </div>
          <div class="panel panel-pad">
            <div class="panel-step">Team power table</div>
            <h2 class="panel-title">Squad strength</h2>
            <div class="team-table">${teamRows(DATA.teams, userSlug)}</div>
          </div>
        </aside>
        <div class="main-stack">
          <section class="leader-grid">
            <div class="leader-card">
              <div class="leader-head"><h3>Goals</h3><span>xG aware</span></div>
              <div class="leader-list">${leaderList(top(filtered, 'goals', 5, p => p.section !== 'GK'), 'goals', 1)}</div>
            </div>
            <div class="leader-card">
              <div class="leader-head"><h3>Assists</h3><span>chance creation</span></div>
              <div class="leader-list">${leaderList(top(filtered, 'assists', 5, p => p.section !== 'GK'), 'assists', 1)}</div>
            </div>
            <div class="leader-card">
              <div class="leader-head"><h3>Avg rating</h3><span>form guide</span></div>
              <div class="leader-list">${leaderList(top(filtered, 'rating', 5), 'rating', 2)}</div>
            </div>
            <div class="leader-card">
              <div class="leader-head"><h3>Ball wins</h3><span>without ball</span></div>
              <div class="leader-list">${leaderList(top(filtered, 'ballWins', 5), 'ballWins', 1)}</div>
            </div>
          </section>

          <details class="panel" open>
            <summary>
              <div class="summary-left">
                <div class="summary-title">Technical player table</div>
                <div class="summary-copy">${filtered.length} players after filters. Your players are highlighted in blue.</div>
              </div>
              <span class="chev">+</span>
            </summary>
            <div class="table-wrap">
              <table>
                <thead>
                  <tr>
                    <th>#</th><th>Player</th><th>Role</th><th>OVR</th><th>Rating</th><th>Impact</th><th>G</th><th>A</th><th>xG</th><th>xA</th><th>Wins</th><th>Carries</th><th>YC / RC</th>
                  </tr>
                </thead>
                <tbody>${tableRows(filtered)}</tbody>
              </table>
            </div>
          </details>

          <details class="panel" open>
            <summary>
              <div class="summary-left">
                <div class="summary-title">Specialist leaderboards</div>
                <div class="summary-copy">Extra lenses for keepers, discipline, xG overperformance and creative volume.</div>
              </div>
              <span class="chev">+</span>
            </summary>
            <div class="note-strip">
              <div class="note"><b>Keeper watch</b><span>${leaderList(top(filtered, 'saves', 3, p => p.section === 'GK'), 'saves', 1) || 'No goalkeepers in current filter.'}</span></div>
              <div class="note"><b>Discipline risk</b><span>${leaderList([...filtered].sort((a,b)=>((b.yellows || 0)+(b.reds || 0)*3)-((a.yellows || 0)+(a.reds || 0)*3)).slice(0,3), 'yellows', 1)}</span></div>
              <div class="note"><b>Creative engine</b><span>${leaderList(top(filtered, 'xa', 3, p => p.section !== 'GK'), 'xa', 1)}</span></div>
            </div>
          </details>
        </div>
      </div>
    `;
  }

  function boot() {
    const setup = readJson('ld_world_cup_setup') || {};
    const draw = readJson('ld_world_cup_draw') || {};
    const fixtures = readJson('ld_world_cup_fixtures') || {};
    const userSlug = fixtures.userSlug || draw.userSlug || setup.teamSlug || '';
    const userTeam = teamBySlug(userSlug);
    if (!userTeam) {
      renderEmpty();
      return;
    }
    applyColors(userTeam);
    const rows = baseRows(userTeam.slug);
    ['searchInput', 'scopeSelect', 'sectionSelect', 'sortSelect', 'minSelect'].forEach(id => {
      document.getElementById(id).addEventListener('input', () => render(rows, userTeam, userTeam.slug));
      document.getElementById(id).addEventListener('change', () => render(rows, userTeam, userTeam.slug));
    });
    render(rows, userTeam, userTeam.slug);
  }

  boot();
</script>
</body>
</html>
