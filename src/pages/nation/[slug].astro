---
import { supabase } from '../../lib/supabase.js';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';

export async function getStaticPaths() {
  const { data: nations } = await supabase.from('nations').select('*');
  const { data: players } = await supabase.from('players').select('*');
  const { data: teams }   = await supabase.from('teams').select('*');
  return (nations ?? []).map(n => ({
    params: { slug: n.name.toLowerCase().replace(/\s+/g,'-') },
    props: { nation: n, allPlayers: players ?? [], allTeams: teams ?? [] }
  }));
}

const { nation: n, allPlayers, allTeams } = Astro.props;

// ─── PLAYER DATA ───────────────────────────────────────────────────────────
function avg(vals) {
  const v = vals.filter(x => x != null && !isNaN(Number(x)));
  return v.length ? Math.round(v.reduce((a,b) => a+Number(b),0)/v.length) : 0;
}
function sortBy(arr, fn) {
  return [...arr].sort((a,b) => fn(b)-fn(a)||(a.name??'').localeCompare(b.name??''));
}

const pool = allPlayers.filter(p =>
  (p.nation??'').toLowerCase() === (n.name??'').toLowerCase() &&
  p.overall_rating != null && p.slug
);

const legendCount  = pool.length;
const avgOvr       = avg(pool.map(p=>p.overall_rating));
const peakOvr      = Math.max(0,...pool.map(p=>p.overall_rating??0));
const avgPace      = avg(pool.map(p=>avg([p.pace,p.acceleration])));
const avgStrength  = avg(pool.map(p=>p.strength).filter(Boolean));
const avgTech      = avg(pool.map(p=>p['first-touch']).filter(Boolean));
const avgHeight    = avg(pool.map(p=>p.height).filter(Boolean));
const leftFoot     = pool.filter(p=>p.preferred_foot==='Left').length;
const rightFoot    = pool.filter(p=>p.preferred_foot==='Right').length;
const totalFoot    = Math.max(leftFoot+rightFoot,1);
const leftPct      = Math.round(leftFoot/totalFoot*100);

const gkCount      = pool.filter(p=>p.role==='GK').length;
const defCount     = pool.filter(p=>['CB','SW','RB','LB'].includes(p.role)).length;
const midCount     = pool.filter(p=>['DM','CM','AM','RM','LM'].includes(p.role)).length;
const attCount     = pool.filter(p=>['ST','FW','RW','LW'].includes(p.role)).length;

const byDecade: Record<string,number> = {};
pool.forEach(p => { if(p.decade) byDecade[p.decade]=(byDecade[p.decade]||0)+1; });
const decadeSorted = Object.entries(byDecade).sort((a,b)=>b[1]-a[1]);
const goldenDecade = decadeSorted[0]?.[0] ? decadeSorted[0][0]+'s' : '—';

const topPlayer    = sortBy(pool, p=>p.overall_rating??0)[0];
const topScorer    = sortBy(pool.filter(p=>(p.nat_goals??0)>0), p=>p.nat_goals??0)[0];
const mostCaps     = sortBy(pool.filter(p=>(p.nat_apps??0)>0), p=>p.nat_apps??0)[0];
const fastest      = sortBy(pool, p=>avg([p.pace,p.acceleration]))[0];
const strongest    = sortBy(pool, p=>p.strength??0)[0];
const mostTech     = sortBy(pool, p=>p['first-touch']??0)[0];
const bestRatio    = sortBy(pool.filter(p=>(p.nat_apps??0)>=10&&(p.nat_goals??0)>0), p=>parseFloat(p.nat_goal_ratio??0))[0];

// top 6 legends by OVR
const top6 = sortBy(pool, p=>p.overall_rating??0).slice(0,6);

// ─── ALL-TIME TEAM CHECK ──────────────────────────────────────────────────
const nationLower = n.name.toLowerCase().replace(/\s+/g,'-');
const allTimeTeam = allTeams.find(t =>
  t.type === 'national team' || t.type === 'national'
    ? t.slug === `all-time-${nationLower}` || t.name?.toLowerCase() === n.name.toLowerCase()
    : false
);

// ─── PHILOSOPHY PILLS ─────────────────────────────────────────────────────
const philosophyPills = (n.philosophy ?? '')
  .split(',')
  .map((s: string) => s.trim())
  .filter((s: string) => s.length > 0);

// ─── COLORS ───────────────────────────────────────────────────────────────
const hex = n.symbol_color ?? '#0071e3';
function hexToRgb(h: string) {
  const r = parseInt(h.slice(1,3),16),
        g = parseInt(h.slice(3,5),16),
        b = parseInt(h.slice(5,7),16);
  return `${r},${g},${b}`;
}
function isColorTooLight(h: string): boolean {
  const r = parseInt(h.slice(1,3),16);
  const g = parseInt(h.slice(3,5),16);
  const b = parseInt(h.slice(5,7),16);
  return (0.299*r + 0.587*g + 0.114*b) / 255 > 0.75;
}
const accentCol  = isColorTooLight(hex) ? '#6e6e73' : hex;
const rgb        = hexToRgb(accentCol);
const heroGrad   = `linear-gradient(135deg, rgba(${rgb},0.12) 0%, rgba(${rgb},0.04) 60%, transparent 100%)`;

// ─── FLAG SVG GENERATOR ───────────────────────────────────────────────────
// Minimal SVG flags by nation name — tricolori and simple designs
